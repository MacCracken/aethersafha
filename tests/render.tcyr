# aethersafha renderer test — alpha blend + damage tracking (pure logic).
# Stdlib + [deps.*] auto-included via cyrius.cyml.
include "lib/bhumi.cyr"
include "src/geom.cyr"
include "src/window.cyr"
include "src/compositor.cyr"
include "src/shell.cyr"   # render_shell_panel reads SH_NetStatus + shell status
include "src/render.cyr"

fn main() {
    alloc_init();

    test_group("render — alpha blend");
    assert_eq(rend_blend(0x000000, 0xFFFFFF, 255), 0xFFFFFF, "full src alpha = src");
    assert_eq(rend_blend(0x000000, 0xFFFFFF, 0), 0x000000, "zero alpha = dst");
    assert_eq(rend_blend(0x000000, 0xFFFFFF, 128), 0x808080, "half alpha = mid grey");
    assert_eq(rend_blend(0x203040, 0x203040, 200), 0x203040, "same src/dst is stable");

    test_group("render — damage tracker");
    var d = rend_dmg_new();
    assert_eq(rend_dmg_valid(d), 0, "empty damage invalid");
    rend_dmg_add(d, 10, 10, 20, 20);
    assert_eq(rend_dmg_valid(d), 1, "first add makes it valid");
    assert_eq(rend_dmg_x(d), 10, "damage x");
    assert_eq(rend_dmg_w(d), 20, "damage w");
    rend_dmg_add(d, 5, 5, 10, 10);
    assert_eq(rend_dmg_x(d), 5, "damage grows left");
    assert_eq(rend_dmg_y(d), 5, "damage grows up");
    assert_eq(rend_dmg_w(d), 25, "damage right edge held (30-5)");
    assert_eq(rend_dmg_h(d), 25, "damage bottom edge held");
    rend_dmg_clear(d);
    assert_eq(rend_dmg_valid(d), 0, "clear resets validity");

    test_group("render — decoration hit-test");
    var win = win_new(1, 100, 100, 400, 300, "T");
    assert_eq(deco_hit(win, 50, 50), Deco.DECO_NONE, "outside window");
    assert_eq(deco_hit(win, 300, 250), Deco.DECO_BODY, "body");
    assert_eq(deco_hit(win, 200, 110), Deco.DECO_TITLEBAR, "titlebar drag strip");
    assert_eq(deco_hit(win, 485, 112), Deco.DECO_CLOSE, "close button");
    assert_eq(deco_hit(win, 463, 112), Deco.DECO_MAX, "maximize button");
    assert_eq(deco_hit(win, 440, 112), Deco.DECO_MIN, "minimize button");
    assert_eq(deco_hit(win, 497, 250), Deco.DECO_RESIZE_R, "right resize edge");
    assert_eq(deco_hit(win, 300, 397), Deco.DECO_RESIZE_B, "bottom resize edge");
    assert_eq(deco_hit(win, 497, 397), Deco.DECO_RESIZE_BR, "bottom-right resize corner");

    test_group("render — shell panel bar-graph fill");
    assert_eq(panel_bar_w(0, 40), 0, "0% → empty");
    assert_eq(panel_bar_w(100, 40), 40, "100% → full");
    assert_eq(panel_bar_w(50, 40), 20, "50% → half");
    assert_eq(panel_bar_w(150, 40), 40, "clamp above 100%");
    assert_eq(panel_bar_w(0 - 10, 40), 0, "clamp below 0%");

    test_group("render — bitmap text (kashi VGA 8x16)");
    kashi_font_init();
    assert_eq(kashi_font_is_ready(), 1, "kashi font initialized");
    assert_eq(kashi_font_width(KASHI_FONT_VGA_8X16), 8, "glyph width 8");
    assert_eq(kashi_font_height(KASHI_FONT_VGA_8X16), 16, "glyph height 16");
    assert_eq(text_width("Hi"), 17, "text width = 2*9 - 1");
    assert_eq(text_width(""), 0, "empty string has width 0");
    var tfb = bhumi_fb_new(16, 20);
    bhumi_fb_clear(tfb, 0);
    var white = bhumi_xrgb(255, 255, 255);
    draw_char(tfb, 'A', 0, 0, white);
    var setpx = 0;
    var yy = 0;
    while (yy < 16) {
        var xx = 0;
        while (xx < 8) {
            if (bhumi_fb_get(tfb, xx, yy) == white) { setpx = setpx + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    var some = (setpx > 0);
    assert(some, "'A' glyph drew pixels");
    var notall = (setpx < 128);
    assert(notall, "'A' glyph is not a solid block");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
