# theme — aethersafha's binding to rupa. The token VALUES are locked in rupa's own
# tests/theme.tcyr; here we verify the INTEGRATION: rupa's tokens are reachable from
# the compositor, and ae_bhumi packs a logical 0xRRGGBB token into a bhumi framebuffer
# colour. Stdlib + [deps.*] (rupa, bhumi) auto-included via cyrius.cyml.
include "src/theme.cyr"

fn main() {
    alloc_init();

    test_group("aethersafha theme — rupa integration");
    var t = rupa_theme_active();
    assert(t != 0, "rupa active theme reachable from the compositor");
    assert_eq(rupa_theme_accent(t), 0x00E5FF, "default active = MUDRA · Carbon cyan");
    assert_eq(rupa_theme_bg(t), 0x0B0C0E, "default active bg = carbon void");

    # ae_bhumi packs the token through the channel helpers into the bhumi format.
    assert(ae_bhumi(rupa_theme_accent(t)) != 0, "ae_bhumi packs a non-black token");
    assert_eq(ae_bhumi(0x000000), bhumi_xrgb(0, 0, 0), "ae_bhumi(black) == bhumi black");
    assert_eq(ae_bhumi(0xE9C46A), bhumi_xrgb(0xE9, 0xC4, 0x6A), "ae_bhumi splits R/G/B correctly");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
