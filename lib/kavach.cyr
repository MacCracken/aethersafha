# kavach.cyr -- bundled distribution
# Version: 3.8.3
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- util.cyr ---

# kavach — shared string helpers + security hardening primitives

# ---- constant-time ops ---------------------------------------------------
# Delegates to the stdlib ct_eq_bytes_lens, which XORs byte-by-byte into an
# accumulator without early exit. Prevents timing side channels on
# HMAC/signature verification (ADR-005 §C1). sigil retired its own ct_eq in
# the 3.x line in favor of this stdlib symbol (identical semantics) — see
# CHANGELOG 3.3.0.

fn ct_streq(a, b) {
    var la = strlen(a);
    var lb = strlen(b);
    if (la != lb) { return 0; }
    return ct_eq_bytes_lens(a, la, b, lb);
}

# ---- overflow-checked arithmetic -----------------------------------------
# Return -1 on overflow instead of wrapping. Use for sizes fed to alloc().

fn checked_add(a, b) {
    if (a < 0) { return 0 - 1; }
    if (b < 0) { return 0 - 1; }
    var r = a + b;
    if (r < a) { return 0 - 1; }
    return r;
}

fn checked_mul(a, b) {
    if (a < 0) { return 0 - 1; }
    if (b < 0) { return 0 - 1; }
    if (a == 0) { return 0; }
    if (b == 0) { return 0; }
    var r = a * b;
    if (r / a != b) { return 0 - 1; }
    return r;
}

# Sum 4 non-negative sizes with overflow detection. Returns -1 on any
# negative input or any intermediate overflow. Unused slots: pass 0.
# Chosen arity keeps our worst alloc sites (audit/quarantine/oci_spec)
# coverable in one call — those stitch at most 4 user-lengths plus a
# bounded constant the caller adds separately.
fn checked_sum4(a, b, c, d) {
    var s = checked_add(a, b);
    if (s < 0) { return 0 - 1; }
    s = checked_add(s, c);
    if (s < 0) { return 0 - 1; }
    s = checked_add(s, d);
    if (s < 0) { return 0 - 1; }
    return s;
}

# Overflow-safe alloc: returns 0 (instead of aborting) if requested size
# is negative or exceeds the attacker-defense ceiling of 64 MiB per
# single allocation. 64 MiB is larger than any legitimate per-op buffer
# kavach allocates (OCI spec worst case ~2 MiB, audit line < 1 MiB).
fn alloc_checked(size) {
    if (size < 0) { return 0; }
    if (size > 67108864) { return 0; }
    return alloc(size);
}

# ---- input validation ----------------------------------------------------

# Reject control chars (NUL, BEL, ESC, …) while allowing tab/newline/CR.
# Prevents JSON injection, log forgery, and terminal escape smuggling.
# Returns 1 if safe, 0 otherwise.
#
# Reads the untrusted input through a bounds-checked slice (`sl[i]` lowers to
# the stdlib `_slice_idx_get_1`, which traps on out-of-range): on this
# security-relevant validation path a future off-by-one becomes a clean abort
# rather than an out-of-bounds read of attacker-influenced memory.
fn is_safe_text(s) {
    var n = strlen(s);
    var sl: [u8] = 0;
    slice_set(&sl, s, n);
    var i = 0;
    while (i < n) {
        var c = sl[i];
        if (c < 32) {
            if (c != 9) {
                if (c != 10) {
                    if (c != 13) { return 0; }
                }
            }
        }
        i = i + 1;
    }
    return 1;
}

# Stricter: reject newlines + CR too (used for command arguments where
# each line becomes a token and could smuggle extra args). Same
# bounds-checked-slice read of untrusted input as is_safe_text.
fn is_safe_argument(s) {
    var n = strlen(s);
    var sl: [u8] = 0;
    slice_set(&sl, s, n);
    var i = 0;
    while (i < n) {
        var c = sl[i];
        if (c < 32) {
            if (c != 9) { return 0; }
        }
        i = i + 1;
    }
    return 1;
}

# ---- secure file I/O -----------------------------------------------------
# O_WRONLY=1, O_CREAT=0x40, O_TRUNC=0x200, O_EXCL=0x80, O_NOFOLLOW=0x20000
# Mode 0600 = 384.

# Human-readable name for a stdlib IoError variant — for the structured
# log/error line emitted on a failed external write (ADR-005 audit trail).
fn io_error_name(e) {
    if (e == IoNotFound) { return "not found"; }
    if (e == IoAccessDenied) { return "access denied"; }
    if (e == IoBadFd) { return "bad fd"; }
    if (e == IoFailed) { return "write incomplete"; }
    return "i/o error";
}

# Result-returning hardened write. Same O_EXCL|O_NOFOLLOW guarantee as
# file_write_secure (refuses to follow a symlink or clobber an existing file;
# mode 0600), but built on the stdlib `_r` primitives so the failure carries a
# distinguishable IoError (ENOENT vs EACCES vs ELOOP/EEXIST→IoOther) instead of
# a bare -1. NOTE: the stdlib file_write_all_r is deliberately NOT used — it
# opens O_WRONLY|O_CREAT|O_TRUNC without the O_EXCL|O_NOFOLLOW hardening
# (ADR-005 §C4). Returns Ok(len) or Err(IoError).
fn file_write_secure_r(path, buf, len): Result {
    var flags = 1 + 64 + 512 + 128 + 131072;
    var fo = file_open_r(path, flags, 384);
    if (is_err_result(fo) == 1) { return fo; }
    var fd = result_unwrap(fo);
    var wr = file_write_r(fd, buf, len);
    file_close_r(fd);
    if (is_err_result(wr) == 1) { return wr; }
    if (result_unwrap(wr) != len) { return Err(IoFailed); }
    return Ok(len);
}

# Back-compat int wrapper: returns bytes written, or -1 on any failure.
# Existing callers that don't need the distinguished error keep using this.
fn file_write_secure(path, buf, len) {
    return result_unwrap_or(file_write_secure_r(path, buf, len), 0 - 1);
}

# As file_write_secure, but honors a caller-supplied final mode via fchmod
# on the same fd that the write went through. Used by credential injection
# (ADR-005 §M2): the file is created mode 0600 by O_CREAT, the content
# lands while still 0600 (no other-readable window), then the fd is
# fchmod'd to the requested mode before close. Closing the fd between
# write and chmod would re-open a TOCTOU window — using fchmod on the
# same fd closes it.
#
# Raw `syscall(91, ...)` because the stdlib doesn't ship a sys_fchmod
# wrapper at cc 5.10.34. SYS_FCHMOD = 91 on x86_64 Linux. Only used here;
# folded back into sys_fchmod when the wrapper lands upstream.
fn file_write_secure_modal(path, buf, len, mode) {
    var flags = 1 + 64 + 512 + 128 + 131072;
    var fd = sys_open(path, flags, 384);
    if (fd < 0) { return 0 - 1; }
    var n = sys_write(fd, buf, len);
    if (n < 0) { sys_close(fd); return 0 - 1; }
    if (n != len) { sys_close(fd); return 0 - 1; }
    # SAFETY: SYS_FCHMOD = 91 on x86_64 Linux; fd is owned by this fn
    # (just opened above), mode is the caller-supplied octal value, the
    # third arg is the standard syscall(...) trailing zero.
    syscall(91, fd, mode, 0);
    sys_close(fd);
    return n;
}

# Restrict an existing file to owner-only (best-effort; ignores errors so
# that failing platforms don't break the exec path — caller still wrote).
fn file_restrict_mode(path) {
    sys_chmod(path, 384);
    return 0;
}

# ---- random bytes --------------------------------------------------------
# Fill `count` bytes of buf from the kernel CSPRNG via getrandom(2) (the
# stdlib random_bytes wrapper). Returns bytes filled, or -1 on failure. Used
# for unpredictable container ids — breaks the /tmp-symlink-precreate attack
# (ADR-005 §C3). getrandom needs no fd and works where /dev/urandom isn't
# mounted (chroot, landlocked, minimal mount ns) — strictly better for a
# sandbox tool than the old open/read/close on /dev/urandom. Blocks only
# until the kernel pool is seeded (immediate post-boot); flags=0, never
# GRND_INSECURE — the unpredictability is a security property here.
fn fill_random(buf, count) {
    var n = random_bytes(buf, count);
    if (n < 0) { return 0 - 1; }
    return n;
}

# Hex-encode `len` bytes from src into dst. dst must fit len*2 + 1 bytes.
fn hex_encode_bytes(src, len, dst) {
    var hex = "0123456789abcdef";
    var i = 0;
    while (i < len) {
        var b = load8(src + i);
        store8(dst + i * 2, load8(hex + ((b >> 4) & 15)));
        store8(dst + i * 2 + 1, load8(hex + (b & 15)));
        i = i + 1;
    }
    store8(dst + len * 2, 0);
    return 0;
}

# 16-char hex id from the kernel CSPRNG (8 random bytes × 2). Returns heap cstr.
fn rand_hex_id() {
    var raw[8];
    fill_random(&raw, 8);
    var out = alloc(17);
    hex_encode_bytes(&raw, 8, out);
    return out;
}

# 64-bit random from the kernel CSPRNG. Used for UUID-v4-equivalent internal
# IDs (sandbox, finding, quarantine entry). Collision probability across
# 2^32 entries is ~2^-32 — sufficient for correlation IDs. Falls back
# to 0 on failure (caller sees a duplicate, which is a visible bug
# rather than a silent TOCTOU).
fn rand_u64() {
    var raw[8];
    if (fill_random(&raw, 8) != 8) { return 0; }
    return load64(&raw);
}

# 32-char hex UUID-like id. Two u64 samples give 128 bits of randomness.
fn rand_uuid_hex() {
    var raw[16];
    fill_random(&raw, 16);
    var out = alloc(33);
    hex_encode_bytes(&raw, 16, out);
    return out;
}

# ---- secret redaction ----------------------------------------------------
# For evidence snippets that may contain an actual secret. Policy: show
# first 4 + '****' + last 4 if len > 8; otherwise full mask. Preserves
# signal (prefix identifies key type, e.g. 'AKIA****') without leaking
# the secret content.

fn redact_evidence(text, start, len) {
    if (len <= 8) {
        var mask = alloc(len + 1);
        memset(mask, 42, len);
        store8(mask + len, 0);
        return mask;
    }
    var buf = alloc(13);
    memcpy(buf, text + start, 4);
    memcpy(buf + 4, "****", 4);
    memcpy(buf + 8, text + start + len - 4, 4);
    store8(buf + 12, 0);
    return buf;
}

# ---- existing helpers ----------------------------------------------------

fn ch_ascii_lower(c) {
    if (c >= 65) {
        if (c <= 90) { return c + 32; }
    }
    return c;
}

# Case-insensitive null-terminated string equality. 1 = equal, 0 = not.
fn strieq(a, b) {
    var i = 0;
    while (1 == 1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ch_ascii_lower(ca) != ch_ascii_lower(cb)) { return 0; }
        if (ca == 0) { return 1; }
        i = i + 1;
    }
    return 0;
}

# --- error.cyr ---

# kavach — error codes
# Ported from rust-old/src/error.rs
#
# Members are namespaced `KAVACH_ERR_*` — the same crate-name prefix
# convention as `SysErrorKind` (src/sys_error.cyr). Cyrius hoists enum
# members to global constants under "last definition wins", and qualified
# `KavachError.X` access is only sugar for that hoisted global (verified:
# a two-enum consumer probe had `KavachError.OK` resolve to a later dep's
# generic `OK`, not 0). Bare generic names (`OK`, `TIMEOUT`, `IO_ERROR`,
# `OTHER`) would therefore silently collide with any dep minting the same
# names — in either direction. The `KAVACH_ERR_*` prefix keeps every member
# globally unique so no consumer surface can clash. See ADR-006 §4.

enum KavachError {
    KAVACH_ERR_OK = 0;
    KAVACH_ERR_BACKEND_UNAVAILABLE = 1;
    KAVACH_ERR_CREATION_FAILED = 2;
    KAVACH_ERR_EXEC_FAILED = 3;
    KAVACH_ERR_TIMEOUT = 4;
    KAVACH_ERR_POLICY_VIOLATION = 5;
    KAVACH_ERR_CREDENTIAL_ERROR = 6;
    KAVACH_ERR_INVALID_TRANSITION = 7;
    KAVACH_ERR_EXTERNALIZATION_BLOCKED = 8;
    KAVACH_ERR_IO_ERROR = 9;
    KAVACH_ERR_OTHER = 10;
}

fn kavach_err_name(code) {
    if (code == KAVACH_ERR_OK) { return "ok"; }
    if (code == KAVACH_ERR_BACKEND_UNAVAILABLE) { return "backend not available"; }
    if (code == KAVACH_ERR_CREATION_FAILED) { return "sandbox creation failed"; }
    if (code == KAVACH_ERR_EXEC_FAILED) { return "sandbox execution failed"; }
    if (code == KAVACH_ERR_TIMEOUT) { return "sandbox timeout"; }
    if (code == KAVACH_ERR_POLICY_VIOLATION) { return "policy violation"; }
    if (code == KAVACH_ERR_CREDENTIAL_ERROR) { return "credential error"; }
    if (code == KAVACH_ERR_INVALID_TRANSITION) { return "lifecycle error"; }
    if (code == KAVACH_ERR_EXTERNALIZATION_BLOCKED) { return "externalization blocked"; }
    if (code == KAVACH_ERR_IO_ERROR) { return "i/o error"; }
    if (code == KAVACH_ERR_OTHER) { return "error"; }
    return "unknown error";
}

fn kavach_err_print(code, detail) {
    var name = kavach_err_name(code);
    # Diagnostics to stderr (fd 2) via the stdlib write wrapper — no raw
    # syscall/magic number. Lengths are strlen of NUL-terminated cstrs or
    # literal byte counts of fixed strings (S3).
    sys_write(2, "kavach: ", 8);
    sys_write(2, name, strlen(name));
    if (detail != 0) {
        sys_write(2, ": ", 2);
        sys_write(2, detail, strlen(detail));
    }
    sys_write(2, "\n", 1);
    return 0;
}

# --- sys_security_syscalls.cyr ---

# sys_security_syscalls.cyr — raw x86_64 *LINUX* syscall numbers the
# internalized security/mac/kernel_audit backends need on the LINUX HOST target.
# (The prior comment mislabeled these "agnos-only" — they are plain Linux
# x86_64 numbers; that mislabel is exactly the confusion the 3.5.3 fix corrects.)
# The landlock / prctl / close numbers come from cyrius's lib/syscalls; only
# these are kept here. Extracted (NOT the whole per-arch layer) with the
# agnosys → agnodrm decomposition, to avoid duplicating cyrius's syscall layer.
#
# ⚠ DANGER ON AGNOS — these numbers ALIAS catastrophically on agnos's own 0-62
# syscall table (#41=sleep_ms, #44=unassigned, #45=getrandom, #49=sock_recv;
# #272/#520 are out of range). A raw syscall() with any of them on agnos would
# invoke the WRONG sovereign syscall (e.g. syscall(49,fd,sockaddr,12) → sock_recv
# with a sockaddr pointer as a destination buffer = memory-unsafe garbage).
# Therefore EVERY consumer of these constants — kernel_audit.cyr
# (audit_open/send_raw/recv_raw/agnos_log) and security.cyr (unshare) — MUST
# reference them ONLY inside a `#ifndef CYRIUS_TARGET_AGNOS` branch; the agnos
# branch returns err_not_supported (the security.cyr precedent). Confinement on
# agnos is the capability layer's job, not these Linux syscalls.
enum SecuritySyscall {
    SYS_UNSHARE = 272;          # Linux x86_64 unshare   (out of agnos 0-62 range)
    SYS_SOCKET_NR = 41;         # Linux x86_64 socket    (agnos #41 = sleep_ms!)
    SYS_BIND_NR = 49;           # Linux x86_64 bind      (agnos #49 = sock_recv!)
    SYS_SENDTO_NR = 44;         # Linux x86_64 sendto    (agnos #44 = unassigned)
    SYS_RECVFROM_NR = 45;       # Linux x86_64 recvfrom  (agnos #45 = getrandom!)
    SYS_AGNOS_AUDIT_LOG = 520;  # claimed-custom; NONEXISTENT on agnos (out of range)
}

# --- sys_error.cyr ---

# error.cyr — unified error type with errno mapping
# Ported from rust-old/src/error.rs
#
# In Cyrius, errors are integer codes. The SysError "enum" becomes
# integer constants, and error messages are string pointers.
#
# Error representation: a Result (tagged union from lib/tagged.cyr)
# where Err payload is a pointer to an error struct:
#   { kind: i64, errno: i64, message: *str }
#
# Convention: all agnosys functions return Result values.
# Ok(value) on success, Err(err_ptr) on failure.

# ================================================================
# Error kind constants (maps to Rust SysError variants)
# ================================================================

enum SysErrorKind {
    KAVACH_ERR_SYSCALL_FAILED = 1;
    KAVACH_ERR_INVALID_ARGUMENT = 2;
    KAVACH_ERR_PERMISSION_DENIED = 3;
    KAVACH_ERR_WOULD_BLOCK = 4;
    KAVACH_ERR_MODULE_NOT_LOADED = 5;
    KAVACH_ERR_NOT_SUPPORTED = 6;
    KAVACH_ERR_UNKNOWN = 7;
    KAVACH_ERR_IO = 8;
}

# ================================================================
# Errno constants (Linux x86_64)
# ================================================================

enum Errno {
    EPERM = 1;
    ENOENT = 2;
    ESRCH = 3;
    EINTR = 4;
    EIO = 5;
    ENXIO = 6;
    EBADF = 9;
    EAGAIN = 11;
    ENOMEM = 12;
    EACCES = 13;
    EFAULT = 14;
    EBUSY = 16;
    EEXIST = 17;
    ENODEV = 19;
    ENOTDIR = 20;
    EISDIR = 21;
    EINVAL = 22;
    EMFILE = 24;
    ENOSPC = 28;
    EPIPE = 32;
    ERANGE = 34;
    ENOSYS = 38;
    ENOTEMPTY = 39;
    ENODATA = 61;
    EOVERFLOW = 75;
    EOPNOTSUPP = 95;
    EADDRINUSE = 98;
    ECONNREFUSED = 111;
    ETIMEDOUT = 110;
}

# ================================================================
# Error struct: { kind, errno, message_ptr }
# Layout: kind at +0, errno at +8, message at +16. Total: 24 bytes.
# ================================================================

# ================================================================
# Error representation — dual encoding
# ================================================================
#
# Packed error: kind << 16 | errno (no message, no heap, value < 0x100000)
# Heap error:   pointer to { kind, errno, message_ptr } (24 bytes, value >= 0x100000)
#
# syserr_kind/errno/message dispatch on the value automatically.

# Pack kind + errno into a single integer (zero allocation)
fn syserr_pack(kind, errno): i64 {
    return kind << 16 | errno;
}

# Create a new error with message (heap-allocated, cold path)
fn syserr_new(kind, errno, message): i64 {
    var e = alloc(24);
    store64(e, kind);
    store64(e + 8, errno);
    store64(e + 16, message);
    return e;
}

# Get error kind (works for both packed and heap errors)
fn syserr_kind(e): i64 {
    if (e < 0x100000) { return e >> 16; }
    return load64(e);
}

# Get errno value (works for both packed and heap errors)
fn syserr_errno(e): i64 {
    if (e < 0x100000) { return e & 0xFFFF; }
    return load64(e + 8);
}

# Get error message pointer (0 for packed errors)
fn syserr_message(e): i64 {
    if (e < 0x100000) { return 0; }
    return load64(e + 16);
}

# ================================================================
# Error constructors — packed (fast, no alloc)
# ================================================================

fn err_syscall_failed_nr(errno): i64 {
    return Err(syserr_pack(KAVACH_ERR_SYSCALL_FAILED, errno));
}

fn err_permission_denied_nr(errno): i64 {
    return Err(syserr_pack(KAVACH_ERR_PERMISSION_DENIED, errno));
}

fn err_would_block(): i64 {
    return Err(syserr_pack(KAVACH_ERR_WOULD_BLOCK, EAGAIN));
}

fn err_invalid_argument_nr(): i64 {
    return Err(syserr_pack(KAVACH_ERR_INVALID_ARGUMENT, EINVAL));
}

fn err_not_supported_nr(): i64 {
    return Err(syserr_pack(KAVACH_ERR_NOT_SUPPORTED, ENOSYS));
}

# ================================================================
# Error constructors — with message (heap, cold path)
# ================================================================

fn err_syscall_failed(errno, message): i64 {
    return Err(syserr_new(KAVACH_ERR_SYSCALL_FAILED, errno, message));
}

fn err_invalid_argument(message): i64 {
    return Err(syserr_new(KAVACH_ERR_INVALID_ARGUMENT, EINVAL, message));
}

fn err_permission_denied(operation): i64 {
    return Err(syserr_new(KAVACH_ERR_PERMISSION_DENIED, EPERM, operation));
}

fn err_module_not_loaded(module): i64 {
    return Err(syserr_new(KAVACH_ERR_MODULE_NOT_LOADED, ENODEV, module));
}

fn err_not_supported(feature): i64 {
    return Err(syserr_new(KAVACH_ERR_NOT_SUPPORTED, ENOSYS, feature));
}

fn err_unknown(message): i64 {
    return Err(syserr_new(KAVACH_ERR_UNKNOWN, 0, message));
}

fn err_io(errno, message): i64 {
    return Err(syserr_new(KAVACH_ERR_IO, errno, message));
}

# ================================================================
# Errno-based error creation — packed (zero alloc, hot path)
# ================================================================

fn err_from_errno(errno): i64 {
    if (errno == EPERM) { return err_permission_denied_nr(EPERM); }
    if (errno == EACCES) { return err_permission_denied_nr(EACCES); }
    if (errno == EAGAIN) { return err_would_block(); }
    if (errno == EINVAL) { return err_invalid_argument_nr(); }
    if (errno == ENOSYS) { return err_not_supported_nr(); }
    return err_syscall_failed_nr(errno);
}

fn err_from_syscall_ret(ret): i64 {
    var errno = 0 - ret;
    return err_from_errno(errno);
}

# ================================================================
# Error printing
# ================================================================

fn syserr_print(e): i64 {
    var kind = syserr_kind(e);
    var msg = syserr_message(e);
    var msglen = 0;
    if (msg != 0) { msglen = strlen(msg); }

    # Exhaustive match — every SysErrorKind variant explicit so cyrius
    # lint catches any future addition that misses a handler. No
    # `_ =>` opt-out: a missing variant should fail loud (fall through
    # to the trailing newline + return) rather than silently degrade.
    match kind {
        KAVACH_ERR_SYSCALL_FAILED => {
            sys_write(2, "syscall failed (errno ", 22);
            var ebuf[24];
            var elen = fmt_int_buf(syserr_errno(e), &ebuf);
            sys_write(2, &ebuf, elen);
            sys_write(2, "): ", 3);
            sys_write(2, msg, msglen);
        }
        KAVACH_ERR_INVALID_ARGUMENT => {
            sys_write(2, "invalid argument: ", 18);
            sys_write(2, msg, msglen);
        }
        KAVACH_ERR_PERMISSION_DENIED => {
            sys_write(2, "permission denied: ", 19);
            sys_write(2, msg, msglen);
        }
        KAVACH_ERR_WOULD_BLOCK => {
            sys_write(2, "resource temporarily unavailable", 32);
        }
        KAVACH_ERR_MODULE_NOT_LOADED => {
            sys_write(2, "kernel module not loaded: ", 25);
            sys_write(2, msg, msglen);
        }
        KAVACH_ERR_NOT_SUPPORTED => {
            sys_write(2, "feature not supported: ", 23);
            sys_write(2, msg, msglen);
        }
        KAVACH_ERR_UNKNOWN => {
            sys_write(2, "unknown error: ", 15);
            sys_write(2, msg, msglen);
        }
        KAVACH_ERR_IO => {
            sys_write(2, "io error (errno ", 16);
            var ibuf[24];
            var ilen = fmt_int_buf(syserr_errno(e), &ibuf);
            sys_write(2, &ibuf, ilen);
            sys_write(2, "): ", 3);
            sys_write(2, msg, msglen);
        }
    }
    sys_write(2, "\n", 1);
    return 0;
}

# Print error from a Result if it's Err, then return the error code.
# Returns 0 if the Result is Ok.
fn result_print_err(res): i64 {
    if (is_ok(res) == 1) { return 0; }
    var e = payload(res);
    syserr_print(e);
    return syserr_errno(e);
}

# ================================================================
# Result helpers for agnosys convention
# ================================================================

# Propagate error: if res is Err, return it immediately.
# Use at top of functions: var val = try_unwrap(res); if (val == 0) { ... }
# Note: Cyrius has no ? operator, so error propagation is manual.
# Pattern:
#   var res = some_call();
#   if (is_err_result(res) == 1) { return res; }
#   var val = payload(res);

# Check if a syscall return value indicates error (negative = errno)
fn is_syscall_err(ret): i64 {
    return ret < 0;
}

# Wrap a raw syscall return: Ok(ret) if >= 0, Err(from_errno) if < 0
fn wrap_syscall(ret): i64 {
    if (ret < 0) { return err_from_syscall_ret(ret); }
    return Ok(ret);
}

# --- sys_util.cyr ---

# agnosys — shared cross-module utilities
#
# Small helpers that several modules need identically. Kept here (rather
# than copied per-module) so a single definition is audited and tested
# once. Public `agnosys_*` prefix per the project's prefix discipline.
#
# Placed in [lib.core] so every profile bundle (core + domain) resolves
# these — consumers span security/storage/trust/system profiles.

# Emit a JSON value for a possibly-null C string into a str_builder:
# `null` when the pointer is 0, otherwise a JSON-quoted/escaped string.
# Replaces the per-module `_<mod>_emit_cstr_or_null` shims (mac, dmverity,
# drm, certpin, update) that were byte-identical.
fn agnosys_json_emit_cstr_or_null(sb, c): i64 {
    if (c == 0) {
        str_builder_add_cstr(sb, "null");
    } else {
        str_builder_add_json_str(sb, str_from(c));
    }
    return 0;
}

# Is `ch` an ASCII hex digit (0-9, a-f, A-F)? Single definition shared by
# the hash/digest validators in ima, dmverity, tpm, update.
fn agnosys_is_hex_char(ch): i64 {
    if (ch >= 48 && ch <= 57) { return 1; }   # 0-9
    if (ch >= 65 && ch <= 70) { return 1; }   # A-F
    if (ch >= 97 && ch <= 102) { return 1; }  # a-f
    return 0;
}

# Is `ch` valid in a device-mapper / volume name (alphanumeric, `-`, `_`)?
# Single source for the dm-name allowlist shared by dmverity and luks.
fn agnosys_is_name_char(ch): i64 {
    if (ch >= 48 && ch <= 57) { return 1; }   # 0-9
    if (ch >= 65 && ch <= 90) { return 1; }   # A-Z
    if (ch >= 97 && ch <= 122) { return 1; }  # a-z
    if (ch == 45) { return 1; }               # -
    if (ch == 95) { return 1; }               # _
    return 0;
}

# Does C string `str` start with C string `prefix`? Single-pass: walks
# `prefix` and compares, stopping at the first mismatch, the prefix
# terminator, or the str terminator — no up-front strlen of either side
# (the previous per-module copies scanned both strings fully first).
fn agnosys_cstr_starts_with(str, prefix): i64 {
    var i = 0;
    var pc = load8(prefix);
    while (pc != 0) {
        var sc = load8(str + i);
        if (sc == 0) { return 0; }
        if (sc != pc) { return 0; }
        i = i + 1;
        pc = load8(prefix + i);
    }
    return 1;
}

# Run a subprocess (cstr argv vec) and capture stdout into a caller buffer.
# Returns Ok(bytes_read) or Err(errmsg) on exec failure. `errmsg` is the
# per-tool diagnostic. Shared by dmverity/luks/tpm `*_run_capture`.
fn agnosys_run_capture(args, buf, buflen, errmsg): i64 {
    var n = exec_capture(args, buf, buflen);
    if (n < 0) {
        return err_unknown(errmsg);
    }
    return Ok(n);
}

# Run a subprocess (cstr argv vec) and check for a zero exit code.
# Returns Ok(0) or Err(errmsg) on non-zero exit / exec failure. Shared by
# dmverity/luks/tpm `*_run_checked`.
fn agnosys_run_checked(args, errmsg): i64 {
    var rc = exec_vec(args);
    if (rc != 0) {
        return err_unknown(errmsg);
    }
    return Ok(0);
}

# Read up to `cap` bytes from `fd` into a fresh heap buffer, NUL-terminate,
# and return it as a Str (also valid as a cstr). Drains short reads. The
# buffer is `cap + 1` bytes so the terminator never writes past the end
# even at a full read (the per-module copies alloc'd exactly `cap`, a
# latent 1-byte overflow when the file filled the buffer). Shared by the
# pam config / passwd readers.
fn agnosys_read_fd_to_str(fd, cap): i64 {
    var buf = alloc(cap + 1);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var n = sys_read(fd, buf + total, cap - total);
        if (n <= 0) {
            rgo = 0;
        } else {
            total = total + n;
            if (total >= cap) { rgo = 0; }
        }
    }
    store8(buf + total, 0);
    return str_new(buf, total);
}

# --- security.cyr ---

# security.cyr — Landlock, seccomp BPF, namespace creation
# Ported from rust-old/src/security.rs
#
# Provides Landlock filesystem sandboxing, seccomp-BPF syscall filtering,
# and Linux namespace creation via raw syscalls.

#define LINUX
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/tagged.cyr"
include "lib/syscalls.cyr"
include "lib/hashmap.cyr"

# ================================================================
# Landlock constants (kernel 5.13+)
# ================================================================
#
# SYS_LANDLOCK_* numbers are arch-invariant and now provided by
# lib/syscalls.cyr (cyrius 5.7.x). SYS_PRCTL is arch-varying and
# supplied by src/syscall_arch.cyr.

enum LandlockConst {
    LANDLOCK_ACCESS_FS_READ_FILE = 4;
    LANDLOCK_ACCESS_FS_READ_DIR = 8;
    LANDLOCK_ACCESS_FS_WRITE_FILE = 2;
    LANDLOCK_RULE_PATH_BENEATH = 1;
}

# Filesystem access levels
enum FsAccess {
    FS_NO_ACCESS = 0;
    FS_READ_ONLY = 1;
    FS_READ_WRITE = 2;
}

# Filesystem rule: { path_ptr, access }
# path_ptr is a null-terminated C string pointer
fn security_fs_rule_new(path, access): i64 {
    var r = alloc(16);
    store64(r, path);
    store64(r + 8, access);
    return r;
}

fn security_fs_rule_path(r): i64 { return load64(r); }
fn security_fs_rule_access(r): i64 { return load64(r + 8); }

fn security_fs_rule_read_only(path): i64 { return security_fs_rule_new(path, FS_READ_ONLY); }
fn security_fs_rule_read_write(path): i64 { return security_fs_rule_new(path, FS_READ_WRITE); }

# ================================================================
# Apply Landlock filesystem restrictions
# ================================================================

# rules: vec of fs_rule pointers, count: number of rules
# Returns Result: Ok(0) on success, Err on failure.
fn security_apply_landlock(rules, count): i64 {
    if (count == 0) { return Ok(0); }

    #ifdef CYRIUS_TARGET_AGNOS
    # AGNOS has no Landlock (a Linux LSM/MAC primitive). FS confinement on AGNOS
    # is the capability layer's responsibility, so report a structured "unsupported
    # on this platform" the system process can surface + branch on — the same way
    # mac.cyr handles SELinux/AppArmor and kernel_audit.cyr handles NETLINK_AUDIT.
    # This is deliberately NOT a silent Ok(0): a silent success would falsely imply
    # the sandbox's FS rules were enforced. Transitional — until AGNOS ships its own
    # FS-confinement mechanism (the native capability-layer Landlock-equivalent),
    # at which point this branch calls that instead of returning unsupported.
    return err_not_supported("LANDLOCK");
    #endif
    #ifndef CYRIUS_TARGET_AGNOS

    var handled_access = LANDLOCK_ACCESS_FS_READ_FILE
    | LANDLOCK_ACCESS_FS_READ_DIR | LANDLOCK_ACCESS_FS_WRITE_FILE;

    # LandlockRulesetAttr: { handled_access_fs: u64 } = 8 bytes.
    # Function-local `var X[N]` is N BYTES (cyrius 6.3.13 moved these to
    # the guard-paged thread stack), so this must be [8] to hold the u64
    # store64 below — `var attr[1]` was a 1-byte local taking an 8-byte
    # write, a latent stack smash that 6.3.13+ turns into a hard fault.
    var attr[8];
    store64(&attr, handled_access);

    var ruleset_fd = syscall(SYS_LANDLOCK_CREATE_RULESET, &attr, 8, 0);
    if (ruleset_fd < 0) {
        var errno = 0 - ruleset_fd;
        if (errno == ENOSYS) { return Ok(0); }
        if (errno == EOPNOTSUPP) { return Ok(0); }
        return err_syscall_failed(errno, "landlock_create_ruleset failed");
    }
    defer { syscall(SYS_CLOSE, ruleset_fd); }

    var idx = 0;
    while (idx < count) {
        var rule = vec_get(rules, idx);
        var access = security_fs_rule_access(rule);

        var allowed_access = 0;
        if (access == FS_READ_ONLY) {
            allowed_access = LANDLOCK_ACCESS_FS_READ_FILE | LANDLOCK_ACCESS_FS_READ_DIR;
        }
        elif (access == FS_READ_WRITE) {
            allowed_access = LANDLOCK_ACCESS_FS_READ_FILE
            | LANDLOCK_ACCESS_FS_READ_DIR | LANDLOCK_ACCESS_FS_WRITE_FILE;
        }

        if (allowed_access != 0) {
            var path = security_fs_rule_path(rule);
            # O_PATH = 0x200000, O_CLOEXEC = 0x80000
            var path_fd = sys_open(path, 0x280000, 0);
            if (path_fd < 0) {
                return err_syscall_failed(0 - path_fd, "landlock open path failed");
            }

            # LandlockPathBeneathAttr: { allowed_access: u64, parent_fd: i32 }
            # Layout: 8 bytes access + 4 bytes fd = 12 bytes (pad to 16)
            var beneath[16];
            store64(&beneath, allowed_access);
            store32(&beneath + 8, path_fd);

            var ret = syscall(SYS_LANDLOCK_ADD_RULE,
            ruleset_fd, LANDLOCK_RULE_PATH_BENEATH, &beneath, 0);
            syscall(SYS_CLOSE, path_fd);

            if (ret < 0) {
                return err_syscall_failed(0 - ret, "landlock_add_rule failed");
            }
        }
        idx = idx + 1;
    }

    # Set no_new_privs (required by Landlock)
    var ret = syscall(SYS_PRCTL, 38, 1, 0, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "PR_SET_NO_NEW_PRIVS failed");
    }

    ret = syscall(SYS_LANDLOCK_RESTRICT_SELF, ruleset_fd, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "landlock_restrict_self failed");
    }

    return Ok(0);
    #endif
}

# ================================================================
# Seccomp BPF
# ================================================================

# BPF instruction constants
enum BpfConst {
    BPF_LD_W_ABS = 0x20;
    BPF_JMP_JEQ_K = 0x15;
    BPF_RET_K = 0x06;
    SECCOMP_RET_ALLOW = 0x7FFF0000;
    SECCOMP_RET_KILL_PROCESS = 0x80000000;
    SECCOMP_RET_TRAP = 0x00030000;
    BPF_MAXINSNS = 4096;
    PR_SET_NO_NEW_PRIVS = 38;
    PR_SET_SECCOMP = 22;
    SECCOMP_MODE_FILTER = 2;
}

# BPF sock_filter instruction — kernel ABI struct (8 bytes).
# Layout enforced by per-field widths; pointer-to-struct dot syntax
# emits store16/store8/store32 at the kernel-correct offsets.
struct bpf_insn {
    code: i16;
    jt: i8;
    jf: i8;
    k: i32;
}

# Write a BPF sock_filter instruction (8 bytes) to buf at offset.
fn security_bpf_write_insn(buf, offset, code, jt, jf, k): i64 {
    var insn: bpf_insn = buf + offset;
    insn.code = code;
    insn.jt = jt;
    insn.jf = jf;
    insn.k = k;
    return 0;
}

# Load a seccomp-BPF filter into the calling process.
# filter: pointer to BPF bytecode, filter_len: total bytes.
# Returns Result.
fn security_load_seccomp(filter, filter_len): i64 {
    if (filter_len == 0) {
        return err_invalid_argument("empty seccomp filter");
    }
    if (filter_len % 8 != 0) {
        return err_invalid_argument("filter size not multiple of 8");
    }
    var num_insns = filter_len / 8;
    if (num_insns > BPF_MAXINSNS) {
        return err_invalid_argument("seccomp filter too large");
    }

    #ifdef CYRIUS_TARGET_AGNOS
    # AGNOS has no seccomp-BPF (a Linux syscall-filtering facility). Syscall-surface
    # restriction on AGNOS is the capability layer's job, so report a structured
    # "unsupported on this platform" (same pattern as Landlock above) rather than a
    # silent Ok(0) that would falsely imply the syscall surface was filtered. The
    # filter is still validated above. Transitional — until AGNOS provides native
    # syscall-surface filtering, at which point this branch calls that instead.
    return err_not_supported("SECCOMP");
    #endif
    #ifndef CYRIUS_TARGET_AGNOS

    # Set no_new_privs
    var ret = syscall(SYS_PRCTL, PR_SET_NO_NEW_PRIVS, 1, 0, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "PR_SET_NO_NEW_PRIVS failed");
    }

    # sock_fprog: { u16 len, pad[6], u64 filter_ptr }
    # On x86_64: { u16 len (2 bytes), 6 pad, ptr (8 bytes) } = 16 bytes
    var prog[16];
    store16(&prog, num_insns);
    store64(&prog + 8, filter);

    ret = syscall(SYS_PRCTL, PR_SET_SECCOMP, SECCOMP_MODE_FILTER, &prog, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "PR_SET_SECCOMP failed");
    }

    return Ok(0);
    #endif
}

# Create a basic seccomp filter allowing safe syscalls.
# Returns Result: Ok(filter_ptr) where payload is {ptr, len}.
# The caller must use the returned pointer and length with security_load_seccomp.
fn security_create_basic_seccomp_filter(): i64 {
    # Pre-computed BPF filter: 23 instructions x 8 bytes = 184 bytes.
    # Layout per insn: u16 code, u8 jt, u8 jf, u32 k (little-endian).
    # 20 allowlisted syscalls: read(0), write(1), close(3), fstat(5),
    # mmap(9), mprotect(10), munmap(11), brk(12), rt_sigreturn(15),
    # exit(60), sigaltstack(131), arch_prctl(158), gettid(186),
    # futex(202), set_tid_address(218), exit_group(231),
    # set_robust_list(273), getrandom(318), clock_gettime(228), rseq(334).
    var filter_size = 184;
    var filter = alloc(filter_size);

    # Insn 0: BPF_LD_W_ABS, k=0 (load syscall nr)
    security_bpf_write_insn(filter, 0, 0x20, 0, 0, 0);
    # Insns 1-20: JEQ for each syscall, jt = skip to ALLOW
    security_bpf_write_insn(filter, 8,   0x15, 20, 0, 0);     # read
    security_bpf_write_insn(filter, 16,  0x15, 19, 0, 1);     # write
    security_bpf_write_insn(filter, 24,  0x15, 18, 0, 3);     # close
    security_bpf_write_insn(filter, 32,  0x15, 17, 0, 5);     # fstat
    security_bpf_write_insn(filter, 40,  0x15, 16, 0, 9);     # mmap
    security_bpf_write_insn(filter, 48,  0x15, 15, 0, 10);    # mprotect
    security_bpf_write_insn(filter, 56,  0x15, 14, 0, 11);    # munmap
    security_bpf_write_insn(filter, 64,  0x15, 13, 0, 12);    # brk
    security_bpf_write_insn(filter, 72,  0x15, 12, 0, 15);    # rt_sigreturn
    security_bpf_write_insn(filter, 80,  0x15, 11, 0, 60);    # exit
    security_bpf_write_insn(filter, 88,  0x15, 10, 0, 131);   # sigaltstack
    security_bpf_write_insn(filter, 96,  0x15, 9,  0, 158);   # arch_prctl
    security_bpf_write_insn(filter, 104, 0x15, 8,  0, 186);   # gettid
    security_bpf_write_insn(filter, 112, 0x15, 7,  0, 202);   # futex
    security_bpf_write_insn(filter, 120, 0x15, 6,  0, 218);   # set_tid_address
    security_bpf_write_insn(filter, 128, 0x15, 5,  0, 231);   # exit_group
    security_bpf_write_insn(filter, 136, 0x15, 4,  0, 273);   # set_robust_list
    security_bpf_write_insn(filter, 144, 0x15, 3,  0, 318);   # getrandom
    security_bpf_write_insn(filter, 152, 0x15, 2,  0, 228);   # clock_gettime
    security_bpf_write_insn(filter, 160, 0x15, 1,  0, 334);   # rseq
    # Insn 21: default KILL
    security_bpf_write_insn(filter, 168, 0x06, 0, 0, 0x80000000);
    # Insn 22: ALLOW
    security_bpf_write_insn(filter, 176, 0x06, 0, 0, 0x7FFF0000);

    var info = alloc(16);
    store64(info, filter);
    store64(info + 8, filter_size);
    return Ok(info);
}

# Get filter pointer from security_create_basic_seccomp_filter result
fn security_seccomp_filter_ptr(info): i64 { return load64(info); }
fn security_seccomp_filter_len(info): i64 { return load64(info + 8); }

# ================================================================
# Namespace creation
# ================================================================

enum CloneFlag {
    CLONE_NEWNET = 0x40000000;
    CLONE_NEWNS = 0x00020000;
    CLONE_NEWPID = 0x20000000;
    CLONE_NEWUSER = 0x10000000;
}

enum NsFlag {
    NS_NETWORK = 1;
    NS_MOUNT = 2;
    NS_PID = 4;
    NS_USER = 8;
}

# SYS_UNSHARE is arch-varying and supplied via src/syscall_arch.cyr.

# Create new namespace(s) with specified flags.
# flags: bitwise OR of NS_NETWORK, NS_MOUNT, NS_PID, NS_USER
# Returns Result.
fn security_create_namespace(flags): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    # AGNOS has no Linux namespaces / unshare(2). Process isolation on AGNOS is the
    # capability layer's job, so report a structured "unsupported on this platform"
    # (same pattern as Landlock/seccomp) rather than a silent Ok(0) that would falsely
    # imply isolation was applied. Transitional — until AGNOS provides native
    # isolation primitives, at which point this branch calls those instead.
    return err_not_supported("NAMESPACES");
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    var sflags = 0;
    if ((flags & NS_NETWORK) != 0) { sflags = sflags | CLONE_NEWNET; }
    if ((flags & NS_MOUNT) != 0) { sflags = sflags | CLONE_NEWNS; }
    if ((flags & NS_PID) != 0) { sflags = sflags | CLONE_NEWPID; }
    if ((flags & NS_USER) != 0) { sflags = sflags | CLONE_NEWUSER; }

    var ret = syscall(SYS_UNSHARE, sflags);
    if (ret < 0) {
        var errno = 0 - ret;
        if (errno == EPERM) { return err_permission_denied("security_create_namespace"); }
        if (errno == EINVAL) { return err_invalid_argument("security_create_namespace: invalid flags"); }
        return err_syscall_failed(errno, "unshare failed");
    }

    return Ok(0);
    #endif
}

# ================================================================
# Syscall name to number mapping (hashmap, O(1) lookup)
# ================================================================

var _syscall_map = 0;

fn security_syscall_map_reset(): i64 { _syscall_map = 0; return 0; }

fn _syscall_map_init(): i64 {
    if (_syscall_map != 0) { return 0; }
    _syscall_map = map_new();
    map_set(_syscall_map, "read", 0);
    map_set(_syscall_map, "write", 1);
    map_set(_syscall_map, "open", 2);
    map_set(_syscall_map, "close", 3);
    map_set(_syscall_map, "stat", 4);
    map_set(_syscall_map, "fstat", 5);
    map_set(_syscall_map, "lseek", 8);
    map_set(_syscall_map, "mmap", 9);
    map_set(_syscall_map, "mprotect", 10);
    map_set(_syscall_map, "munmap", 11);
    map_set(_syscall_map, "brk", 12);
    map_set(_syscall_map, "rt_sigreturn", 15);
    map_set(_syscall_map, "ioctl", 16);
    map_set(_syscall_map, "access", 21);
    map_set(_syscall_map, "pipe", 22);
    map_set(_syscall_map, "dup", 32);
    map_set(_syscall_map, "dup2", 33);
    map_set(_syscall_map, "getpid", 39);
    map_set(_syscall_map, "socket", 41);
    map_set(_syscall_map, "connect", 42);
    map_set(_syscall_map, "accept", 43);
    map_set(_syscall_map, "sendto", 44);
    map_set(_syscall_map, "recvfrom", 45);
    map_set(_syscall_map, "bind", 49);
    map_set(_syscall_map, "listen", 50);
    map_set(_syscall_map, "fork", 57);
    map_set(_syscall_map, "execve", 59);
    map_set(_syscall_map, "exit", 60);
    map_set(_syscall_map, "wait4", 61);
    map_set(_syscall_map, "kill", 62);
    map_set(_syscall_map, "fcntl", 72);
    map_set(_syscall_map, "fsync", 74);
    map_set(_syscall_map, "getcwd", 79);
    map_set(_syscall_map, "chdir", 80);
    map_set(_syscall_map, "mkdir", 83);
    map_set(_syscall_map, "rmdir", 84);
    map_set(_syscall_map, "unlink", 87);
    map_set(_syscall_map, "chmod", 90);
    map_set(_syscall_map, "getuid", 102);
    map_set(_syscall_map, "getgid", 104);
    map_set(_syscall_map, "geteuid", 107);
    map_set(_syscall_map, "getegid", 108);
    map_set(_syscall_map, "getppid", 110);
    map_set(_syscall_map, "setsid", 112);
    map_set(_syscall_map, "prctl", 157);
    map_set(_syscall_map, "mount", 165);
    map_set(_syscall_map, "umount2", 166);
    map_set(_syscall_map, "gettid", 186);
    map_set(_syscall_map, "futex", 202);
    map_set(_syscall_map, "getdents64", 217);
    map_set(_syscall_map, "set_tid_address", 218);
    map_set(_syscall_map, "clock_gettime", 228);
    map_set(_syscall_map, "exit_group", 231);
    map_set(_syscall_map, "openat", 257);
    map_set(_syscall_map, "set_robust_list", 273);
    map_set(_syscall_map, "pipe2", 293);
    map_set(_syscall_map, "epoll_create1", 291);
    map_set(_syscall_map, "getrandom", 318);
    map_set(_syscall_map, "rseq", 334);
    return 0;
}

# Map a syscall name to its x86_64 number. Returns -1 if not found.
fn security_syscall_name_to_nr(name): i64 {
    _syscall_map_init();
    if (map_has(_syscall_map, name) == 1) {
        return map_get(_syscall_map, name);
    }
    return 0 - 1;
}

# --- mac.cyr ---

# mac.cyr — Mandatory Access Control (MAC) interface
# Ported from rust-old/src/mac.rs
#
# Auto-detects the active Linux Security Module (SELinux or AppArmor)
# and provides security context / profile management.
#
# Reads /sys/kernel/security/lsm for LSM detection. SELinux mode from
# /sys/fs/selinux/enforce. AppArmor profiles via /proc/self/attr/current.
#
# Requires: lib/syscalls.cyr, lib/string.cyr, lib/str.cyr, src/error.cyr

#define LINUX
include "lib/string.cyr"
include "lib/alloc.cyr"
include "lib/str.cyr"
include "lib/tagged.cyr"
include "lib/syscalls.cyr"

# ================================================================
# MAC system constants
# ================================================================

enum MacSystem {
    MAC_NONE = 0;
    MAC_SELINUX = 1;
    MAC_APPARMOR = 2;
}

# ================================================================
# SELinux mode constants
# ================================================================

enum SELinuxMode {
    SELINUX_ENFORCING = 1;
    SELINUX_PERMISSIVE = 2;
    SELINUX_DISABLED = 3;
}

# ================================================================
# AppArmor profile state constants
# ================================================================

enum AppArmorState {
    AA_ENFORCE = 1;
    AA_COMPLAIN = 2;
    AA_UNCONFINED = 3;
}

# ================================================================
# File read helper — read a small file into a Str
# Returns Result: Ok(str_ptr) or Err(syserr)
# ================================================================

fn mac_read_file(path): i64 {
    var fd = sys_open(path, O_RDONLY, 0);
    if (fd < 0) {
        return err_io(0 - fd, path);
    }
    defer { sys_close(fd); }
    # Read up to 4096 bytes (plenty for sysfs/procfs files)
    var buf = alloc(4097);
    memset(buf, 0, 4097);
    var n = sys_read(fd, buf, 4096);
    if (n < 0) {
        return err_io(0 - n, path);
    }
    # Null-terminate
    store8(buf + n, 0);
    # Create Str from buffer
    var s = str_new(buf, n);
    return Ok(s);
}

# ================================================================
# File write helper — write a C string to a file
# Returns Result: Ok(0) or Err(syserr)
# ================================================================

fn mac_write_file(path, data, data_len): i64 {
    var fd = sys_open(path, O_WRONLY, 0);
    if (fd < 0) {
        var errno = 0 - fd;
        if (errno == EPERM) { return err_permission_denied(path); }
        if (errno == EACCES) { return err_permission_denied(path); }
        return err_io(errno, path);
    }
    defer { sys_close(fd); }
    var n = sys_write(fd, data, data_len);
    if (n < 0) {
        var werrno = 0 - n;
        if (werrno == EPERM) { return err_permission_denied(path); }
        if (werrno == EACCES) { return err_permission_denied(path); }
        return err_io(werrno, path);
    }
    return Ok(0);
}

# ================================================================
# File existence check — returns 1 if file exists, 0 otherwise
# ================================================================

fn mac_file_exists(path): i64 {
    # F_OK = 0
    return sys_access(path, 0) == 0;
}

# ================================================================
# Detect which MAC system is active on this kernel
# Reads /sys/kernel/security/lsm — returns MAC_SELINUX, MAC_APPARMOR,
# or MAC_NONE.
# ================================================================

fn mac_detect_system(): i64 {
    var res = mac_read_file("/sys/kernel/security/lsm");
    if (is_err_result(res) == 1) {
        # Cannot read LSM file — no MAC detection available
        return MAC_NONE;
    }
    var contents = payload(res);

    # Check SELinux first (higher priority if both are listed)
    if (str_contains(contents, str_from("selinux")) == 1) {
        return MAC_SELINUX;
    }
    # Also check uppercase variant
    if (str_contains(contents, str_from("SELinux")) == 1) {
        return MAC_SELINUX;
    }

    if (str_contains(contents, str_from("apparmor")) == 1) {
        return MAC_APPARMOR;
    }
    if (str_contains(contents, str_from("AppArmor")) == 1) {
        return MAC_APPARMOR;
    }

    return MAC_NONE;
}

# ================================================================
# SELinux mode query
# Reads /sys/fs/selinux/enforce.
# Returns Result: Ok(mode) where mode is SELINUX_ENFORCING,
# SELINUX_PERMISSIVE, or SELINUX_DISABLED.
# ================================================================

fn mac_get_selinux_mode(): i64 {
    var enforce_path = "/sys/fs/selinux/enforce";

    if (mac_file_exists(enforce_path) == 0) {
        return Ok(SELINUX_DISABLED);
    }

    var res = mac_read_file(enforce_path);
    if (is_err_result(res) == 1) { return res; }

    var contents = payload(res);
    var trimmed = str_trim(contents);
    var data = str_data(trimmed);
    var tlen = str_len(trimmed);

    # "1" = enforcing, "0" = permissive
    if (tlen >= 1) {
        var ch = load8(data);
        if (ch == 49) { return Ok(SELINUX_ENFORCING); }
        if (ch == 48) { return Ok(SELINUX_PERMISSIVE); }
    }

    return Ok(SELINUX_DISABLED);
}

# ================================================================
# Set SELinux enforcement mode
# Writes to /sys/fs/selinux/enforce. Requires CAP_MAC_ADMIN.
# Returns Result: Ok(0) or Err.
# ================================================================

fn mac_set_selinux_mode(mode): i64 {
    var enforce_path = "/sys/fs/selinux/enforce";

    if (mac_file_exists(enforce_path) == 0) {
        return err_not_supported("selinux");
    }

    if (mode == SELINUX_DISABLED) {
        return err_invalid_argument("cannot disable SELinux at runtime; use kernel boot parameter");
    }

    if (mode == SELINUX_ENFORCING) {
        return mac_write_file(enforce_path, "1", 1);
    }
    if (mode == SELINUX_PERMISSIVE) {
        return mac_write_file(enforce_path, "0", 1);
    }

    return err_invalid_argument("invalid SELinux mode");
}

# ================================================================
# Get the current SELinux security context of this process
# Reads /proc/self/attr/current.
# Returns Result: Ok(str_ptr) or Err.
# ================================================================

fn mac_get_selinux_context(): i64 {
    var path = "/proc/self/attr/current";

    if (mac_file_exists(path) == 0) {
        return err_not_supported("selinux");
    }

    var res = mac_read_file(path);
    if (is_err_result(res) == 1) { return res; }

    var raw = payload(res);
    # Trim trailing nulls and whitespace
    var trimmed = str_trim(raw);
    return Ok(trimmed);
}

# ================================================================
# Set the SELinux security context for this process
# context: null-terminated C string (user:role:type:level)
# on_exec: if 1, apply on next exec (writes /proc/self/attr/exec)
#          if 0, apply immediately (writes /proc/self/attr/current)
# Returns Result: Ok(0) or Err.
# ================================================================

fn mac_set_selinux_context(context, on_exec): i64 {
    if (strlen(context) == 0) {
        return err_invalid_argument("SELinux context cannot be empty");
    }

    # Validate format: must have at least 3 colons (user:role:type:level)
    var ctx_len = strlen(context);
    var colon_count = 0;
    var vi = 0;
    while (vi < ctx_len) {
        if (load8(context + vi) == 58) {
            colon_count = colon_count + 1;
        }
        vi = vi + 1;
    }
    if (colon_count < 3) {
        return err_invalid_argument(
        "invalid SELinux context format (expected user:role:type:level)");
    }

    var path = "/proc/self/attr/current";
    if (on_exec == 1) {
        path = "/proc/self/attr/exec";
    }

    if (mac_file_exists(path) == 0) {
        return err_not_supported("selinux");
    }

    return mac_write_file(path, context, ctx_len);
}

# ================================================================
# Get the current AppArmor mode/profile of this process
# Reads /proc/self/attr/current.
# Returns Result: Ok(state) where state is AA_ENFORCE, AA_COMPLAIN,
# or AA_UNCONFINED.
# ================================================================

fn mac_get_apparmor_mode(): i64 {
    var path = "/proc/self/attr/current";

    if (mac_file_exists(path) == 0) {
        return err_not_supported("apparmor");
    }

    var res = mac_read_file(path);
    if (is_err_result(res) == 1) { return res; }

    var raw = payload(res);
    var trimmed = str_trim(raw);

    # AppArmor format: "profile_name (mode)" or "unconfined"
    if (str_contains(trimmed, str_from("unconfined")) == 1) {
        return Ok(AA_UNCONFINED);
    }
    if (str_contains(trimmed, str_from("enforce")) == 1) {
        return Ok(AA_ENFORCE);
    }
    if (str_contains(trimmed, str_from("complain")) == 1) {
        return Ok(AA_COMPLAIN);
    }

    # Default: if we got a non-empty profile, assume enforce mode
    if (str_len(trimmed) > 0) {
        return Ok(AA_ENFORCE);
    }

    return Ok(AA_UNCONFINED);
}

# ================================================================
# Change the AppArmor profile of the current process
# Writes "changeprofile <name>" to /proc/self/attr/current.
# profile_name: null-terminated C string.
# Returns Result: Ok(0) or Err.
# ================================================================

fn mac_apparmor_change_profile(profile_name): i64 {
    var name_len = strlen(profile_name);

    if (name_len == 0) {
        return err_invalid_argument("AppArmor profile name cannot be empty");
    }

    # Validate: no slashes or nulls in profile name
    var ci = 0;
    while (ci < name_len) {
        var ch = load8(profile_name + ci);
        if (ch == 47) {
            return err_invalid_argument("invalid AppArmor profile name: contains /");
        }
        if (ch == 0) {
            return err_invalid_argument("invalid AppArmor profile name: contains null");
        }
        ci = ci + 1;
    }

    var attr_path = "/proc/self/attr/current";
    if (mac_file_exists(attr_path) == 0) {
        return err_not_supported("apparmor");
    }

    # Build "changeprofile <name>" command
    var prefix = "changeprofile ";
    var prefix_len = strlen(prefix);
    var cmd_len = prefix_len + name_len;
    var cmd = alloc(cmd_len + 1);
    memcpy(cmd, prefix, prefix_len);
    memcpy(cmd + prefix_len, profile_name, name_len);
    store8(cmd + cmd_len, 0);

    return mac_write_file(attr_path, cmd, cmd_len);
}

# ================================================================
# Agent MAC profile struct
# Each field is a pointer to a null-terminated C string (or 0 for none).
# Total: 24 bytes (3 * 8). Accessors auto-generated:
#   getters: mac_profile_<field>(p)
#   setters: mac_profile_set_<field>(p, v)
# ================================================================

#derive(accessors)
struct mac_profile { agent_type; selinux_ctx; apparmor_name; }

fn mac_profile_new(agent_type): i64 {
    var p = alloc(24);
    mac_profile_set_agent_type(p, agent_type);
    mac_profile_set_selinux_ctx(p, 0);
    mac_profile_set_apparmor_name(p, 0);
    return p;
}

# Hand-rolled JSON serializer (cyrius v5.10.15 #derive(Serialize)
# doesn't support cstring-pointer fields; cyrius issue filed
# 2026-05-09). Mirrors the codegen output shape for migration when
# cstring support lands.
fn mac_profile_to_json(p, sb): i64 {
    str_builder_add_cstr(sb, "{\"agent_type\":");
    agnosys_json_emit_cstr_or_null(sb, mac_profile_agent_type(p));
    str_builder_add_cstr(sb, ",\"selinux_ctx\":");
    agnosys_json_emit_cstr_or_null(sb, mac_profile_selinux_ctx(p));
    str_builder_add_cstr(sb, ",\"apparmor_name\":");
    agnosys_json_emit_cstr_or_null(sb, mac_profile_apparmor_name(p));
    str_builder_add_cstr(sb, "}");
    return 0;
}

# ================================================================
# Create a default agent MAC profile from an agent type string
# Generates standard SELinux context and AppArmor profile name.
# agent_type: null-terminated C string (e.g. "user", "service", "system")
# ================================================================

fn mac_default_profile(agent_type): i64 {
    var p = mac_profile_new(agent_type);
    var tlen = strlen(agent_type);

    # Build SELinux context: "system_u:system_r:agnos_agent_<type>_t:s0"
    # Max: 29 + 32 (type) + 5 = 66 bytes
    var ctx_prefix = "system_u:system_r:agnos_agent_";
    var ctx_suffix = "_t:s0";
    var cplen = 29;
    var cslen = 5;
    # Build straight into the heap allocation (caller may hold the pointer
    # beyond alloc_reset). Skips a static staging buffer + the extra
    # buffer→heap copy, and avoids the function-scoped `var buf[N]`
    # static-data hazard.
    var ctx_total = cplen + tlen + cslen;
    var ctx = alloc(ctx_total + 1);
    memcpy(ctx, ctx_prefix, cplen);
    memcpy(ctx + cplen, agent_type, tlen);
    memcpy(ctx + cplen + tlen, ctx_suffix, cslen);
    store8(ctx + cplen + tlen + cslen, 0);
    mac_profile_set_selinux_ctx(p, ctx);

    # Build AppArmor profile: "agnos-agent-<type>"
    var aa_prefix = "agnos-agent-";
    var aplen = 12;
    var aa_total = aplen + tlen;
    var aa = alloc(aa_total + 1);
    memcpy(aa, aa_prefix, aplen);
    memcpy(aa + aplen, agent_type, tlen);
    store8(aa + aplen + tlen, 0);
    mac_profile_set_apparmor_name(p, aa);

    return p;
}

# ================================================================
# Validate an agent MAC profile for a given MAC system
# Returns Result: Ok(0) on valid, Err on invalid.
# ================================================================

fn mac_profile_validate(profile, mac_system): i64 {
    var agent_type = mac_profile_agent_type(profile);
    if (agent_type == 0) {
        return err_invalid_argument("agent type cannot be empty");
    }
    if (strlen(agent_type) == 0) {
        return err_invalid_argument("agent type cannot be empty");
    }

    if (mac_system == MAC_SELINUX) {
        var ctx = mac_profile_selinux_ctx(profile);
        if (ctx == 0) {
            return err_invalid_argument("SELinux context required but not set");
        }
        var ctx_len = strlen(ctx);
        if (ctx_len == 0) {
            return err_invalid_argument("SELinux context required but not set");
        }
        # Count colons — must have at least 3 (user:role:type:level)
        var colon_count = 0;
        var vi = 0;
        while (vi < ctx_len) {
            if (load8(ctx + vi) == 58) { colon_count = colon_count + 1; }
            vi = vi + 1;
        }
        if (colon_count < 3) {
            return err_invalid_argument("invalid SELinux context format");
        }
    }

    if (mac_system == MAC_APPARMOR) {
        var aa_name = mac_profile_apparmor_name(profile);
        if (aa_name == 0) {
            return err_invalid_argument("AppArmor profile name required but not set");
        }
        var aa_len = strlen(aa_name);
        if (aa_len == 0) {
            return err_invalid_argument("AppArmor profile name required but not set");
        }
        # No slashes or nulls allowed
        var ai = 0;
        while (ai < aa_len) {
            if (load8(aa_name + ai) == 47) {
                return err_invalid_argument("invalid AppArmor profile name");
            }
            ai = ai + 1;
        }
    }

    return Ok(0);
}

# ================================================================
# Apply agent MAC profile based on detected MAC system
# Detects the active MAC system, finds the matching profile,
# validates it, and applies it.
# agent_type: C string of agent type to match
# profiles: vec of mac_profile pointers
# profile_count: number of profiles
# Returns Result: Ok(0) or Err.
# ================================================================

fn mac_apply_agent_profile(agent_type, profiles, profile_count): i64 {
    var mac_system = mac_detect_system();

    if (mac_system == MAC_NONE) {
        # No MAC system active — nothing to do
        return Ok(0);
    }

    # Find matching profile
    var found = 0;
    var idx = 0;
    while (idx < profile_count) {
        var p = vec_get(profiles, idx);
        var ptype = mac_profile_agent_type(p);
        if (streq(ptype, agent_type) == 1) {
            found = p;
            idx = profile_count;  # match found — end the loop (no break in var-loop)
        } else {
            idx = idx + 1;
        }
    }

    if (found == 0) {
        return err_invalid_argument("no MAC profile found for agent type");
    }

    # Validate the profile
    var vres = mac_profile_validate(found, mac_system);
    if (is_err_result(vres) == 1) { return vres; }

    if (mac_system == MAC_SELINUX) {
        var ctx = mac_profile_selinux_ctx(found);
        # Apply on next exec
        return mac_set_selinux_context(ctx, 1);
    }

    if (mac_system == MAC_APPARMOR) {
        var aa_name = mac_profile_apparmor_name(found);
        return mac_apparmor_change_profile(aa_name);
    }

    return err_unknown("cannot apply MAC profile: unknown MAC system");
}

# --- kernel_audit.cyr ---

# audit.cyr — Linux Audit Subsystem interface
# Ported from rust-old/src/audit.rs
#
# Provides netlink audit socket management, event sending, status queries,
# rule add/delete, and AGNOS /proc audit reading.
#
# Requires CAP_AUDIT_CONTROL for configuration and CAP_AUDIT_WRITE for events.
#
# Requires: lib/syscalls.cyr, lib/string.cyr, lib/str.cyr,
#           lib/net.cyr, src/error.cyr

#define LINUX
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/tagged.cyr"
include "lib/syscalls.cyr"
include "lib/net.cyr"
include "lib/process.cyr"

# ================================================================
# Netlink / audit constants
# ================================================================

enum AuditConst {
    AF_NETLINK = 16;
    SOCK_RAW = 3;
    SOCK_CLOEXEC = 524288;
    NETLINK_AUDIT = 9;
    NLMSG_HDRLEN = 16;
    NLM_F_REQUEST = 1;
    NLMSG_NOOP = 1;
    NLMSG_ERROR = 2;
    NLMSG_DONE = 3;
    AUDIT_GET = 1000;
    AUDIT_SET = 1001;
    AUDIT_USER = 1005;
    AUDIT_ADD_RULE = 1011;
    AUDIT_DEL_RULE = 1012;
    SYS_AGNOS_AUDIT_LOG = 520;
    AUDIT_MAX_MSG_LEN = 8192;
    AUDIT_MAX_KEY_LEN = 256;
    AUDIT_STATUS_ENABLED = 1;
    EPROTONOSUPPORT = 93;
}

# Socket-syscall numbers (SYS_SOCKET_NR/SYS_BIND_NR/SYS_SENDTO_NR/
# SYS_RECVFROM_NR) are hardcoded LINUX x86_64 numbers supplied by
# src/sys_security_syscalls.cyr. They are referenced ONLY from the
# `#ifndef CYRIUS_TARGET_AGNOS` branches below — on agnos they alias to wholly
# different sovereign syscalls (memory-unsafe), so the agnos branch never issues
# them (see the DANGER note in sys_security_syscalls.cyr).

# ================================================================
# Audit rule type constants
# ================================================================

enum AuditRuleType {
    AUDIT_RULE_FILE_WATCH = 1;
    AUDIT_RULE_SYSCALL_WATCH = 2;
}

# ================================================================
# Audit config struct — 3 fields * 8 = 24 bytes.
# 1.0 surface uses asymmetric setter names: getters keep the `use_`
# prefix (`audit_config_use_netlink/use_proc`) but setters drop it
# (`audit_config_set_netlink/set_proc`). Field names match the
# getters; the asymmetric setters stay as thin hand-written wrappers
# delegating through the derive-generated `set_use_*`.
# ================================================================

#derive(accessors)
struct audit_config { use_netlink; use_proc; proc_path; }

fn audit_config_new(): i64 {
    var c = alloc(24);
    audit_config_set_use_netlink(c, 1);
    audit_config_set_use_proc(c, 0);
    audit_config_set_proc_path(c, "/proc/agnos/audit");
    return c;
}

# 1.0 API preservation — asymmetric setter names delegate to derive.
fn audit_config_set_netlink(c, val): i64 { return audit_config_set_use_netlink(c, val); }
fn audit_config_set_proc(c, val): i64 { return audit_config_set_use_proc(c, val); }

# ================================================================
# Audit handle struct — 2 fields * 8 = 16 bytes.
# ================================================================

#derive(accessors)
struct audit_handle { fd; config; }

fn audit_handle_new(fd, config): i64 {
    var h = alloc(16);
    audit_handle_set_fd(h, fd);
    audit_handle_set_config(h, config);
    return h;
}

# ================================================================
# Audit status struct — 6 i64 fields * 8 = 48 bytes.
# ================================================================

#derive(accessors)
#derive(Serialize)
struct audit_status { enabled; failure_action; pid; backlog_limit; lost; backlog; }

fn audit_status_new(): i64 {
    var s = alloc(48);
    audit_status_set_enabled(s, 0);
    audit_status_set_failure_action(s, 1);    # printk
    audit_status_set_pid(s, 0);
    audit_status_set_backlog_limit(s, 8192);
    audit_status_set_lost(s, 0);
    audit_status_set_backlog(s, 0);
    return s;
}

# ================================================================
# Audit rule struct — 4 fields * 8 = 32 bytes.
# 1.0 surface uses `audit_rule_syscall(r)` as the getter, but
# `syscall` is a cyrius builtin so it can't be a struct field name.
# Field is named `syscall_nr` (matches the constructor arg);
# the 1.0 `audit_rule_syscall(r)` getter stays as a thin wrapper.
# ================================================================

#derive(accessors)
struct audit_rule { type; path; syscall_nr; key; }

fn audit_rule_new(rule_type, path, syscall_nr, key): i64 {
    var r = alloc(32);
    audit_rule_set_type(r, rule_type);
    audit_rule_set_path(r, path);
    audit_rule_set_syscall_nr(r, syscall_nr);
    audit_rule_set_key(r, key);
    return r;
}

# 1.0 API preservation — `syscall` getter delegates to `syscall_nr`.
fn audit_rule_syscall(r): i64 { return audit_rule_syscall_nr(r); }

# Create a file watch rule
fn audit_rule_file_watch(path, key): i64 {
    return audit_rule_new(AUDIT_RULE_FILE_WATCH, path, 0, key);
}

# Create a syscall watch rule
fn audit_rule_syscall_watch(syscall_nr, key): i64 {
    return audit_rule_new(AUDIT_RULE_SYSCALL_WATCH, 0, syscall_nr, key);
}

# ================================================================
# Rule validation
# Returns Result: Ok(0) if valid, Err if not.
# ================================================================

fn audit_rule_validate(rule): i64 {
    var key = audit_rule_key(rule);
    if (key == 0) {
        return err_invalid_argument("audit rule key cannot be empty");
    }
    var key_len = strlen(key);
    if (key_len == 0) {
        return err_invalid_argument("audit rule key cannot be empty");
    }
    if (key_len > AUDIT_MAX_KEY_LEN) {
        return err_invalid_argument("audit rule key too long (max 256)");
    }

    var rtype = audit_rule_type(rule);
    if (rtype == AUDIT_RULE_FILE_WATCH) {
        var path = audit_rule_path(rule);
        if (path == 0) {
            return err_invalid_argument("FileWatch rule requires a path");
        }
        var path_len = strlen(path);
        if (path_len == 0) {
            return err_invalid_argument("FileWatch path cannot be empty");
        }
        # Path must be absolute (start with '/')
        if (load8(path) != 47) {
            return err_invalid_argument("FileWatch path must be absolute");
        }
        # Reject path traversal via ".." components
        var pi = 0;
        while (pi < path_len - 1) {
            if (load8(path + pi) == 46 && load8(path + pi + 1) == 46) {
                return err_invalid_argument("audit path contains ..");
            }
            pi = pi + 1;
        }
    }
    elif (rtype == AUDIT_RULE_SYSCALL_WATCH) {
        # syscall_nr is stored directly, 0 is a valid syscall (read)
        # so we just accept it
    }
    else {
        return err_invalid_argument("unknown audit rule type");
    }

    return Ok(0);
}

# ================================================================
# Kernel-ABI structs — typed fields enforce the byte layout the
# kernel expects via syscall (sockaddr_nl: 12 B; nlmsghdr: 16 B;
# audit_kstatus: 32 B). Pointer-to-struct dot syntax produces
# tight-packed kernel-correct offsets; using `var s: <struct> = buf;`
# avoids derive(accessors) which lays fields out at i64 slots.
# Width-correct codegen (cyrius 5.8.16+) emits the right
# store16/store32/load32 instructions automatically.
# ================================================================

struct sockaddr_nl {
    nl_family: i16;
    nl_pad: i16;
    nl_pid: i32;
    nl_groups: i32;
}

struct nlmsghdr {
    nlmsg_len: i32;
    nlmsg_type: i16;
    nlmsg_flags: i16;
    nlmsg_seq: i32;
    nlmsg_pid: i32;
}

# Kernel `struct audit_status` (first 32 bytes — agnosys reads/writes
# the fields it needs; kernel struct continues with additional fields
# we currently don't touch).
struct audit_kstatus {
    mask: i32;
    enabled: i32;
    failure: i32;
    pid: i32;
    rate_limit: i32;
    backlog_limit: i32;
    lost: i32;
    backlog: i32;
}

fn audit_sockaddr_nl(pid): i64 {
    var buf = alloc(12);
    memset(buf, 0, 12);
    var sa: sockaddr_nl = buf;
    sa.nl_family = AF_NETLINK;
    sa.nl_pid = pid;
    return buf;
}

# ================================================================
# Build a netlink message header + payload
# Returns pointer to the buffer (stores total length at the head).
# ================================================================

fn audit_build_nlmsg(msg_type, payload_ptr, payload_len): i64 {
    var total_len = NLMSG_HDRLEN + payload_len;
    var buf = alloc(total_len);
    memset(buf, 0, total_len);

    var hdr: nlmsghdr = buf;
    hdr.nlmsg_len = total_len;
    hdr.nlmsg_type = msg_type;
    hdr.nlmsg_flags = NLM_F_REQUEST;
    hdr.nlmsg_seq = 1;
    hdr.nlmsg_pid = sys_getpid();

    if (payload_len > 0) {
        memcpy(buf + NLMSG_HDRLEN, payload_ptr, payload_len);
    }

    return buf;
}

# Get total length of a built nlmsg (read from the header)
fn audit_nlmsg_len(buf): i64 {
    return load32(buf);
}

# ================================================================
# Open an audit connection
# config: pointer to audit_config struct
# Returns Result: Ok(handle_ptr) or Err.
# ================================================================

fn audit_open(config): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    # AGNOS has no NETLINK_AUDIT and no BSD sockets. The socket()/bind() numbers
    # used below (SYS_SOCKET_NR=41, SYS_BIND_NR=49) are LINUX x86_64 and alias
    # DANGEROUSLY on agnos's 0-62 table (#41=sleep_ms, #49=sock_recv), so a raw
    # syscall(49, fd, sockaddr, 12) would invoke sock_recv with a sockaddr as a
    # destination buffer — memory-unsafe. Never reach them; report unsupported the
    # same way security.cyr does for LANDLOCK/SECCOMP/NAMESPACES. The sovereign
    # audit path on AGNOS is the HMAC chain in audit.cyr, not netlink.
    return err_not_supported("NETLINK_AUDIT");
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    var fd = 0 - 1;

    if (audit_config_use_netlink(config) == 1) {
        # socket(AF_NETLINK, SOCK_RAW | SOCK_CLOEXEC, NETLINK_AUDIT)
        var sock_flags = SOCK_RAW | SOCK_CLOEXEC;
        fd = syscall(SYS_SOCKET_NR, AF_NETLINK, sock_flags, NETLINK_AUDIT);
        if (fd < 0) {
            var errno = 0 - fd;
            if (errno == EPERM) {
                return err_permission_denied("open_audit netlink socket");
            }
            if (errno == EACCES) {
                return err_permission_denied("open_audit netlink socket");
            }
            if (errno == EPROTONOSUPPORT) {
                return err_not_supported("NETLINK_AUDIT");
            }
            return err_syscall_failed(errno, "socket(NETLINK_AUDIT) failed");
        }

        # Bind the socket
        var sa = audit_sockaddr_nl(sys_getpid());
        var ret = syscall(SYS_BIND_NR, fd, sa, 12);
        if (ret < 0) {
            sys_close(fd);
            return err_syscall_failed(0 - ret, "bind(NETLINK_AUDIT) failed");
        }
    }

    # Verify proc path if configured
    if (audit_config_use_proc(config) == 1) {
        var proc_path = audit_config_proc_path(config);
        # Non-fatal: netlink still works even if the proc path is unreadable.
        # (agnosys log_warn dropped in the agnosys→kavach fold — no kavach logger
        # wired yet; rewire to kavach's logging when one exists.)
    }

    var handle = audit_handle_new(fd, config);
    return Ok(handle);
    #endif
}

# ================================================================
# Close an audit handle
# Closes the netlink socket if open.
# ================================================================

fn audit_close(handle): i64 {
    var fd = audit_handle_fd(handle);
    if (fd >= 0) {
        syscall(SYS_CLOSE, fd);
    }
    return 0;
}

# ================================================================
# Send raw netlink message on audit socket
# Returns Result: Ok(bytes_sent) or Err.
# ================================================================

fn audit_send_raw(handle, buf, buf_len): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    # SYS_SENDTO_NR=44 is LINUX; on agnos #44 is unassigned. No netlink on agnos.
    return err_not_supported("NETLINK_AUDIT");
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # sendto(fd, buf, len, 0, NULL, 0)
    var ret = syscall(SYS_SENDTO_NR, fd, buf, buf_len, 0, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "send(audit) failed");
    }
    return Ok(ret);
    #endif
}

# ================================================================
# Receive raw netlink message from audit socket
# buf: receive buffer, buf_len: buffer capacity
# Returns Result: Ok(bytes_received) or Err.
# ================================================================

fn audit_recv_raw(handle, buf, buf_len): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    # SYS_RECVFROM_NR=45 is LINUX; on agnos #45 is getrandom. No netlink on agnos.
    return err_not_supported("NETLINK_AUDIT");
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # recvfrom(fd, buf, len, 0, NULL, NULL)
    var ret = syscall(SYS_RECVFROM_NR, fd, buf, buf_len, 0, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "recv(audit) failed");
    }
    return Ok(ret);
    #endif
}

# ================================================================
# Send an audit user event
# event_type: C string (e.g. "AGENT_START")
# message: C string payload
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_send_event(handle, event_type, message): i64 {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    if (strlen(event_type) == 0) {
        return err_invalid_argument("event type cannot be empty");
    }

    var msg_len = strlen(message);
    if (msg_len > AUDIT_MAX_MSG_LEN) {
        return err_invalid_argument("audit message too large (max 8192)");
    }

    # Build payload: "op=<event_type> <message>"
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "op=");
    str_builder_add_cstr(sb, event_type);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, message);
    var payload = str_builder_build(sb);

    var payload_data = str_data(payload);
    var payload_len = str_len(payload);

    # Build netlink message with AUDIT_USER type
    var nlmsg = audit_build_nlmsg(AUDIT_USER, payload_data, payload_len);
    var total_len = audit_nlmsg_len(nlmsg);

    var res = audit_send_raw(handle, nlmsg, total_len);
    if (is_err_result(res) == 1) { return res; }

    return Ok(0);
}

# ================================================================
# Get audit subsystem status (AUDIT_GET)
# Returns Result: Ok(audit_status_ptr) or Err.
# ================================================================

fn audit_get_status(handle): i64 {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # Send AUDIT_GET request (no payload)
    var nlmsg = audit_build_nlmsg(AUDIT_GET, 0, 0);
    var total_len = audit_nlmsg_len(nlmsg);

    var sres = audit_send_raw(handle, nlmsg, total_len);
    if (is_err_result(sres) == 1) { return sres; }

    # Receive response
    var recv_buf = alloc(4096);
    memset(recv_buf, 0, 4096);

    var rres = audit_recv_raw(handle, recv_buf, 4096);
    if (is_err_result(rres) == 1) { return rres; }

    var nbytes = payload(rres);
    # Audit F-6 (2026-04-26): validate the full nlmsghdr, not just length.
    # Per CVE-2026-31495 (ctnetlink) and the broader netlink validation
    # CVE class, defensive parsers must verify type + seq match the
    # request and surface NLMSG_ERROR replies as structured errors
    # instead of treating them as success.
    if (nbytes < NLMSG_HDRLEN) {
        return err_unknown("AUDIT_GET reply truncated (no nlmsghdr)");
    }
    var hdr: nlmsghdr = recv_buf;
    if (hdr.nlmsg_len > nbytes) {
        return err_unknown("AUDIT_GET reply nlmsg_len exceeds bytes received");
    }
    if (hdr.nlmsg_seq != 1) {
        return err_unknown("AUDIT_GET reply seq mismatch (expected 1)");
    }
    if (hdr.nlmsg_type == NLMSG_ERROR) {
        # struct nlmsgerr { s32 error; struct nlmsghdr msg; }
        if (nbytes < NLMSG_HDRLEN + 4) {
            return err_unknown("NLMSG_ERROR reply truncated (no error code)");
        }
        var nerr = load32(recv_buf + NLMSG_HDRLEN);  # negative errno
        if (nerr == 0) {
            return err_unknown("NLMSG_ERROR with zero error (ack-only)");
        }
        return err_syscall_failed(0 - nerr, "AUDIT_GET kernel returned NLMSG_ERROR");
    }
    if (hdr.nlmsg_type != AUDIT_GET) {
        return err_unknown("AUDIT_GET reply unexpected nlmsg_type");
    }
    if (nbytes < NLMSG_HDRLEN + 24) {
        return err_unknown("AUDIT_GET response too short for audit_status");
    }

    # Parse audit_status from payload after nlmsghdr.
    var ks: audit_kstatus = recv_buf + NLMSG_HDRLEN;
    var status = audit_status_new();
    audit_status_set_enabled(status, ks.enabled);
    audit_status_set_failure_action(status, ks.failure);
    audit_status_set_pid(status, ks.pid);
    audit_status_set_backlog_limit(status, ks.backlog_limit);
    audit_status_set_lost(status, ks.lost);
    audit_status_set_backlog(status, ks.backlog);

    return Ok(status);
}

# ================================================================
# Enable or disable the audit subsystem (AUDIT_SET)
# enabled: 1 to enable, 0 to disable
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_set_enabled(handle, enabled): i64 {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # Build audit_status payload — set mask=AUDIT_STATUS_ENABLED (1)
    # and the enabled field; other fields stay zero.
    var pld_len = 32;
    var pld = alloc(pld_len);
    memset(pld, 0, pld_len);
    var ks: audit_kstatus = pld;
    ks.mask = AUDIT_STATUS_ENABLED;
    ks.enabled = enabled;

    var nlmsg = audit_build_nlmsg(AUDIT_SET, pld, pld_len);
    var total_len = audit_nlmsg_len(nlmsg);

    var res = audit_send_raw(handle, nlmsg, total_len);
    if (is_err_result(res) == 1) { return res; }

    return Ok(0);
}

# ================================================================
# Send an audit rule message (add or delete)
# msg_type: AUDIT_ADD_RULE or AUDIT_DEL_RULE
# rule: pointer to audit rule struct
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_send_rule_msg(handle, rule, msg_type): i64 {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # Build rule text payload
    var sb = str_builder_new();
    var rtype = audit_rule_type(rule);

    if (rtype == AUDIT_RULE_FILE_WATCH) {
        str_builder_add_cstr(sb, "watch=");
        var path = audit_rule_path(rule);
        if (path != 0) {
            str_builder_add_cstr(sb, path);
        }
        str_builder_add_cstr(sb, " key=");
        str_builder_add_cstr(sb, audit_rule_key(rule));
    }
    elif (rtype == AUDIT_RULE_SYSCALL_WATCH) {
        str_builder_add_cstr(sb, "syscall=");
        str_builder_add_int(sb, audit_rule_syscall(rule));
        str_builder_add_cstr(sb, " key=");
        str_builder_add_cstr(sb, audit_rule_key(rule));
    }

    var rule_text = str_builder_build(sb);
    var rule_data = str_data(rule_text);
    var rule_len = str_len(rule_text);

    var nlmsg = audit_build_nlmsg(msg_type, rule_data, rule_len);
    var total_len = audit_nlmsg_len(nlmsg);

    var res = audit_send_raw(handle, nlmsg, total_len);
    if (is_err_result(res) == 1) { return res; }

    return Ok(0);
}

# ================================================================
# Add an audit rule
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_add_rule(handle, rule): i64 {
    var vres = audit_rule_validate(rule);
    if (is_err_result(vres) == 1) { return vres; }

    return audit_send_rule_msg(handle, rule, AUDIT_ADD_RULE);
}

# ================================================================
# Delete an audit rule
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_delete_rule(handle, rule): i64 {
    var vres = audit_rule_validate(rule);
    if (is_err_result(vres) == 1) { return vres; }

    return audit_send_rule_msg(handle, rule, AUDIT_DEL_RULE);
}

# ================================================================
# Read audit events from /proc/agnos/audit
# Reads the file line-by-line and returns a vec of raw line Str pointers.
# (Full JSON parsing is beyond Cyrius scope — consumers parse the Strs.)
# proc_path: C string path to the proc file
# Returns Result: Ok(vec_of_strs) or Err.
# ================================================================

fn audit_read_proc_events(proc_path): i64 {
    # Check if file exists
    if (sys_access(proc_path, 0) != 0) {
        # File does not exist — return empty vec
        return Ok(vec_new());
    }

    var fd = sys_open(proc_path, O_RDONLY, 0);
    if (fd < 0) {
        return err_io(0 - fd, proc_path);
    }
    defer { sys_close(fd); }

    # Read entire file (up to 64KB)
    var buf_size = 65536;
    var buf = alloc(buf_size + 1);
    memset(buf, 0, buf_size + 1);
    var total_read = 0;

    var rgo = 1;
    while (rgo == 1) {
        var n = sys_read(fd, buf + total_read, buf_size - total_read);
        if (n <= 0) {
            rgo = 0;
        } else {
            total_read = total_read + n;
            if (total_read >= buf_size) { rgo = 0; }
        }
    }

    if (total_read == 0) {
        return Ok(vec_new());
    }

    # Null-terminate
    store8(buf + total_read, 0);

    # Split into lines (by newline = 10)
    var contents = str_new(buf, total_read);
    var lines = str_split(contents, 10);
    var entries = vec_new();

    var line_count = vec_len(lines);
    var li = 0;
    while (li < line_count) {
        var line = vec_get(lines, li);
        var trimmed = str_trim(line);
        if (str_len(trimmed) > 0) {
            vec_push(entries, trimmed);
        }
        li = li + 1;
    }

    return Ok(entries);
}

# ================================================================
# Log via AGNOS custom syscall (SYS_AGNOS_AUDIT_LOG = 520)
# action: C string (max 256 bytes)
# data: C string (max 4096 bytes)
# result_code: integer result code (0 = success)
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_agnos_log(action, data, result_code): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    # SYS_AGNOS_AUDIT_LOG=520 is out of agnos's 0-62 syscall range (no #520 arm
    # exists → dispatch returns -1); despite the name there is NO kernel audit-log
    # syscall on agnos. The sovereign audit path is the HMAC chain in audit.cyr.
    return err_not_supported("SYS_AGNOS_AUDIT_LOG");
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    var action_len = strlen(action);
    if (action_len == 0) {
        return err_invalid_argument("audit action cannot be empty");
    }
    if (action_len > 256) {
        return err_invalid_argument("audit action too long (max 256)");
    }

    var data_len = strlen(data);
    if (data_len > 4096) {
        return err_invalid_argument("audit data too long (max 4096)");
    }

    var ret = syscall(SYS_AGNOS_AUDIT_LOG, action, data, result_code);
    if (ret < 0) {
        var errno = 0 - ret;
        if (errno == ENOSYS) {
            return err_not_supported("SYS_AGNOS_AUDIT_LOG");
        }
        if (errno == EPERM) {
            return err_permission_denied("agnos_audit_log");
        }
        return err_syscall_failed(errno, "SYS_AGNOS_AUDIT_LOG failed");
    }

    return Ok(0);
    #endif
}

# --- backend.cyr ---

# kavach — Backend enum and metadata
# Ported from rust-old/src/backend/mod.rs

enum Backend {
    PROCESS = 0;
    GVISOR = 1;
    FIRECRACKER = 2;
    WASM = 3;
    OCI = 4;
    SGX = 5;
    SEV = 6;
    TDX = 7;
    SY_AGNOS = 8;
    NOOP = 9;
}

var BACKEND_COUNT = 10;

# Renamed from `backend_name` (3.8.2): ai-hwaccel — pulled transitively via
# [deps.samay] since 3.8.0 — defines its own `backend_name(b)` over a DIFFERENT
# enum (BACKEND_CUDA..BACKEND_WINDOWS, 17 hardware-detection backends). Both
# enums start at 0, cycc resolves duplicate fns last-definition-wins, and
# ai-hwaccel sorts after kavach — so the collision silently returned hardware
# names for OS backends (`backend_name(Backend.OCI)` → "intel-npu"). `os_`
# marks this as the OS/isolation-backend namer; ai-hwaccel keeps the bare name.
fn os_backend_name(b) {
    if (b == Backend.PROCESS) { return "process"; }
    if (b == Backend.GVISOR) { return "gvisor"; }
    if (b == Backend.FIRECRACKER) { return "firecracker"; }
    if (b == Backend.WASM) { return "wasm"; }
    if (b == Backend.OCI) { return "oci"; }
    if (b == Backend.SGX) { return "sgx"; }
    if (b == Backend.SEV) { return "sev"; }
    if (b == Backend.TDX) { return "tdx"; }
    if (b == Backend.SY_AGNOS) { return "sy-agnos"; }
    if (b == Backend.NOOP) { return "noop"; }
    return "unknown";
}

# Case-insensitive parse. Returns backend code on success, -1 on unknown.
fn backend_parse(s) {
    if (strieq(s, "process") == 1) { return Backend.PROCESS; }
    if (strieq(s, "gvisor") == 1) { return Backend.GVISOR; }
    if (strieq(s, "firecracker") == 1) { return Backend.FIRECRACKER; }
    if (strieq(s, "wasm") == 1) { return Backend.WASM; }
    if (strieq(s, "oci") == 1) { return Backend.OCI; }
    if (strieq(s, "sgx") == 1) { return Backend.SGX; }
    if (strieq(s, "sev") == 1) { return Backend.SEV; }
    if (strieq(s, "tdx") == 1) { return Backend.TDX; }
    if (strieq(s, "sy-agnos") == 1) { return Backend.SY_AGNOS; }
    if (strieq(s, "syagnos") == 1) { return Backend.SY_AGNOS; }
    if (strieq(s, "noop") == 1) { return Backend.NOOP; }
    return 0 - 1;
}

# Existence check via the stdlib access(2) wrapper with F_OK (mode 0).
# Returns 1 if the path exists, 0 otherwise. (Was a raw `syscall(21, ...)`;
# routing through sys_access drops the bare syscall + magic number — S2.)
fn path_exists(path) {
    if (sys_access(path, 0) == 0) { return 1; }
    return 0;
}

# Check common PATH locations for a binary. Returns 1 if any exists.
fn which_exists(name) {
    var nlen = strlen(name);
    var buf = alloc(nlen + 24);

    var p1 = "/usr/local/bin/";
    memcpy(buf, p1, strlen(p1));
    memcpy(buf + strlen(p1), name, nlen + 1);
    if (path_exists(buf) == 1) { return 1; }

    var p2 = "/usr/bin/";
    memcpy(buf, p2, strlen(p2));
    memcpy(buf + strlen(p2), name, nlen + 1);
    if (path_exists(buf) == 1) { return 1; }

    var p3 = "/bin/";
    memcpy(buf, p3, strlen(p3));
    memcpy(buf + strlen(p3), name, nlen + 1);
    if (path_exists(buf) == 1) { return 1; }

    var p4 = "/usr/sbin/";
    memcpy(buf, p4, strlen(p4));
    memcpy(buf + strlen(p4), name, nlen + 1);
    if (path_exists(buf) == 1) { return 1; }

    return 0;
}

fn backend_is_available(b) {
    if (b == Backend.NOOP) { return 1; }
    if (b == Backend.PROCESS) { return 1; }
    if (b == Backend.WASM) { return 0; }
    if (b == Backend.GVISOR) { return which_exists("runsc"); }
    if (b == Backend.FIRECRACKER) { return which_exists("firecracker"); }
    if (b == Backend.OCI) {
        if (which_exists("runc") == 1) { return 1; }
        if (which_exists("crun") == 1) { return 1; }
        return 0;
    }
    if (b == Backend.SGX) { return path_exists("/dev/sgx_enclave"); }
    if (b == Backend.SEV) { return path_exists("/dev/sev"); }
    if (b == Backend.TDX) { return path_exists("/dev/tdx_guest"); }
    if (b == Backend.SY_AGNOS) {
        if (which_exists("docker") == 1) { return 1; }
        if (which_exists("podman") == 1) { return 1; }
        return 0;
    }
    return 0;
}

# Iterate all 10 backends by index 0..BACKEND_COUNT.
fn backend_at(i) {
    return i;
}

# ---- shared exec-backend epilogue ----------------------------------------
# Every exec-capture backend (process / gvisor / oci / wasm / sgx / sev /
# tdx / sy-agnos / firecracker) builds its ExecResult the same way. These
# three helpers carry that shared shape so the logic — and its hardening —
# lives in exactly one place.

# Simple failure result: exit 1, no stdout, caller-supplied stderr, zero
# duration. Replaces the per-backend `_X_error` helpers.
fn backend_error_result(msg) {
    var r = exec_result_new();
    ExecResult_set_exit_code(r, 1);
    ExecResult_set_stdout(r, "");
    ExecResult_set_stderr(r, msg);
    ExecResult_set_duration_ms(r, 0);
    ExecResult_set_timed_out(r, 0);
    return r;
}

# Runtime-guard violation result: exit 126 with the first violation's
# description. Call only when vec_len(violations) > 0.
fn backend_guard_result(violations) {
    var r = exec_result_new();
    ExecResult_set_exit_code(r, 126);
    var v0 = vec_get(violations, 0);
    ExecResult_set_stderr(r, GuardViolation_description(v0));
    ExecResult_set_duration_ms(r, 0);
    ExecResult_set_timed_out(r, 0);
    return r;
}

# Build the success/failure ExecResult from a captured-output buffer.
#
# SAFETY (M1, 3.3.1): `exec_capture` fills until `total >= buflen` and can
# return exactly `out_cap`. Writing `store8(out_buf + n, 0)` with n == out_cap
# is one byte past `alloc(out_cap)` — a heap overflow on attacker-influenced
# subprocess output. Clamping n into [0, out_cap - 1] before the NUL makes the
# terminator always land inside the allocation. At the exact-fill boundary this
# drops the final byte of an already-truncated 1 MiB capture — acceptable; the
# alternative (reading past the buffer) is not. Centralizing here fixes the
# off-by-one for all nine capture backends at once.
fn backend_capture_finish(out_buf, n, out_cap, fail_msg, start_ns, end_ns) {
    var r = exec_result_new();
    if (n < 0) {
        ExecResult_set_exit_code(r, 1);
        ExecResult_set_stdout(r, "");
        ExecResult_set_stderr(r, fail_msg);
    }
    else {
        if (n >= out_cap) { n = out_cap - 1; }
        store8(out_buf + n, 0);
        ExecResult_set_exit_code(r, 0);
        ExecResult_set_stdout(r, out_buf);
        ExecResult_set_stderr(r, "");
    }
    ExecResult_set_duration_ms(r, (end_ns - start_ns) / 1000000);
    ExecResult_set_timed_out(r, 0);
    return r;
}

# --- policy.cyr ---

# kavach — SandboxPolicy
# Ported from rust-old/src/policy/mod.rs
#
# No floats in Cyrius core — cpu_limit stored as tenths (10 = 1.0 core).

#derive(accessors)
struct SandboxPolicy {
    seccomp_enabled;
    seccomp_profile;
    landlock_rules_len;
    network_enabled;
    network_tcp_bind_len;
    network_tcp_connect_len;
    read_only_rootfs;
    memory_limit_mb;
    cpu_limit_tenths;
    max_pids;
    landlock_abstract_unix;
    landlock_signal;
}

var SANDBOX_POLICY_SIZE = 96;

fn policy_new() {
    var p = alloc(SANDBOX_POLICY_SIZE);
    var i = 0;
    while (i < SANDBOX_POLICY_SIZE) {
        store64(p + i, 0);
        i = i + 8;
    }
    return p;
}

fn policy_minimal() {
    return policy_new();
}

fn policy_basic() {
    var p = policy_new();
    SandboxPolicy_set_seccomp_enabled(p, 1);
    SandboxPolicy_set_seccomp_profile(p, "basic");
    return p;
}

fn policy_strict() {
    var p = policy_new();
    SandboxPolicy_set_seccomp_enabled(p, 1);
    SandboxPolicy_set_seccomp_profile(p, "strict");
    SandboxPolicy_set_read_only_rootfs(p, 1);
    SandboxPolicy_set_memory_limit_mb(p, 512);
    SandboxPolicy_set_cpu_limit_tenths(p, 10);
    SandboxPolicy_set_max_pids(p, 64);
    SandboxPolicy_set_landlock_abstract_unix(p, 1);
    SandboxPolicy_set_landlock_signal(p, 1);
    return p;
}

# Case-insensitive preset lookup. Returns 0 on unknown name.
fn policy_from_preset(name) {
    if (strieq(name, "minimal") == 1) { return policy_minimal(); }
    if (strieq(name, "basic") == 1) { return policy_basic(); }
    if (strieq(name, "strict") == 1) { return policy_strict(); }
    return 0;
}

# --- scoring.cyr ---

# kavach — strength scoring (0-100)
# Ported from rust-old/src/scoring/mod.rs

fn base_score(backend) {
    if (backend == Backend.NOOP) { return 0; }
    if (backend == Backend.PROCESS) { return 50; }
    if (backend == Backend.OCI) { return 55; }
    if (backend == Backend.WASM) { return 65; }
    if (backend == Backend.GVISOR) { return 70; }
    if (backend == Backend.SGX) { return 80; }
    if (backend == Backend.SEV) { return 82; }
    if (backend == Backend.TDX) { return 85; }
    if (backend == Backend.SY_AGNOS) { return 80; }
    if (backend == Backend.FIRECRACKER) { return 90; }
    return 0;
}

fn score_label(score) {
    if (score < 30) { return "minimal"; }
    if (score < 50) { return "basic"; }
    if (score < 70) { return "standard"; }
    if (score < 85) { return "hardened"; }
    if (score <= 100) { return "fortress"; }
    return "unknown";
}

# Score a backend with policy modifiers applied. Matches SY reference.
fn score_backend(backend, policy) {
    var score = base_score(backend);

    if (SandboxPolicy_seccomp_enabled(policy) == 1) { score = score + 5; }
    if (SandboxPolicy_landlock_rules_len(policy) > 0) { score = score + 3; }
    if (SandboxPolicy_network_enabled(policy) == 0) { score = score + 5; }
    if (SandboxPolicy_read_only_rootfs(policy) == 1) { score = score + 3; }

    # Resource limits: +2 once if either memory or cpu is set
    if (SandboxPolicy_memory_limit_mb(policy) > 0) { score = score + 2; }
    elif (SandboxPolicy_cpu_limit_tenths(policy) > 0) { score = score + 2; }

    # Landlock TCP ports (ABI v4): +3 once if either list is non-empty
    if (SandboxPolicy_network_tcp_bind_len(policy) > 0) { score = score + 3; }
    elif (SandboxPolicy_network_tcp_connect_len(policy) > 0) { score = score + 3; }

    # Landlock scoping (ABI v6)
    if (SandboxPolicy_landlock_abstract_unix(policy) == 1) { score = score + 2; }
    if (SandboxPolicy_landlock_signal(policy) == 1) { score = score + 2; }

    if (score > 100) { score = 100; }
    if (score < 0) { score = 0; }
    return score;
}

# Rank all available backends by score under `policy`. Returns strongest
# available backend code. Falls back to Backend.NOOP if nothing else passes.
fn resolve_best_backend(policy) {
    var best = Backend.NOOP;
    var best_score = 0 - 1;
    var i = 0;
    while (i < BACKEND_COUNT) {
        var b = backend_at(i);
        if (b != Backend.NOOP) {
            if (backend_is_available(b) == 1) {
                var s = score_backend(b, policy);
                if (s > best_score) {
                    best_score = s;
                    best = b;
                }
            }
        }
        i = i + 1;
    }
    return best;
}

# Returns strongest backend meeting min_score, or -1 if none.
fn resolve_min_strength_backend(policy, min_score) {
    var best = 0 - 1;
    var best_score = min_score - 1;
    var i = 0;
    while (i < BACKEND_COUNT) {
        var b = backend_at(i);
        if (backend_is_available(b) == 1) {
            var s = score_backend(b, policy);
            if (s >= min_score) {
                if (s > best_score) {
                    best_score = s;
                    best = b;
                }
            }
        }
        i = i + 1;
    }
    return best;
}

# --- lifecycle.cyr ---

# kavach — sandbox lifecycle (state machine, config, exec result, Sandbox)
# Ported from rust-old/src/lifecycle/mod.rs
#
# Deferred vs Rust: async is synchronous here, UUID is a monotonic counter,
# timestamps are nanoseconds from CLOCK_MONOTONIC (0 = unset), SecretRef/
# ExternalizationPolicy/RuntimeManifest plumbing omitted until those modules land.

# ---- SandboxState ---------------------------------------------------------

enum SandboxState {
    CREATED = 0;
    RUNNING = 1;
    PAUSED = 2;
    STOPPED = 3;
    DESTROYED = 4;
}

fn state_name(s) {
    if (s == SandboxState.CREATED) { return "created"; }
    if (s == SandboxState.RUNNING) { return "running"; }
    if (s == SandboxState.PAUSED) { return "paused"; }
    if (s == SandboxState.STOPPED) { return "stopped"; }
    if (s == SandboxState.DESTROYED) { return "destroyed"; }
    return "unknown";
}

# Valid FSM edges, mirroring the Rust matches!(...) table:
#   Created  -> Running
#   Running  -> Paused | Stopped | Destroyed
#   Paused   -> Running | Stopped | Destroyed
#   Stopped  -> Destroyed
fn valid_transition(from, to) {
    if (from == SandboxState.CREATED) {
        if (to == SandboxState.RUNNING) { return 1; }
        return 0;
    }
    if (from == SandboxState.RUNNING) {
        if (to == SandboxState.PAUSED) { return 1; }
        if (to == SandboxState.STOPPED) { return 1; }
        if (to == SandboxState.DESTROYED) { return 1; }
        return 0;
    }
    if (from == SandboxState.PAUSED) {
        if (to == SandboxState.RUNNING) { return 1; }
        if (to == SandboxState.STOPPED) { return 1; }
        if (to == SandboxState.DESTROYED) { return 1; }
        return 0;
    }
    if (from == SandboxState.STOPPED) {
        if (to == SandboxState.DESTROYED) { return 1; }
        return 0;
    }
    return 0;
}

# ---- ExecResult -----------------------------------------------------------

#derive(accessors)
struct ExecResult {
    exit_code;
    stdout;
    stderr;
    duration_ms;
    timed_out;
}

var EXEC_RESULT_SIZE = 40;

fn exec_result_new() {
    var r = alloc(EXEC_RESULT_SIZE);
    var i = 0;
    while (i < EXEC_RESULT_SIZE) { store64(r + i, 0); i = i + 8; }
    ExecResult_set_stdout(r, "");
    ExecResult_set_stderr(r, "");
    return r;
}

# ---- SandboxConfig --------------------------------------------------------

#derive(accessors)
struct SandboxConfig {
    backend;
    policy;
    timeout_ms;
    inner_backend;
    agent_id;
    hostname;
    domainname;
    workdir;
}

var SANDBOX_CONFIG_SIZE = 64;

# Defaults match Rust's SandboxConfig::default():
#   backend=Process, policy=basic(), timeout_ms=30000, inner_backend=-1 (none)
fn config_new() {
    var c = alloc(SANDBOX_CONFIG_SIZE);
    var i = 0;
    while (i < SANDBOX_CONFIG_SIZE) { store64(c + i, 0); i = i + 8; }
    SandboxConfig_set_backend(c, Backend.PROCESS);
    SandboxConfig_set_policy(c, policy_basic());
    SandboxConfig_set_timeout_ms(c, 30000);
    SandboxConfig_set_inner_backend(c, 0 - 1);
    return c;
}

# Fluent-ish setters: mutate in place and return the config pointer so
# callers may chain if they wish.
fn config_backend(c, b)        { SandboxConfig_set_backend(c, b); return c; }
fn config_policy(c, p)         { SandboxConfig_set_policy(c, p); return c; }
fn config_timeout_ms(c, ms)    { SandboxConfig_set_timeout_ms(c, ms); return c; }
fn config_inner_backend(c, b)  { SandboxConfig_set_inner_backend(c, b); return c; }
fn config_agent_id(c, s)       { SandboxConfig_set_agent_id(c, s); return c; }
fn config_hostname(c, s)       { SandboxConfig_set_hostname(c, s); return c; }
fn config_domainname(c, s)     { SandboxConfig_set_domainname(c, s); return c; }
fn config_workdir(c, s)        { SandboxConfig_set_workdir(c, s); return c; }

# Convenience: enable seccomp with a profile name on the config's policy.
fn config_policy_seccomp(c, profile) {
    var p = SandboxConfig_policy(c);
    SandboxPolicy_set_seccomp_enabled(p, 1);
    SandboxPolicy_set_seccomp_profile(p, profile);
    return c;
}

fn config_network(c, enabled) {
    var p = SandboxConfig_policy(c);
    SandboxPolicy_set_network_enabled(p, enabled);
    return c;
}

# ---- Sandbox --------------------------------------------------------------

#derive(accessors)
struct Sandbox {
    id;
    config;
    state;
    created_at;
    started_at;
    stopped_at;
}

var SANDBOX_SIZE = 48;

# Sandbox IDs: 64 bits from /dev/urandom, UUID-v4-equivalent for
# correlation. Collision probability across 2^32 sandboxes is ~2^-32.
# Previously a monotonic counter (deferred per ADR-004 §8); closed in
# v3.0 now that util.cyr ships rand_u64().

# Monotonic nanoseconds. Thin alias over the stdlib chrono.clock_now_ns
# (chrono is already a dep) — was a byte-for-byte duplicate of it
# (CLOCK_MONOTONIC clock_gettime). Kept as a named wrapper so the ~22
# backend/lifecycle call sites stay put and the raw syscall + magic 228
# live in one upstream place (S1).
fn mono_now_ns() {
    return clock_now_ns();
}

# Create a sandbox from config. Fails with BACKEND_UNAVAILABLE if the
# selected backend is not present on this system.
fn sandbox_create(config) {
    var b = SandboxConfig_backend(config);
    if (backend_is_available(b) == 0) {
        kavach_err_print(KAVACH_ERR_BACKEND_UNAVAILABLE, os_backend_name(b));
        return 0;
    }
    var s = alloc(SANDBOX_SIZE);
    Sandbox_set_id(s, rand_u64());
    Sandbox_set_config(s, config);
    Sandbox_set_state(s, SandboxState.CREATED);
    Sandbox_set_created_at(s, mono_now_ns());
    Sandbox_set_started_at(s, 0);
    Sandbox_set_stopped_at(s, 0);
    return s;
}

# Transition to a new state. Returns KAVACH_ERR_OK on success,
# KAVACH_ERR_INVALID_TRANSITION otherwise.
fn sandbox_transition(s, to) {
    var from = Sandbox_state(s);
    if (valid_transition(from, to) == 0) {
        return KAVACH_ERR_INVALID_TRANSITION;
    }
    Sandbox_set_state(s, to);
    if (to == SandboxState.RUNNING) {
        Sandbox_set_started_at(s, mono_now_ns());
    }
    if (to == SandboxState.STOPPED) { Sandbox_set_stopped_at(s, mono_now_ns()); }
    if (to == SandboxState.DESTROYED) { Sandbox_set_stopped_at(s, mono_now_ns()); }
    return KAVACH_ERR_OK;
}

# Destroy the sandbox. Transitions through STOPPED if still running.
fn sandbox_destroy(s) {
    var st = Sandbox_state(s);
    if (st == SandboxState.RUNNING) {
        sandbox_transition(s, SandboxState.STOPPED);
    }
    if (st == SandboxState.PAUSED) {
        sandbox_transition(s, SandboxState.STOPPED);
    }
    return sandbox_transition(s, SandboxState.DESTROYED);
}

# ---- SandboxPool ----------------------------------------------------------

#derive(accessors)
struct SandboxPool {
    template;
    warm_count;
    pool_vec;
}

fn sandbox_pool_new(template, warm_count) {
    var p = alloc(24);
    SandboxPool_set_template(p, template);
    SandboxPool_set_warm_count(p, warm_count);
    var v = vec_new();
    var i = 0;
    while (i < warm_count) {
        var sb = sandbox_create(template);
        if (sb == 0) { return 0; }
        vec_push(v, sb);
        i = i + 1;
    }
    SandboxPool_set_pool_vec(p, v);
    return p;
}

# Pop a pre-created sandbox from the pool; cold-start one on miss.
fn sandbox_pool_claim(p) {
    var v = SandboxPool_pool_vec(p);
    if (vec_len(v) > 0) {
        return vec_pop(v);
    }
    return sandbox_create(SandboxPool_template(p));
}

fn sandbox_pool_replenish(p) {
    var v = SandboxPool_pool_vec(p);
    var target = SandboxPool_warm_count(p);
    while (vec_len(v) < target) {
        var sb = sandbox_create(SandboxPool_template(p));
        if (sb == 0) { return KAVACH_ERR_CREATION_FAILED; }
        vec_push(v, sb);
    }
    return KAVACH_ERR_OK;
}

fn sandbox_pool_available(p) {
    return vec_len(SandboxPool_pool_vec(p));
}

# --- scanning_types.cyr ---

# kavach — scanning types
# Ported from rust-old/src/scanning/types.rs

enum Severity {
    INFO = 0;
    LOW = 1;
    MEDIUM = 2;
    HIGH = 3;
    CRITICAL = 4;
}

enum ScanVerdict {
    PASS = 0;
    WARN = 1;
    QUARANTINE = 2;
    BLOCK = 3;
}

fn severity_name(s) {
    if (s == Severity.INFO) { return "info"; }
    if (s == Severity.LOW) { return "low"; }
    if (s == Severity.MEDIUM) { return "medium"; }
    if (s == Severity.HIGH) { return "high"; }
    if (s == Severity.CRITICAL) { return "critical"; }
    return "unknown";
}

fn verdict_name(v) {
    if (v == ScanVerdict.PASS) { return "pass"; }
    if (v == ScanVerdict.WARN) { return "warn"; }
    if (v == ScanVerdict.QUARANTINE) { return "quarantine"; }
    if (v == ScanVerdict.BLOCK) { return "block"; }
    return "unknown";
}

# A single finding from a scanner.
#derive(accessors)
struct ScanFinding {
    id;
    scanner;
    severity;
    category;
    message;
    evidence;
}

var SCAN_FINDING_SIZE = 48;

# Finding IDs: 64-bit random from /dev/urandom (UUID-v4-equivalent).
# Swapped from a monotonic counter in v3.0 — see ADR-004 §8.
fn finding_new(scanner, severity, category, message, evidence) {
    var f = alloc(SCAN_FINDING_SIZE);
    ScanFinding_set_id(f, rand_u64());
    ScanFinding_set_scanner(f, scanner);
    ScanFinding_set_severity(f, severity);
    ScanFinding_set_category(f, category);
    ScanFinding_set_message(f, message);
    ScanFinding_set_evidence(f, evidence);
    return f;
}

#derive(accessors)
struct ScanResult {
    verdict;
    findings;
    worst_severity;
}

var SCAN_RESULT_SIZE = 24;

fn scan_result_new() {
    var r = alloc(SCAN_RESULT_SIZE);
    ScanResult_set_verdict(r, ScanVerdict.PASS);
    ScanResult_set_findings(r, vec_new());
    ScanResult_set_worst_severity(r, Severity.INFO);
    return r;
}

fn scan_result_push(r, finding) {
    var v = ScanResult_findings(r);
    vec_push(v, finding);
    var sev = ScanFinding_severity(finding);
    if (sev > ScanResult_worst_severity(r)) {
        ScanResult_set_worst_severity(r, sev);
    }
    return 0;
}

# Externalization gate policy.
#derive(accessors)
struct ExternalizationPolicy {
    enabled;
    max_artifact_size_bytes;
    block_threshold;
    quarantine_threshold;
    redact_secrets;
}

var EXT_POLICY_SIZE = 40;

fn ext_policy_default() {
    var p = alloc(EXT_POLICY_SIZE);
    ExternalizationPolicy_set_enabled(p, 1);
    # 50 MiB
    ExternalizationPolicy_set_max_artifact_size_bytes(p, 52428800);
    ExternalizationPolicy_set_block_threshold(p, Severity.CRITICAL);
    ExternalizationPolicy_set_quarantine_threshold(p, Severity.HIGH);
    ExternalizationPolicy_set_redact_secrets(p, 1);
    return p;
}

# --- aho_corasick.cyr ---

# kavach — Aho-Corasick multi-pattern matcher
#
# Replaces the scanners' per-pattern full-buffer re-scan (O(patterns × n × m)
# naive substring, ~150 cstr_contains calls in scanning_code.cyr) with a
# single O(n + matches) pass: build one automaton over the literal pattern set,
# run the text through it once, and read each pattern's first-match position
# out of a hit table.
#
# The automaton is built once over a static pattern set and cached by the
# caller (the pattern set is compile-time fixed), so build cost is amortized to
# zero across scans; only the O(n) search runs per artifact.
#
# Patterns are matched case-sensitively against bytes — callers that want
# case-insensitive matching pre-lower both the text and the patterns (which is
# exactly what the code/data scanners already do against their `lower` buffer).
#
# Memory model (all heap, manual): dense 256-way goto so a transition is a flat
# load; node count is bounded by the total pattern length, built once.
#
#   automaton struct (64 bytes):
#     +0  goto_base   (num_nodes_cap * 256 i64; 0 = no transition, root = node 0)
#     +8  fail_base   (num_nodes_cap i64)
#     +16 term_base   (num_nodes_cap i64; pattern id ending at node, or -1)
#     +24 dict_base   (num_nodes_cap i64; output/suffix link to nearest terminal)
#     +32 patlen_base (num_pats i64; byte length of each pattern)
#     +40 num_pats
#     +48 num_nodes   (actual, after build)

# Build an automaton from a vec of pattern cstrs. Pattern ids are the vec
# indices. Returns a heap automaton pointer (never freed — cache it).
fn ac_build(patterns) {
    var np = vec_len(patterns);

    # Upper bound on trie nodes: root + one per pattern char (shared prefixes
    # only ever use fewer). Sized exactly once.
    var total = 0;
    var i = 0;
    while (i < np) {
        total = total + strlen(vec_get(patterns, i));
        i = i + 1;
    }
    var cap = total + 1;

    var goto_b = alloc(cap * 256 * 8);
    memset(goto_b, 0, cap * 256 * 8);
    var fail_b = alloc(cap * 8);
    memset(fail_b, 0, cap * 8);
    var dict_b = alloc(cap * 8);
    memset(dict_b, 0, cap * 8);
    var term_b = alloc(cap * 8);
    var patlen_b = alloc(np * 8);

    # term[] initialised to -1 (no pattern ends here).
    var t = 0;
    while (t < cap) { store64(term_b + t * 8, 0 - 1); t = t + 1; }

    var num_nodes = 1;   # node 0 = root

    # ---- insert patterns into the trie ----
    i = 0;
    while (i < np) {
        var p = vec_get(patterns, i);
        var plen = strlen(p);
        store64(patlen_b + i * 8, plen);
        var node = 0;
        var j = 0;
        while (j < plen) {
            var c = load8(p + j);
            var slot = goto_b + (node * 256 + c) * 8;
            var nxt = load64(slot);
            if (nxt == 0) {
                nxt = num_nodes;
                num_nodes = num_nodes + 1;
                store64(slot, nxt);
            }
            node = nxt;
            j = j + 1;
        }
        store64(term_b + node * 8, i);   # pattern i terminates at `node`
        i = i + 1;
    }

    # ---- BFS to compute failure + dict (output) links ----
    var queue = vec_new();
    # depth-1 nodes (root's children) fail to root.
    var c0 = 0;
    while (c0 < 256) {
        var ch = load64(goto_b + c0 * 8);   # goto[root][c0]
        if (ch != 0) {
            store64(fail_b + ch * 8, 0);
            vec_push(queue, ch);
        }
        c0 = c0 + 1;
    }
    var qi = 0;
    while (qi < vec_len(queue)) {
        var u = vec_get(queue, qi);
        qi = qi + 1;
        var cc = 0;
        while (cc < 256) {
            var v = load64(goto_b + (u * 256 + cc) * 8);
            if (v != 0) {
                # follow u's fail chain to find the longest proper suffix that
                # has a transition on cc
                var f = load64(fail_b + u * 8);
                while (f != 0) {
                    if (load64(goto_b + (f * 256 + cc) * 8) != 0) { break; }
                    f = load64(fail_b + f * 8);
                }
                var ff = load64(goto_b + (f * 256 + cc) * 8);
                if (ff == v) { ff = 0; }   # never let a node fail to itself
                store64(fail_b + v * 8, ff);
                # dict link: nearest terminal node reachable via fail links
                if (load64(term_b + ff * 8) != (0 - 1)) {
                    store64(dict_b + v * 8, ff);
                }
                else {
                    store64(dict_b + v * 8, load64(dict_b + ff * 8));
                }
                vec_push(queue, v);
            }
            cc = cc + 1;
        }
    }

    var ac = alloc(64);
    store64(ac + 0, goto_b);
    store64(ac + 8, fail_b);
    store64(ac + 16, term_b);
    store64(ac + 24, dict_b);
    store64(ac + 32, patlen_b);
    store64(ac + 40, np);
    store64(ac + 48, num_nodes);
    return ac;
}

fn ac_num_pats(ac) { return load64(ac + 40); }

# Allocate a hit-position table for `ac`, initialised to -1 (no match).
# Indexed by pattern id; on a hit, holds the START offset of the first match.
fn ac_hits_new(ac) {
    var np = load64(ac + 40);
    var h = alloc(np * 8);
    var i = 0;
    while (i < np) { store64(h + i * 8, 0 - 1); i = i + 1; }
    return h;
}

# Run `text` (length n) through the automaton, recording the first-match start
# offset of every pattern into `hit_pos` (caller-allocated via ac_hits_new).
fn ac_search(ac, text, n, hit_pos) {
    var goto_b = load64(ac + 0);
    var fail_b = load64(ac + 8);
    var term_b = load64(ac + 16);
    var dict_b = load64(ac + 24);
    var patlen_b = load64(ac + 32);

    var node = 0;
    var i = 0;
    while (i < n) {
        var c = load8(text + i);
        # follow fail links until a transition on c exists (or we're at root)
        while (node != 0) {
            if (load64(goto_b + (node * 256 + c) * 8) != 0) { break; }
            node = load64(fail_b + node * 8);
        }
        node = load64(goto_b + (node * 256 + c) * 8);   # 0 (root) if none
        # emit every pattern ending at this position via the dict-link chain
        var u = node;
        if (load64(term_b + u * 8) == (0 - 1)) { u = load64(dict_b + u * 8); }
        while (u != 0) {
            var pid = load64(term_b + u * 8);
            if (pid != (0 - 1)) {
                if (load64(hit_pos + pid * 8) == (0 - 1)) {
                    store64(hit_pos + pid * 8, i - load64(patlen_b + pid * 8) + 1);
                }
            }
            u = load64(dict_b + u * 8);
        }
        i = i + 1;
    }
    return 0;
}

# --- scanning_secrets.cyr ---

# kavach — secrets scanner
# Ported from rust-old/src/scanning/secrets.rs
#
# Cyrius' `lib/regex.cyr` is glob-only; PCRE character classes aren't
# available yet. This port uses hand-rolled literal-prefix + char-class
# matchers for patterns with distinctive prefixes. Patterns that rely on
# case-insensitive or negative lookahead (AWS secret, generic api_key,
# bearer, password assign, email) are left as TODO until a full regex
# engine lands in the stdlib.

# ---- character classes ---------------------------------------------------

fn is_upper_c(c) {
    if (c >= 65) { if (c <= 90) { return 1; } }
    return 0;
}
fn is_lower_c(c) {
    if (c >= 97) { if (c <= 122) { return 1; } }
    return 0;
}
fn is_digit_c(c) {
    if (c >= 48) { if (c <= 57) { return 1; } }
    return 0;
}
fn is_alnum_c(c) {
    if (is_upper_c(c) == 1) { return 1; }
    if (is_lower_c(c) == 1) { return 1; }
    if (is_digit_c(c) == 1) { return 1; }
    return 0;
}
# [A-Za-z0-9_]
fn is_token_c(c) {
    if (is_alnum_c(c) == 1) { return 1; }
    if (c == 95) { return 1; }
    return 0;
}
# [A-Za-z0-9_-]
fn is_jwt_c(c) {
    if (is_token_c(c) == 1) { return 1; }
    if (c == 45) { return 1; }
    return 0;
}

# Literal prefix check: returns 1 if text[i..] starts with prefix.
fn starts_with_at(text, i, n, prefix) {
    var plen = strlen(prefix);
    if (i + plen > n) { return 0; }
    var j = 0;
    while (j < plen) {
        if (load8(text + i + j) != load8(prefix + j)) { return 0; }
        j = j + 1;
    }
    return 1;
}

# ---- individual pattern matchers -----------------------------------------
# Each returns match length on success, 0 otherwise.

# AKIA + 16 [A-Z0-9]
fn match_aws_access_key(text, i, n) {
    if (i + 20 > n) { return 0; }
    if (load8(text + i) != 65) { return 0; }
    if (load8(text + i + 1) != 75) { return 0; }
    if (load8(text + i + 2) != 73) { return 0; }
    if (load8(text + i + 3) != 65) { return 0; }
    var j = 0;
    while (j < 16) {
        var c = load8(text + i + 4 + j);
        if (is_upper_c(c) == 0) {
            if (is_digit_c(c) == 0) { return 0; }
        }
        j = j + 1;
    }
    return 20;
}

# gh[ps]_ + 36+ [A-Za-z0-9_]
fn match_github_token(text, i, n) {
    if (i + 4 > n) { return 0; }
    if (load8(text + i) != 103) { return 0; }      # g
    if (load8(text + i + 1) != 104) { return 0; }  # h
    var c2 = load8(text + i + 2);
    if (c2 != 112) {                                # p
        if (c2 != 115) { return 0; }                # s
    }
    if (load8(text + i + 3) != 95) { return 0; }    # _
    var j = 0;
    while (i + 4 + j < n) {
        if (is_token_c(load8(text + i + 4 + j)) == 0) {
            if (j >= 36) { return 4 + j; }
            return 0;
        }
        j = j + 1;
    }
    if (j >= 36) { return 4 + j; }
    return 0;
}

# AIza + 35 [A-Za-z0-9_-]
fn match_gcp_key(text, i, n) {
    if (i + 39 > n) { return 0; }
    if (load8(text + i) != 65) { return 0; }      # A
    if (load8(text + i + 1) != 73) { return 0; }  # I
    if (load8(text + i + 2) != 122) { return 0; } # z
    if (load8(text + i + 3) != 97) { return 0; }  # a
    var j = 0;
    while (j < 35) {
        if (is_jwt_c(load8(text + i + 4 + j)) == 0) { return 0; }
        j = j + 1;
    }
    return 39;
}

# eyJ<jwt_c+>.eyJ<jwt_c+>.<jwt_c+>
fn match_jwt(text, i, n) {
    if (i + 3 > n) { return 0; }
    if (load8(text + i) != 101) { return 0; }     # e
    if (load8(text + i + 1) != 121) { return 0; } # y
    if (load8(text + i + 2) != 74) { return 0; }  # J
    var j = 3;
    var seg1 = 0;
    while (i + j < n) {
        if (is_jwt_c(load8(text + i + j)) == 0) { break; }
        j = j + 1;
        seg1 = seg1 + 1;
    }
    if (seg1 < 10) { return 0; }
    if (i + j + 4 > n) { return 0; }
    if (load8(text + i + j) != 46) { return 0; }    # .
    if (load8(text + i + j + 1) != 101) { return 0; } # e
    if (load8(text + i + j + 2) != 121) { return 0; } # y
    if (load8(text + i + j + 3) != 74) { return 0; }  # J
    j = j + 4;
    var seg2 = 0;
    while (i + j < n) {
        if (is_jwt_c(load8(text + i + j)) == 0) { break; }
        j = j + 1;
        seg2 = seg2 + 1;
    }
    if (seg2 < 10) { return 0; }
    if (i + j + 1 > n) { return 0; }
    if (load8(text + i + j) != 46) { return 0; }
    j = j + 1;
    var seg3 = 0;
    while (i + j < n) {
        if (is_jwt_c(load8(text + i + j)) == 0) { break; }
        j = j + 1;
        seg3 = seg3 + 1;
    }
    if (seg3 < 10) { return 0; }
    return j;
}

# \b\d{3}-\d{2}-\d{4}\b
fn match_ssn(text, i, n) {
    if (i + 11 > n) { return 0; }
    # Word boundary: preceding char (if any) must not be alnum/_
    if (i > 0) {
        var prev = load8(text + i - 1);
        if (is_token_c(prev) == 1) { return 0; }
    }
    if (is_digit_c(load8(text + i)) == 0) { return 0; }
    if (is_digit_c(load8(text + i + 1)) == 0) { return 0; }
    if (is_digit_c(load8(text + i + 2)) == 0) { return 0; }
    if (load8(text + i + 3) != 45) { return 0; }
    if (is_digit_c(load8(text + i + 4)) == 0) { return 0; }
    if (is_digit_c(load8(text + i + 5)) == 0) { return 0; }
    if (load8(text + i + 6) != 45) { return 0; }
    if (is_digit_c(load8(text + i + 7)) == 0) { return 0; }
    if (is_digit_c(load8(text + i + 8)) == 0) { return 0; }
    if (is_digit_c(load8(text + i + 9)) == 0) { return 0; }
    if (is_digit_c(load8(text + i + 10)) == 0) { return 0; }
    if (i + 11 < n) {
        if (is_token_c(load8(text + i + 11)) == 1) { return 0; }
    }
    return 11;
}

# (postgres|mysql|mongodb|redis)://<non-space>{10,256}
fn _scheme_len(text, i, n) {
    if (starts_with_at(text, i, n, "postgres://") == 1) { return 11; }
    if (starts_with_at(text, i, n, "mysql://") == 1) { return 8; }
    if (starts_with_at(text, i, n, "mongodb://") == 1) { return 10; }
    if (starts_with_at(text, i, n, "redis://") == 1) { return 8; }
    return 0;
}

fn match_conn_string(text, i, n) {
    var sl = _scheme_len(text, i, n);
    if (sl == 0) { return 0; }
    var body = 0;
    while (i + sl + body < n) {
        var c = load8(text + i + sl + body);
        if (c == 32) { break; }
        if (c == 9) { break; }
        if (c == 10) { break; }
        if (c == 13) { break; }
        body = body + 1;
        if (body >= 256) { break; }
    }
    if (body < 10) { return 0; }
    return sl + body;
}

# ---- evidence truncation -------------------------------------------------

# Evidence is stored in ScanFinding and may end up in audit logs and
# quarantine metadata. Delegate to util.cyr's redact_evidence, which
# keeps a 4-char prefix + '****' + 4-char suffix — enough signal to
# identify the finding type (e.g. 'AKIA****DATA') without leaking the
# actual secret into at-rest artifacts. See ADR-005 §H1.
fn _evidence_copy(text, start, len) {
    return redact_evidence(text, start, len);
}

# ---- in-place redaction for WARN verdict (ADR-004 §7) --------------------
# Walks text once, rewriting every matched secret span to
# "[REDACTED:CATEGORY]" and leaving non-matches untouched. Returns a
# heap-allocated cstr. Called from scanning_gate.cyr when a WARN verdict
# is reached with policy.redact_secrets enabled.

fn _redact_append_marker(out, out_pos, category) {
    var prefix = "[REDACTED:";
    memcpy(out + out_pos, prefix, 10);
    out_pos = out_pos + 10;
    memcpy(out + out_pos, category, strlen(category));
    out_pos = out_pos + strlen(category);
    store8(out + out_pos, 93);
    return out_pos + 1;
}

fn secrets_redact(text) {
    var n = strlen(text);
    var starts = vec_new();
    var lens = vec_new();
    var cats = vec_new();

    var i = 0;
    while (i < n) {
        var m = match_aws_access_key(text, i, n);
        if (m > 0) {
            vec_push(starts, i); vec_push(lens, m); vec_push(cats, "cloud_credential");
            i = i + m;
        }
        elif (starts_with_at(text, i, n, "-----BEGIN RSA PRIVATE KEY-----") == 1) {
            vec_push(starts, i); vec_push(lens, 31); vec_push(cats, "private_key");
            i = i + 31;
        }
        elif (starts_with_at(text, i, n, "-----BEGIN EC PRIVATE KEY-----") == 1) {
            vec_push(starts, i); vec_push(lens, 30); vec_push(cats, "private_key");
            i = i + 30;
        }
        elif (starts_with_at(text, i, n, "-----BEGIN OPENSSH PRIVATE KEY-----") == 1) {
            vec_push(starts, i); vec_push(lens, 35); vec_push(cats, "private_key");
            i = i + 35;
        }
        elif (starts_with_at(text, i, n, "-----BEGIN PRIVATE KEY-----") == 1) {
            vec_push(starts, i); vec_push(lens, 27); vec_push(cats, "private_key");
            i = i + 27;
        }
        else {
            var g = match_github_token(text, i, n);
            if (g > 0) {
                vec_push(starts, i); vec_push(lens, g); vec_push(cats, "api_token");
                i = i + g;
            }
            else {
                var k = match_gcp_key(text, i, n);
                if (k > 0) {
                    vec_push(starts, i); vec_push(lens, k); vec_push(cats, "cloud_credential");
                    i = i + k;
                }
                else {
                    var jw = match_jwt(text, i, n);
                    if (jw > 0) {
                        vec_push(starts, i); vec_push(lens, jw); vec_push(cats, "auth_token");
                        i = i + jw;
                    }
                    else {
                        var cs = match_conn_string(text, i, n);
                        if (cs > 0) {
                            vec_push(starts, i); vec_push(lens, cs); vec_push(cats, "connection_string");
                            i = i + cs;
                        }
                        else {
                            var ss = match_ssn(text, i, n);
                            if (ss > 0) {
                                vec_push(starts, i); vec_push(lens, ss); vec_push(cats, "pii");
                                i = i + ss;
                            }
                            else {
                                i = i + 1;
                            }
                        }
                    }
                }
            }
        }
    }

    if (vec_len(starts) == 0) {
        var copy = alloc(n + 1);
        memcpy(copy, text, n);
        store8(copy + n, 0);
        return copy;
    }

    # Output cap: original text + up to 32 bytes overhead per match.
    var match_count = vec_len(starts);
    var overhead = checked_mul(match_count, 32);
    if (overhead < 0) { return 0; }
    var cap = checked_add(n, overhead);
    if (cap < 0) { return 0; }
    cap = checked_add(cap, 1);
    if (cap < 0) { return 0; }
    var out = alloc_checked(cap);
    if (out == 0) { return 0; }

    var cursor = 0;
    var out_pos = 0;
    var j = 0;
    while (j < match_count) {
        var s = vec_get(starts, j);
        var l = vec_get(lens, j);
        var c = vec_get(cats, j);
        if (s > cursor) {
            memcpy(out + out_pos, text + cursor, s - cursor);
            out_pos = out_pos + (s - cursor);
        }
        out_pos = _redact_append_marker(out, out_pos, c);
        cursor = s + l;
        j = j + 1;
    }
    if (cursor < n) {
        memcpy(out + out_pos, text + cursor, n - cursor);
        out_pos = out_pos + (n - cursor);
    }
    store8(out + out_pos, 0);
    return out;
}

# ---- scan loop -----------------------------------------------------------

var MAX_FINDINGS = 1000;

fn secrets_scan(text, result) {
    var i = 0;
    var n = strlen(text);
    while (i < n) {
        var v = ScanResult_findings(result);
        if (vec_len(v) >= MAX_FINDINGS) { return 0; }

        var m = match_aws_access_key(text, i, n);
        if (m > 0) {
            scan_result_push(result, finding_new("secrets", Severity.CRITICAL,
            "cloud_credential", "AWS Access Key detected",
            _evidence_copy(text, i, m)));
            i = i + m;
        }
        elif (starts_with_at(text, i, n, "-----BEGIN RSA PRIVATE KEY-----") == 1) {
            scan_result_push(result, finding_new("secrets", Severity.CRITICAL,
            "private_key", "RSA Private Key detected",
            _evidence_copy(text, i, 20)));
            i = i + 31;
        }
        elif (starts_with_at(text, i, n, "-----BEGIN EC PRIVATE KEY-----") == 1) {
            scan_result_push(result, finding_new("secrets", Severity.CRITICAL,
            "private_key", "EC Private Key detected",
            _evidence_copy(text, i, 20)));
            i = i + 30;
        }
        elif (starts_with_at(text, i, n, "-----BEGIN OPENSSH PRIVATE KEY-----") == 1) {
            scan_result_push(result, finding_new("secrets", Severity.CRITICAL,
            "private_key", "OpenSSH Private Key detected",
            _evidence_copy(text, i, 20)));
            i = i + 35;
        }
        elif (starts_with_at(text, i, n, "-----BEGIN PRIVATE KEY-----") == 1) {
            scan_result_push(result, finding_new("secrets", Severity.CRITICAL,
            "private_key", "Generic Private Key detected",
            _evidence_copy(text, i, 20)));
            i = i + 27;
        }
        else {
            var j = match_github_token(text, i, n);
            if (j > 0) {
                scan_result_push(result, finding_new("secrets", Severity.CRITICAL,
                "api_token", "GitHub Token detected",
                _evidence_copy(text, i, j)));
                i = i + j;
            }
            else {
                var k = match_gcp_key(text, i, n);
                if (k > 0) {
                    scan_result_push(result, finding_new("secrets", Severity.HIGH,
                    "cloud_credential", "GCP API Key detected",
                    _evidence_copy(text, i, k)));
                    i = i + k;
                }
                else {
                    var jw = match_jwt(text, i, n);
                    if (jw > 0) {
                        scan_result_push(result, finding_new("secrets", Severity.HIGH,
                        "auth_token", "JWT detected",
                        _evidence_copy(text, i, jw)));
                        i = i + jw;
                    }
                    else {
                        var cs = match_conn_string(text, i, n);
                        if (cs > 0) {
                            scan_result_push(result, finding_new("secrets", Severity.CRITICAL,
                            "connection_string", "Database Connection String detected",
                            _evidence_copy(text, i, cs)));
                            i = i + cs;
                        }
                        else {
                            var ss = match_ssn(text, i, n);
                            if (ss > 0) {
                                scan_result_push(result, finding_new("secrets", Severity.CRITICAL,
                                "pii", "SSN detected",
                                _evidence_copy(text, i, ss)));
                                i = i + ss;
                            }
                            else {
                                i = i + 1;
                            }
                        }
                    }
                }
            }
        }
    }
    return 0;
}

# --- scanning_code.cyr ---

# kavach — code violation scanner
# Ported from rust-old/src/scanning/code.rs
#
# Rust used &str substring match against a pre-lowered copy of the text.
# Same strategy here: lowercase once, then scan 25 pattern groups.

# ---- helpers -------------------------------------------------------------

# Copy src (null-terminated) into dst, ascii-lowered. dst must be sized.
fn str_to_lower_into(src, dst) {
    var i = 0;
    while (1 == 1) {
        var c = load8(src + i);
        store8(dst + i, ch_ascii_lower(c));
        if (c == 0) { return 0; }
        i = i + 1;
    }
    return 0;
}

# 1 if haystack contains needle (both null-terminated cstrs). Linear search.
fn cstr_contains(haystack, needle) {
    var hlen = strlen(haystack);
    var nlen = strlen(needle);
    if (nlen == 0) { return 1; }
    if (nlen > hlen) { return 0; }
    var i = 0;
    while (i + nlen <= hlen) {
        var j = 0;
        while (j < nlen) {
            if (load8(haystack + i + j) != load8(needle + j)) { break; }
            j = j + 1;
        }
        if (j == nlen) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Find position of needle in haystack, or -1.
fn cstr_index_of(haystack, needle) {
    var hlen = strlen(haystack);
    var nlen = strlen(needle);
    if (nlen == 0) { return 0; }
    if (nlen > hlen) { return 0 - 1; }
    var i = 0;
    while (i + nlen <= hlen) {
        var j = 0;
        while (j < nlen) {
            if (load8(haystack + i + j) != load8(needle + j)) { break; }
            j = j + 1;
        }
        if (j == nlen) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

# Extract up to 20 bytes on each side of the match, from the ORIGINAL
# (case-preserved) text. Returns a heap copy (null-terminated).
fn code_extract_evidence(text, lower, pattern) {
    var pos = cstr_index_of(lower, pattern);
    if (pos < 0) { return 0; }
    var plen = strlen(pattern);
    var tlen = strlen(text);
    var start = pos - 20;
    if (start < 0) { start = 0; }
    var end = pos + plen + 20;
    if (end > tlen) { end = tlen; }
    var n = end - start;
    var buf = alloc(n + 1);
    memcpy(buf, text + start, n);
    store8(buf + n, 0);
    return buf;
}

fn code_emit(text, lower, result, severity, category, name, matched) {
    var msg_buf = alloc(strlen(name) + 10);
    var offset = 0;
    memcpy(msg_buf, name, strlen(name));
    offset = strlen(name);
    memcpy(msg_buf + offset, " detected", 9);
    store8(msg_buf + offset + 9, 0);
    scan_result_push(result, finding_new("code", severity, category,
    msg_buf, code_extract_evidence(text, lower, matched)));
    return 1;
}

# Extract up to 20 bytes on each side of a KNOWN match span [start, start+len)
# in the original text. Returns a heap copy (NUL-terminated). Unlike
# code_extract_evidence, this does NO re-scan — the caller already has the
# position, so the snippet is taken from the actual match (not the first
# occurrence of a stand-in pattern) and a multi-MiB artifact isn't re-walked
# per finding.
fn code_extract_evidence_at(text, start, len) {
    var tlen = strlen(text);
    var s = start - 20;
    if (s < 0) { s = 0; }
    var e = start + len + 20;
    if (e > tlen) { e = tlen; }
    var n = e - s;
    var buf = alloc(n + 1);
    memcpy(buf, text + s, n);
    store8(buf + n, 0);
    return buf;
}

# As code_emit, but for callers that already know the match position+length
# (e.g. the structural PII matchers) — avoids the stand-in-pattern re-scan.
fn code_emit_at(text, result, severity, category, name, start, len) {
    var msg_buf = alloc(strlen(name) + 10);
    var offset = 0;
    memcpy(msg_buf, name, strlen(name));
    offset = strlen(name);
    memcpy(msg_buf + offset, " detected", 9);
    store8(msg_buf + offset + 9, 0);
    scan_result_push(result, finding_new("code", severity, category,
    msg_buf, code_extract_evidence_at(text, start, len)));
    return 1;
}

# ---- Aho-Corasick presence pass -----------------------------------------
# The 26 pattern groups below each used to call cstr_contains(lower, LIT) per
# literal — ~109 full re-scans of the (pre-lowered) artifact, i.e. O(patterns ×
# n × m). code_scan now runs ONE Aho-Corasick pass over `lower` and the groups
# query a cheap per-pattern hit table via _cg_hit(). The master pattern list
# below must mirror the literals the groups check; a literal NOT in it falls
# back to a direct cstr_contains scan, so a drifted list can only cost speed,
# never correctness. The automaton + list are built once and cached (the
# pattern set is static); only the O(n) search runs per scan.
#
# Scan context lives in module globals set at the top of code_scan. kavach's
# scan path is synchronous (ADR-004 §1 — no async/threads), so this is safe;
# it is not reentrant.

var _cg_pats_cache = 0;
var _cg_ac = 0;
var _cg_hits = 0;
var _cg_lower = 0;

fn _cg_master_patterns() {
    if (_cg_pats_cache != 0) { return _cg_pats_cache; }
    var v = vec_new();
    vec_push(v, "exec(");
    vec_push(v, "execsync(");
    vec_push(v, "child_process");
    vec_push(v, "spawn(");
    vec_push(v, "spawnsync(");
    vec_push(v, "eval(");
    vec_push(v, "function(");
    vec_push(v, "/bin/sh");
    vec_push(v, "/bin/bash");
    vec_push(v, "/bin/zsh");
    vec_push(v, "cmd.exe");
    vec_push(v, "powershell");
    vec_push(v, "$(");
    vec_push(v, "${");
    vec_push(v, "| sh");
    vec_push(v, "| bash");
    vec_push(v, "; sh");
    vec_push(v, "; bash");
    vec_push(v, "/dev/tcp");
    vec_push(v, "<(");
    vec_push(v, ">(");
    vec_push(v, "curl | sh");
    vec_push(v, "curl | bash");
    vec_push(v, "wget | sh");
    vec_push(v, "wget | bash");
    vec_push(v, "fetch(");
    vec_push(v, "axios.");
    vec_push(v, "http.request(");
    vec_push(v, "https.request(");
    vec_push(v, "dns.resolve");
    vec_push(v, "dns.lookup");
    vec_push(v, "nslookup");
    vec_push(v, "dig ");
    vec_push(v, "mkfifo");
    vec_push(v, "/dev/tcp/");
    vec_push(v, "nc -e");
    vec_push(v, "ncat -e");
    vec_push(v, "socat exec:");
    vec_push(v, "bash -i >& /dev/tcp");
    vec_push(v, "nc ");
    vec_push(v, "ncat ");
    vec_push(v, "socat ");
    vec_push(v, "telnet ");
    vec_push(v, "nmap ");
    vec_push(v, "sudo ");
    vec_push(v, "su -");
    vec_push(v, "su root");
    vec_push(v, "chmod ");
    vec_push(v, "chown ");
    vec_push(v, "chgrp ");
    vec_push(v, "setuid");
    vec_push(v, "setgid");
    vec_push(v, "insmod ");
    vec_push(v, "modprobe ");
    vec_push(v, "rmmod ");
    vec_push(v, "mount ");
    vec_push(v, "umount ");
    vec_push(v, "mount(");
    vec_push(v, "setcap ");
    vec_push(v, "getcap ");
    vec_push(v, "capsh ");
    vec_push(v, "npm install");
    vec_push(v, "pip install");
    vec_push(v, "gem install");
    vec_push(v, "cargo install");
    vec_push(v, "go install");
    vec_push(v, "apt install");
    vec_push(v, "apt-get install");
    vec_push(v, "yum install");
    vec_push(v, "dnf install");
    vec_push(v, "pacman -s");
    vec_push(v, "wget -o - |");
    vec_push(v, "curl -ssl |");
    vec_push(v, "require(");
    vec_push(v, "import(");
    vec_push(v, "__import__(");
    vec_push(v, "atob(");
    vec_push(v, "base64 -d");
    vec_push(v, "base64 --decode");
    vec_push(v, "b64decode");
    vec_push(v, "\\u00");
    vec_push(v, "\\x00");
    vec_push(v, "string.fromcharcode");
    vec_push(v, "\\x");
    vec_push(v, "fromhex(");
    vec_push(v, "hex.decode");
    vec_push(v, "/etc/shadow");
    vec_push(v, "/etc/passwd");
    vec_push(v, "/etc/sudoers");
    vec_push(v, "/.ssh/");
    vec_push(v, "/.gnupg/");
    vec_push(v, "/.aws/");
    vec_push(v, "/.kube/");
    vec_push(v, "/dev/mem");
    vec_push(v, "/dev/kmem");
    vec_push(v, "/proc/kcore");
    vec_push(v, "../");
    vec_push(v, "..\\");
    vec_push(v, "rm -rf");
    vec_push(v, "dd if=");
    vec_push(v, "mkfs.");
    vec_push(v, "shred ");
    vec_push(v, "md5(");
    vec_push(v, "sha1(");
    vec_push(v, "aes_key =");
    vec_push(v, "encryption_key =");
    vec_push(v, "secret_key =");
    _cg_pats_cache = v;
    return v;
}

fn _cg_automaton() {
    if (_cg_ac == 0) { _cg_ac = ac_build(_cg_master_patterns()); }
    return _cg_ac;
}

# 1 if `lit` occurs in the current scan's lowered text, else 0. O(patterns)
# lookup over the AC hit table; falls back to a direct substring scan if `lit`
# isn't in the master set (correctness over speed).
fn _cg_hit(lit) {
    var pats = _cg_master_patterns();
    var np = vec_len(pats);
    var i = 0;
    while (i < np) {
        if (streq(vec_get(pats, i), lit) == 1) {
            if (load64(_cg_hits + i * 8) >= 0) { return 1; }
            return 0;
        }
        i = i + 1;
    }
    return cstr_contains(_cg_lower, lit);
}

# ---- pattern groups -------------------------------------------------------
# Each returns 1 if any pattern matched (one finding emitted per group).

fn _cg_shell_exec(text, lower, result) {
    if (_cg_hit("exec(") == 1) {
        return code_emit(text, lower, result,
        Severity.CRITICAL, "command_injection", "Shell exec", "exec(");
    }
    if (_cg_hit("execsync(") == 1) {
        return code_emit(text, lower, result,
        Severity.CRITICAL, "command_injection", "Shell exec", "execsync(");
    }
    if (_cg_hit("child_process") == 1) {
        return code_emit(text, lower, result,
        Severity.CRITICAL, "command_injection", "Shell exec", "child_process");
    }
    return 0;
}

