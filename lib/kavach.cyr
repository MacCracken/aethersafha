fn _cg_shell_meta(text, lower, result) {
    if (_cg_hit("$(") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", "$(");
    }
    if (_cg_hit("${") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", "${");
    }
    if (_cg_hit("| sh") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", "| sh");
    }
    if (_cg_hit("| bash") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", "| bash");
    }
    if (_cg_hit("; sh") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", "; sh");
    }
    if (_cg_hit("; bash") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", "; bash");
    }
    if (_cg_hit("/dev/tcp") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", "/dev/tcp");
    }
    if (_cg_hit("<(") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", "<(");
    }
    if (_cg_hit(">(") == 1) {
        return code_emit(text, lower, result,
        Severity.HIGH, "command_injection", "Shell metacharacters", ">(");
    }
    return 0;
}

