        Severity.HIGH, "crypto_misuse", "Hardcoded key", "secret_key =");
    }
    return 0;
}

# ---- main scan -----------------------------------------------------------

fn code_scan(text, result) {
    var n = strlen(text);
    var lower = alloc(n + 1);
    str_to_lower_into(text, lower);

    # Single Aho-Corasick pass over the lowered text replaces the ~109
    # per-pattern re-scans the groups below used to do. Results go into the
    # module-global hit table the groups read via _cg_hit().
    var ac = _cg_automaton();
    _cg_hits = ac_hits_new(ac);
    _cg_lower = lower;
    ac_search(ac, lower, n, _cg_hits);

    _cg_shell_exec(text, lower, result);
    _cg_process_spawn(text, lower, result);
    _cg_eval_exec(text, lower, result);
    _cg_shell_invoc(text, lower, result);
    _cg_shell_meta(text, lower, result);
    _cg_pipe_shell(text, lower, result);
    _cg_http_req(text, lower, result);
    _cg_dns_exfil(text, lower, result);
    _cg_reverse_shell(text, lower, result);
    _cg_net_tools(text, lower, result);
    _cg_sudo(text, lower, result);
    _cg_perm_change(text, lower, result);
    _cg_kernel_mod(text, lower, result);
    _cg_mount(text, lower, result);
    _cg_capability(text, lower, result);
    _cg_pkg_install(text, lower, result);
    _cg_remote_script(text, lower, result);
    _cg_dyn_import(text, lower, result);
    _cg_base64(text, lower, result);
    _cg_unicode_esc(text, lower, result);
    _cg_hex_enc(text, lower, result);
    _cg_sens_path(text, lower, result);
    _cg_traversal(text, lower, result);
    _cg_destructive(text, lower, result);
    _cg_weak_hash(text, lower, result);
    _cg_hardcoded_key(text, lower, result);
    return 0;
}

# --- scanning_data.cyr ---

# kavach — data/compliance scanner (PII + HIPAA/GDPR/PCI/SOC2)
# Ported from rust-old/src/scanning/data.rs
#
# Compliance keywords are case-insensitive multi-word substrings — matched
# against a pre-lowered copy of the text. Numeric/structural PII patterns
# (credit cards, phone, IPv4, IBAN) use hand-rolled char-class scanners.

fn _dg_emit(text, lower, result, severity, category, name, matched) {
    return code_emit(text, lower, result, severity, category, name, matched);
}

# Position-aware emit for the structural PII matchers, which already know the
# match offset+length. The old path passed a single stand-in char ("4"/"0"/…)
# as `matched`, so evidence extraction re-scanned the whole artifact and
# pointed the snippet at the first stray digit instead of the real match.
fn _dg_emit_at(text, result, severity, category, name, start, len) {
    return code_emit_at(text, result, severity, category, name, start, len);
}

# ---- Credit card matchers ------------------------------------------------

# Word boundary: position 0 or preceding char is non-token.
fn _at_word_start(text, i) {
    if (i == 0) { return 1; }
    if (is_token_c(load8(text + i - 1)) == 0) { return 1; }
    return 0;
}

# Word boundary: position == length or next char is non-token.
fn _at_word_end(text, i, n) {
    if (i >= n) { return 1; }
    if (is_token_c(load8(text + i)) == 0) { return 1; }
    return 0;
}

# Consecutive digit run starting at i; returns count.
fn _digit_run(text, i, n) {
    var j = 0;
    while (i + j < n) {
        if (is_digit_c(load8(text + i + j)) == 0) { return j; }
        j = j + 1;
    }
    return j;
}

# Visa: 4 + 12 digits, optionally +3 more, word-bounded. Returns match len.
fn match_visa(text, i, n) {
    if (_at_word_start(text, i) == 0) { return 0; }
    if (i + 13 > n) { return 0; }
    if (load8(text + i) != 52) { return 0; }
    var run = _digit_run(text, i, n);
    if (run == 16) {
        if (_at_word_end(text, i + 16, n) == 1) { return 16; }
        return 0;
    }
    if (run == 13) {
        if (_at_word_end(text, i + 13, n) == 1) { return 13; }
        return 0;
    }
    return 0;
}

# Mastercard: 5[1-5] + 14 digits = 16 total.
fn match_mastercard(text, i, n) {
    if (_at_word_start(text, i) == 0) { return 0; }
    if (i + 16 > n) { return 0; }
    if (load8(text + i) != 53) { return 0; }
    var c2 = load8(text + i + 1);
    if (c2 < 49) { return 0; }
    if (c2 > 53) { return 0; }
    var run = _digit_run(text, i, n);
    if (run == 16) {
        if (_at_word_end(text, i + 16, n) == 1) { return 16; }
    }
    return 0;
}

# Amex: 3[47] + 13 digits = 15 total.
fn match_amex(text, i, n) {
    if (_at_word_start(text, i) == 0) { return 0; }
    if (i + 15 > n) { return 0; }
    if (load8(text + i) != 51) { return 0; }
    var c2 = load8(text + i + 1);
    if (c2 != 52) { if (c2 != 55) { return 0; } }
    var run = _digit_run(text, i, n);
    if (run == 15) {
        if (_at_word_end(text, i + 15, n) == 1) { return 15; }
    }
    return 0;
}

# Parse a 1-3 digit octet (0-255) starting at i. Returns (value+1, len) or (0,0).
# We use value+1 so 0 return indicates failure even for octet 0.
fn _parse_octet(text, i, n) {
    if (i >= n) { return (0, 0); }
    var c1 = load8(text + i);
    if (is_digit_c(c1) == 0) { return (0, 0); }
    var v = c1 - 48;
    var len = 1;
    if (i + 1 < n) {
        var c2 = load8(text + i + 1);
        if (is_digit_c(c2) == 1) {
            v = v * 10 + (c2 - 48);
            len = 2;
            if (i + 2 < n) {
                var c3 = load8(text + i + 2);
                if (is_digit_c(c3) == 1) {
                    var v3 = v * 10 + (c3 - 48);
                    if (v3 <= 255) {
                        v = v3;
                        len = 3;
                    }
                }
            }
        }
    }
    return (v + 1, len);
}

# IPv4: octet '.' octet '.' octet '.' octet, all 0-255, word-bounded.
fn match_ipv4(text, i, n) {
    if (_at_word_start(text, i) == 0) { return 0; }
    var pos = i;
    var k = 0;
    while (k < 3) {
        var v, l = _parse_octet(text, pos, n);
        if (v == 0) { return 0; }
        pos = pos + l;
        if (pos >= n) { return 0; }
        if (load8(text + pos) != 46) { return 0; }
        pos = pos + 1;
        k = k + 1;
    }
    var v4, l4 = _parse_octet(text, pos, n);
    if (v4 == 0) { return 0; }
    pos = pos + l4;
    if (_at_word_end(text, pos, n) == 0) { return 0; }
    return pos - i;
}

# IBAN: [A-Z]{2}[0-9]{2}[A-Z0-9]{4}[0-9]{7}[A-Z0-9]{0,18}, word-bounded.
fn match_iban(text, i, n) {
    if (_at_word_start(text, i) == 0) { return 0; }
    if (i + 15 > n) { return 0; }
    if (is_upper_c(load8(text + i)) == 0) { return 0; }
    if (is_upper_c(load8(text + i + 1)) == 0) { return 0; }
    if (is_digit_c(load8(text + i + 2)) == 0) { return 0; }
    if (is_digit_c(load8(text + i + 3)) == 0) { return 0; }
    var j = 4;
    while (j < 8) {
        var c = load8(text + i + j);
        if (is_upper_c(c) == 0) {
            if (is_digit_c(c) == 0) { return 0; }
        }
        j = j + 1;
    }
    while (j < 15) {
        if (is_digit_c(load8(text + i + j)) == 0) { return 0; }
        j = j + 1;
    }
    # Optional 0..18 more [A-Z0-9]
    var extra = 0;
    while (extra < 18) {
        if (i + j + extra >= n) { break; }
        var c = load8(text + i + j + extra);
        if (is_upper_c(c) == 0) {
            if (is_digit_c(c) == 0) { break; }
        }
        extra = extra + 1;
    }
    if (_at_word_end(text, i + j + extra, n) == 0) { return 0; }
    return j + extra;
}

# US phone: "(###) ###-####" or "###-###-####" or "###.###.####" — simplified.
# Rust had a complex regex; we accept the common formats.
fn _is_phone_sep(c) {
    if (c == 45) { return 1; }   # -
    if (c == 46) { return 1; }   # .
    if (c == 32) { return 1; }   # space
    return 0;
}

fn match_us_phone(text, i, n) {
    if (_at_word_start(text, i) == 0) { return 0; }
    var pos = i;
    # Optional "(": skip if present, expect ")" after 3 digits
    var paren = 0;
    if (pos < n) {
        if (load8(text + pos) == 40) {
            paren = 1;
            pos = pos + 1;
        }
    }
    var k = 0;
    while (k < 3) {
        if (pos >= n) { return 0; }
        if (is_digit_c(load8(text + pos)) == 0) { return 0; }
        pos = pos + 1;
        k = k + 1;
    }
    if (paren == 1) {
        if (pos >= n) { return 0; }
        if (load8(text + pos) != 41) { return 0; }
        pos = pos + 1;
    }
    # Optional separator
    if (pos < n) {
        if (_is_phone_sep(load8(text + pos)) == 1) { pos = pos + 1; }
    }
    k = 0;
    while (k < 3) {
        if (pos >= n) { return 0; }
        if (is_digit_c(load8(text + pos)) == 0) { return 0; }
        pos = pos + 1;
        k = k + 1;
    }
    if (pos < n) {
        if (_is_phone_sep(load8(text + pos)) == 1) { pos = pos + 1; }
    }
    k = 0;
    while (k < 4) {
        if (pos >= n) { return 0; }
        if (is_digit_c(load8(text + pos)) == 0) { return 0; }
        pos = pos + 1;
        k = k + 1;
    }
    if (_at_word_end(text, pos, n) == 0) { return 0; }
    return pos - i;
}

# ---- PII dispatch (credit cards, phone, IP, IBAN) ------------------------
# Walk the text once, try each matcher at each position, emit on first hit.

fn _data_scan_pii(text, lower, result) {
    var n = strlen(text);
    var i = 0;
    while (i < n) {
        var m = match_visa(text, i, n);
        if (m > 0) {
            _dg_emit_at(text, result, Severity.CRITICAL,
            "pii_financial", "Credit Card (Visa)", i, m);
            i = i + m;
        }
        else {
            var mc = match_mastercard(text, i, n);
            if (mc > 0) {
                _dg_emit_at(text, result, Severity.CRITICAL,
                "pii_financial", "Credit Card (Mastercard)", i, mc);
                i = i + mc;
            }
            else {
                var amex = match_amex(text, i, n);
                if (amex > 0) {
                    _dg_emit_at(text, result, Severity.CRITICAL,
                    "pii_financial", "Credit Card (Amex)", i, amex);
                    i = i + amex;
                }
                else {
                    var ip = match_ipv4(text, i, n);
                    if (ip > 0) {
                        _dg_emit_at(text, result, Severity.LOW,
                        "pii_network", "IP Address (IPv4)", i, ip);
                        i = i + ip;
                    }
                    else {
                        var ib = match_iban(text, i, n);
                        if (ib > 0) {
                            _dg_emit_at(text, result, Severity.HIGH,
                            "pii_financial", "IBAN", i, ib);
                            i = i + ib;
                        }
                        else {
                            var ph = match_us_phone(text, i, n);
                            if (ph > 0) {
                                _dg_emit_at(text, result, Severity.MEDIUM,
                                "pii", "US Phone Number", i, ph);
                                i = i + ph;
                            }
                            else {
                                i = i + 1;
                            }
                        }
                    }
                }
            }
        }
    }
    return 0;
}

# ---- Compliance keyword groups (substring, case-insensitive) -------------

fn _dg_hipaa(text, lower, result) {
    if (cstr_contains(lower, "patient id") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "patient id");
    }
    if (cstr_contains(lower, "patient name") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "patient name");
    }
    if (cstr_contains(lower, "patient record") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "patient record");
    }
    if (cstr_contains(lower, "patient dob") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "patient dob");
    }
    if (cstr_contains(lower, "patient ssn") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "patient ssn");
    }
    if (cstr_contains(lower, "patient mrn") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "patient mrn");
    }
    if (cstr_contains(lower, "medical record number") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "medical record number");
    }
    if (cstr_contains(lower, "health insurance claim") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "health insurance claim");
    }
    if (cstr_contains(lower, "protected health information") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_hipaa", "HIPAA identifier", "protected health information");
    }
    return 0;
}

fn _dg_gdpr(text, lower, result) {
    if (cstr_contains(lower, "data subject") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_gdpr", "GDPR personal data", "data subject");
    }
    if (cstr_contains(lower, "right to erasure") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_gdpr", "GDPR personal data", "right to erasure");
    }
    if (cstr_contains(lower, "right to be forgotten") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_gdpr", "GDPR personal data", "right to be forgotten");
    }
    if (cstr_contains(lower, "consent withdraw") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_gdpr", "GDPR personal data", "consent withdraw");
    }
    if (cstr_contains(lower, "data processing agreement") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_gdpr", "GDPR personal data", "data processing agreement");
    }
    if (cstr_contains(lower, "data controller") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_gdpr", "GDPR personal data", "data controller");
    }
    if (cstr_contains(lower, "data processor") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_gdpr", "GDPR personal data", "data processor");
    }
    return 0;
}

fn _dg_pci(text, lower, result) {
    if (cstr_contains(lower, "cardholder data") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_pci", "PCI-DSS cardholder data", "cardholder data");
    }
    if (cstr_contains(lower, "card verification") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_pci", "PCI-DSS cardholder data", "card verification");
    }
    if (cstr_contains(lower, "cvv") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_pci", "PCI-DSS cardholder data", "cvv");
    }
    if (cstr_contains(lower, "cvc") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_pci", "PCI-DSS cardholder data", "cvc");
    }
    if (cstr_contains(lower, "primary account number") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_pci", "PCI-DSS cardholder data", "primary account number");
    }
    if (cstr_contains(lower, "pan data") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_pci", "PCI-DSS cardholder data", "pan data");
    }
    if (cstr_contains(lower, "track data") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_pci", "PCI-DSS cardholder data", "track data");
    }
    if (cstr_contains(lower, "magnetic stripe") == 1) {
        return _dg_emit(text, lower, result,
        Severity.HIGH, "compliance_pci", "PCI-DSS cardholder data", "magnetic stripe");
    }
    return 0;
}

fn _dg_soc2(text, lower, result) {
    if (cstr_contains(lower, "soc 2") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_soc2", "SOC2 audit artifact", "soc 2");
    }
    if (cstr_contains(lower, "soc2") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_soc2", "SOC2 audit artifact", "soc2");
    }
    if (cstr_contains(lower, "trust service criteria") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_soc2", "SOC2 audit artifact", "trust service criteria");
    }
    if (cstr_contains(lower, "system description") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_soc2", "SOC2 audit artifact", "system description");
    }
    if (cstr_contains(lower, "complementary user entity controls") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_soc2", "SOC2 audit artifact", "complementary user entity controls");
    }
    if (cstr_contains(lower, "cuec") == 1) {
        return _dg_emit(text, lower, result,
        Severity.MEDIUM, "compliance_soc2", "SOC2 audit artifact", "cuec");
    }
    return 0;
}

# ---- main scan -----------------------------------------------------------

fn data_scan(text, result) {
    var n = strlen(text);
    var lower = alloc(n + 1);
    str_to_lower_into(text, lower);

    _data_scan_pii(text, lower, result);
    _dg_hipaa(text, lower, result);
    _dg_gdpr(text, lower, result);
    _dg_pci(text, lower, result);
    _dg_soc2(text, lower, result);
    return 0;
}

# --- scanning_gate.cyr ---

# kavach — externalization gate (orchestrates 3 scanners into a verdict)
# Ported from rust-old/src/scanning/gate.rs
#
# Secrets redaction on WARN verdict is stubbed — TODO once a single-pass
# redactor is ported (Rust Cow-based impl needs reworking for Cyrius).

fn determine_verdict(worst, policy) {
    if (worst >= ExternalizationPolicy_block_threshold(policy)) {
        return ScanVerdict.BLOCK;
    }
    if (worst >= ExternalizationPolicy_quarantine_threshold(policy)) {
        return ScanVerdict.QUARANTINE;
    }
    if (worst > Severity.INFO) {
        return ScanVerdict.WARN;
    }
    return ScanVerdict.PASS;
}

# Combine stdout + "\n" + stderr into a fresh heap cstr. Newline separator
# prevents false positives at the stdout/stderr boundary.
fn _concat_with_nl(a, b) {
    var alen = strlen(a);
    var blen = strlen(b);
    var buf = alloc(alen + blen + 2);
    memcpy(buf, a, alen);
    store8(buf + alen, 10);
    memcpy(buf + alen + 1, b, blen);
    store8(buf + alen + 1 + blen, 0);
    return buf;
}

# Apply the externalization gate. Returns a ScanResult with verdict set.
# Callers use verdict to decide whether to release the artifact:
#   PASS       → release as-is
#   WARN       → release (optionally redacted)
#   QUARANTINE → hold, require approval
#   BLOCK      → reject
fn gate_apply(result, policy) {
    var sr = scan_result_new();

    if (ExternalizationPolicy_enabled(policy) == 0) {
        ScanResult_set_verdict(sr, ScanVerdict.PASS);
        return sr;
    }

    var stdout = ExecResult_stdout(result);
    var stderr = ExecResult_stderr(result);
    var total = strlen(stdout) + strlen(stderr);
    if (total > ExternalizationPolicy_max_artifact_size_bytes(policy)) {
        scan_result_push(sr, finding_new("gate", Severity.CRITICAL,
        "size_limit", "output size exceeds limit", 0));
        ScanResult_set_verdict(sr, ScanVerdict.BLOCK);
        return sr;
    }

    var combined = _concat_with_nl(stdout, stderr);
    secrets_scan(combined, sr);
    code_scan(combined, sr);
    data_scan(combined, sr);

    var verdict = determine_verdict(ScanResult_worst_severity(sr), policy);
    ScanResult_set_verdict(sr, verdict);

    # WARN-verdict redaction: replace every secret span in stdout/stderr
    # with [REDACTED:CATEGORY] so the caller can release the artifact
    # without leaking. Closed in v3.0 per ADR-004 §7; only fires when
    # the policy opts in (ExternalizationPolicy.redact_secrets == 1).
    if (verdict == ScanVerdict.WARN) {
        if (ExternalizationPolicy_redact_secrets(policy) == 1) {
            var red_out = secrets_redact(stdout);
            if (red_out != 0) { ExecResult_set_stdout(result, red_out); }
            var red_err = secrets_redact(stderr);
            if (red_err != 0) { ExecResult_set_stderr(result, red_err); }
        }
    }
    return sr;
}

# --- scanning_runtime.cyr ---

# kavach — runtime guards (fork bomb, paths, commands, shell injection)
# Ported from rust-old/src/scanning/runtime.rs
#
# Integrity monitoring (PID/mount/user namespace checks) is deferred —
# needs /proc file reads which aren't in the current stdlib stub.

# ---- Violation types -----------------------------------------------------

enum ViolationType {
    FORK_BOMB = 0;
    SENSITIVE_PATH = 1;
    BLOCKED_COMMAND = 2;
    SHELL_INJECTION = 3;
    TIME_ANOMALY = 4;
}

fn violation_type_name(t) {
    if (t == ViolationType.FORK_BOMB) { return "fork_bomb"; }
    if (t == ViolationType.SENSITIVE_PATH) { return "sensitive_path"; }
    if (t == ViolationType.BLOCKED_COMMAND) { return "blocked_command"; }
    if (t == ViolationType.SHELL_INJECTION) { return "shell_injection"; }
    if (t == ViolationType.TIME_ANOMALY) { return "time_anomaly"; }
    return "unknown";
}

#derive(accessors)
struct GuardViolation {
    violation_type;
    description;
}

fn guard_violation_new(t, desc) {
    var v = alloc(16);
    GuardViolation_set_violation_type(v, t);
    GuardViolation_set_description(v, desc);
    return v;
}

# ---- Guard config --------------------------------------------------------

#derive(accessors)
struct RuntimeGuardConfig {
    max_pids;
    block_sensitive_paths;
    enforce_command_blocklist;
    time_anomaly_multiplier_x100;
}

fn runtime_guard_config_default() {
    var c = alloc(32);
    RuntimeGuardConfig_set_max_pids(c, 64);
    RuntimeGuardConfig_set_block_sensitive_paths(c, 1);
    RuntimeGuardConfig_set_enforce_command_blocklist(c, 1);
    RuntimeGuardConfig_set_time_anomaly_multiplier_x100(c, 200);
    return c;
}

# ---- Command parsing -----------------------------------------------------

# Return heap cstr of base command name (first whitespace-separated token,
# stripped of path prefix). "ls -la" -> "ls"; "/bin/bash -c" -> "bash".
fn _base_command(cmd) {
    var n = strlen(cmd);
    # Skip leading whitespace
    var start = 0;
    while (start < n) {
        var c = load8(cmd + start);
        if (c != 32) { if (c != 9) { break; } }
        start = start + 1;
    }
    # End at whitespace
    var end = start;
    while (end < n) {
        var c = load8(cmd + end);
        if (c == 32) { break; }
        if (c == 9) { break; }
        if (c == 10) { break; }
        end = end + 1;
    }
    # Last slash in [start, end) — chars after it are the base name
    var base_start = start;
    var i = start;
    while (i < end) {
        if (load8(cmd + i) == 47) { base_start = i + 1; }
        i = i + 1;
    }
    var len = end - base_start;
    var buf = alloc(len + 1);
    memcpy(buf, cmd + base_start, len);
    store8(buf + len, 0);
    return buf;
}

# ---- Blocklist checks ----------------------------------------------------

fn _is_blocked_command(base) {
    if (streq(base, "bash") == 1) { return 1; }
    if (streq(base, "sh") == 1) { return 1; }
    if (streq(base, "zsh") == 1) { return 1; }
    if (streq(base, "fish") == 1) { return 1; }
    if (streq(base, "dash") == 1) { return 1; }
    if (streq(base, "csh") == 1) { return 1; }
    if (streq(base, "tcsh") == 1) { return 1; }
    if (streq(base, "python") == 1) { return 1; }
    if (streq(base, "python3") == 1) { return 1; }
    if (streq(base, "perl") == 1) { return 1; }
    if (streq(base, "ruby") == 1) { return 1; }
    if (streq(base, "php") == 1) { return 1; }
    if (streq(base, "lua") == 1) { return 1; }
    if (streq(base, "node") == 1) { return 1; }
    if (streq(base, "deno") == 1) { return 1; }
    if (streq(base, "bun") == 1) { return 1; }
    if (streq(base, "gcc") == 1) { return 1; }
    if (streq(base, "cc") == 1) { return 1; }
    if (streq(base, "g++") == 1) { return 1; }
    if (streq(base, "clang") == 1) { return 1; }
    if (streq(base, "make") == 1) { return 1; }
    if (streq(base, "cmake") == 1) { return 1; }
    if (streq(base, "cargo") == 1) { return 1; }
    if (streq(base, "go") == 1) { return 1; }
    if (streq(base, "rustc") == 1) { return 1; }
    if (streq(base, "javac") == 1) { return 1; }
    return 0;
}

fn is_allowed_command(base) {
    if (streq(base, "ls") == 1) { return 1; }
    if (streq(base, "cat") == 1) { return 1; }
    if (streq(base, "head") == 1) { return 1; }
    if (streq(base, "tail") == 1) { return 1; }
    if (streq(base, "wc") == 1) { return 1; }
    if (streq(base, "grep") == 1) { return 1; }
    if (streq(base, "find") == 1) { return 1; }
    if (streq(base, "df") == 1) { return 1; }
    if (streq(base, "du") == 1) { return 1; }
    if (streq(base, "uname") == 1) { return 1; }
    if (streq(base, "hostname") == 1) { return 1; }
    if (streq(base, "ip") == 1) { return 1; }
    if (streq(base, "ss") == 1) { return 1; }
    if (streq(base, "ps") == 1) { return 1; }
    if (streq(base, "top") == 1) { return 1; }
    if (streq(base, "free") == 1) { return 1; }
    if (streq(base, "lsblk") == 1) { return 1; }
    if (streq(base, "lscpu") == 1) { return 1; }
    if (streq(base, "date") == 1) { return 1; }
    if (streq(base, "whoami") == 1) { return 1; }
    if (streq(base, "id") == 1) { return 1; }
    if (streq(base, "env") == 1) { return 1; }
    if (streq(base, "printenv") == 1) { return 1; }
    if (streq(base, "echo") == 1) { return 1; }
    if (streq(base, "true") == 1) { return 1; }
    if (streq(base, "false") == 1) { return 1; }
    if (streq(base, "test") == 1) { return 1; }
    return 0;
}

fn _check_sensitive_paths(cmd_lower, out_vec) {
    var n = 0;
    if (cstr_contains(cmd_lower, "/etc/shadow") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /etc/shadow"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/etc/gshadow") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /etc/gshadow"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/etc/sudoers") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /etc/sudoers"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/root/") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /root/"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/.ssh/") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /.ssh/"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/.gnupg/") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /.gnupg/"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/.aws/") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /.aws/"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/.kube/") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /.kube/"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/.docker/") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /.docker/"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/dev/mem") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /dev/mem"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/dev/kmem") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /dev/kmem"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/dev/port") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /dev/port"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/proc/kcore") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: /proc/kcore"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/proc/sysrq-trigger") == 1) {
        vec_push(out_vec, guard_violation_new(
        ViolationType.SENSITIVE_PATH, "sensitive path access: /proc/sysrq-trigger"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/sys/firmware/efi/efivars") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SENSITIVE_PATH, "sensitive path access: efivars"));
        n = n + 1;
    }
    return n;
}

fn _check_shell_meta(cmd_lower, out_vec) {
    var n = 0;
    if (cstr_contains(cmd_lower, "| sh") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: | sh"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "| bash") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: | bash"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "; sh") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: ; sh"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "; bash") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: ; bash"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "| /bin/sh") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: | /bin/sh"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "| /bin/bash") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: | /bin/bash"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "$(") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: $("));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "${") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: ${"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "/dev/tcp") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: /dev/tcp"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "mkfifo") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: mkfifo"));
        n = n + 1;
    }
    if (cstr_contains(cmd_lower, "`") == 1) {
        vec_push(out_vec, guard_violation_new(ViolationType.SHELL_INJECTION, "shell metacharacter: backtick"));
        n = n + 1;
    }
    return n;
}

# ---- Main entry points ---------------------------------------------------

# Returns a vec of GuardViolation pointers (empty = safe).
fn check_command(command, config) {
    var violations = vec_new();
    var n = strlen(command);
    var lower = alloc(n + 1);
    str_to_lower_into(command, lower);

    if (RuntimeGuardConfig_enforce_command_blocklist(config) == 1) {
        var base = _base_command(command);
        if (_is_blocked_command(base) == 1) {
            var msg_len = strlen(base) + 18;
            var msg = alloc(msg_len + 1);
            memcpy(msg, "blocked command: ", 17);
            memcpy(msg + 17, base, strlen(base));
            store8(msg + 17 + strlen(base), 0);
            vec_push(violations, guard_violation_new(ViolationType.BLOCKED_COMMAND, msg));
        }
    }

    if (RuntimeGuardConfig_block_sensitive_paths(config) == 1) {
        _check_sensitive_paths(lower, violations);
    }

    _check_shell_meta(lower, violations);
    return violations;
}

# Returns GuardViolation ptr if fork bomb detected, 0 otherwise.
fn check_fork_bomb(current_pids, config) {
    if (current_pids > RuntimeGuardConfig_max_pids(config)) {
        return guard_violation_new(ViolationType.FORK_BOMB, "process count exceeds limit");
    }
    return 0;
}

# Returns GuardViolation ptr if duration is anomalous, 0 otherwise.
# multiplier_x100 = 200 means "2.0x expected".
fn check_time_anomaly(duration_ms, expected_ms, config) {
    var threshold = expected_ms * RuntimeGuardConfig_time_anomaly_multiplier_x100(config) / 100;
    if (duration_ms > threshold) {
        return guard_violation_new(ViolationType.TIME_ANOMALY, "execution duration anomalous");
    }
    return 0;
}

# ---- Sandbox integrity monitoring ---------------------------------------
# Ported from rust-old/src/scanning/runtime.rs check_integrity(). Reads
# /proc to verify the current process is in a separate PID, mount, and
# user namespace from the host. Used by callers that want to assert
# isolation is actually in effect before proceeding with sensitive work.

#derive(accessors)
struct IntegrityCheck {
    name;
    passed;
    detail;
}

fn _integrity_check_new(name, passed, detail) {
    var c = alloc(24);
    IntegrityCheck_set_name(c, name);
    IntegrityCheck_set_passed(c, passed);
    IntegrityCheck_set_detail(c, detail);
    return c;
}

#derive(accessors)
struct IntegrityReport {
    intact;
    checks;
    checked_at;
}

fn runtime_integrity_report_new() {
    var r = alloc(24);
    IntegrityReport_set_intact(r, 0);
    IntegrityReport_set_checks(r, vec_new());
    IntegrityReport_set_checked_at(r, 0);
    return r;
}

# PID namespace check: /proc/1/cmdline should not contain 'systemd' or
# 'init'. If the read fails (e.g. /proc masked), assume isolated — the
# caller can't see host state anyway.
fn _integrity_check_pid_ns() {
    var buf = alloc(512);
    # Read at most size-1 so the NUL terminator below always lands inside the
    # allocation — file_read_all can fill the whole buffer otherwise, making
    # store8(buf + n, 0) a one-byte heap overflow (matches cgroup_supported).
    var n = file_read_all("/proc/1/cmdline", buf, 511);
    if (n <= 0) {
        return _integrity_check_new("pid_namespace", 1, "proc not readable (assume isolated)");
    }
    store8(buf + n, 0);
    if (cstr_contains(buf, "systemd") == 1) {
        return _integrity_check_new("pid_namespace", 0, "host systemd visible as PID 1");
    }
    if (cstr_contains(buf, "/init") == 1) {
        return _integrity_check_new("pid_namespace", 0, "host init visible as PID 1");
    }
    return _integrity_check_new("pid_namespace", 1, "PID namespace isolated");
}

# Mount namespace check: /proc/mounts should not expose host /home
# unless overlay-mounted (containers commonly overlay user dirs).
fn _integrity_check_mount_ns() {
    var buf = alloc(8192);
    # size-1 read limit — see _integrity_check_pid_ns for the rationale.
    var n = file_read_all("/proc/mounts", buf, 8191);
    if (n <= 0) {
        return _integrity_check_new("mount_namespace", 1, "/proc/mounts not readable");
    }
    store8(buf + n, 0);
    if (cstr_contains(buf, "/home/") == 1) {
        if (cstr_contains(buf, "overlay") == 0) {
            return _integrity_check_new("mount_namespace", 0, "host /home visible");
        }
    }
    return _integrity_check_new("mount_namespace", 1, "mount namespace isolated");
}

# User namespace check: /proc/self/uid_map should be non-empty when a
# user namespace is in effect.
fn _integrity_check_user_ns() {
    var buf = alloc(256);
    # size-1 read limit — see _integrity_check_pid_ns for the rationale.
    var n = file_read_all("/proc/self/uid_map", buf, 255);
    if (n <= 0) {
        return _integrity_check_new("user_namespace", 0, "no UID mapping");
    }
    store8(buf + n, 0);
    if (n < 4) {
        return _integrity_check_new("user_namespace", 0, "UID map suspiciously small");
    }
    return _integrity_check_new("user_namespace", 1, "user namespace active");
}

fn check_integrity() {
    var report = runtime_integrity_report_new();
    IntegrityReport_set_checked_at(report, clock_epoch_secs());
    var checks = IntegrityReport_checks(report);

    var c1 = _integrity_check_pid_ns();
    var c2 = _integrity_check_mount_ns();
    var c3 = _integrity_check_user_ns();
    vec_push(checks, c1);
    vec_push(checks, c2);
    vec_push(checks, c3);

    var intact = 1;
    if (IntegrityCheck_passed(c1) == 0) { intact = 0; }
    if (IntegrityCheck_passed(c2) == 0) { intact = 0; }
    if (IntegrityCheck_passed(c3) == 0) { intact = 0; }
    IntegrityReport_set_intact(report, intact);
    return report;
}

# --- scanning_threat.cyr ---

# kavach — threat classification (intent scoring + kill-chain)
# Ported from rust-old/src/scanning/threat.rs
#
# Cyrius i64 arithmetic; Rust floats are expressed as fixed-point x1000:
#   intent_score 0..1000 represents 0.000..1.000.
# OffenderTracker (time-decay + agent keying) landed in v3.0 using
# chrono + rand_u64 — see bottom of file.

enum KillChainStage {
    RECONNAISSANCE = 0;
    WEAPONIZATION = 1;
    DELIVERY = 2;
    EXPLOITATION = 3;
    INSTALLATION = 4;
    COMMAND_AND_CONTROL = 5;
    EXFILTRATION = 6;
}

fn kill_chain_stage_name(s) {
    if (s == KillChainStage.RECONNAISSANCE) { return "reconnaissance"; }
    if (s == KillChainStage.WEAPONIZATION) { return "weaponization"; }
    if (s == KillChainStage.DELIVERY) { return "delivery"; }
    if (s == KillChainStage.EXPLOITATION) { return "exploitation"; }
    if (s == KillChainStage.INSTALLATION) { return "installation"; }
    if (s == KillChainStage.COMMAND_AND_CONTROL) { return "command_and_control"; }
    if (s == KillChainStage.EXFILTRATION) { return "exfiltration"; }
    return "unknown";
}

enum ThreatTier {
    BENIGN = 0;
    SUSPICIOUS = 1;
    LIKELY_MALICIOUS = 2;
    MALICIOUS = 3;
}

enum EscalationTier {
    TIER1_LOG = 0;
    TIER2_ALERT = 1;
    TIER3_SUSPEND = 2;
    TIER4_REVOKE = 3;
}

fn threat_tier_name(t) {
    if (t == ThreatTier.BENIGN) { return "benign"; }
    if (t == ThreatTier.SUSPICIOUS) { return "suspicious"; }
    if (t == ThreatTier.LIKELY_MALICIOUS) { return "likely_malicious"; }
    if (t == ThreatTier.MALICIOUS) { return "malicious"; }
    return "unknown";
}

fn escalation_tier_name(e) {
    if (e == EscalationTier.TIER1_LOG) { return "tier1_log"; }
    if (e == EscalationTier.TIER2_ALERT) { return "tier2_alert"; }
    if (e == EscalationTier.TIER3_SUSPEND) { return "tier3_suspend"; }
    if (e == EscalationTier.TIER4_REVOKE) { return "tier4_revoke"; }
    return "unknown";
}

#derive(accessors)
struct ThreatAssessment {
    intent_score_x1000;
    classification;
    escalation;
    kill_chain_stages;
    finding_count;
}

fn _severity_weight_x1000(sev) {
    if (sev == Severity.INFO) { return 50; }
    if (sev == Severity.LOW) { return 150; }
    if (sev == Severity.MEDIUM) { return 350; }
    if (sev == Severity.HIGH) { return 600; }
    if (sev == Severity.CRITICAL) { return 900; }
    return 0;
}

# Map a finding category to its kill-chain stage. Returns -1 if no mapping.
fn _category_to_stage(category) {
    if (streq(category, "pii_network") == 1) { return KillChainStage.RECONNAISSANCE; }
    if (streq(category, "obfuscation") == 1) { return KillChainStage.WEAPONIZATION; }
    if (streq(category, "crypto_misuse") == 1) { return KillChainStage.WEAPONIZATION; }
    if (streq(category, "supply_chain") == 1) { return KillChainStage.DELIVERY; }
    if (streq(category, "command_injection") == 1) { return KillChainStage.EXPLOITATION; }
    if (streq(category, "privilege_escalation") == 1) { return KillChainStage.EXPLOITATION; }
    if (streq(category, "filesystem_abuse") == 1) { return KillChainStage.INSTALLATION; }
    if (streq(category, "data_exfiltration") == 1) { return KillChainStage.COMMAND_AND_CONTROL; }
    if (streq(category, "cloud_credential") == 1) { return KillChainStage.EXFILTRATION; }
    if (streq(category, "api_token") == 1) { return KillChainStage.EXFILTRATION; }
    if (streq(category, "auth_token") == 1) { return KillChainStage.EXFILTRATION; }
    if (streq(category, "private_key") == 1) { return KillChainStage.EXFILTRATION; }
    if (streq(category, "connection_string") == 1) { return KillChainStage.EXFILTRATION; }
    if (streq(category, "credential") == 1) { return KillChainStage.EXFILTRATION; }
    if (streq(category, "pii") == 1) { return KillChainStage.EXFILTRATION; }
    if (streq(category, "pii_financial") == 1) { return KillChainStage.EXFILTRATION; }
    return 0 - 1;
}

fn _vec_contains_stage(v, stage) {
    var i = 0;
    while (i < vec_len(v)) {
        if (vec_get(v, i) == stage) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Classify findings (vec<ScanFinding>) into a ThreatAssessment.
fn classify_threat(findings) {
    var assessment = alloc(40);
    ThreatAssessment_set_finding_count(assessment, vec_len(findings));
    ThreatAssessment_set_kill_chain_stages(assessment, vec_new());

    if (vec_len(findings) == 0) {
        ThreatAssessment_set_intent_score_x1000(assessment, 0);
        ThreatAssessment_set_classification(assessment, ThreatTier.BENIGN);
        ThreatAssessment_set_escalation(assessment, EscalationTier.TIER1_LOG);
        return assessment;
    }

    var raw_x1000 = 0;
    var stages = vec_new();
    var i = 0;
    while (i < vec_len(findings)) {
        var f = vec_get(findings, i);
        raw_x1000 = raw_x1000 + _severity_weight_x1000(ScanFinding_severity(f));
        var st = _category_to_stage(ScanFinding_category(f));
        if (st >= 0) {
            if (_vec_contains_stage(stages, st) == 0) { vec_push(stages, st); }
        }
        i = i + 1;
    }
    ThreatAssessment_set_kill_chain_stages(assessment, stages);

    # Co-occurrence amplifier (x1000):
    #   >= 3 stages -> 1.5x (1500)
    #   >= 2 stages -> 1.3x (1300)
    #   else         -> 1.0x (1000)
    var amp = 1000;
    if (vec_len(stages) >= 3) { amp = 1500; }
    elif (vec_len(stages) >= 2) { amp = 1300; }

    var intent = raw_x1000 * amp / 1000;
    if (intent > 1000) { intent = 1000; }
    ThreatAssessment_set_intent_score_x1000(assessment, intent);

    var cls = ThreatTier.BENIGN;
    if (intent >= 200) { cls = ThreatTier.SUSPICIOUS; }
    if (intent >= 500) { cls = ThreatTier.LIKELY_MALICIOUS; }
    if (intent >= 800) { cls = ThreatTier.MALICIOUS; }
    ThreatAssessment_set_classification(assessment, cls);

    var esc = EscalationTier.TIER1_LOG;
    if (cls == ThreatTier.SUSPICIOUS) { esc = EscalationTier.TIER2_ALERT; }
    if (cls == ThreatTier.LIKELY_MALICIOUS) { esc = EscalationTier.TIER3_SUSPEND; }
    if (cls == ThreatTier.MALICIOUS) { esc = EscalationTier.TIER4_REVOKE; }
    ThreatAssessment_set_escalation(assessment, esc);

    return assessment;
}

# ---- Repeat-offender tracking --------------------------------------------
# Ported from rust-old/src/scanning/threat.rs OffenderTracker. Each
# agent_id accumulates a weighted violation score that decays with time
# (half-life = half the rolling window). When the agent's decayed score
# exceeds the escalation_threshold_x1000, should_escalate() returns 1.
#
# Storage: three parallel vecs keyed by insertion order. A violation
# record is (agent_id cstr, score_x1000, timestamp_secs). Pruning
# drops records older than window_secs.

#derive(accessors)
struct OffenderTracker {
    window_secs;
    decay_factor_x1000;
    escalation_threshold_x1000;
    records;
}

#derive(accessors)
struct ViolationRecord {
    timestamp_secs;
    score_x1000;
    agent_id;
}

fn _violation_record_new(ts, score, agent_id) {
    var r = alloc(24);
    ViolationRecord_set_timestamp_secs(r, ts);
    ViolationRecord_set_score_x1000(r, score);
    ViolationRecord_set_agent_id(r, agent_id);
    return r;
}

# Defaults match Rust:
#   window_secs=3600 (1h), decay=0.5 per half-window, threshold=3.0 score
fn offender_tracker_new() {
    var t = alloc(32);
    OffenderTracker_set_window_secs(t, 3600);
    OffenderTracker_set_decay_factor_x1000(t, 500);
    OffenderTracker_set_escalation_threshold_x1000(t, 3000);
    OffenderTracker_set_records(t, vec_new());
    return t;
}

fn offender_tracker_with_config(window_secs, decay_x1000, threshold_x1000) {
    if (window_secs <= 0) { return 0; }
    var t = alloc(32);
    OffenderTracker_set_window_secs(t, window_secs);
    OffenderTracker_set_decay_factor_x1000(t, decay_x1000);
    OffenderTracker_set_escalation_threshold_x1000(t, threshold_x1000);
    OffenderTracker_set_records(t, vec_new());
    return t;
}

# Record a violation. Intent score comes from a ThreatAssessment
# (intent_score_x1000). Duplicate agent_ids accumulate across records;
# decay is applied at query time, not at insert.
fn offender_tracker_record(tracker, agent_id, assessment) {
    var now = clock_epoch_secs();
    var score = ThreatAssessment_intent_score_x1000(assessment);
    var rec = _violation_record_new(now, score, agent_id);
    vec_push(OffenderTracker_records(tracker), rec);
    return 0;
}

# Walk records, drop those older than window. Called implicitly by
# agent_score; callers can invoke manually after a burst.
fn offender_tracker_prune(tracker) {
    var now = clock_epoch_secs();
    var window = OffenderTracker_window_secs(tracker);
    var recs = OffenderTracker_records(tracker);
    var keep = vec_new();
    var i = 0;
    while (i < vec_len(recs)) {
        var r = vec_get(recs, i);
        if (now - ViolationRecord_timestamp_secs(r) <= window) {
            vec_push(keep, r);
        }
        i = i + 1;
    }
    OffenderTracker_set_records(tracker, keep);
    return 0;
}

# Compute decayed score for an agent. Each record's contribution is
# multiplied by (decay_factor)^(age / half_window) — age is rounded to
# half-windows to stay in i64-land without floats. After N half-lives,
# contribution is score * (decay^N) via repeated division.
fn offender_tracker_agent_score(tracker, agent_id) {
    offender_tracker_prune(tracker);
    var now = clock_epoch_secs();
    var half_window = OffenderTracker_window_secs(tracker) / 2;
    if (half_window <= 0) { half_window = 1; }
    var decay = OffenderTracker_decay_factor_x1000(tracker);
    var recs = OffenderTracker_records(tracker);
    var total = 0;
    var i = 0;
    while (i < vec_len(recs)) {
        var r = vec_get(recs, i);
        if (streq(ViolationRecord_agent_id(r), agent_id) == 1) {
            var age = now - ViolationRecord_timestamp_secs(r);
            var half_lives = age / half_window;
            var contribution = ViolationRecord_score_x1000(r);
            var k = 0;
            while (k < half_lives) {
                contribution = contribution * decay / 1000;
                if (contribution == 0) { break; }
                k = k + 1;
            }
            total = total + contribution;
        }
        i = i + 1;
    }
    return total;
}

fn offender_tracker_should_escalate(tracker, agent_id) {
    var score = offender_tracker_agent_score(tracker, agent_id);
    if (score >= OffenderTracker_escalation_threshold_x1000(tracker)) { return 1; }
    return 0;
}

fn offender_tracker_count(tracker) {
    return vec_len(OffenderTracker_records(tracker));
}

# --- audit.cyr ---

# kavach — HMAC-SHA256 audit chain (append-only, tamper-evident)
# Ported from rust-old/src/scanning/audit.rs
#
# Each entry:
#   serial (u64) | event_type (cstr) | payload (cstr) | timestamp | hmac | prev_hmac
# HMAC is computed over "serial:event_type:payload:timestamp:prev_hmac"
# using a caller-supplied key. File format is JSONL; verify walks linearly.
#
# Deferred vs Rust:
#   - payload is pre-serialized cstr, not serde_json::Value (cleaner anyway)
#   - timestamp is epoch-seconds decimal, not ISO 8601 rfc3339
#   - reopen/verify-on-open is stubbed until fs line-read is wired

# ---- Hex encoding --------------------------------------------------------

var _HEX_CHARS = "0123456789abcdef";

# Hex-encode 32 bytes into a 65-byte output buffer (64 hex + NUL).
fn hex_encode32(bytes, out) {
    var i = 0;
    while (i < 32) {
        var b = load8(bytes + i);
        var hi = (b >> 4) & 15;
        var lo = b & 15;
        store8(out + i * 2, load8(_HEX_CHARS + hi));
        store8(out + i * 2 + 1, load8(_HEX_CHARS + lo));
        i = i + 1;
    }
    store8(out + 64, 0);
    return 0;
}

# ---- AuditEntry ----------------------------------------------------------

#derive(accessors)
struct AuditEntry {
    serial;
    event_type;
    payload;
    timestamp;
    hmac;
    prev_hmac;
}

fn audit_entry_new() {
    var e = alloc(48);
    AuditEntry_set_event_type(e, "");
    AuditEntry_set_payload(e, "");
    AuditEntry_set_timestamp(e, "");
    AuditEntry_set_hmac(e, "");
    AuditEntry_set_prev_hmac(e, "");
    return e;
}

# ---- AuditChain ----------------------------------------------------------

#derive(accessors)
struct AuditChain {
    log_path;
    hmac_key;
    hmac_key_len;
    last_hmac;
    next_serial;
}

# Compute HMAC-SHA256 over a cstr message; return 65-byte hex cstr.
# Returns 0 on null msg (propagated overflow from upstream).
fn _hmac_hex(key, key_len, msg) {
    if (msg == 0) { return 0; }
    var raw[32];
    hmac_sha256(key, key_len, msg, strlen(msg), &raw);
    var out = alloc(65);
    hex_encode32(&raw, out);
    return out;
}

# Build the signing input: serial:event_type:payload:timestamp:prev_hmac
# Sizes are checked-summed to defend against overflow — if any input
# is malformed, returns 0 and the HMAC site will observe a null msg.
# (All callers already guard against a null return before hashing.)
fn _sign_input(serial, event_type, payload, timestamp, prev_hmac) {
    var serial_buf[24];
    var serial_len = fmt_int_buf(serial, &serial_buf);
    var user_lens = checked_sum4(strlen(event_type), strlen(payload),
    strlen(timestamp), strlen(prev_hmac));
    if (user_lens < 0) { return 0; }
    var total = checked_add(user_lens, serial_len + 5);
    if (total < 0) { return 0; }
    var buf = alloc_checked(total);
    if (buf == 0) { return 0; }
    var pos = 0;
    memcpy(buf + pos, &serial_buf, serial_len); pos = pos + serial_len;
    store8(buf + pos, 58); pos = pos + 1;
    memcpy(buf + pos, event_type, strlen(event_type)); pos = pos + strlen(event_type);
    store8(buf + pos, 58); pos = pos + 1;
    memcpy(buf + pos, payload, strlen(payload)); pos = pos + strlen(payload);
    store8(buf + pos, 58); pos = pos + 1;
    memcpy(buf + pos, timestamp, strlen(timestamp)); pos = pos + strlen(timestamp);
    store8(buf + pos, 58); pos = pos + 1;
    memcpy(buf + pos, prev_hmac, strlen(prev_hmac)); pos = pos + strlen(prev_hmac);
    store8(buf + pos, 0);
    return buf;
}

# JSONL serializer. Event_type and payload are user-controllable, so both
# pass through oci_json_escape (full RFC-8259 control-char escaping).
# Timestamp is epoch-seconds decimal (digits-only; no escape needed).
# Hmac + prev_hmac are hex (64 chars or empty; no escape needed).
# See ADR-005 §C2.
fn _entry_to_jsonl(entry) {
    var serial_buf[24];
    var slen = fmt_int_buf(AuditEntry_serial(entry), &serial_buf);
    var ev = oci_json_escape(AuditEntry_event_type(entry));
    var pl = oci_json_escape(AuditEntry_payload(entry));
    var ts = AuditEntry_timestamp(entry);
    var h = AuditEntry_hmac(entry);
    var ph = AuditEntry_prev_hmac(entry);
    var user_lens = checked_sum4(strlen(ev), strlen(pl), strlen(ts),
    strlen(h) + strlen(ph));
    if (user_lens < 0) { return 0; }
    var cap = checked_add(user_lens, slen + 256);
    if (cap < 0) { return 0; }
    var buf = alloc_checked(cap);
    if (buf == 0) { return 0; }
    var pos = 0;
    var prefix = "{\"serial\":";
    memcpy(buf + pos, prefix, strlen(prefix)); pos = pos + strlen(prefix);
    memcpy(buf + pos, &serial_buf, slen); pos = pos + slen;
    var k1 = ",\"event_type\":\"";
    memcpy(buf + pos, k1, strlen(k1)); pos = pos + strlen(k1);
    memcpy(buf + pos, ev, strlen(ev)); pos = pos + strlen(ev);
    var k2 = "\",\"payload\":\"";
    memcpy(buf + pos, k2, strlen(k2)); pos = pos + strlen(k2);
    memcpy(buf + pos, pl, strlen(pl)); pos = pos + strlen(pl);
    var k3 = "\",\"timestamp\":\"";
    memcpy(buf + pos, k3, strlen(k3)); pos = pos + strlen(k3);
    memcpy(buf + pos, ts, strlen(ts)); pos = pos + strlen(ts);
    var k4 = "\",\"hmac\":\"";
    memcpy(buf + pos, k4, strlen(k4)); pos = pos + strlen(k4);
    memcpy(buf + pos, h, strlen(h)); pos = pos + strlen(h);
    var k5 = "\",\"prev_hmac\":\"";
    memcpy(buf + pos, k5, strlen(k5)); pos = pos + strlen(k5);
    memcpy(buf + pos, ph, strlen(ph)); pos = pos + strlen(ph);
    var k6 = "\"}\n";
    memcpy(buf + pos, k6, strlen(k6)); pos = pos + strlen(k6);
    store8(buf + pos, 0);
    return buf;
}

# Open (or create) an audit chain at log_path with the given HMAC key.
# If the path exists, the file is left in place and the chain resumes from
# wherever the caller last recorded — file-based reload/verify is a TODO.
fn audit_chain_open(log_path, hmac_key, hmac_key_len) {
    sha256_global_init();
    var c = alloc(40);
    AuditChain_set_log_path(c, log_path);
    AuditChain_set_hmac_key(c, hmac_key);
    AuditChain_set_hmac_key_len(c, hmac_key_len);
    AuditChain_set_last_hmac(c, "");
    AuditChain_set_next_serial(c, 0);

    # Emit genesis entry
    audit_chain_record(c, "genesis", "audit chain initialized");
    return c;
}

# Record an event. event_type and payload must be cstrs; payload should be
# pre-serialized (no escape handling here).
fn audit_chain_record(chain, event_type, payload) {
    var serial = AuditChain_next_serial(chain);
    var ts_buf[24];
    var ts_len = fmt_int_buf(clock_epoch_secs(), &ts_buf);
    var timestamp = alloc(ts_len + 1);
    memcpy(timestamp, &ts_buf, ts_len);
    store8(timestamp + ts_len, 0);

    var prev = AuditChain_last_hmac(chain);
    var msg = _sign_input(serial, event_type, payload, timestamp, prev);
    var hmac_hex = _hmac_hex(AuditChain_hmac_key(chain),
    AuditChain_hmac_key_len(chain), msg);

    var entry = audit_entry_new();
    AuditEntry_set_serial(entry, serial);
    AuditEntry_set_event_type(entry, event_type);
    AuditEntry_set_payload(entry, payload);
    AuditEntry_set_timestamp(entry, timestamp);
    AuditEntry_set_hmac(entry, hmac_hex);
    AuditEntry_set_prev_hmac(entry, prev);

    var line = _entry_to_jsonl(entry);
    # file_append_locked creates the file at 0644 on first write; tighten
    # to 0600 immediately afterward. (A wider `file_append_locked_mode`
    # wrapper is scheduled for Cyrius stdlib 4.4.0; until then this
    # best-effort chmod is the hardening path — see ADR-005 §C4.)
    if (file_append_locked(AuditChain_log_path(chain), line, strlen(line)) < 0) {
        kavach_err_print(KAVACH_ERR_IO_ERROR, "audit chain write failed");
        return 0;
    }
    file_restrict_mode(AuditChain_log_path(chain));

    AuditChain_set_last_hmac(chain, hmac_hex);
    AuditChain_set_next_serial(chain, serial + 1);
    return entry;
}

fn audit_chain_len(chain) {
    return AuditChain_next_serial(chain);
}

# Recompute hmac for an AuditEntry using `key` and compare to entry.hmac.
# Uses constant-time comparison (ct_streq → sigil ct_eq) to prevent timing
# side-channel attacks on the signing key. See ADR-005 §C1.
# Returns 1 if valid, 0 otherwise.
fn audit_entry_verify(entry, key, key_len) {
    var msg = _sign_input(AuditEntry_serial(entry),
    AuditEntry_event_type(entry),
    AuditEntry_payload(entry),
    AuditEntry_timestamp(entry),
    AuditEntry_prev_hmac(entry));
    var expected = _hmac_hex(key, key_len, msg);
    return ct_streq(expected, AuditEntry_hmac(entry));
}

# Zero the HMAC key buffer. Callers that no longer need a chain should
# invoke this to minimize key-material exposure in core dumps or swap.
# Uses sigil's zeroize_key (sigil/dist/sigil.cyr:2834) which is compiler
# barrier-protected against dead-store elimination.
fn audit_chain_close(chain) {
    var key = AuditChain_hmac_key(chain);
    var key_len = AuditChain_hmac_key_len(chain);
    if (key != 0) {
        if (key_len > 0) { zeroize_key(key, key_len); }
    }
    AuditChain_set_hmac_key(chain, 0);
    AuditChain_set_hmac_key_len(chain, 0);
    return 0;
}

# --- credential.cyr ---

# kavach — credential proxy (SecretRef + direct injection)
# Ported from rust-old/src/credential/mod.rs
#
# Three injection methods: env var, file, stdin.
# HTTP proxy layer is a separate module (deferred — needs http/tls).

enum InjectionMethod {
    ENV_VAR = 0;
    FILE = 1;
    STDIN = 2;
}

#derive(accessors)
struct SecretRef {
    name;
    inject_via;
    param1;
    param2;
}

# Build a SecretRef for env-var injection.
fn secret_ref_env(name, var_name) {
    var r = alloc(32);
    SecretRef_set_name(r, name);
    SecretRef_set_inject_via(r, InjectionMethod.ENV_VAR);
    SecretRef_set_param1(r, var_name);
    SecretRef_set_param2(r, 0);
    return r;
}

# Build a SecretRef for file injection (mode is octal, e.g. 0o600 = 384).
fn secret_ref_file(name, path, mode) {
    var r = alloc(32);
    SecretRef_set_name(r, name);
    SecretRef_set_inject_via(r, InjectionMethod.FILE);
    SecretRef_set_param1(r, path);
    SecretRef_set_param2(r, mode);
    return r;
}

fn secret_ref_stdin(name) {
    var r = alloc(32);
    SecretRef_set_name(r, name);
    SecretRef_set_inject_via(r, InjectionMethod.STDIN);
    SecretRef_set_param1(r, 0);
    SecretRef_set_param2(r, 0);
    return r;
}

#derive(accessors)
struct FileInjection {
    path;
    content;
    mode;
}

fn file_injection_new(path, content, mode) {
    var f = alloc(24);
    FileInjection_set_path(f, path);
    FileInjection_set_content(f, content);
    FileInjection_set_mode(f, mode);
    return f;
}

# ---- CredentialProxy -----------------------------------------------------

#derive(accessors)
struct CredentialProxy {
    secrets;
}

fn credential_proxy_new() {
    var p = alloc(8);
    CredentialProxy_set_secrets(p, map_new());
    return p;
}

fn credential_proxy_register(proxy, name, value) {
    map_set(CredentialProxy_secrets(proxy), name, value);
    return 0;
}

# Returns resolved cstr or 0 (no match).
fn credential_proxy_resolve(proxy, secret_ref) {
    return map_get(CredentialProxy_secrets(proxy), SecretRef_name(secret_ref));
}

fn credential_proxy_len(proxy) {
    return map_count(CredentialProxy_secrets(proxy));
}

# Build env var pairs for ENV_VAR refs. Returns vec of interleaved
# (var_name, value) cstrs. Only refs that resolve are emitted.
fn credential_proxy_env_vars(proxy, refs) {
    var out = vec_new();
    var i = 0;
    while (i < vec_len(refs)) {
        var r = vec_get(refs, i);
        if (SecretRef_inject_via(r) == InjectionMethod.ENV_VAR) {
            var v = credential_proxy_resolve(proxy, r);
            if (v != 0) {
                vec_push(out, SecretRef_param1(r));
                vec_push(out, v);
            }
        }
        i = i + 1;
    }
    return out;
}

# Build FileInjection structs for FILE refs.
fn credential_proxy_file_injections(proxy, refs) {
    var out = vec_new();
    var i = 0;
    while (i < vec_len(refs)) {
        var r = vec_get(refs, i);
        if (SecretRef_inject_via(r) == InjectionMethod.FILE) {
            var v = credential_proxy_resolve(proxy, r);
            if (v != 0) {
                vec_push(out, file_injection_new(
                SecretRef_param1(r), v, SecretRef_param2(r)));
            }
        }
        i = i + 1;
    }
    return out;
}

# Write each FileInjection in the vec to disk, honoring its `mode` field.
# Each file lands via file_write_secure_modal — O_CREAT|O_EXCL|O_NOFOLLOW
# at mode 0600, content written while still 0600 (no other-readable
# window), then fchmod to the FileInjection.mode before close (no TOCTOU
# window between write and chmod).
#
# ADR-005 §M2: closes the v3.0 gap where FileInjection.mode was stored
# but not honored. Returns the number of files successfully written; on
# any failure returns `-(n + 1)` where `n` is the count successful before
# the failure — caller can resume / report which injection broke.
fn credential_inject_files(injections) {
    var written = 0;
    var i = 0;
    while (i < vec_len(injections)) {
        var f = vec_get(injections, i);
        var content = FileInjection_content(f);
        var clen = strlen(content);
        var r = file_write_secure_modal(
        FileInjection_path(f), content, clen, FileInjection_mode(f));
        if (r < 0) { return 0 - (written + 1); }
        written = written + 1;
        i = i + 1;
    }
    return written;
}

# Join stdin-method secrets with newlines. Returns cstr or 0 if none.
fn credential_proxy_stdin_payload(proxy, refs) {
    var parts = vec_new();
    var total = 0;
    var i = 0;
    while (i < vec_len(refs)) {
        var r = vec_get(refs, i);
        if (SecretRef_inject_via(r) == InjectionMethod.STDIN) {
            var v = credential_proxy_resolve(proxy, r);
            if (v != 0) {
                vec_push(parts, v);
                # Overflow-checked accumulation on attacker-influenced secret
                # lengths — bail to 0 rather than wrap into an undersized alloc.
                total = checked_add(total, strlen(v));
                if (total < 0) { return 0; }
            }
        }
        i = i + 1;
    }
    if (vec_len(parts) == 0) { return 0; }
    total = checked_add(total, vec_len(parts));
    if (total < 0) { return 0; }
    var buf = alloc_checked(total);
    if (buf == 0) { return 0; }
    var pos = 0;
    var j = 0;
    while (j < vec_len(parts)) {
        var s = vec_get(parts, j);
        var slen = strlen(s);
        memcpy(buf + pos, s, slen);
        pos = pos + slen;
        if (j + 1 < vec_len(parts)) {
            store8(buf + pos, 10);
            pos = pos + 1;
        }
        j = j + 1;
    }
    store8(buf + pos, 0);
    return buf;
}

# --- credential_http.cyr ---

# kavach — HTTP credential proxy (local-only)
#
# Closes ADR-004 §4: kavach exposes secrets to the sandbox over an HTTP
# endpoint on 127.0.0.1:<port> rather than via on-disk file injection.
# The sandbox makes `GET /v1/secret/<name>` calls; kavach serves them
# from CredentialProxy (in-memory store) with an allowlist gate. Every
# fetch hits the audit chain when one is wired.
#
# Threat model:
# - **Localhost-only.** Listener binds 127.0.0.1, never INADDR_ANY. A
#   peer outside the same loopback namespace can't reach the listener.
# - **Allowlist-bound.** Each proxy instance carries a vec of allowed
#   secret names. Fetches for names outside the allowlist return 403
#   without checking CredentialProxy (no oracle for "does this name
#   exist?").
# - **Audit-logged.** Every served fetch + every 403/404 is recorded
#   on the audit chain (when one is wired via the constructor).
# - **Secret never lands on disk.** Unlike file injection (which
#   writes secret-to-tmpfs-file), HTTP serves the bytes in-memory and
#   the sandbox process consumes them in-memory.
#
# Routes:
#   GET /v1/secret/<name>   200 with raw secret value, content-type text/plain
#                           403 if <name> not in this proxy's allowlist
#                           404 if <name> not registered with CredentialProxy
#   GET /v1/health          200 "ok"
#   *                       405 Method Not Allowed
#
# No TLS — by design. The listener is loopback-only; in a deployment that
# spans network namespaces, the consumer-side runs in the same netns as
# the kavach process via vsock or a unix-socket-relay shim (out of scope).

# ---- sandhi TLS-session-cache shims --------------------------------------
# sandhi 1.3.3 calls hashmap_new_a / hashmap_get / hashmap_set_a / hashmap_len
# from its TLS session-cache surface; the stdlib hashmap module exports the
# same surface under `map_*` names. The kavach HTTP credential proxy is
# loopback-only and never reaches the TLS session-cache code paths, but the
# linker still resolves the references at build time. These shims bridge
# the call gap so the build is warning-clean. If a future kavach feature
# wires sandhi as a TLS client (e.g. fetching secrets from a remote vault),
# revisit this — the shims will be load-bearing then. Tracked: file an
# upstream sandhi issue for the hashmap_ vs map_ naming inconsistency.
fn hashmap_new_a(a)              { return map_new_a(a); }
fn hashmap_get(h, k)             { return map_get(h, k); }
fn hashmap_set_a(a, h, k, v)     { return map_set_a(a, h, k, v); }
fn hashmap_len(h)                { return map_count(h); }

#derive(accessors)
struct CredentialHttpProxy {
    listen_fd;
    port;
    proxy_ref;
    allowed_names;
    audit_chain;
    request_count;
    denied_count;
    not_found_count;
}

fn credential_http_proxy_new(proxy, allowed_vec, audit) {
    var h = alloc(64);
    CredentialHttpProxy_set_listen_fd(h, 0 - 1);
    CredentialHttpProxy_set_port(h, 0);
    CredentialHttpProxy_set_proxy_ref(h, proxy);
    CredentialHttpProxy_set_allowed_names(h, allowed_vec);
    CredentialHttpProxy_set_audit_chain(h, audit);
    CredentialHttpProxy_set_request_count(h, 0);
    CredentialHttpProxy_set_denied_count(h, 0);
    CredentialHttpProxy_set_not_found_count(h, 0);
    return h;
}

# Bind to 127.0.0.1:<port> and start listening. Returns 0 on success,
# -1 on socket/bind/listen failure. Port 0 lets the kernel pick; the
# chosen port lands in the handle's `port` field (NOT auto-populated
# from getsockname today — caller should pass a chosen port).
fn credential_http_proxy_listen(http, port) {
    var sock_res = tcp_socket();
    if (is_err_result(sock_res) == 1) { return 0 - 1; }
    var fd = payload(sock_res);
    sock_reuse(fd);
    var bind_res = sock_bind(fd, INADDR_LOOPBACK(), port);
    if (is_err_result(bind_res) == 1) {
        sock_close(fd);
        return 0 - 1;
    }
    var listen_res = sock_listen(fd, 8);
    if (is_err_result(listen_res) == 1) {
        sock_close(fd);
        return 0 - 1;
    }
    CredentialHttpProxy_set_listen_fd(http, fd);
    CredentialHttpProxy_set_port(http, port);
    return 0;
}

fn credential_http_proxy_close(http) {
    var fd = CredentialHttpProxy_listen_fd(http);
    if (fd >= 0) {
        sock_close(fd);
        CredentialHttpProxy_set_listen_fd(http, 0 - 1);
    }
    return 0;
}

# Linear allowlist check. Allowlists are expected to be small (<20 entries).
fn _http_allowed(http, name) {
    var allowed = CredentialHttpProxy_allowed_names(http);
    if (allowed == 0) { return 0; }
    var i = 0;
    while (i < vec_len(allowed)) {
        var n = vec_get(allowed, i);
        if (streq(n, name) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn _http_audit(http, event, payload) {
    var chain = CredentialHttpProxy_audit_chain(http);
    if (chain != 0) { audit_chain_record(chain, event, payload); }
    return 0;
}

# Extract <name> from a path like "/v1/secret/<name>". Returns 0 if the
# path doesn't match the prefix. Returned cstr is a fresh allocation.
fn _http_extract_secret_name(path) {
    var prefix = "/v1/secret/";
    var plen = strlen(prefix);
    var path_len = strlen(path);
    if (path_len <= plen) { return 0; }
    var i = 0;
    while (i < plen) {
        if (load8(path + i) != load8(prefix + i)) { return 0; }
        i = i + 1;
    }
    var tail_len = path_len - plen;
    if (tail_len == 0) { return 0; }
    # Disallow any "/" in the suffix — secret names must be flat.
    var j = 0;
    while (j < tail_len) {
        if (load8(path + plen + j) == 47) { return 0; }
        j = j + 1;
    }
    var out = alloc(tail_len + 1);
    memcpy(out, path + plen, tail_len);
    store8(out + tail_len, 0);
    return out;
}

# Handle one accepted connection: parse, dispatch, respond, close.
# Returns 1 on a request fully served, 0 on a malformed-request short-circuit,
# -1 on socket error.
fn _http_handle_conn(http, conn_fd) {
    var buf = alloc(8192);
    var req_len = sandhi_server_recv_request(conn_fd, buf, 8191);
    if (req_len <= 0) {
        sock_close(conn_fd);
        return 0 - 1;
    }
    CredentialHttpProxy_set_request_count(http,
    CredentialHttpProxy_request_count(http) + 1);

    var method = sandhi_server_get_method(buf, req_len);
    var path = sandhi_server_get_path(buf, req_len);
    if (method == 0) { method = ""; }
    if (path == 0) { path = ""; }

    # GET only.
    if (streq(method, "GET") == 0) {
        sandhi_server_send_status(conn_fd, 405, "Method Not Allowed");
        sock_close(conn_fd);
        return 1;
    }

    # GET /v1/health
    if (streq(path, "/v1/health") == 1) {
        sandhi_server_send_response(conn_fd, 200, "OK",
        "text/plain", "ok", 2, 0);
        sock_close(conn_fd);
        return 1;
    }

    # GET /v1/secret/<name>
    var name = _http_extract_secret_name(path);
    if (name == 0) {
        sandhi_server_send_status(conn_fd, 404, "Not Found");
        _http_audit(http, "http_cred_404", path);
        sock_close(conn_fd);
        return 1;
    }

    if (_http_allowed(http, name) == 0) {
        sandhi_server_send_status(conn_fd, 403, "Forbidden");
        CredentialHttpProxy_set_denied_count(http,
        CredentialHttpProxy_denied_count(http) + 1);
        _http_audit(http, "http_cred_403", name);
        sock_close(conn_fd);
        return 1;
    }

    # Allowed — resolve from the in-memory proxy. We build a transient
    # SecretRef just to satisfy credential_proxy_resolve's signature; only
    # the .name field is consulted.
    var sr = secret_ref_env(name, "");
    var value = credential_proxy_resolve(
    CredentialHttpProxy_proxy_ref(http), sr);
    if (value == 0) {
        sandhi_server_send_status(conn_fd, 404, "Not Found");
        CredentialHttpProxy_set_not_found_count(http,
        CredentialHttpProxy_not_found_count(http) + 1);
        _http_audit(http, "http_cred_404", name);
        sock_close(conn_fd);
        return 1;
    }

    var vlen = strlen(value);
    sandhi_server_send_response(conn_fd, 200, "OK",
    "text/plain", value, vlen, 0);
    _http_audit(http, "http_cred_served", name);
    sock_close(conn_fd);
    return 1;
}

# Accept one pending connection (blocking) and serve it. Returns 1 if a
# request was processed, -1 on accept error. Designed for use in a
# polling loop; callers can interleave with other work.
fn credential_http_proxy_serve_one(http) {
    var fd = CredentialHttpProxy_listen_fd(http);
    if (fd < 0) { return 0 - 1; }
    var ar = sock_accept(fd);
    if (is_err_result(ar) == 1) { return 0 - 1; }
    var conn_fd = payload(ar);
    return _http_handle_conn(http, conn_fd);
}

# Serve up to `max_requests` requests, then return. Returns count actually
# served. A value of 0 for max_requests means "serve until accept fails".
fn credential_http_proxy_serve(http, max_requests) {
    var served = 0;
    while (1) {
        if (max_requests > 0) {
            if (served >= max_requests) { return served; }
        }
        var r = credential_http_proxy_serve_one(http);
        if (r < 0) { return served; }
        served = served + 1;
    }
    return served;
}

# --- quarantine.cyr ---

# kavach — file-based quarantine storage
# Ported from rust-old/src/scanning/quarantine.rs
#
# Layout:
#   <base_dir>/<id>.bin        raw artifact bytes
#   <base_dir>/<id>.meta       JSON sidecar (sandbox_id, verdict, status, ts)
#
# UUID is replaced with a monotonic counter (padded decimal) for v3.0;
# full UUIDv4 waits on a random-bytes provider.

enum QuarantineStatus {
    QUARANTINED = 0;
    APPROVED = 1;
    RELEASED = 2;
    REJECTED = 3;
}

fn quarantine_status_name(s) {
    if (s == QuarantineStatus.QUARANTINED) { return "quarantined"; }
    if (s == QuarantineStatus.APPROVED) { return "approved"; }
    if (s == QuarantineStatus.RELEASED) { return "released"; }
    if (s == QuarantineStatus.REJECTED) { return "rejected"; }
    return "unknown";
}

#derive(accessors)
struct QuarantineStorage {
    base_dir;
    next_id;
}

fn quarantine_storage_new(base_dir) {
    # Mode 0700 — only owner may enter. EEXIST is acceptable for the
    # storage dir (unlike per-entry files) since operators intentionally
    # reuse the location across runs.
    sys_mkdir(base_dir, 448);
    # Best-effort tighten in case a pre-existing dir was wider.
    sys_chmod(base_dir, 448);
    var q = alloc(16);
    QuarantineStorage_set_base_dir(q, base_dir);
    # next_id field retained for API compat; actual entry IDs are 64-bit
    # random per quarantine_store() call.
    QuarantineStorage_set_next_id(q, 1);
    return q;
}

# Build "<base_dir>/<id>.<ext>"
fn _qpath(base_dir, id, ext) {
    var id_buf[24];
    var id_len = fmt_int_buf(id, &id_buf);
    var blen = strlen(base_dir);
    var elen = strlen(ext);
    var total = checked_sum4(blen, id_len, elen, 3);
    if (total < 0) { return 0; }
    var buf = alloc_checked(total);
    if (buf == 0) { return 0; }
    var pos = 0;
    memcpy(buf + pos, base_dir, blen); pos = pos + blen;
    store8(buf + pos, 47); pos = pos + 1;
    memcpy(buf + pos, &id_buf, id_len); pos = pos + id_len;
    store8(buf + pos, 46); pos = pos + 1;
    memcpy(buf + pos, ext, elen); pos = pos + elen;
    store8(buf + pos, 0);
    return buf;
}

# Serialize metadata as simple JSON. sandbox_id is user-controllable so
# it must be JSON-escaped (ADR-005 §C2).
fn _meta_jsonl(id, sandbox_id, verdict, status) {
    var id_buf[24];
    var id_len = fmt_int_buf(id, &id_buf);
    var sid_raw = sandbox_id;
    if (sid_raw == 0) { sid_raw = ""; }
    var sid = oci_json_escape(sid_raw);
    var vn = verdict_name(verdict);
    var sn = quarantine_status_name(status);
    var ts_buf[24];
    var ts_len = fmt_int_buf(clock_epoch_secs(), &ts_buf);

    var user_lens = checked_sum4(id_len, strlen(sid), strlen(vn),
    strlen(sn) + ts_len);
    if (user_lens < 0) { return 0; }
    var cap = checked_add(user_lens, 256);
    if (cap < 0) { return 0; }
    var buf = alloc_checked(cap);
    if (buf == 0) { return 0; }
    var pos = 0;
    var p1 = "{\"id\":";
    memcpy(buf + pos, p1, strlen(p1)); pos = pos + strlen(p1);
    memcpy(buf + pos, &id_buf, id_len); pos = pos + id_len;
    var p2 = ",\"sandbox_id\":\"";
    memcpy(buf + pos, p2, strlen(p2)); pos = pos + strlen(p2);
    memcpy(buf + pos, sid, strlen(sid)); pos = pos + strlen(sid);
    var p3 = "\",\"verdict\":\"";
    memcpy(buf + pos, p3, strlen(p3)); pos = pos + strlen(p3);
    memcpy(buf + pos, vn, strlen(vn)); pos = pos + strlen(vn);
    var p4 = "\",\"status\":\"";
    memcpy(buf + pos, p4, strlen(p4)); pos = pos + strlen(p4);
    memcpy(buf + pos, sn, strlen(sn)); pos = pos + strlen(sn);
    var p5 = "\",\"quarantined_at\":";
    memcpy(buf + pos, p5, strlen(p5)); pos = pos + strlen(p5);
    memcpy(buf + pos, &ts_buf, ts_len); pos = pos + ts_len;
    store8(buf + pos, 125); pos = pos + 1;
    store8(buf + pos, 10); pos = pos + 1;
    store8(buf + pos, 0);
    return buf;
}

# Store artifact + metadata. Returns the assigned id on success, -1 on
# failure. Both files are created with O_EXCL|O_NOFOLLOW + mode 0600
# (file_write_secure) — attacker-staged symlinks at the target paths
# cannot redirect the write. Artifact writes that fail abort the op
# instead of silently returning a fake id. See ADR-005 §C4 + §H2.
fn quarantine_store(storage, artifact, artifact_len, scan_result, sandbox_id) {
    # 64-bit random entry id; unpredictable filenames defeat the
    # symlink-preseed vector on the base dir. See ADR-004 §8.
    var id = rand_u64();
    var base = QuarantineStorage_base_dir(storage);

    var art_path = _qpath(base, id, "bin");
    if (art_path == 0) { return 0 - 1; }
    # Use the Result-returning secure write so a failed quarantine — a
    # security-relevant event — records *why* (access denied vs not found vs
    # a staged symlink) in the error trail rather than an opaque -1.
    var aw = file_write_secure_r(art_path, artifact, artifact_len);
    if (is_err_result(aw) == 1) {
        kavach_err_print(KAVACH_ERR_IO_ERROR, io_error_name(err_code_of(aw)));
        return 0 - 1;
    }

    var meta_path = _qpath(base, id, "meta");
    if (meta_path == 0) { sys_unlink(art_path); return 0 - 1; }
    var meta = _meta_jsonl(id, sandbox_id,
    ScanResult_verdict(scan_result),
    QuarantineStatus.QUARANTINED);
    var mw = file_write_secure_r(meta_path, meta, strlen(meta));
    if (is_err_result(mw) == 1) {
        kavach_err_print(KAVACH_ERR_IO_ERROR, io_error_name(err_code_of(mw)));
        sys_unlink(art_path);
        return 0 - 1;
    }
    return id;
}

# Approve or reject an entry by rewriting its metadata with new status.
# Callers must re-read the artifact separately.
fn quarantine_update_status(storage, id, status) {
    var base = QuarantineStorage_base_dir(storage);
    var meta_path = _qpath(base, id, "meta");
    if (meta_path == 0) { return KAVACH_ERR_IO_ERROR; }
    # For v3.0 we just drop a new meta — readers see the latest. Parsing the
    # previous file requires a JSON parser and is deferred.
    var placeholder = _meta_jsonl(id, 0, ScanVerdict.QUARANTINE, status);
    file_write_all(meta_path, placeholder, strlen(placeholder));
    return KAVACH_ERR_OK;
}

# --- cgroup.cyr ---

# kavach — cgroups v2 resource limits
#
# Wires SandboxPolicy.{memory_limit_mb,cpu_limit_tenths,max_pids} into a
# per-sandbox cgroup under /sys/fs/cgroup/kavach-<id>/.
#
# Placement model: cgroups are created as direct children of the cgroup-v2
# root. That avoids the "no internal processes" rule (root cgroup is the
# only one allowed to host both processes AND child cgroups; non-root
# non-leaf cgroups can't host processes). Requires that the running
# system has cgroup v2 mounted at /sys/fs/cgroup (the unified hierarchy
# default on modern systemd) and that the desired controllers (memory,
# cpu, pids) are enabled in the root's cgroup.subtree_control.
#
# PID assignment uses the "shell-prepend" pattern — the user command is
# wrapped in `sh -c 'echo $$ > /sys/fs/cgroup/<scope>/cgroup.procs;
# exec <cmd>'`. The shell writes its own PID into the cgroup, then
# exec()s the user command, which inherits the cgroup placement. The
# window between fork and the write is bounded by sh's startup (a few
# syscalls); no userspace work runs in the unrestricted cgroup. This is
# the standard Linux-container-runtime pattern for unprivileged
# placement without a custom fork+pre_exec helper.
#
# Graceful degradation: if /sys/fs/cgroup isn't writable (read-only
# mount, missing controllers, unprivileged container, non-Linux), every
# entry point returns 0 / no-op and cgroup_supported() returns 0 so
# callers can decline to wrap.

var CGROUP_ROOT = "/sys/fs/cgroup";

# Whole-token match in a whitespace-separated list. cgroup.subtree_control
# is a space-separated controller list ("cpuset cpu io memory pids"), so a
# naive substring check for "cpu" spuriously matches "cpuset" — reporting the
# cpu controller present when only cpuset is. Require the token to be bounded
# by start-of-string/whitespace on both sides.
fn _cgroup_has_controller(list, name) {
    var llen = strlen(list);
    var nlen = strlen(name);
    var i = 0;
    while (i + nlen <= llen) {
        var ok = 1;
        if (i > 0) {
            var pc = load8(list + i - 1);
            if (pc != 32) { if (pc != 10) { if (pc != 9) { ok = 0; } } }
        }
        if (ok == 1) {
            var j = 0;
            while (j < nlen) {
                if (load8(list + i + j) != load8(name + j)) { ok = 0; break; }
                j = j + 1;
            }
            if (ok == 1) {
                var after = i + nlen;
                if (after < llen) {
                    var ac = load8(list + after);
                    if (ac != 32) { if (ac != 10) { if (ac != 9) { ok = 0; } } }
                }
                if (ok == 1) { return 1; }
            }
        }
        i = i + 1;
    }
    return 0;
}

# Check whether cgroup v2 is mounted and writable. Returns 1 if the root
# is writable AND the memory + cpu + pids controllers are enabled in the
# root's cgroup.subtree_control (so child cgroups can use them).
fn cgroup_supported() {
    if (sys_access(CGROUP_ROOT, 2) < 0) { return 0; }
    var buf = alloc(512);
    var n = file_read_all("/sys/fs/cgroup/cgroup.subtree_control", buf, 511);
    if (n <= 0) { return 0; }
    store8(buf + n, 0);
    if (_cgroup_has_controller(buf, "memory") == 0) { return 0; }
    if (_cgroup_has_controller(buf, "cpu") == 0) { return 0; }
    if (_cgroup_has_controller(buf, "pids") == 0) { return 0; }
    return 1;
}

# Build the cgroup path for a sandbox id (a random u64). Returns a freshly
# allocated cstr the caller owns.
fn _cgroup_path(scope_id) {
    var prefix = "/sys/fs/cgroup/kavach-";
    var prefix_len = strlen(prefix);
    var id_buf[24];
    var id_len = fmt_int_buf(scope_id, &id_buf);
    var out = alloc(prefix_len + id_len + 1);
    memcpy(out, prefix, prefix_len);
    memcpy(out + prefix_len, &id_buf, id_len);
    store8(out + prefix_len + id_len, 0);
    return out;
}

# Build a child file path under a cgroup directory. Caller owns return.
fn _cgroup_file(cgroup_path, name) {
    var clen = strlen(cgroup_path);
    var nlen = strlen(name);
    var out = alloc(clen + 1 + nlen + 1);
    memcpy(out, cgroup_path, clen);
    store8(out + clen, 47);
    memcpy(out + clen + 1, name, nlen);
    store8(out + clen + 1 + nlen, 0);
    return out;
}

# Write a numeric value to a cgroup controller file (e.g. memory.max).
# Returns 0 on success, -1 on failure (gracefully ignored by caller).
fn _cgroup_write_int(cgroup_path, name, value) {
    var fpath = _cgroup_file(cgroup_path, name);
    var buf[32];
    var len = fmt_int_buf(value, &buf);
    var r = file_write_all(fpath, &buf, len);
    if (r < 0) { return 0 - 1; }
    return 0;
}

# Write a literal string to a cgroup controller file. Used for cpu.max
# which takes "<quota_us> <period_us>" rather than a bare integer.
fn _cgroup_write_str(cgroup_path, name, value) {
    var fpath = _cgroup_file(cgroup_path, name);
    var r = file_write_all(fpath, value, strlen(value));
    if (r < 0) { return 0 - 1; }
    return 0;
}

# Build the cpu.max content for a tenths value (10 = 1.0 cores, 25 = 2.5 cores).
# cgroup v2 cpu.max takes "<quota_us> <period_us>"; we use a 100ms period and
# scale the quota accordingly: 1.0 cores = "100000 100000", 2.5 = "250000 100000".
# Returns a freshly-allocated cstr.
fn _cpu_max_string(tenths) {
    var period_us = 100000;
    var quota_us = (period_us * tenths) / 10;
    var qbuf[24];
    var qlen = fmt_int_buf(quota_us, &qbuf);
    var pbuf[24];
    var plen = fmt_int_buf(period_us, &pbuf);
    var out = alloc(qlen + 1 + plen + 1);
    memcpy(out, &qbuf, qlen);
    store8(out + qlen, 32);
    memcpy(out + qlen + 1, &pbuf, plen);
    store8(out + qlen + 1 + plen, 0);
    return out;
}

# Create the per-sandbox cgroup directory and write the limit files from
# policy. Returns the cgroup_path cstr on success, 0 on any failure
# (caller should fall back to running without cgroups).
#
# Honors: memory_limit_mb (memory.max in bytes), cpu_limit_tenths
# (cpu.max as "<quota> <period>"), max_pids (pids.max).
fn cgroup_setup(policy) {
    if (cgroup_supported() == 0) { return 0; }
    var scope = rand_u64();
    if (scope < 0) { scope = 0 - scope; }
    var path = _cgroup_path(scope);
    # sys_mkdir mode is ignored by cgroupfs (it owns the dir mode), but
    # passing 0700 keeps the intent visible.
    if (sys_mkdir(path, 448) < 0) { return 0; }

    var mem_mb = SandboxPolicy_memory_limit_mb(policy);
    if (mem_mb > 0) {
        _cgroup_write_int(path, "memory.max", mem_mb * 1048576);
    }
    var cpu_t = SandboxPolicy_cpu_limit_tenths(policy);
    if (cpu_t > 0) {
        var cpu_max = _cpu_max_string(cpu_t);
        _cgroup_write_str(path, "cpu.max", cpu_max);
    }
    var pids = SandboxPolicy_max_pids(policy);
    if (pids > 0) {
        _cgroup_write_int(path, "pids.max", pids);
    }
    return path;
}

# Tear down a cgroup created by cgroup_setup. Safe to call with 0 (no-op).
# The kernel rmdirs the cgroup only when no processes remain in it; after
# the wrapped command exits, kavach's wait() returns and the cgroup is
# empty.
fn cgroup_teardown(cgroup_path) {
    if (cgroup_path == 0) { return 0; }
    sys_rmdir(cgroup_path);
    return 0;
}

# Return 1 if `policy` has any cgroup-controlled limit set (memory, cpu,
# or pids). Backends use this to decide whether to apply the wrapping at
# all — no limits = no wrapping = no shell dependency.
fn cgroup_policy_has_limits(policy) {
    if (SandboxPolicy_memory_limit_mb(policy) > 0) { return 1; }
    if (SandboxPolicy_cpu_limit_tenths(policy) > 0) { return 1; }
    if (SandboxPolicy_max_pids(policy) > 0) { return 1; }
    return 0;
}

# Build the cgroup-join "-c" body string for the sh wrapper.
# Shape: `echo $$ > <cgroup_path>/cgroup.procs; exec "$@"`
#
# The `exec "$@"` pattern passes the user argv through positionally —
# sh does NOT re-interpret quotes / variables / metachars in the user
# command, only the literal `echo $$` line and the `exec "$@"` directive
# are under shell control. This preserves the no-shell-interpretation
# guarantee that direct execve would give, while still letting us write
# the shell's own PID into cgroup.procs before it execs the user command.
fn _cgroup_sh_body(cgroup_path) {
    var head = "echo $$ > ";
    var tail = "/cgroup.procs; exec \"$@\"";
    var hl = strlen(head);
    var cp = strlen(cgroup_path);
    var tl = strlen(tail);
    var out = alloc(hl + cp + tl + 1);
    var pos = 0;
    memcpy(out + pos, head, hl); pos = pos + hl;
    memcpy(out + pos, cgroup_path, cp); pos = pos + cp;
    memcpy(out + pos, tail, tl); pos = pos + tl;
    store8(out + pos, 0);
    return out;
}

# Wrap a user argv vec with the cgroup-join shell prelude, returning a
# new argv vec. The resulting argv shape is:
#
#   ["sh", "-c", "echo $$ > <cgroup_path>/cgroup.procs; exec \"$@\"",
#    "--", <user argv...>]
#
# `--` separates sh's own positional args ($0 = "--", $1.. = user argv).
# Per `man sh`, $0 receives whatever follows "-c <body>", so the first
# positional arg goes into $0 — passing "--" there is the standard way
# to skip the slot.
#
# The returned vec is freshly allocated; the user_argv vec is not consumed
# (callers can free / reuse it).
fn cgroup_wrap_argv(cgroup_path, user_argv) {
    var out = vec_new();
    vec_push(out, "sh");
    vec_push(out, "-c");
    vec_push(out, _cgroup_sh_body(cgroup_path));
    vec_push(out, "--");
    var i = 0;
    while (i < vec_len(user_argv)) {
        vec_push(out, vec_get(user_argv, i));
        i = i + 1;
    }
    return out;
}

# --- oci_spec.cyr ---

# kavach — OCI runtime spec (v1.0.2) generator shared by gVisor + OCI backends.
# Ported from rust-old/src/backend/oci_spec.rs.
#
# Minimal spec: pid/ipc/uts/mount namespaces always included, network
# namespace conditional on policy, resource limits applied when set, readonly
# rootfs per policy, command wrapped in `/bin/sh -c`.

var _oci_id_counter = 1;

# Container id = <prefix>-<epoch>-<counter>-<16 hex chars from /dev/urandom>.
# Randomness breaks the predictable-id vector that let a local attacker
# pre-create /tmp/<id> as a symlink. See ADR-005 §C3.
fn oci_container_id(prefix) {
    var ts_buf[24];
    var ts_len = fmt_int_buf(clock_epoch_secs(), &ts_buf);
    var ctr = _oci_id_counter;
    _oci_id_counter = _oci_id_counter + 1;
    var ctr_buf[24];
    var ctr_len = fmt_int_buf(ctr, &ctr_buf);
    var rand_id = rand_hex_id();

    var out = alloc(strlen(prefix) + 1 + ts_len + 1 + ctr_len + 1 + 17);
    var pos = 0;
    memcpy(out + pos, prefix, strlen(prefix)); pos = pos + strlen(prefix);
    store8(out + pos, 45); pos = pos + 1;
    memcpy(out + pos, &ts_buf, ts_len); pos = pos + ts_len;
    store8(out + pos, 45); pos = pos + 1;
    memcpy(out + pos, &ctr_buf, ctr_len); pos = pos + ctr_len;
    store8(out + pos, 45); pos = pos + 1;
    memcpy(out + pos, rand_id, strlen(rand_id)); pos = pos + strlen(rand_id);
    store8(out + pos, 0);
    return out;
}

# RFC 8259 §7 compliant JSON string escape. Worst-case expansion is 6×
# (e.g. 0x01 → \u0001). Returns allocated null-terminated cstr.
# Protects the audit log + OCI configs against log forgery and JSON
# injection via control chars / ANSI escape sequences (ADR-005 §C2).
fn oci_json_escape(s) {
    var n = strlen(s);
    # Overflow guard: reject absurd inputs early (see util.cyr checked_mul).
    if (n > 1048576) {
        var tr = alloc(4);
        memcpy(tr, "...", 4);
        return tr;
    }
    var dst = alloc(n * 6 + 1);
    var di = 0;
    var hex = "0123456789abcdef";
    var i = 0;
    while (i < n) {
        var c = load8(s + i);
        if (c == 34) {
            store8(dst + di, 92); di = di + 1;
            store8(dst + di, 34); di = di + 1;
        }
        elif (c == 92) {
            store8(dst + di, 92); di = di + 1;
            store8(dst + di, 92); di = di + 1;
        }
        elif (c == 10) {
            store8(dst + di, 92); di = di + 1;
            store8(dst + di, 110); di = di + 1;
        }
        elif (c == 13) {
            store8(dst + di, 92); di = di + 1;
            store8(dst + di, 114); di = di + 1;
        }
        elif (c == 9) {
            store8(dst + di, 92); di = di + 1;
            store8(dst + di, 116); di = di + 1;
        }
        elif (c == 8) {
            store8(dst + di, 92); di = di + 1;
            store8(dst + di, 98); di = di + 1;
        }
        elif (c == 12) {
            store8(dst + di, 92); di = di + 1;
            store8(dst + di, 102); di = di + 1;
        }
        elif (c < 32) {
            # Generic control char: \u00XX
            store8(dst + di, 92); di = di + 1;
            store8(dst + di, 117); di = di + 1;
            store8(dst + di, 48); di = di + 1;
            store8(dst + di, 48); di = di + 1;
            store8(dst + di, load8(hex + ((c >> 4) & 15))); di = di + 1;
            store8(dst + di, load8(hex + (c & 15))); di = di + 1;
        }
        else {
            store8(dst + di, c); di = di + 1;
        }
        i = i + 1;
    }
    store8(dst + di, 0);
    return dst;
}

fn oci_network_mode(policy) {
    if (SandboxPolicy_network_enabled(policy) == 1) { return "host"; }
    return "none";
}

# Render OCI runtime config.json v1.0.2. Returns allocated cstr.
fn oci_generate_spec(sandbox, command) {
    var config = Sandbox_config(sandbox);
    var policy = SandboxConfig_policy(config);
    var cmd_escaped = oci_json_escape(command);

    var mem = SandboxPolicy_memory_limit_mb(policy);
    var pids = SandboxPolicy_max_pids(policy);
    var readonly = "false";
    if (SandboxPolicy_read_only_rootfs(policy) == 1) { readonly = "true"; }

    var resources = "";
    if (mem > 0) {
        var mem_buf[32];
        var mem_bytes = mem * 1048576;
        var mem_len = fmt_int_buf(mem_bytes, &mem_buf);
        # Render the pids int up front so the buffer can be sized to fit it.
        # The fixed JSON fragments are p1(32) + optional p2(18) + p3(2) + NUL;
        # 64 covers them with margin. The old `alloc(64 + mem_len)` ignored
        # pids_len entirely and overflowed for max_pids > ~10 digits (C1).
        var pids_buf[24];
        var pids_len = 0;
        if (pids > 0) { pids_len = fmt_int_buf(pids, &pids_buf); }
        var rcap = checked_sum4(64, mem_len, pids_len, 0);
        if (rcap < 0) { return 0; }
        var r = alloc_checked(rcap);
        if (r == 0) { return 0; }
        var rpos = 0;
        var p1 = ",\"resources\":{\"memory\":{\"limit\":";
        memcpy(r + rpos, p1, strlen(p1)); rpos = rpos + strlen(p1);
        memcpy(r + rpos, &mem_buf, mem_len); rpos = rpos + mem_len;
        if (pids > 0) {
            var p2 = "},\"pids\":{\"limit\":";
            memcpy(r + rpos, p2, strlen(p2)); rpos = rpos + strlen(p2);
            memcpy(r + rpos, &pids_buf, pids_len); rpos = rpos + pids_len;
        }
        var p3 = "}}";
        memcpy(r + rpos, p3, strlen(p3)); rpos = rpos + strlen(p3);
        store8(r + rpos, 0);
        resources = r;
    }

    var netns = "{\"type\":\"network\"},";
    if (SandboxPolicy_network_enabled(policy) == 1) { netns = ""; }

    var cap = checked_add(strlen(cmd_escaped), strlen(resources));
    if (cap < 0) { return 0; }
    cap = checked_add(cap, 2048);
    if (cap < 0) { return 0; }
    var buf = alloc_checked(cap);
    if (buf == 0) { return 0; }
    var pos = 0;
    var head = "{\"ociVersion\":\"1.0.2\",\"process\":{\"terminal\":false,\"args\":[\"/bin/sh\",\"-c\",\"";
    memcpy(buf + pos, head, strlen(head)); pos = pos + strlen(head);
    memcpy(buf + pos, cmd_escaped, strlen(cmd_escaped)); pos = pos + strlen(cmd_escaped);
    var mid1a = "\"],\"env\":[\"PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\",\"TERM=xterm\"],";
    var mid1b = "\"cwd\":\"/\"},\"root\":{\"path\":\"rootfs\",\"readonly\":";
    memcpy(buf + pos, mid1a, strlen(mid1a)); pos = pos + strlen(mid1a);
    memcpy(buf + pos, mid1b, strlen(mid1b)); pos = pos + strlen(mid1b);
    memcpy(buf + pos, readonly, strlen(readonly)); pos = pos + strlen(readonly);
    var mid2 = "},\"linux\":{\"namespaces\":[";
    memcpy(buf + pos, mid2, strlen(mid2)); pos = pos + strlen(mid2);
    memcpy(buf + pos, netns, strlen(netns)); pos = pos + strlen(netns);
    var ns_rest = "{\"type\":\"pid\"},{\"type\":\"ipc\"},{\"type\":\"uts\"},{\"type\":\"mount\"}]";
    memcpy(buf + pos, ns_rest, strlen(ns_rest)); pos = pos + strlen(ns_rest);
    memcpy(buf + pos, resources, strlen(resources)); pos = pos + strlen(resources);
    var tail = "}}";
    memcpy(buf + pos, tail, strlen(tail)); pos = pos + strlen(tail);
    store8(buf + pos, 0);
    return buf;
}

# Create bundle dir under /tmp with an empty rootfs and a config.json.
# Mode 0700 on both dirs; file_write_secure opens with O_CREAT|O_EXCL|
# O_NOFOLLOW, mode 0600. Any mkdir failure aborts — no "silently clobber
# an attacker-staged symlink" path. See ADR-005 §C3 + §C4.
# Returns the bundle path, or 0 on failure.
fn oci_prepare_bundle(container_id, sandbox, command) {
    var bundle = alloc(32 + strlen(container_id));
    var pos = 0;
    var prefix = "/tmp/";
    memcpy(bundle + pos, prefix, strlen(prefix)); pos = pos + strlen(prefix);
    memcpy(bundle + pos, container_id, strlen(container_id)); pos = pos + strlen(container_id);
    store8(bundle + pos, 0);
    # Mode 0700 = 448. EEXIST aborts (random id, so collision is attack-
    # signal, not natural occurrence).
    if (sys_mkdir(bundle, 448) < 0) { return 0; }

    var rootfs = alloc(strlen(bundle) + 8);
    memcpy(rootfs, bundle, strlen(bundle));
    memcpy(rootfs + strlen(bundle), "/rootfs", 8);
    if (sys_mkdir(rootfs, 448) < 0) { sys_rmdir(bundle); return 0; }

    var cfg_path = alloc(strlen(bundle) + 16);
    memcpy(cfg_path, bundle, strlen(bundle));
    memcpy(cfg_path + strlen(bundle), "/config.json", 13);

    var spec = oci_generate_spec(sandbox, command);
    if (spec == 0) {
        sys_rmdir(rootfs);
        sys_rmdir(bundle);
        return 0;
    }
    var r = file_write_secure(cfg_path, spec, strlen(spec));
    if (r < 0) {
        sys_rmdir(rootfs);
        sys_rmdir(bundle);
        return 0;
    }
    return bundle;
}

# Best-effort cleanup: unlink config.json, rmdir rootfs/, rmdir bundle/.
fn oci_cleanup_bundle(bundle) {
    var cfg_path = alloc(strlen(bundle) + 16);
    memcpy(cfg_path, bundle, strlen(bundle));
    memcpy(cfg_path + strlen(bundle), "/config.json", 13);
    sys_unlink(cfg_path);

    var rootfs = alloc(strlen(bundle) + 8);
    memcpy(rootfs, bundle, strlen(bundle));
    memcpy(rootfs + strlen(bundle), "/rootfs", 8);
    sys_rmdir(rootfs);

    sys_rmdir(bundle);
    return 0;
}

# --- backend_dispatch.cyr ---

# kavach — backend dispatch table
# Each backend registers function pointers for exec/health/destroy.
# Lookup is O(1) via Backend enum index.

# Slot layout (per backend, 32 bytes):
#   0: exec_fn(sandbox, command) -> ExecResult*
#   8: health_fn(sandbox) -> 1/0
#  16: destroy_fn(sandbox) -> 0 ok, nonzero err
#  24: reserved
var _backend_table[320];
var BACKEND_SLOT_SIZE = 32;

fn _backend_slot(backend_id) {
    return &_backend_table + backend_id * BACKEND_SLOT_SIZE;
}

# Bounds-checked fn-pointer fetch. `backend_id` flows from semi-trusted
# config (backend_parse can yield -1); an out-of-range id would otherwise
# index _backend_table[320] out of bounds and load a wild function pointer.
# Returns 0 (== "no implementation") for any id outside [0, BACKEND_COUNT).
fn _backend_fp(backend_id, offset) {
    if (backend_id < 0) { return 0; }
    if (backend_id >= BACKEND_COUNT) { return 0; }
    return load64(_backend_slot(backend_id) + offset);
}

fn backend_register_exec(backend_id, fp) {
    store64(_backend_slot(backend_id) + 0, fp);
    return 0;
}

fn backend_register_health(backend_id, fp) {
    store64(_backend_slot(backend_id) + 8, fp);
    return 0;
}

fn backend_register_destroy(backend_id, fp) {
    store64(_backend_slot(backend_id) + 16, fp);
    return 0;
}

# Dispatch entry points. Callers pass sandbox pointer (contains config).
# Returns 0 on missing implementation, after logging an error.
fn backend_dispatch_exec(sandbox, command) {
    var bid = SandboxConfig_backend(Sandbox_config(sandbox));
    var fp = _backend_fp(bid, 0);
    if (fp == 0) {
        kavach_err_print(KAVACH_ERR_BACKEND_UNAVAILABLE, os_backend_name(bid));
        return 0;
    }
    return fncall2(fp, sandbox, command);
}

fn backend_dispatch_health(sandbox) {
    var bid = SandboxConfig_backend(Sandbox_config(sandbox));
    var fp = _backend_fp(bid, 8);
    if (fp == 0) { return 0; }
    return fncall1(fp, sandbox);
}

fn backend_dispatch_destroy(sandbox) {
    var bid = SandboxConfig_backend(Sandbox_config(sandbox));
    var fp = _backend_fp(bid, 16);
    if (fp == 0) { return 0; }
    return fncall1(fp, sandbox);
}

fn backend_is_registered(backend_id) {
    if (_backend_fp(backend_id, 0) != 0) { return 1; }
    return 0;
}

# --- backend_noop.cyr ---

# kavach — Noop backend (no isolation, testing only)
# Matches Rust's NoopBackend: returns a clean ExecResult with exit_code=0.

fn noop_exec(sandbox, command) {
    var r = exec_result_new();
    ExecResult_set_exit_code(r, 0);
    ExecResult_set_stdout(r, "");
    ExecResult_set_stderr(r, "");
    ExecResult_set_duration_ms(r, 0);
    ExecResult_set_timed_out(r, 0);
    return r;
}

fn noop_health(sandbox) { return 1; }
fn noop_destroy(sandbox) { return 0; }

fn backend_noop_register() {
    backend_register_exec(Backend.NOOP, &noop_exec);
    backend_register_health(Backend.NOOP, &noop_health);
    backend_register_destroy(Backend.NOOP, &noop_destroy);
    return 0;
}

# --- backend_process.cyr ---

# kavach — Process backend (minimum-viable fork+exec+wait via lib/process.cyr)
# Ported from rust-old/src/backend/process/mod.rs
#
# This is the v3.0 skeleton: fork+exec+wait + runtime-guard precheck.
# Seccomp/Landlock/cgroups/namespaces are separate modules that will hook
# into pre_exec once their syscall wrappers land.

var PROCESS_MAX_OUTPUT = 1048576;

# Whitespace-split command into a vec of cstrs. No quote handling —
# callers with quoted args should build the vec themselves and bypass.
fn _split_command(cmdline) {
    var args = vec_new();
    var n = strlen(cmdline);
    var i = 0;
    while (i < n) {
        while (i < n) {
            var c = load8(cmdline + i);
            if (c != 32) { if (c != 9) { break; } }
            i = i + 1;
        }
        if (i >= n) { break; }
        var start = i;
        while (i < n) {
            var c = load8(cmdline + i);
            if (c == 32) { break; }
            if (c == 9) { break; }
            i = i + 1;
        }
        var len = i - start;
        var tok = alloc(len + 1);
        memcpy(tok, cmdline + start, len);
        store8(tok + len, 0);
        vec_push(args, tok);
    }
    return args;
}

fn process_exec(sandbox, command) {
    var start_ns = mono_now_ns();

    # Reject control chars before tokenizing. A NUL/CR/newline in `command`
    # would otherwise split into multiple argv tokens and smuggle extra
    # arguments past the runtime guard. Tab is allowed as a whitespace
    # separator; newline/CR/NUL/ESC are not. See ADR-005 §H3.
    if (is_safe_argument(command) == 0) {
        var er = exec_result_new();
        ExecResult_set_exit_code(er, 126);
        ExecResult_set_stderr(er, "command contains illegal control chars");
        return er;
    }

    # Runtime-guard precheck — policy-violating commands never hit fork.
    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    var args = _split_command(command);
    if (vec_len(args) == 0) {
        return backend_error_result("empty command");
    }

    # Cgroup wrap: if the sandbox's policy carries any resource limit
    # (memory.max / cpu.max / pids.max), create a per-sandbox cgroup,
    # wrap the user argv in the cgroup-join sh prelude, and tear the
    # cgroup down after exec. Graceful fall-through when cgroup v2 is
    # unavailable: setup returns 0 and we run unwrapped.
    var cgroup_path = 0;
    var cfg = Sandbox_config(sandbox);
    if (cfg != 0) {
        var policy = SandboxConfig_policy(cfg);
        if (policy != 0) {
            if (cgroup_policy_has_limits(policy) == 1) {
                cgroup_path = cgroup_setup(policy);
                if (cgroup_path != 0) {
                    args = cgroup_wrap_argv(cgroup_path, args);
                }
            }
        }
    }

    var buf = alloc(PROCESS_MAX_OUTPUT);
    var n = exec_capture(args, buf, PROCESS_MAX_OUTPUT);
    cgroup_teardown(cgroup_path);
    var end_ns = mono_now_ns();

    return backend_capture_finish(buf, n, PROCESS_MAX_OUTPUT, "exec failed", start_ns, end_ns);
}

fn process_health(sandbox) { return 1; }
fn process_destroy(sandbox) { return 0; }

fn backend_process_register() {
    backend_register_exec(Backend.PROCESS, &process_exec);
    backend_register_health(Backend.PROCESS, &process_health);
    backend_register_destroy(Backend.PROCESS, &process_destroy);
    return 0;
}

# --- persistent.cyr ---

# kavach — persistent guest execution (live stdin / stdout)
#
# The one-shot PROCESS backend (backend_process.cyr) runs a guest to completion
# and captures its stdout. This module adds a PERSISTENT guest: fork+exec the
# command with a live stdin pipe (the parent writes) and a stdout pipe (the
# parent reads), so a host can STREAM input to a running guest and read its
# output over time. This is the execution primitive the swallow stage's M3
# protocol shim delivers events over (mehman → aethersafha).
#
# SECURITY: the same pre-exec command safety the one-shot path enforces applies
# here — `is_safe_argument` (reject control chars) + `check_command` (runtime
# guard) before the fork. What does NOT apply is the externalization gate: it
# scans a full captured output buffer, which is meaningless for an open-ended
# stream, so a persistent guest's stdout is NOT gate-scanned. Persistent
# execution is for trusted-shape guests behind the swallow capability contract;
# raw streaming is the deliberate trade for interactivity.
#
# LIMITATIONS: (1) writing to a guest that already exited on its own raises
# SIGPIPE (no SIG_IGN wrapper in the stdlib yet). `persistent_send` guards on the
# `alive` flag, so write-after-terminate is safe; stop sending once the guest is
# known dead. (2) `persistent_read` is blocking (a non-blocking variant via
# O_NONBLOCK/pipe2 is the follow-on for a compositor frame loop).

# Fields (all i64):
#   pid        — the child pid
#   stdin_fd   — parent's write end of the guest's stdin
#   stdout_fd  — parent's read end of the guest's stdout
#   alive      — 1 = running, 0 = terminated + reaped
#derive(accessors)
struct PersistentGuest {
    pid;
    stdin_fd;
    stdout_fd;
    alive;
}
var PERSISTENT_GUEST_SIZE = 32;

# Spawn `command` as a persistent guest with live stdin/stdout pipes. Runs the
# pre-exec safety checks, then fork + dup2 + execve (mirrors backend_process's
# argv build + the exec_capture pipe pattern, with a second pipe for stdin).
# -> PersistentGuest* (0 on an unsafe/blocked command, empty split, or fork/OOM).
fn persistent_spawn(command) {
    if (is_safe_argument(command) == 0) { return 0; }
    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) { return 0; }
    var args = _split_command(command);
    var argc = vec_len(args);
    if (argc == 0) { return 0; }

    var argv = alloc((argc + 1) * 8);
    var i = 0;
    while (i < argc) { store64(argv + i * 8, vec_get(args, i)); i = i + 1; }
    store64(argv + argc * 8, 0);
    var envp = alloc(8);
    store64(envp, 0);

    # stdin pipe: parent writes in_wfd -> child reads in_rfd (its fd 0)
    var inpipe[16];
    sys_pipe(&inpipe);
    var in_rfd = load32(&inpipe);
    var in_wfd = load32(&inpipe + 4);
    # stdout pipe: child writes out_wfd (its fd 1) -> parent reads out_rfd
    var outpipe[16];
    sys_pipe(&outpipe);
    var out_rfd = load32(&outpipe);
    var out_wfd = load32(&outpipe + 4);

    var pid = sys_fork();
    if (pid < 0) {
        sys_close(in_rfd); sys_close(in_wfd);
        sys_close(out_rfd); sys_close(out_wfd);
        return 0;
    }
    if (pid == 0) {
        # child: wire the pipe ends to stdin/stdout, /dev/null to stderr
        sys_close(in_wfd);
        sys_close(out_rfd);
        sys_dup2(in_rfd, 0);
        sys_close(in_rfd);
        sys_dup2(out_wfd, 1);
        sys_close(out_wfd);
        var devnull = sys_open("/dev/null", 1, 0);   # 1 = O_WRONLY (mirrors exec_capture)
        if (devnull >= 0) { sys_dup2(devnull, 2); sys_close(devnull); }
        sys_execve(vec_get(args, 0), argv, envp);
        sys_exit(127);
    }
    # parent: keep the write-stdin + read-stdout ends
    sys_close(in_rfd);
    sys_close(out_wfd);
    var g = alloc(PERSISTENT_GUEST_SIZE);
    if (g == 0) { sys_close(in_wfd); sys_close(out_rfd); return 0; }
    PersistentGuest_set_pid(g, pid);
    PersistentGuest_set_stdin_fd(g, in_wfd);
    PersistentGuest_set_stdout_fd(g, out_rfd);
    PersistentGuest_set_alive(g, 1);
    return g;
}

# Write `len` bytes to the guest's stdin. -> bytes written, or -1 if the guest is
# null / already terminated.
fn persistent_send(g, bytes, len): i64 {
    if (g == 0) { return 0 - 1; }
    if (PersistentGuest_alive(g) == 0) { return 0 - 1; }
    return sys_write(PersistentGuest_stdin_fd(g), bytes, len);
}

# Read up to `len` bytes of the guest's stdout into `buf` (blocking). -> bytes
# read (0 at EOF), or -1 for a null / terminated guest.
fn persistent_read(g, buf, len): i64 {
    if (g == 0) { return 0 - 1; }
    if (PersistentGuest_alive(g) == 0) { return 0 - 1; }
    return sys_read(PersistentGuest_stdout_fd(g), buf, len);
}

fn persistent_pid(g): i64   { if (g == 0) { return 0 - 1; } return PersistentGuest_pid(g); }
fn persistent_alive(g): i64 { if (g == 0) { return 0; } return PersistentGuest_alive(g); }

# Terminate + reap the guest: close its stdin (EOF), SIGKILL, waitpid (no zombie),
# close its stdout. Idempotent. -> 0 (or -1 for a null guest).
fn persistent_terminate(g): i64 {
    if (g == 0) { return 0 - 1; }
    if (PersistentGuest_alive(g) == 1) {
        sys_close(PersistentGuest_stdin_fd(g));
        sys_kill(PersistentGuest_pid(g), 9);   # 9 = SIGKILL (guaranteed reap)
        var stbuf[1];
        sys_waitpid(PersistentGuest_pid(g), &stbuf, 0);
        sys_close(PersistentGuest_stdout_fd(g));
        PersistentGuest_set_alive(g, 0);
    }
    return 0;
}

# --- backend_gvisor.cyr ---

# kavach — gVisor (runsc) backend
# Ported from rust-old/src/backend/gvisor/mod.rs
#
# OCI spec generation is shared with the OCI backend via src/oci_spec.cyr.
# This module handles only the runsc-specific orchestration: locate the
# binary, run with --network <mode>, clean up the container on exit.

fn _gvisor_runsc_path() {
    if (path_exists("/usr/local/bin/runsc") == 1) { return "/usr/local/bin/runsc"; }
    if (path_exists("/usr/bin/runsc") == 1) { return "/usr/bin/runsc"; }
    return 0;
}

fn _gvisor_run(runsc, bundle, container_id, network, out_buf, out_cap) {
    var args = vec_new();
    vec_push(args, runsc);
    vec_push(args, "--network");
    vec_push(args, network);
    vec_push(args, "run");
    vec_push(args, "--bundle");
    vec_push(args, bundle);
    vec_push(args, container_id);
    return exec_capture(args, out_buf, out_cap);
}

fn _gvisor_delete(runsc, container_id) {
    var args = vec_new();
    vec_push(args, runsc);
    vec_push(args, "delete");
    vec_push(args, "--force");
    vec_push(args, container_id);
    var sink[32];
    exec_capture(args, &sink, 32);
    return 0;
}

fn gvisor_exec(sandbox, command) {
    var start_ns = mono_now_ns();
    var runsc = _gvisor_runsc_path();
    if (runsc == 0) {
        return backend_error_result("runsc not found in PATH");
    }

    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    var container_id = oci_container_id("kavach-gvisor");
    var bundle = oci_prepare_bundle(container_id, sandbox, command);
    if (bundle == 0) {
        return backend_error_result("failed to prepare OCI bundle");
    }

    var policy = SandboxConfig_policy(Sandbox_config(sandbox));
    var network = oci_network_mode(policy);

    var out_cap = 1048576;
    var out_buf = alloc(out_cap);
    var n = _gvisor_run(runsc, bundle, container_id, network, out_buf, out_cap);
    var end_ns = mono_now_ns();

    _gvisor_delete(runsc, container_id);
    oci_cleanup_bundle(bundle);

    return backend_capture_finish(out_buf, n, out_cap, "runsc run failed", start_ns, end_ns);
}

fn gvisor_health(sandbox) {
    if (_gvisor_runsc_path() == 0) { return 0; }
    return 1;
}

fn gvisor_destroy(sandbox) { return 0; }

fn backend_gvisor_register() {
    backend_register_exec(Backend.GVISOR, &gvisor_exec);
    backend_register_health(Backend.GVISOR, &gvisor_health);
    backend_register_destroy(Backend.GVISOR, &gvisor_destroy);
    return 0;
}

# --- backend_oci.cyr ---

# kavach — OCI (runc/crun) backend
# Ported from rust-old/src/backend/oci/mod.rs
#
# Shell-out to a standard OCI runtime: `runc run` (or `crun run`) against an
# OCI bundle generated by src/oci_spec.cyr. Picks the first available runtime
# in PATH; falls back across /usr/local/bin, /usr/bin, /bin.
#
# Forward direction: stiva will eventually provide a first-party container
# runtime. When its Cyrius port lands, `_oci_runtime_path()` can prepend
# the stiva binary; the rest of this backend is already bundle-driven via
# src/oci_spec.cyr and requires no API change.

# Discover a usable OCI runtime. Returns path cstr, or 0 if none.
fn _oci_runtime_path() {
    if (path_exists("/usr/local/bin/runc") == 1) { return "/usr/local/bin/runc"; }
    if (path_exists("/usr/bin/runc") == 1) { return "/usr/bin/runc"; }
    if (path_exists("/usr/local/bin/crun") == 1) { return "/usr/local/bin/crun"; }
    if (path_exists("/usr/bin/crun") == 1) { return "/usr/bin/crun"; }
    return 0;
}

fn _oci_run(runtime, bundle, container_id, out_buf, out_cap) {
    var args = vec_new();
    vec_push(args, runtime);
    vec_push(args, "run");
    vec_push(args, "--bundle");
    vec_push(args, bundle);
    vec_push(args, container_id);
    return exec_capture(args, out_buf, out_cap);
}

fn _oci_delete(runtime, container_id) {
    var args = vec_new();
    vec_push(args, runtime);
    vec_push(args, "delete");
    vec_push(args, "--force");
    vec_push(args, container_id);
    var sink[32];
    exec_capture(args, &sink, 32);
    return 0;
}

fn oci_exec(sandbox, command) {
    var start_ns = mono_now_ns();
    var runtime = _oci_runtime_path();
    if (runtime == 0) {
        return backend_error_result("no OCI runtime (runc/crun) found in PATH");
    }

    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    var container_id = oci_container_id("kavach-oci");
    var bundle = oci_prepare_bundle(container_id, sandbox, command);
    if (bundle == 0) {
        return backend_error_result("failed to prepare OCI bundle");
    }

    var out_cap = 1048576;
    var out_buf = alloc(out_cap);
    var n = _oci_run(runtime, bundle, container_id, out_buf, out_cap);
    var end_ns = mono_now_ns();

    _oci_delete(runtime, container_id);
    oci_cleanup_bundle(bundle);

    return backend_capture_finish(out_buf, n, out_cap, "OCI runtime run failed", start_ns, end_ns);
}

fn oci_health(sandbox) {
    if (_oci_runtime_path() == 0) { return 0; }
    return 1;
}

fn oci_destroy(sandbox) { return 0; }

fn backend_oci_register() {
    backend_register_exec(Backend.OCI, &oci_exec);
    backend_register_health(Backend.OCI, &oci_health);
    backend_register_destroy(Backend.OCI, &oci_destroy);
    return 0;
}

# --- backend_wasm.cyr ---

# kavach — WASM (wasmtime) backend
# Ported from rust-old/src/backend/wasm/mod.rs
#
# The Rust version embedded wasmtime via Cargo crates. Cyrius v3.0 shells
# out to the `wasmtime` CLI binary instead, which accepts the same
# --fuel / --dir / --env / --max-memory-size flags. Module format is still
# `command = path to .wasm file`.
#
# Deferred: WAT inline modules, custom linker hooks. Both require embedding
# a real WASM runtime — v3.0 or whenever mabda/yukti exposes one.

# Look for wasmtime on PATH. Returns path cstr, or 0 if none.
fn _wasm_binary_path() {
    if (path_exists("/usr/local/bin/wasmtime") == 1) { return "/usr/local/bin/wasmtime"; }
    if (path_exists("/usr/bin/wasmtime") == 1) { return "/usr/bin/wasmtime"; }
    # Fall back to a cargo-installed wasmtime under $HOME/.cargo/bin. getenv
    # ships in the stdlib now (reads /proc/self/environ + allocates) — call it
    # here at config time only, never post-fork (it is not async-signal-safe).
    var home = getenv("HOME");
    if (home != 0) {
        var suffix = "/.cargo/bin/wasmtime";
        var hlen = strlen(home);
        var slen = strlen(suffix);
        var path = alloc_checked(checked_sum4(hlen, slen, 1, 0));
        if (path != 0) {
            memcpy(path, home, hlen);
            memcpy(path + hlen, suffix, slen);
            store8(path + hlen + slen, 0);
            if (path_exists(path) == 1) { return path; }
        }
    }
    return 0;
}

# Fuel calibration from timeout_ms. Matches Rust:
#   fuel ≈ timeout_ms * 1_000_000 (≈ 1B instr/sec assumption)
fn _wasm_fuel_from_timeout(timeout_ms) {
    return timeout_ms * 1000000;
}

# Append "--dir <path>" pair for each landlock rule. Writes into argv vec.
# Cyrius stdlib doesn't yet expose landlock_rules as a vec — our SandboxPolicy
# only carries a cached length — so for v3.0 we preopen the configured
# `workdir` (if any) read-only, matching the most common caller pattern.
fn _wasm_append_preopens(args, sandbox) {
    var cfg = Sandbox_config(sandbox);
    var wd = SandboxConfig_workdir(cfg);
    if (wd != 0) {
        if (strlen(wd) > 0) {
            vec_push(args, "--dir");
            vec_push(args, wd);
        }
    }
    return 0;
}

# Append resource-limit flags from policy.
fn _wasm_append_limits(args, policy, timeout_ms) {
    # Memory limit: --max-memory-size <bytes>
    var mem = SandboxPolicy_memory_limit_mb(policy);
    if (mem > 0) {
        var mem_buf[32];
        var mem_bytes = mem * 1048576;
        var mem_len = fmt_int_buf(mem_bytes, &mem_buf);
        var mem_str = alloc(mem_len + 1);
        memcpy(mem_str, &mem_buf, mem_len);
        store8(mem_str + mem_len, 0);
        vec_push(args, "--max-memory-size");
        vec_push(args, mem_str);
    }

    # Fuel metering: --fuel <N>
    var fuel = _wasm_fuel_from_timeout(timeout_ms);
    if (fuel > 0) {
        var f_buf[32];
        var f_len = fmt_int_buf(fuel, &f_buf);
        var f_str = alloc(f_len + 1);
        memcpy(f_str, &f_buf, f_len);
        store8(f_str + f_len, 0);
        vec_push(args, "--fuel");
        vec_push(args, f_str);
    }
    return 0;
}

# Trim leading/trailing ASCII whitespace. Returns allocated cstr.
fn _wasm_trim(s) {
    var n = strlen(s);
    var start = 0;
    while (start < n) {
        var c = load8(s + start);
        if (c != 32) { if (c != 9) { if (c != 10) { if (c != 13) { break; } } } }
        start = start + 1;
    }
    var end = n;
    while (end > start) {
        var c = load8(s + end - 1);
        if (c != 32) { if (c != 9) { if (c != 10) { if (c != 13) { break; } } } }
        end = end - 1;
    }
    var len = end - start;
    var out = alloc(len + 1);
    memcpy(out, s + start, len);
    store8(out + len, 0);
    return out;
}

fn wasm_exec(sandbox, command) {
    var start_ns = mono_now_ns();
    var wasmtime = _wasm_binary_path();
    if (wasmtime == 0) {
        return backend_error_result("wasmtime not found in PATH");
    }

    # The command is expected to be a .wasm file path.
    var wasm_path = _wasm_trim(command);
    if (strlen(wasm_path) == 0) {
        return backend_error_result("WASM backend requires a .wasm file path as the command");
    }
    if (path_exists(wasm_path) == 0) {
        return backend_error_result("WASM module file not found");
    }

    # Runtime-guard precheck is still useful — a .wasm path containing
    # shell metacharacters (e.g., "/tmp/foo.wasm; cat /etc/shadow") would
    # only be sent as a literal argv element, but the sandbox caller still
    # deserves the warning.
    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    var cfg = Sandbox_config(sandbox);
    var policy = SandboxConfig_policy(cfg);
    var timeout = SandboxConfig_timeout_ms(cfg);

    var args = vec_new();
    vec_push(args, wasmtime);
    vec_push(args, "run");
    _wasm_append_limits(args, policy, timeout);
    _wasm_append_preopens(args, sandbox);
    # `--` separator guards against .wasm paths starting with '-'.
    vec_push(args, "--");
    vec_push(args, wasm_path);

    var out_cap = 1048576;
    var out_buf = alloc(out_cap);
    var n = exec_capture(args, out_buf, out_cap);
    var end_ns = mono_now_ns();

    return backend_capture_finish(out_buf, n, out_cap, "wasmtime run failed", start_ns, end_ns);
}

fn wasm_health(sandbox) {
    if (_wasm_binary_path() == 0) { return 0; }
    return 1;
}

fn wasm_destroy(sandbox) { return 0; }

fn backend_wasm_register() {
    backend_register_exec(Backend.WASM, &wasm_exec);
    backend_register_health(Backend.WASM, &wasm_health);
    backend_register_destroy(Backend.WASM, &wasm_destroy);
    return 0;
}

# --- backend_sy_agnos.cyr ---

# kavach — SyAgnos backend (hardened AGNOS OS image as container sandbox)
# Ported from rust-old/src/backend/sy_agnos/mod.rs
#
# Shells out to docker/podman running the `ghcr.io/maccracken/sy-agnos`
# image. The image carries its own baked hardening (immutable squashfs
# rootfs, seccomp-BPF, default-deny nftables); this backend translates
# SandboxPolicy into the runtime flags (--memory, --cpus, --pids-limit,
# --read-only, --network none|bridge) and optionally runs the Phylax
# scanner on output.
#
# Deferred vs Rust:
#   - Image manager (pull/build/list) — skipped for v3.0
#   - Tier detection from /etc/sy-agnos-release — needs JSON parse
#   - AttestationReport + PCR verify — wait for sigil TPM helpers

var SY_AGNOS_DEFAULT_IMAGE = "ghcr.io/maccracken/agnos:latest";

enum SyAgnosTier {
    MINIMAL = 0;
    DMVERITY = 1;
    TPM_MEASURED = 2;
}

fn sy_agnos_tier_name(t) {
    if (t == SyAgnosTier.MINIMAL) { return "minimal"; }
    if (t == SyAgnosTier.DMVERITY) { return "dmverity"; }
    if (t == SyAgnosTier.TPM_MEASURED) { return "tpm_measured"; }
    return "unknown";
}

fn sy_agnos_tier_strength(t) {
    if (t == SyAgnosTier.MINIMAL) { return 80; }
    if (t == SyAgnosTier.DMVERITY) { return 85; }
    if (t == SyAgnosTier.TPM_MEASURED) { return 88; }
    return 80;
}

fn sy_agnos_tier_parse(s) {
    if (streq(s, "tpm_measured") == 1) { return SyAgnosTier.TPM_MEASURED; }
    if (streq(s, "dmverity") == 1) { return SyAgnosTier.DMVERITY; }
    return SyAgnosTier.MINIMAL;
}

# ---- Runtime detection ---------------------------------------------------

fn _sy_agnos_runtime() {
    if (path_exists("/usr/local/bin/docker") == 1) { return "/usr/local/bin/docker"; }
    if (path_exists("/usr/bin/docker") == 1) { return "/usr/bin/docker"; }
    if (path_exists("/usr/local/bin/podman") == 1) { return "/usr/local/bin/podman"; }
    if (path_exists("/usr/bin/podman") == 1) { return "/usr/bin/podman"; }
    return 0;
}

# ---- Phylax scanner (sy-agnos-specific patterns) -------------------------
# Extends the normal secrets scanner with container-escape indicators.
# Each hit is tagged with one of: VERITY / NFTABLES_BYPASS /
# NAMESPACE_ESCAPE / MOUNT_ESCAPE.

fn _phylax_emit(text, lower, result, category, matched) {
    return code_emit(text, lower, result, Severity.CRITICAL, category,
    "Phylax indicator", matched);
}

fn phylax_scan(text, result) {
    # Run the standard secrets scanner first.
    secrets_scan(text, result);

    var n = strlen(text);
    var lower = alloc(n + 1);
    str_to_lower_into(text, lower);

    if (cstr_contains(lower, "dm-verity") == 1) {
        _phylax_emit(text, lower, result, "VERITY", "dm-verity");
    }
    if (cstr_contains(lower, "verity validation failed") == 1) {
        _phylax_emit(text, lower, result, "VERITY", "verity validation failed");
    }
    if (cstr_contains(lower, "device-mapper: verity") == 1) {
        _phylax_emit(text, lower, result, "VERITY", "device-mapper: verity");
    }
    if (cstr_contains(lower, "nft ") == 1) {
        _phylax_emit(text, lower, result, "NFTABLES_BYPASS", "nft ");
    }
    if (cstr_contains(lower, "nftables") == 1) {
        _phylax_emit(text, lower, result, "NFTABLES_BYPASS", "nftables");
    }
    if (cstr_contains(lower, "iptables") == 1) {
        _phylax_emit(text, lower, result, "NFTABLES_BYPASS", "iptables");
    }
    if (cstr_contains(lower, "nsenter") == 1) {
        _phylax_emit(text, lower, result, "NAMESPACE_ESCAPE", "nsenter");
    }
    if (cstr_contains(lower, "setns(") == 1) {
        _phylax_emit(text, lower, result, "NAMESPACE_ESCAPE", "setns(");
    }
    if (cstr_contains(lower, "unshare(") == 1) {
        _phylax_emit(text, lower, result, "NAMESPACE_ESCAPE", "unshare(");
    }
    if (cstr_contains(lower, "/proc/1/ns/") == 1) {
        _phylax_emit(text, lower, result, "NAMESPACE_ESCAPE", "/proc/1/ns/");
    }
    if (cstr_contains(lower, "mount -t proc") == 1) {
        _phylax_emit(text, lower, result, "MOUNT_ESCAPE", "mount -t proc");
    }
    if (cstr_contains(lower, "mount -o remount,rw") == 1) {
        _phylax_emit(text, lower, result, "MOUNT_ESCAPE", "mount -o remount,rw");
    }
    if (cstr_contains(lower, "pivot_root") == 1) {
        _phylax_emit(text, lower, result, "MOUNT_ESCAPE", "pivot_root");
    }
    if (cstr_contains(lower, "chroot") == 1) {
        _phylax_emit(text, lower, result, "MOUNT_ESCAPE", "chroot");
    }
    return 0;
}

# ---- Arg building --------------------------------------------------------

fn _sy_agnos_append_int_flag(args, flag, value, suffix) {
    var buf[32];
    var n = fmt_int_buf(value, &buf);
    var s = alloc(n + strlen(suffix) + 1);
    memcpy(s, &buf, n);
    memcpy(s + n, suffix, strlen(suffix));
    store8(s + n + strlen(suffix), 0);
    vec_push(args, flag);
    vec_push(args, s);
    return 0;
}

# ---- Exec ----------------------------------------------------------------

fn sy_agnos_exec(sandbox, command) {
    var start_ns = mono_now_ns();
    var runtime = _sy_agnos_runtime();
    if (runtime == 0) {
        return backend_error_result("no container runtime (docker/podman) found");
    }

    # Runtime-guard precheck — same defense-in-depth as other backends.
    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    var config = Sandbox_config(sandbox);
    var policy = SandboxConfig_policy(config);

    var args = vec_new();
    vec_push(args, runtime);
    vec_push(args, "run");
    vec_push(args, "--rm");

    vec_push(args, "--network");
    if (SandboxPolicy_network_enabled(policy) == 1) {
        vec_push(args, "bridge");
    }
    else {
        vec_push(args, "none");
    }

    var mem = SandboxPolicy_memory_limit_mb(policy);
    if (mem > 0) {
        _sy_agnos_append_int_flag(args, "--memory", mem, "m");
    }

    # cpu limit is tenths × 10 → whole cores as string. Example: 10 -> "1".
    var cpu_x10 = SandboxPolicy_cpu_limit_tenths(policy);
    if (cpu_x10 > 0) {
        _sy_agnos_append_int_flag(args, "--cpus", cpu_x10 / 10, "");
    }

    var max_pids = SandboxPolicy_max_pids(policy);
    if (max_pids > 0) {
        _sy_agnos_append_int_flag(args, "--pids-limit", max_pids, "");
    }

    if (SandboxPolicy_read_only_rootfs(policy) == 1) {
        vec_push(args, "--read-only");
    }

    vec_push(args, "--entrypoint");
    vec_push(args, "/bin/sh");
    vec_push(args, SY_AGNOS_DEFAULT_IMAGE);
    vec_push(args, "-c");
    vec_push(args, command);

    var out_cap = 1048576;
    var out_buf = alloc(out_cap);
    var n = exec_capture(args, out_buf, out_cap);
    var end_ns = mono_now_ns();

    return backend_capture_finish(out_buf, n, out_cap, "sy-agnos container run failed", start_ns, end_ns);
}

fn sy_agnos_health(sandbox) {
    if (_sy_agnos_runtime() == 0) { return 0; }
    return 1;
}

fn sy_agnos_destroy(sandbox) { return 0; }

fn backend_sy_agnos_register() {
    backend_register_exec(Backend.SY_AGNOS, &sy_agnos_exec);
    backend_register_health(Backend.SY_AGNOS, &sy_agnos_health);
    backend_register_destroy(Backend.SY_AGNOS, &sy_agnos_destroy);
    return 0;
}

# --- backend_sgx.cyr ---

# kavach — Intel SGX (Gramine-SGX) backend
# Ported from rust-old/src/backend/sgx/mod.rs
#
# Generates a minimal Gramine manifest and runs `gramine-sgx <prefix>`.
# Requires /dev/sgx_enclave and the gramine-sgx binary.
#
# Deferred vs Rust:
#   - Remote attestation (SgxAttestationReport + IAS quote fetch) —
#     needs sigil HTTPS + IAS certificate handling
#   - Sealing / unsealing (SealedData, SealKeyPolicy) — needs gramine-sgx-seal
#     wrapper and AES-GCM support in sigil

fn _sgx_gramine_path() {
    if (path_exists("/usr/local/bin/gramine-sgx") == 1) { return "/usr/local/bin/gramine-sgx"; }
    if (path_exists("/usr/bin/gramine-sgx") == 1) { return "/usr/bin/gramine-sgx"; }
    return 0;
}

fn _sgx_device_present() {
    return path_exists("/dev/sgx_enclave");
}

# Generate a minimal Gramine manifest. Writes to <workdir>/app.manifest
# and returns the path. NOTE: real-world SGX deployments sign the manifest
# with gramine-sgx-sign; for v3.0 we produce an unsigned template that
# consumers must post-process. Path returned is the `.manifest.sgx` prefix
# that `gramine-sgx` expects.
fn _sgx_manifest_path(workdir) {
    var buf = alloc(strlen(workdir) + 32);
    memcpy(buf, workdir, strlen(workdir));
    memcpy(buf + strlen(workdir), "/app", 5);
    return buf;
}

fn _sgx_manifest_file(workdir) {
    var buf = alloc(strlen(workdir) + 32);
    memcpy(buf, workdir, strlen(workdir));
    memcpy(buf + strlen(workdir), "/app.manifest", 14);
    return buf;
}

fn _sgx_write_manifest(workdir, sandbox, command) {
    var cfg = Sandbox_config(sandbox);
    var policy = SandboxConfig_policy(cfg);
    var mem = SandboxPolicy_memory_limit_mb(policy);
    if (mem == 0) { mem = 256; }

    var cmd_escaped = oci_json_escape(command);
    var mem_buf[32];
    var mem_len = fmt_int_buf(mem, &mem_buf);

    var buf = alloc(2048 + strlen(cmd_escaped));
    var pos = 0;

    var p1a = "# kavach SGX enclave manifest (auto-generated)\n[libos]\nentrypoint = \"/bin/sh\"\n\n";
    var p1b = "[loader]\nentrypoint = \"file:{{ gramine.libos }}\"\nargv = [\"/bin/sh\", \"-c\", \"";
    memcpy(buf + pos, p1a, strlen(p1a)); pos = pos + strlen(p1a);
    memcpy(buf + pos, p1b, strlen(p1b)); pos = pos + strlen(p1b);
    memcpy(buf + pos, cmd_escaped, strlen(cmd_escaped)); pos = pos + strlen(cmd_escaped);

    var p2a = "\"]\nloader.env.PATH = \"/usr/local/bin:/usr/bin:/bin\"\nloader.env.HOME = \"/tmp\"\n\n";
    var p2b = "[sgx]\nenclave_size = \"";
    memcpy(buf + pos, p2a, strlen(p2a)); pos = pos + strlen(p2a);
    memcpy(buf + pos, p2b, strlen(p2b)); pos = pos + strlen(p2b);
    memcpy(buf + pos, &mem_buf, mem_len); pos = pos + mem_len;

    var p3a = "M\"\nmax_threads = 4\nedmm_enable = false\n\n[fs]\nmounts = [\n";
    var p3b = "  { path = \"/lib\", uri = \"file:{{ gramine.runtimedir() }}\" },\n";
    var p3c = "  { path = \"/usr\", uri = \"file:/usr\" },\n  { path = \"/bin\", uri = \"file:/bin\" },\n";
    var p3d = "  { path = \"/tmp\", uri = \"file:/tmp\", type = \"tmpfs\" },\n]\n\n";
    var p3e = "[[fs.trusted_files]]\nuri = \"file:{{ gramine.libos }}\"\n\n";
    var p3f = "[[fs.trusted_files]]\nuri = \"file:/bin/sh\"\n";
    memcpy(buf + pos, p3a, strlen(p3a)); pos = pos + strlen(p3a);
    memcpy(buf + pos, p3b, strlen(p3b)); pos = pos + strlen(p3b);
    memcpy(buf + pos, p3c, strlen(p3c)); pos = pos + strlen(p3c);
    memcpy(buf + pos, p3d, strlen(p3d)); pos = pos + strlen(p3d);
    memcpy(buf + pos, p3e, strlen(p3e)); pos = pos + strlen(p3e);
    memcpy(buf + pos, p3f, strlen(p3f)); pos = pos + strlen(p3f);
    store8(buf + pos, 0);

    var path = _sgx_manifest_file(workdir);
    # O_EXCL|O_NOFOLLOW write (ADR-005 §C4) — refuses to follow a symlink or
    # clobber a pre-existing file at the manifest path. Paired with the
    # unpredictable mode-0700 workdir, this closes the symlink-TOCTOU window.
    file_write_secure(path, buf, pos);
    return path;
}

fn sgx_exec(sandbox, command) {
    var start_ns = mono_now_ns();
    var gramine = _sgx_gramine_path();
    if (gramine == 0) {
        return backend_error_result("gramine-sgx not found in PATH");
    }
    if (_sgx_device_present() == 0) {
        return backend_error_result("SGX device /dev/sgx_enclave not found");
    }

    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    # Unpredictable workdir name (ADR-005 §C3): a predictable
    # /tmp/kavach-sgx-<epoch> let a local attacker pre-create the path (or a
    # symlink at it) before we write. A 16-hex-char random id from
    # /dev/urandom defeats the pre-seed, and mode 0700 + abort-on-EEXIST
    # means a real collision is a hard error, never a silent reuse.
    var rid = rand_hex_id();
    var prefix = "/tmp/kavach-sgx-";
    var workdir = alloc(strlen(prefix) + 17);
    memcpy(workdir, prefix, strlen(prefix));
    memcpy(workdir + strlen(prefix), rid, 16);
    store8(workdir + strlen(prefix) + 16, 0);
    if (sys_mkdir(workdir, 448) < 0) {
        return backend_error_result("failed to create SGX workdir");
    }

    _sgx_write_manifest(workdir, sandbox, command);

    var args = vec_new();
    vec_push(args, gramine);
    vec_push(args, _sgx_manifest_path(workdir));

    var out_cap = 1048576;
    var out_buf = alloc(out_cap);
    var n = exec_capture(args, out_buf, out_cap);
    var end_ns = mono_now_ns();

    # Cleanup: unlink manifest, rmdir workdir.
    var manifest = _sgx_manifest_file(workdir);
    sys_unlink(manifest);
    sys_rmdir(workdir);

    return backend_capture_finish(out_buf, n, out_cap, "gramine-sgx run failed", start_ns, end_ns);
}

fn sgx_health(sandbox) {
    if (_sgx_gramine_path() == 0) { return 0; }
    if (_sgx_device_present() == 0) { return 0; }
    return 1;
}

fn sgx_destroy(sandbox) { return 0; }

fn backend_sgx_register() {
    backend_register_exec(Backend.SGX, &sgx_exec);
    backend_register_health(Backend.SGX, &sgx_health);
    backend_register_destroy(Backend.SGX, &sgx_destroy);
    return 0;
}

# --- backend_sev.cyr ---

# kavach — AMD SEV-SNP backend (encrypted VM via QEMU)
# Ported from rust-old/src/backend/sev/mod.rs
#
# Launches a QEMU-KVM VM with SEV-SNP enabled. The command is expected to
# be a guest-kernel path (bzImage) passed via -kernel. The guest agent
# inside the image is responsible for running the actual workload.
#
# Deferred vs Rust:
#   - Attestation report fetching (SevAttestationReport) — needs sigil EAR
#   - Guest policy bit flags (SevGuestPolicy) — fold into v3.0 sigil
#     attestation helpers
#   - Live snapshots / migration

fn _sev_qemu_path() {
    if (path_exists("/usr/local/bin/qemu-system-x86_64") == 1) { return "/usr/local/bin/qemu-system-x86_64"; }
    if (path_exists("/usr/bin/qemu-system-x86_64") == 1) { return "/usr/bin/qemu-system-x86_64"; }
    return 0;
}

fn _sev_device_present() {
    return path_exists("/dev/sev");
}

fn sev_exec(sandbox, command) {
    var start_ns = mono_now_ns();
    var qemu = _sev_qemu_path();
    if (qemu == 0) {
        return backend_error_result("qemu-system-x86_64 not found in PATH");
    }
    if (_sev_device_present() == 0) {
        return backend_error_result("SEV device /dev/sev not found");
    }

    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    var cfg = Sandbox_config(sandbox);
    var policy = SandboxConfig_policy(cfg);

    var args = vec_new();
    vec_push(args, qemu);
    vec_push(args, "-machine");
    vec_push(args, "q35,confidential-guest-support=sev0");
    vec_push(args, "-object");
    vec_push(args, "sev-snp-guest,id=sev0,cbitpos=51,reduced-phys-bits=1");
    vec_push(args, "-cpu");
    vec_push(args, "EPYC-v4");

    var mem = SandboxPolicy_memory_limit_mb(policy);
    if (mem == 0) { mem = 512; }
    var mem_buf[32];
    var mem_len = fmt_int_buf(mem, &mem_buf);
    var mem_str = alloc(mem_len + 2);
    memcpy(mem_str, &mem_buf, mem_len);
    memcpy(mem_str + mem_len, "M", 2);
    vec_push(args, "-m");
    vec_push(args, mem_str);

    vec_push(args, "-nographic");
    vec_push(args, "-serial");
    vec_push(args, "stdio");
    vec_push(args, "-kernel");
    vec_push(args, command);

    var out_cap = 1048576;
    var out_buf = alloc(out_cap);
    var n = exec_capture(args, out_buf, out_cap);
    var end_ns = mono_now_ns();

    return backend_capture_finish(out_buf, n, out_cap, "qemu SEV run failed", start_ns, end_ns);
}

fn sev_health(sandbox) {
    if (_sev_qemu_path() == 0) { return 0; }
    if (_sev_device_present() == 0) { return 0; }
    return 1;
}

fn sev_destroy(sandbox) { return 0; }

fn backend_sev_register() {
    backend_register_exec(Backend.SEV, &sev_exec);
    backend_register_health(Backend.SEV, &sev_health);
    backend_register_destroy(Backend.SEV, &sev_destroy);
    return 0;
}

# --- backend_tdx.cyr ---

# kavach — Intel TDX backend (Trust Domain Extensions via QEMU)
# Skeleton port — no dedicated Rust tdx/ module existed in v1.x; this
# backend shares the QEMU code path with SEV, differentiated by guest
# object + CPU flags. Command is a guest-kernel path (bzImage).
#
# Deferred: TDX attestation (quote fetch + verify via sigil EAR), guest
# measurement. Waits on sigil TDX helpers.

fn _tdx_qemu_path() {
    if (path_exists("/usr/local/bin/qemu-system-x86_64") == 1) { return "/usr/local/bin/qemu-system-x86_64"; }
    if (path_exists("/usr/bin/qemu-system-x86_64") == 1) { return "/usr/bin/qemu-system-x86_64"; }
    return 0;
}

fn _tdx_device_present() {
    return path_exists("/dev/tdx_guest");
}

fn tdx_exec(sandbox, command) {
    var start_ns = mono_now_ns();
    var qemu = _tdx_qemu_path();
    if (qemu == 0) {
        return backend_error_result("qemu-system-x86_64 not found in PATH");
    }
    if (_tdx_device_present() == 0) {
        return backend_error_result("TDX device /dev/tdx_guest not found");
    }

    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    var cfg = Sandbox_config(sandbox);
    var policy = SandboxConfig_policy(cfg);

    var args = vec_new();
    vec_push(args, qemu);
    vec_push(args, "-machine");
    vec_push(args, "q35,kernel_irqchip=split,confidential-guest-support=tdx0");
    vec_push(args, "-object");
    vec_push(args, "tdx-guest,id=tdx0,sept-ve-disable=off");
    vec_push(args, "-cpu");
    vec_push(args, "host,-kvm-steal-time,pmu=off");

    var mem = SandboxPolicy_memory_limit_mb(policy);
    if (mem == 0) { mem = 512; }
    var mem_buf[32];
    var mem_len = fmt_int_buf(mem, &mem_buf);
    var mem_str = alloc(mem_len + 2);
    memcpy(mem_str, &mem_buf, mem_len);
    memcpy(mem_str + mem_len, "M", 2);
    vec_push(args, "-m");
    vec_push(args, mem_str);

    vec_push(args, "-nographic");
    vec_push(args, "-serial");
    vec_push(args, "stdio");
    vec_push(args, "-kernel");
    vec_push(args, command);

    var out_cap = 1048576;
    var out_buf = alloc(out_cap);
    var n = exec_capture(args, out_buf, out_cap);
    var end_ns = mono_now_ns();

    return backend_capture_finish(out_buf, n, out_cap, "qemu TDX run failed", start_ns, end_ns);
}

fn tdx_health(sandbox) {
    if (_tdx_qemu_path() == 0) { return 0; }
    if (_tdx_device_present() == 0) { return 0; }
    return 1;
}

fn tdx_destroy(sandbox) { return 0; }

fn backend_tdx_register() {
    backend_register_exec(Backend.TDX, &tdx_exec);
    backend_register_health(Backend.TDX, &tdx_health);
    backend_register_destroy(Backend.TDX, &tdx_destroy);
    return 0;
}

# --- backend_firecracker.cyr ---

# kavach — Firecracker (microVM) backend
# Ported from rust-old/src/backend/firecracker/{mod,config,network,vsock,snapshot}.rs
#
# Generates a minimal Firecracker VM config.json and boots a microVM via
# `firecracker --no-api --config-file <path>`. The `command` argument is
# interpreted as the path to a guest kernel image (bzImage); the rootfs is
# not wired here — callers staging a rootfs drive should extend the
# generated config and re-run.
#
# Deferred vs Rust:
#   - jailer wrapping — v3.1; needs uid/gid/cgroup plumbing
#   - vsock + snapshot + network/TAP — require networking syscalls
#     that aren't yet in the kavach stdlib surface
#   - `--log-path` wiring — replaced with /dev/null for v3.0

fn _fc_binary_path() {
    if (path_exists("/usr/local/bin/firecracker") == 1) { return "/usr/local/bin/firecracker"; }
    if (path_exists("/usr/bin/firecracker") == 1) { return "/usr/bin/firecracker"; }
    return 0;
}

# Generate a minimal Firecracker VM config JSON. The kernel path is the
# caller-supplied `command`. Memory and vCPU come from SandboxPolicy.
fn _fc_generate_config(sandbox, kernel_path) {
    var cfg = Sandbox_config(sandbox);
    var policy = SandboxConfig_policy(cfg);

    var mem = SandboxPolicy_memory_limit_mb(policy);
    if (mem == 0) { mem = 128; }

    # cpu_limit_tenths: 10 = 1 vCPU, 20 = 2 vCPU, etc.
    var vcpu = SandboxPolicy_cpu_limit_tenths(policy) / 10;
    if (vcpu < 1) { vcpu = 1; }

    var kernel_escaped = oci_json_escape(kernel_path);
    var mem_buf[24];
    var mem_len = fmt_int_buf(mem, &mem_buf);
    var vcpu_buf[24];
    var vcpu_len = fmt_int_buf(vcpu, &vcpu_buf);

    var buf = alloc(1024 + strlen(kernel_escaped));
    var pos = 0;
    var p1 = "{\"boot-source\":{\"kernel_image_path\":\"";
    memcpy(buf + pos, p1, strlen(p1)); pos = pos + strlen(p1);
    memcpy(buf + pos, kernel_escaped, strlen(kernel_escaped)); pos = pos + strlen(kernel_escaped);

    var p2 = "\",\"boot_args\":\"console=ttyS0 reboot=k panic=1 pci=off\"},\"machine-config\":{\"vcpu_count\":";
    memcpy(buf + pos, p2, strlen(p2)); pos = pos + strlen(p2);
    memcpy(buf + pos, &vcpu_buf, vcpu_len); pos = pos + vcpu_len;

    var p3 = ",\"mem_size_mib\":";
    memcpy(buf + pos, p3, strlen(p3)); pos = pos + strlen(p3);
    memcpy(buf + pos, &mem_buf, mem_len); pos = pos + mem_len;

    var p4 = ",\"smt\":false},\"drives\":[]}";
    memcpy(buf + pos, p4, strlen(p4)); pos = pos + strlen(p4);
    store8(buf + pos, 0);
    return buf;
}

fn firecracker_exec(sandbox, command) {
    var start_ns = mono_now_ns();
    var fc = _fc_binary_path();
    if (fc == 0) {
        return backend_error_result("firecracker not found in PATH");
    }

    var guard_cfg = runtime_guard_config_default();
    var violations = check_command(command, guard_cfg);
    if (vec_len(violations) > 0) {
        return backend_guard_result(violations);
    }

    if (path_exists(command) == 0) {
        return backend_error_result("kernel image not found");
    }

    # Prepare workdir and config file. Unpredictable random name + mode 0700
    # + abort-on-EEXIST defeats the /tmp symlink-preseed vector that a
    # predictable /tmp/kavach-fc-<epoch> exposed (ADR-005 §C3).
    var rid = rand_hex_id();
    var prefix = "/tmp/kavach-fc-";
    var workdir = alloc(strlen(prefix) + 17);
    memcpy(workdir, prefix, strlen(prefix));
    memcpy(workdir + strlen(prefix), rid, 16);
    store8(workdir + strlen(prefix) + 16, 0);
    if (sys_mkdir(workdir, 448) < 0) {
        return backend_error_result("failed to create firecracker workdir");
    }

    var cfg_path = alloc(strlen(workdir) + 16);
    memcpy(cfg_path, workdir, strlen(workdir));
    memcpy(cfg_path + strlen(workdir), "/config.json", 13);

    var cfg_json = _fc_generate_config(sandbox, command);
    # O_EXCL|O_NOFOLLOW write (ADR-005 §C4) — no symlink-follow, no clobber.
    file_write_secure(cfg_path, cfg_json, strlen(cfg_json));

    var args = vec_new();
    vec_push(args, fc);
    vec_push(args, "--no-api");
    vec_push(args, "--config-file");
    vec_push(args, cfg_path);
    vec_push(args, "--log-path");
    vec_push(args, "/dev/null");
    vec_push(args, "--level");
    vec_push(args, "Warning");

    var out_cap = 1048576;
    var out_buf = alloc(out_cap);
    var n = exec_capture(args, out_buf, out_cap);
    var end_ns = mono_now_ns();

    # Cleanup workdir
    sys_unlink(cfg_path);
    sys_rmdir(workdir);

    return backend_capture_finish(out_buf, n, out_cap, "firecracker run failed", start_ns, end_ns);
}

fn firecracker_health(sandbox) {
    if (_fc_binary_path() == 0) { return 0; }
    return 1;
}

fn firecracker_destroy(sandbox) { return 0; }

fn backend_firecracker_register() {
    backend_register_exec(Backend.FIRECRACKER, &firecracker_exec);
    backend_register_health(Backend.FIRECRACKER, &firecracker_health);
    backend_register_destroy(Backend.FIRECRACKER, &firecracker_destroy);
    return 0;
}

# --- composite.cyr ---

# kavach — composite backend (defense-in-depth policy layering)
# Ported from rust-old/src/backend/composite.rs
#
# Merges an outer backend (runtime boundary) with an inner policy layer.
# The outer's exec dispatches as usual; the caller's policy is merged
# with the inner's policy before the call, always taking the stricter
# side per field.
#
# Merge rules:
#   seccomp_enabled        OR  of the two sides
#   seccomp_profile        "strict" wins over "basic" wins over None
#   network_enabled        AND (both must allow)
#   read_only_rootfs       OR  (either enforces)
#   landlock rules         additive (concat)
#   landlock_abstract_unix OR
#   landlock_signal        OR
#   memory_limit_mb        min (stricter is smaller; 0 = unset)
#   cpu_limit_tenths       min (0 = unset)
#   max_pids               min (0 = unset)
#   tcp_bind_len           max (more restriction signal)
#   tcp_connect_len        max

fn _stricter_profile(a, b) {
    # a and b are cstr or 0.
    if (a == 0) { return b; }
    if (b == 0) { return a; }
    if (streq(a, "strict") == 1) { return a; }
    if (streq(b, "strict") == 1) { return b; }
    return a;
}

fn _min_nz(a, b) {
    if (a == 0) { return b; }
    if (b == 0) { return a; }
    if (a < b) { return a; }
    return b;
}

fn _max(a, b) {
    if (a > b) { return a; }
    return b;
}

fn _or_bool(a, b) {
    if (a == 1) { return 1; }
    if (b == 1) { return 1; }
    return 0;
}

fn _and_bool(a, b) {
    if (a == 1) { if (b == 1) { return 1; } }
    return 0;
}

# Merge two policies into a fresh SandboxPolicy pointer.
# Neither input is mutated.
fn merge_policies(base, overlay) {
    var out = policy_new();
    SandboxPolicy_set_seccomp_enabled(out,
    _or_bool(SandboxPolicy_seccomp_enabled(base),
    SandboxPolicy_seccomp_enabled(overlay)));
    SandboxPolicy_set_seccomp_profile(out,
    _stricter_profile(SandboxPolicy_seccomp_profile(base),
    SandboxPolicy_seccomp_profile(overlay)));

    # Network: both must enable. Default disabled wins.
    SandboxPolicy_set_network_enabled(out,
    _and_bool(SandboxPolicy_network_enabled(base),
    SandboxPolicy_network_enabled(overlay)));

    SandboxPolicy_set_read_only_rootfs(out,
    _or_bool(SandboxPolicy_read_only_rootfs(base),
    SandboxPolicy_read_only_rootfs(overlay)));

    SandboxPolicy_set_landlock_rules_len(out,
    SandboxPolicy_landlock_rules_len(base)
    + SandboxPolicy_landlock_rules_len(overlay));

    SandboxPolicy_set_landlock_abstract_unix(out,
    _or_bool(SandboxPolicy_landlock_abstract_unix(base),
    SandboxPolicy_landlock_abstract_unix(overlay)));
    SandboxPolicy_set_landlock_signal(out,
    _or_bool(SandboxPolicy_landlock_signal(base),
    SandboxPolicy_landlock_signal(overlay)));

    SandboxPolicy_set_memory_limit_mb(out,
    _min_nz(SandboxPolicy_memory_limit_mb(base),
    SandboxPolicy_memory_limit_mb(overlay)));
    SandboxPolicy_set_cpu_limit_tenths(out,
    _min_nz(SandboxPolicy_cpu_limit_tenths(base),
    SandboxPolicy_cpu_limit_tenths(overlay)));
    SandboxPolicy_set_max_pids(out,
    _min_nz(SandboxPolicy_max_pids(base),
    SandboxPolicy_max_pids(overlay)));

    SandboxPolicy_set_network_tcp_bind_len(out,
    _max(SandboxPolicy_network_tcp_bind_len(base),
    SandboxPolicy_network_tcp_bind_len(overlay)));
    SandboxPolicy_set_network_tcp_connect_len(out,
    _max(SandboxPolicy_network_tcp_connect_len(base),
    SandboxPolicy_network_tcp_connect_len(overlay)));
    return out;
}

# Score a composite = max(outer_base, inner_base) + 5, clamped to 100.
# The +5 reflects the layering bonus (both runtime boundary AND policy
# enforcement, which is additive defense).
fn score_composite(outer, inner, policy) {
    var a = base_score(outer);
    var b = base_score(inner);
    var base = a;
    if (b > a) { base = b; }
    var policy_score = score_backend(outer, policy) - base_score(outer);
    var composite = base + policy_score + 5;
    if (composite > 100) { composite = 100; }
    if (composite < 0) { composite = 0; }
    return composite;
}

# Dispatcher wrapper: execute via `outer` backend with the merged policy.
# Caller passes the outer+inner backend ids separately from the sandbox
# so the Sandbox struct layout stays v2.0-compatible.
#
# Typical flow:
#   var merged_policy = merge_policies(caller_policy, inner_policy);
#   # swap policy on config for the dispatch, preserving the original
#   SandboxConfig_set_policy(config, merged_policy);
#   var result = backend_dispatch_exec_as(outer_backend, sandbox, cmd);
fn composite_exec(outer_backend, inner_backend, sandbox, command, inner_policy) {
    var config = Sandbox_config(sandbox);
    var caller_policy = SandboxConfig_policy(config);
    var merged = merge_policies(caller_policy, inner_policy);
    var saved = caller_policy;
    SandboxConfig_set_policy(config, merged);
    SandboxConfig_set_backend(config, outer_backend);
    var result = backend_dispatch_exec(sandbox, command);
    SandboxConfig_set_policy(config, saved);
    return result;
}

# --- observability.cyr ---

# kavach — observability types (health, metrics, spawn handle)
# Ported from rust-old/src/backend/{health,metrics,exec_util}.rs.
#
# These are the public data types consumers of kavach use to observe
# sandbox state. Population of the fields is backend-specific; the v2.0
# process/gvisor/oci/wasm backends expose health via the dispatch table
# and leave metrics as a zeroed struct (real collection lives alongside
# cgroup v2 readers — see roadmap v3.0 blocked items).

# ---- HealthStatus --------------------------------------------------------

enum HealthState {
    HEALTHY = 0;
    DEGRADED = 1;
    UNHEALTHY = 2;
    UNKNOWN = 3;
}

fn health_state_name(s) {
    if (s == HealthState.HEALTHY) { return "healthy"; }
    if (s == HealthState.DEGRADED) { return "degraded"; }
    if (s == HealthState.UNHEALTHY) { return "unhealthy"; }
    return "unknown";
}

#derive(accessors)
struct HealthStatus {
    state;
    last_check_at;
    detail;
}

fn health_status_new(state, detail) {
    var h = alloc(24);
    HealthStatus_set_state(h, state);
    HealthStatus_set_last_check_at(h, clock_epoch_secs());
    HealthStatus_set_detail(h, detail);
    return h;
}

# Probe a sandbox's backend via the dispatch table and report a status.
fn health_probe(sandbox) {
    var ok = backend_dispatch_health(sandbox);
    if (ok == 1) {
        return health_status_new(HealthState.HEALTHY, "ok");
    }
    return health_status_new(HealthState.UNHEALTHY, "backend health check failed");
}

# ---- SandboxMetrics ------------------------------------------------------
# Resource-usage snapshot. Populated by cgroup v2 readers once those
# syscalls land in the Cyrius stdlib; until then the struct is available
# for API compatibility with zeroed fields.

#derive(accessors)
struct SandboxMetrics {
    cpu_time_ns;
    memory_bytes_peak;
    memory_bytes_current;
    pid_count;
    io_read_bytes;
    io_write_bytes;
    wall_duration_ms;
}

var SANDBOX_METRICS_SIZE = 56;

fn sandbox_metrics_new() {
    var m = alloc(SANDBOX_METRICS_SIZE);
    var i = 0;
    while (i < SANDBOX_METRICS_SIZE) { store64(m + i, 0); i = i + 8; }
    return m;
}

# Populate metrics from an ExecResult's wall clock. CPU/memory/PID/IO
# fields remain 0 until cgroup-backed collectors ship (v3.0 blocked item).
fn sandbox_metrics_from_result(result) {
    var m = sandbox_metrics_new();
    SandboxMetrics_set_wall_duration_ms(m, ExecResult_duration_ms(result));
    return m;
}

# ---- SpawnedProcess ------------------------------------------------------
# Fire-and-forget handle for long-running workloads. Backends that do not
# support spawning (noop, wasm per-invocation) return 0 and the caller
# falls back to exec().

#derive(accessors)
struct SpawnedProcess {
    pid;
    backend;
    started_at;
}

fn spawned_process_new(pid, backend) {
    var s = alloc(24);
    SpawnedProcess_set_pid(s, pid);
    SpawnedProcess_set_backend(s, backend);
    SpawnedProcess_set_started_at(s, clock_epoch_secs());
    return s;
}

# --- attestation.cyr ---

# kavach — unified attestation types
# Ported from rust-old/src/backend/attestation.rs (types only; EAR
# serialization + IAS / AMD-SEV / Intel-TDX quote verification are
# deferred to v3.1, gated on sigil EAR helpers — see ADR-004 §2).
#
# The AttestationResult struct is backend-agnostic: callers evaluate
# trust via `trust` + `backend` without hardware-specific parsing.

# Ordering matters: Contraindicated < Warning < None < Affirming
# (higher = more trusted). Values chosen so direct comparison works.
enum AttestationTrust {
    CONTRAINDICATED = 0;
    WARNING = 1;
    NONE = 2;
    AFFIRMING = 3;
}

fn attestation_trust_name(t) {
    if (t == AttestationTrust.CONTRAINDICATED) { return "contraindicated"; }
    if (t == AttestationTrust.WARNING) { return "warning"; }
    if (t == AttestationTrust.NONE) { return "none"; }
    if (t == AttestationTrust.AFFIRMING) { return "affirming"; }
    return "unknown";
}

# Backend-agnostic attestation result. Each confidential-computing
# backend (SGX/SEV/TDX) produces one of these; consumers treat them
# uniformly. Populated fields depend on the producer.
#derive(accessors)
struct AttestationResult {
    backend;
    trust;
    measurement_hex;
    signer_hex;
    svn;
    fresh_at;
    details;
}

fn attestation_result_new(backend) {
    var a = alloc(48);
    AttestationResult_set_backend(a, backend);
    AttestationResult_set_trust(a, AttestationTrust.NONE);
    AttestationResult_set_measurement_hex(a, "");
    AttestationResult_set_signer_hex(a, "");
    AttestationResult_set_svn(a, 0);
    AttestationResult_set_fresh_at(a, clock_epoch_secs());
    AttestationResult_set_details(a, "");
    return a;
}

# Evaluate whether an attestation result meets a minimum trust bar.
# Returns 1 if `result.trust >= minimum`, 0 otherwise.
fn attestation_is_acceptable(result, minimum_trust) {
    if (AttestationResult_trust(result) >= minimum_trust) { return 1; }
    return 0;
}

# ---- SGX-specific report (struct only; verify waits on sigil) ------------

#derive(accessors)
struct SgxAttestationReport {
    mrenclave_hex;
    mrsigner_hex;
    isv_prod_id;
    isv_svn;
    report_data_len;
    ias_signature;
    timestamp;
}

fn sgx_report_new() {
    var r = alloc(56);
    SgxAttestationReport_set_mrenclave_hex(r, "");
    SgxAttestationReport_set_mrsigner_hex(r, "");
    SgxAttestationReport_set_isv_prod_id(r, 0);
    SgxAttestationReport_set_isv_svn(r, 0);
    SgxAttestationReport_set_report_data_len(r, 0);
    SgxAttestationReport_set_ias_signature(r, "");
    SgxAttestationReport_set_timestamp(r, 0);
    return r;
}

# Structural verification: MRENCLAVE / MRSIGNER are 64-char lowercase
# hex, IAS signature is non-trivial (>= 32 chars). Cryptographic
# verification of the IAS signature against the Intel root cert is
# deferred — needs sigil EAR helpers + cert-chain validation.
fn sgx_report_verify_structure(report) {
    var me = SgxAttestationReport_mrenclave_hex(report);
    var ms = SgxAttestationReport_mrsigner_hex(report);
    var sig = SgxAttestationReport_ias_signature(report);
    if (strlen(me) != 64) { return 0; }
    if (strlen(ms) != 64) { return 0; }
    if (strlen(sig) < 32) { return 0; }
    # Check hex-ness of measurements
    var i = 0;
    while (i < 64) {
        var c = load8(me + i);
        if (is_digit_c(c) == 0) {
            if (c < 97) { return 0; }
            if (c > 102) { return 0; }
        }
        i = i + 1;
    }
    return 1;
}

# ---- Seal key policy (SGX sealing; struct-only for now) ------------------

enum SealKeyPolicy {
    MR_ENCLAVE = 0;
    MR_SIGNER = 1;
}

fn seal_key_policy_name(p) {
    if (p == SealKeyPolicy.MR_ENCLAVE) { return "mrenclave"; }
    if (p == SealKeyPolicy.MR_SIGNER) { return "mrsigner"; }
    return "unknown";
}

# --- sandbox_exec.cyr ---

# kavach — end-to-end exec flow
# sandbox_exec() is the primary entry point for running a command
# through the full kavach pipeline:
#
#   1. Verify sandbox is in RUNNING state
#   2. Backend dispatch (backend.exec)
#   3. Externalization gate (secrets + code + data + verdict)
#   4. Threat classification (intent score + kill chain)
#   5. Audit record (HMAC-SHA256 chain)
#
# On BLOCK/QUARANTINE verdicts, returns 0 and logs via audit; caller
# inspects the sandbox's last_scan_result for details.

# ---- Sandbox runtime wrapper ---------------------------------------------
# We extend the lifecycle Sandbox with post-exec observations:
#   - last_scan_result: ScanResult* from the last gate run
#   - last_assessment:  ThreatAssessment* from the last classification
#   - audit_chain:      optional AuditChain*
# These are stored in a parallel SandboxRuntime struct keyed by sandbox id.
# For v3.0 port we carry them on the Sandbox pointer via appended fields.

# ---- Global scan / audit context -----------------------------------------
# One global ext policy, one global audit chain for the v3.0 skeleton.
# Consumers can swap these via sandbox_exec_set_policy / ...set_audit.
var _default_ext_policy = 0;
var _global_audit_chain = 0;
var _last_scan_result = 0;
var _last_assessment = 0;

fn sandbox_exec_set_ext_policy(p) { _default_ext_policy = p; return 0; }
fn sandbox_exec_set_audit_chain(c) { _global_audit_chain = c; return 0; }
fn sandbox_exec_last_scan_result() { return _last_scan_result; }
fn sandbox_exec_last_assessment() { return _last_assessment; }

fn _ensure_default_ext_policy() {
    if (_default_ext_policy == 0) {
        _default_ext_policy = ext_policy_default();
    }
    return _default_ext_policy;
}

# ---- Audit payload builders ----------------------------------------------

fn _audit_record_if(chain, event_type, payload) {
    if (chain != 0) { audit_chain_record(chain, event_type, payload); }
    return 0;
}

# ---- Main entry -----------------------------------------------------------

# Execute a command through the full pipeline.
# Returns ExecResult* on PASS/WARN, 0 on BLOCK/QUARANTINE/error.
fn sandbox_exec(sandbox, command) {
    if (Sandbox_state(sandbox) != SandboxState.RUNNING) {
        kavach_err_print(KAVACH_ERR_EXEC_FAILED, "sandbox not running");
        return 0;
    }

    var policy = _ensure_default_ext_policy();
    var audit = _global_audit_chain;

    _audit_record_if(audit, "exec_begin", command);

    # 1. Backend dispatch
    var result = backend_dispatch_exec(sandbox, command);
    if (result == 0) {
        _audit_record_if(audit, "exec_error", "backend dispatch failed");
        return 0;
    }

    # 2. Externalization gate
    var scan = gate_apply(result, policy);
    _last_scan_result = scan;

    # 3. Threat classification
    var assessment = classify_threat(ScanResult_findings(scan));
    _last_assessment = assessment;

    var verdict = ScanResult_verdict(scan);

    # 4. Audit record — one entry per exec with verdict payload
    if (audit != 0) {
        var vname = verdict_name(verdict);
        audit_chain_record(audit, "exec_complete", vname);
    }

    if (verdict == ScanVerdict.BLOCK) {
        kavach_err_print(KAVACH_ERR_EXTERNALIZATION_BLOCKED, "blocked by gate");
        return 0;
    }
    if (verdict == ScanVerdict.QUARANTINE) {
        kavach_err_print(KAVACH_ERR_EXTERNALIZATION_BLOCKED, "quarantined");
        return 0;
    }
    return result;
}

# ---- Initialization -------------------------------------------------------
# Call once at startup to register the v3.0 skeleton backends.
fn kavach_init() {
    alloc_init();
    sha256_global_init();
    backend_noop_register();
    backend_process_register();
    backend_gvisor_register();
    backend_oci_register();
    backend_wasm_register();
    backend_sy_agnos_register();
    backend_sgx_register();
    backend_sev_register();
    backend_tdx_register();
    backend_firecracker_register();
    return 0;
}
