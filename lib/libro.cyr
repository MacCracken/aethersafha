    ERR_INTEGRITY = 1;
    ERR_STORE = 2;
    ERR_IO = 3;
    ERR_JSON = 4;
    ERR_FIELD_TOO_LONG = 5;
    ERR_TIMESTAMP = 6;
    ERR_ANCHORING = 7;
