    store64(e, code);
    store64(e + 8, msg);
    store64(e + 16, 0);
    store64(e + 24, 0);
    store64(e + 32, 0);
    store64(e + 40, 0);
    return e;
}

fn error_integrity(index, expected, actual) {
    var e = fl_alloc(48);
    store64(e, ERR_INTEGRITY);
    store64(e + 8, "integrity violation");
    store64(e + 16, 0);
    store64(e + 24, index);
    store64(e + 32, expected);
    store64(e + 40, actual);
    return e;
}

