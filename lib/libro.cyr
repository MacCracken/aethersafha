    _uuid_hi; _uuid_lo;
    timestamp; severity; source; action; details;
    agent_id; prev_hash; hash; hash_algorithm;
}

fn entry_id(e) { return e; }

# ================================================================
# UUID v4 generation via /dev/urandom
# ================================================================

fn uuid_v4(buf) {
    # Fail-closed on /dev/urandom unavailability: a predictable UUID would
    # make the libro audit chain forgeable. Upstream libro 1.0.3 silently
    # ignored short reads; t-ron's vendored copy aborts instead.
#ifdef CYRIUS_TARGET_AGNOS
    # agnos has no /dev/urandom — draw 16 bytes from getrandom #45
    # (RDRAND-seeded CSPRNG). Same fail-closed contract as the Linux path.
    var got = syscall(SYS_GETRANDOM, buf, 16, 0);
    if (got != 16) {
        syscall(SYS_WRITE, 2, "libro: getrandom failed (fail-closed)\n", 38);
        syscall(SYS_EXIT, 74);
    }
#else
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) {
        syscall(SYS_WRITE, 2, "libro: /dev/urandom unavailable (fail-closed)\n", 46);
        syscall(SYS_EXIT, 74);   # EX_IOERR
    }
    var got = file_read(fd, buf, 16);
    file_close(fd);
    if (got != 16) {
        syscall(SYS_WRITE, 2, "libro: short read from /dev/urandom (fail-closed)\n", 50);
        syscall(SYS_EXIT, 74);
    }
#endif
    # Version 4: byte 6 high nibble = 0100
    var b6 = load8(buf + 6) & 0xFF;
    store8(buf + 6, (b6 & 0x0F) | 0x40);
    # Variant RFC 4122: byte 8 high bits = 10
    var b8 = load8(buf + 8) & 0xFF;
    store8(buf + 8, (b8 & 0x3F) | 0x80);
    return 0;
}

# Format UUID as 8-4-4-4-12 hex string (36 chars)
# Write one byte of `buf` as two lowercase hex chars at out[pos..pos+2].
fn _uuid_hex_byte(buf, bi, out, pos) {
    var b = load8(buf + bi) & 0xFF;
    var hi = (b >> 4) & 0xF;
    var lo = b & 0xF;
    if (hi < 10) { store8(out + pos, 48 + hi); }
    else { store8(out + pos, 87 + hi); }
    if (lo < 10) { store8(out + pos + 1, 48 + lo); }
    else { store8(out + pos + 1, 87 + lo); }
    return 0;
}

# Single-pass UUID formatter. Writes 36 chars (8-4-4-4-12) + NUL into
# one fresh 37-byte buffer and wraps it once. Replaces the former
# 5× hex_encode_str + str_builder path that allocated ~12 intermediate
# objects per UUID. bench_entry_hash and every export/proof call pays
# this once per entry.
fn uuid_format(buf) {
    var out = alloc(37);
    # bytes 0..3 → out[0..7]
    _uuid_hex_byte(buf, 0, out, 0);
    _uuid_hex_byte(buf, 1, out, 2);
    _uuid_hex_byte(buf, 2, out, 4);
    _uuid_hex_byte(buf, 3, out, 6);
    store8(out + 8, 45);
    # bytes 4..5 → out[9..12]
    _uuid_hex_byte(buf, 4, out, 9);
    _uuid_hex_byte(buf, 5, out, 11);
    store8(out + 13, 45);
    # bytes 6..7 → out[14..17]
    _uuid_hex_byte(buf, 6, out, 14);
    _uuid_hex_byte(buf, 7, out, 16);
    store8(out + 18, 45);
    # bytes 8..9 → out[19..22]
    _uuid_hex_byte(buf, 8, out, 19);
    _uuid_hex_byte(buf, 9, out, 21);
    store8(out + 23, 45);
    # bytes 10..15 → out[24..35]
    _uuid_hex_byte(buf, 10, out, 24);
    _uuid_hex_byte(buf, 11, out, 26);
    _uuid_hex_byte(buf, 12, out, 28);
    _uuid_hex_byte(buf, 13, out, 30);
    _uuid_hex_byte(buf, 14, out, 32);
    _uuid_hex_byte(buf, 15, out, 34);
    store8(out + 36, 0);
    return str_new(out, 36);
}

# ================================================================
# Timestamp — wall-clock via clock_gettime(CLOCK_REALTIME)
# ================================================================

var _ts_buf = 0;

fn get_epoch_secs() {
#ifdef CYRIUS_TARGET_AGNOS
    # agnos: time_unix #46 returns unix seconds directly in rax (no timespec).
    return syscall(SYS_TIME_UNIX);
#else
    if (_ts_buf == 0) { _ts_buf = alloc(16); }
    # clock_gettime(CLOCK_REALTIME=0, &timespec)
    syscall(228, 0, _ts_buf);
    return load64(_ts_buf);
#endif
}

# Format helpers for zero-padded decimals
fn _fmt_02d(buf, n) {
    store8(buf, 48 + n / 10);
    store8(buf + 1, 48 + (n - (n / 10) * 10));
    return 0;
}

fn _fmt_04d(buf, n) {
    store8(buf, 48 + (n / 1000) - (n / 10000) * 10);
    store8(buf + 1, 48 + (n / 100) - (n / 1000) * 10);
    store8(buf + 2, 48 + (n / 10) - (n / 100) * 10);
    store8(buf + 3, 48 + n - (n / 10) * 10);
    return 0;
}

# Civil date from days since epoch (Hinnant algorithm)
# Returns year in _cd_y, month in _cd_m, day in _cd_d
var _cd_y = 0;
var _cd_m = 0;
var _cd_d = 0;

fn civil_from_days(days) {
    var z = days + 719468;
    var era = z / 146097;
    if (z < 0) { era = (z - 146096) / 146097; }
    var doe = z - era * 146097;
    var yoe = (doe - doe / 1461 + doe / 36524 - doe / 146097) / 365;
    var y = yoe + era * 400;
    var doy = doe - (365 * yoe + yoe / 4 - yoe / 100);
    var mp = (5 * doy + 2) / 153;
    _cd_d = doy - (153 * mp + 2) / 5 + 1;
    _cd_m = mp + 3;
    if (mp >= 10) { _cd_m = mp - 9; }
    _cd_y = y;
    if (_cd_m <= 2) { _cd_y = y + 1; }
    return 0;
}

fn timestamp_rfc3339(epoch_secs) {
    var secs_in_day = 86400;
    var days = epoch_secs / secs_in_day;
    var time_of_day = epoch_secs - days * secs_in_day;
    if (time_of_day < 0) {
        time_of_day = time_of_day + secs_in_day;
        days = days - 1;
    }

    civil_from_days(days);

    var hour = time_of_day / 3600;
    var minute = (time_of_day - hour * 3600) / 60;
    var second = time_of_day - hour * 3600 - minute * 60;

    # Format: "YYYY-MM-DDTHH:MM:SSZ" = 20 chars
    var buf = alloc(21);
    _fmt_04d(buf, _cd_y);
    store8(buf + 4, 45);
    _fmt_02d(buf + 5, _cd_m);
    store8(buf + 7, 45);
    _fmt_02d(buf + 8, _cd_d);
    store8(buf + 10, 84);
    _fmt_02d(buf + 11, hour);
    store8(buf + 13, 58);
    _fmt_02d(buf + 14, minute);
    store8(buf + 16, 58);
    _fmt_02d(buf + 17, second);
    store8(buf + 19, 90);
    store8(buf + 20, 0);
    return str_new(buf, 20);
}

# ================================================================
# Canonical JSON hashing (recursive, depth-unlimited)
# ================================================================
# Walks raw JSON bytes and emits a canonical form into the hasher:
#   null, true, false, numbers → emitted verbatim, whitespace stripped
#   strings → emitted as "…" with original escapes preserved verbatim
#   objects → "{"k":v,…}" with keys sorted lexicographically
#   arrays  → "[v,v,…]" in original order (no sort)
#
# 2.0 rewrite: flat-only canonicalizer via lib/json.cyr replaced with
# a direct byte-walker that handles arbitrary nesting. Flat objects
# with all-string values hash identically to the 1.x form; any use of
# numbers, bools, null, arrays, or nested objects as top-level details
# values now hashes differently (1.x emitted all values as
# quoted strings, silently miscoercing non-strings). Consumers that
# stored hashes computed from non-string-only flat JSON in 1.x will
# see a hash break on re-verify — which is correct behaviour and one
# of the reasons this is a 2.0 feature.

fn canonical_json_hash_str(json_str, hasher) {
    var slen = str_len(json_str);
    if (slen == 0) {
        hasher_update(hasher, "null", 4);
        return 0;
    }
    var sdata = str_data(json_str);
    _cjh_emit(sdata, 0, slen, hasher);
    return 0;
}

# Lexicographic Str comparison: returns <0, 0, or >0
fn _str_cmp(a, b) {
    var alen = str_len(a);
    var blen = str_len(b);
    var ad = str_data(a);
    var bd = str_data(b);
    var minlen = alen;
    if (blen < minlen) { minlen = blen; }
    var i = 0;
    while (i < minlen) {
        var ca = load8(ad + i) & 0xFF;
        var cb = load8(bd + i) & 0xFF;
        if (ca != cb) { return ca - cb; }
        i += 1;
    }
    return alen - blen;
}

fn _cjh_is_ws(c) {
    if (c == 32 || c == 10 || c == 13 || c == 9) { return 1; }
    return 0;
}

fn _cjh_skip_ws(data, pos, slen) {
    while (pos < slen && _cjh_is_ws(load8(data + pos) & 0xFF) == 1) { pos += 1; }
    return pos;
}

# Skip past a string (incl. surrounding quotes); handles backslash escapes.
# Precondition: data[pos] == '"'. Returns position *after* the closing quote.
fn _cjh_skip_string(data, pos, slen) {
    pos += 1;
    var stop = 0;
    while (pos < slen && stop == 0) {
        var c = load8(data + pos) & 0xFF;
        if (c == 92) {
            pos += 2;
        } elif (c == 34) {
            pos += 1;
            stop = 1;
        } else {
            pos += 1;
        }
    }
    return pos;
}

# Skip past a bracket-balanced span starting at `open` (123='{' or 91='[').
fn _cjh_skip_container(data, pos, slen, open, close) {
    pos += 1;
    var depth = 1;
    while (pos < slen && depth > 0) {
        var c = load8(data + pos) & 0xFF;
        if (c == 34) {
            pos = _cjh_skip_string(data, pos, slen);
        } elif (c == open) {
            depth += 1;
            pos += 1;
        } elif (c == close) {
            depth -= 1;
            pos += 1;
        } else {
            pos += 1;
        }
    }
    return pos;
}

# Skip past a scalar (number / true / false / null) — stops at
# delimiter byte (whitespace, ',', '}', ']').
fn _cjh_skip_scalar(data, pos, slen) {
    while (pos < slen) {
        var c = load8(data + pos) & 0xFF;
        if (c == 44 || c == 125 || c == 93 || _cjh_is_ws(c) == 1) { return pos; }
        pos += 1;
    }
    return pos;
}

fn _cjh_skip_value(data, pos, slen) {
    pos = _cjh_skip_ws(data, pos, slen);
    if (pos >= slen) { return pos; }
    var c = load8(data + pos) & 0xFF;
    if (c == 34)  { return _cjh_skip_string(data, pos, slen); }
    if (c == 123) { return _cjh_skip_container(data, pos, slen, 123, 125); }
    if (c == 91)  { return _cjh_skip_container(data, pos, slen, 91, 93); }
    return _cjh_skip_scalar(data, pos, slen);
}

# Emit any JSON value starting at `pos`. Returns position after the value.
fn _cjh_emit(data, pos, slen, hasher) {
    pos = _cjh_skip_ws(data, pos, slen);
    if (pos >= slen) { return pos; }
    var c = load8(data + pos) & 0xFF;
    if (c == 123) { return _cjh_emit_object(data, pos, slen, hasher); }
    if (c == 91)  { return _cjh_emit_array(data, pos, slen, hasher); }
    if (c == 34)  {
        var end = _cjh_skip_string(data, pos, slen);
        hasher_update(hasher, data + pos, end - pos);
        return end;
    }
    # Scalar: emit trimmed bytes verbatim.
    var scalar_end = _cjh_skip_scalar(data, pos, slen);
    hasher_update(hasher, data + pos, scalar_end - pos);
    return scalar_end;
}

# Emit an object with keys sorted lexicographically. Parallel vecs hold
# each pair's key and its value byte-range in `data` so we can recurse
# into values after sort without materializing an AST.
fn _cjh_emit_object(data, start, slen, hasher) {
    var pos = start + 1;
    var keys = vec_new();
    var val_starts = vec_new();
    var val_ends = vec_new();

    var stop = 0;
    while (pos < slen && stop == 0) {
        pos = _cjh_skip_ws(data, pos, slen);
        if (pos >= slen) { stop = 1; }
        elif ((load8(data + pos) & 0xFF) == 125) { pos += 1; stop = 1; }
        elif ((load8(data + pos) & 0xFF) == 44) { pos += 1; }
        elif ((load8(data + pos) & 0xFF) == 34) {
            var key_start = pos + 1;
            pos = _cjh_skip_string(data, pos, slen);
            var key_end = pos - 1;
            var k = str_new(data + key_start, key_end - key_start);
            pos = _cjh_skip_ws(data, pos, slen);
            if (pos < slen && (load8(data + pos) & 0xFF) == 58) { pos += 1; }
            pos = _cjh_skip_ws(data, pos, slen);
            var vs = pos;
            pos = _cjh_skip_value(data, pos, slen);
            var ve = pos;
            vec_push(keys, k);
            vec_push(val_starts, vs);
            vec_push(val_ends, ve);
        } else {
            pos += 1;
        }
    }

    var n = vec_len(keys);
    var idx = vec_new();
    var i = 0;
    while (i < n) { vec_push(idx, i); i += 1; }

    # Insertion sort idx by keys[idx[i]] lexicographically.
    i = 1;
    while (i < n) {
        var ki = vec_get(idx, i);
        var j = i - 1;
        var settled = 0;
        while (j >= 0 && settled == 0) {
            var kj = vec_get(idx, j);
            if (_str_cmp(vec_get(keys, kj), vec_get(keys, ki)) > 0) {
                vec_set(idx, j + 1, kj);
                j -= 1;
            } else {
                settled = 1;
            }
        }
        vec_set(idx, j + 1, ki);
        i += 1;
    }

    hasher_update(hasher, "{", 1);
    i = 0;
    while (i < n) {
        if (i > 0) { hasher_update(hasher, ",", 1); }
        var j2 = vec_get(idx, i);
        var k2 = vec_get(keys, j2);
        hasher_update(hasher, "\"", 1);
        hasher_update(hasher, str_data(k2), str_len(k2));
        hasher_update(hasher, "\":", 2);
        _cjh_emit(data, vec_get(val_starts, j2), vec_get(val_ends, j2), hasher);
        i += 1;
    }
    hasher_update(hasher, "}", 1);
    return pos;
}

# Emit an array in original order.
fn _cjh_emit_array(data, start, slen, hasher) {
    var pos = start + 1;
    hasher_update(hasher, "[", 1);
    var count = 0;
    var stop = 0;
    while (pos < slen && stop == 0) {
        pos = _cjh_skip_ws(data, pos, slen);
        if (pos >= slen) { stop = 1; }
        elif ((load8(data + pos) & 0xFF) == 93) { pos += 1; stop = 1; }
        elif ((load8(data + pos) & 0xFF) == 44) { pos += 1; }
        else {
            if (count > 0) { hasher_update(hasher, ",", 1); }
            pos = _cjh_emit(data, pos, slen, hasher);
            count += 1;
        }
    }
    hasher_update(hasher, "]", 1);
    return pos;
}

# Convert Str to null-terminated C string (for json_get lookup)
fn _entry_to_cstr(s) {
    if (s == 0) { return ""; }
    var len = str_len(s);
    var buf = alloc(len + 1);
    memcpy(buf, str_data(s), len);
    store8(buf + len, 0);
    return buf;
}

# ================================================================
# Entry construction
# ================================================================

fn entry_new(severity, source, action, details, prev_hash) {
    var e = fl_alloc(88);

    # Generate UUID v4 (writes 16 bytes at e+0)
    uuid_v4(e);

    # Generate timestamp
    var ts = timestamp_rfc3339(get_epoch_secs());
    store64(e + 16, ts);

    store64(e + 24, severity);
    store64(e + 32, source);
    store64(e + 40, action);
    store64(e + 48, details);
    store64(e + 56, 0);
    store64(e + 64, prev_hash);
    store64(e + 80, str_from(HASH_ALGORITHM));

    # Compute and store hash
    var hash = entry_compute_hash(e);
    store64(e + 72, hash);
    return e;
}

fn entry_with_agent(e, agent_id) {
    store64(e + 56, agent_id);
    var hash = entry_compute_hash(e);
    store64(e + 72, hash);
    return e;
}

# Validated entry construction — checks field lengths
fn entry_new_validated(severity, source, action, details, prev_hash) {
    if (str_len(source) > MAX_SOURCE_LEN) {
        return error_field("source", str_len(source), MAX_SOURCE_LEN);
    }
    if (str_len(action) > MAX_ACTION_LEN) {
        return error_field("action", str_len(action), MAX_ACTION_LEN);
    }
    if (str_len(details) > MAX_DETAILS_SIZE) {
        return error_field("details", str_len(details), MAX_DETAILS_SIZE);
    }
    return entry_new(severity, source, action, details, prev_hash);
}

# ================================================================
# Hash computation — must match Rust field order exactly
# ================================================================
# Order: id(16 raw, no prefix) → timestamp → severity_str →
#         source → action → canonical_json(details) →
#         agent_id → prev_hash (all length-prefixed)

fn entry_compute_hash(e) {
    var hasher = hasher_new();

    # 1. UUID (16 raw bytes, no prefix)
    hasher_update(hasher, e, 16);

    # 2. Timestamp (length-prefixed)
    var ts = load64(e + 16);
    hash_field(hasher, str_data(ts), str_len(ts));

    # 3. Severity string (length-prefixed). severity_len avoids a strlen
    # on the constant cstr that severity_as_str returns.
    var sev_val = load64(e + 24);
    hash_field(hasher, severity_as_str(sev_val), severity_len(sev_val));

    # 4. Source (length-prefixed)
    var src = load64(e + 32);
    hash_field(hasher, str_data(src), str_len(src));

    # 5. Action (length-prefixed)
    var act = load64(e + 40);
    hash_field(hasher, str_data(act), str_len(act));

    # 6. Canonical JSON of details
    var det = load64(e + 48);
    canonical_json_hash_str(det, hasher);

    # 7. Agent ID (empty string if none, length-prefixed)
    var aid = load64(e + 56);
    if (aid == 0) {
        hash_field(hasher, "", 0);
    } else {
        hash_field(hasher, str_data(aid), str_len(aid));
    }

    # 8. Previous hash (length-prefixed)
    var ph = load64(e + 64);
    hash_field(hasher, str_data(ph), str_len(ph));

    return hasher_finalize_hex(hasher);
}

# ================================================================
# Entry verification — recompute hash and compare
# ================================================================

fn entry_verify(e) {
    var computed = entry_compute_hash(e);
    var stored = load64(e + 72);
    return constant_time_eq_str(computed, stored);
}

# --- verify.cyr ---

# verify.cyr — chain integrity verification
# Verifies self-hashes and hash linkage across a chain of entries.
#
# BREAKING 2.0: `verify_chain` now takes `base_index` as a second argument —
# the global index of entries[0] in the full chain (0 for a standalone chain,
# non-zero for a streaming/offset segment). `verify_chain_offset` was folded
# in. All in-tree call sites pass 0 unless verifying a sub-range.

fn verify_chain(entries, base_index) {
    sakshi_debug("verify: chain", 13);
    var n = vec_len(entries);
    if (n == 0) { return 0; }

    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);

        # Check self-hash
        var valid = entry_verify(e);
        if (valid == 0) {
            sakshi_error("verify: hash mismatch", 21);
            var computed = entry_compute_hash(e);
            var stored = entry_hash(e);
            return error_integrity(base_index + i, stored, computed);
        }

        # Check linkage to previous entry
        if (i > 0) {
            var prev = vec_get(entries, i - 1);
            var prev_h = entry_hash(prev);
            var this_prev = entry_prev_hash(e);
            if (constant_time_eq_str(this_prev, prev_h) == 0) {
                sakshi_error("verify: linkage broken", 22);
                return error_integrity(base_index + i, prev_h, this_prev);
            }
        }

        i += 1;
    }
    return 0;
}

# --- query.cyr ---

# query.cyr — composable query filters for audit entries
# All filter fields are optional (0 = unset). Conditions are ANDed.

# ================================================================
# QueryFilter layout (56 bytes, 7 fields x 8 bytes)
# ================================================================
#   +0   source        Str pointer (0 = any)
#   +8   severity      i64 (-1 = any, else exact SEV_* match)
#   +16  agent_id      Str pointer (0 = any)
#   +24  after         i64 epoch secs (0 = no lower bound)
#   +32  before        i64 epoch secs (0 = no upper bound)
#   +40  action        Str pointer (0 = any)
#   +48  min_severity  i64 (-1 = any, else >= threshold)

fn query_new() {
    var q = fl_alloc(56);
    store64(q, 0);
    store64(q + 8, -1);
    store64(q + 16, 0);
    store64(q + 24, 0);
    store64(q + 32, 0);
    store64(q + 40, 0);
    store64(q + 48, -1);
    return q;
}

# Builder methods — return the filter for chaining
fn query_source(q, source) {
    store64(q, source);
    return q;
}

fn query_severity(q, severity) {
    store64(q + 8, severity);
    return q;
}

fn query_agent_id(q, agent_id) {
    store64(q + 16, agent_id);
    return q;
}

fn query_after(q, epoch_secs) {
    store64(q + 24, epoch_secs);
    return q;
}

fn query_before(q, epoch_secs) {
    store64(q + 32, epoch_secs);
    return q;
}

fn query_action(q, action) {
    store64(q + 40, action);
    return q;
}

fn query_min_severity(q, min_sev) {
    store64(q + 48, min_sev);
    return q;
}

# ================================================================
# Match — test if an entry passes all filter conditions
# ================================================================
# Returns 1 if entry matches, 0 otherwise.
# Unset fields (0 or -1) are skipped (match anything).

fn query_matches(q, e) {
    # Source filter
    var qsrc = load64(q);
    if (qsrc != 0) {
        if (str_eq(entry_source(e), qsrc) == 0) { return 0; }
    }

    # Exact severity filter
    var qsev = load64(q + 8);
    if (qsev != -1) {
        if (entry_severity(e) != qsev) { return 0; }
    }

    # Agent ID filter
    var qaid = load64(q + 16);
    if (qaid != 0) {
        var eaid = entry_agent_id(e);
        if (eaid == 0) { return 0; }
        if (str_eq(eaid, qaid) == 0) { return 0; }
    }

    # Action filter
    var qact = load64(q + 40);
    if (qact != 0) {
        if (str_eq(entry_action(e), qact) == 0) { return 0; }
    }

    # Min severity filter
    var qmin = load64(q + 48);
    if (qmin != -1) {
        if (entry_severity(e) < qmin) { return 0; }
    }

    # After filter (exclusive: entry timestamp > after)
    var qafter = load64(q + 24);
    if (qafter != 0) {
        var ets = _query_parse_ts(entry_timestamp(e));
        if (ets <= qafter) { return 0; }
    }

    # Before filter (exclusive: entry timestamp < before)
    var qbefore = load64(q + 32);
    if (qbefore != 0) {
        var ets2 = _query_parse_ts(entry_timestamp(e));
        if (ets2 >= qbefore) { return 0; }
    }

    return 1;
}

# Parse RFC 3339 timestamp Str back to epoch seconds (simple parser)
# Expects "YYYY-MM-DDTHH:MM:SSZ" format
fn _query_parse_ts(ts) {
    var d = str_data(ts);
    var year = _parse_digits(d, 4);
    var month = _parse_digits(d + 5, 2);
    var day = _parse_digits(d + 8, 2);
    var hour = _parse_digits(d + 11, 2);
    var minute = _parse_digits(d + 14, 2);
    var second = _parse_digits(d + 17, 2);

    # Convert to epoch seconds (days since epoch + time of day)
    var days = _days_from_civil(year, month, day);
    return days * 86400 + hour * 3600 + minute * 60 + second;
}

fn _parse_digits(buf, count) {
    var result = 0;
    var i = 0;
    while (i < count) {
        result = result * 10 + ((load8(buf + i) & 0xFF) - 48);
        i += 1;
    }
    return result;
}

# Inverse of civil_from_days — civil date to days since epoch
fn _days_from_civil(y, m, d) {
    if (m <= 2) { y = y - 1; }
    var era = y / 400;
    if (y < 0) { era = (y - 399) / 400; }
    var yoe = y - era * 400;
    var mp = m;
    if (m > 2) { mp = m - 3; } else { mp = m + 9; }
    var doy = (153 * mp + 2) / 5 + d - 1;
    var doe = yoe * 365 + yoe / 4 - yoe / 100 + doy;
    return era * 146097 + doe - 719468;
}

# ================================================================
# Apply — filter a vec of entries, return vec of matching ptrs
# ================================================================

fn query_apply(q, entries) {
    var result = vec_new();
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (query_matches(q, e) == 1) {
            vec_push(result, e);
        }
        i += 1;
    }
    return result;
}

# --- retention.cyr ---

# retention.cyr — retention policies for audit chain lifecycle
# Determines which entries to archive vs retain.

# ================================================================
# RetentionPolicy types
# ================================================================

enum RetentionType {
    RETAIN_COUNT = 0;
    RETAIN_DURATION = 1;
    RETAIN_AFTER = 2;
}

# Layout — generated accessors: retention_kind, retention_value.
# Field named `kind` (not `type`; `type` shadows a Cyrius keyword).
# A `retention_type()` back-compat alias is kept below for 1.x callers.
#derive(accessors)
struct retention { kind; value; }

fn retention_type(r) { return retention_kind(r); }

fn retention_keep_count(n) {
    var r = fl_alloc(16);
    store64(r, RETAIN_COUNT);
    store64(r + 8, n);
    return r;
}

fn retention_keep_duration(secs) {
    var r = fl_alloc(16);
    store64(r, RETAIN_DURATION);
    store64(r + 8, secs);
    return r;
}

fn retention_keep_after(epoch_secs) {
    var r = fl_alloc(16);
    store64(r, RETAIN_AFTER);
    store64(r + 8, epoch_secs);
    return r;
}

# ================================================================
# Compliance presets
# ================================================================

fn retention_pci_dss() {
    return retention_keep_duration(365 * 86400);
}

fn retention_hipaa() {
    return retention_keep_duration(6 * 365 * 86400);
}

fn retention_sox() {
    return retention_keep_duration(7 * 365 * 86400);
}

fn retention_gdpr(purpose_duration_secs) {
    return retention_keep_duration(purpose_duration_secs);
}

# ================================================================
# split_index — returns the index where archives begin
# ================================================================
# Entries [0..split) are archived, [split..len) are retained.
# Returns 0 if nothing should be archived.

fn retention_split_index(r, entries) {
    var rtype = load64(r);
    var rval = load64(r + 8);
    var n = vec_len(entries);

    if (rtype == RETAIN_COUNT) {
        if (n <= rval) { return 0; }
        return n - rval;
    }

    if (rtype == RETAIN_DURATION) {
        var now = get_epoch_secs();
        var cutoff = now - rval;
        return _retention_first_after(entries, cutoff);
    }

    if (rtype == RETAIN_AFTER) {
        return _retention_first_after(entries, rval);
    }

    return 0;
}

# Find first entry with timestamp > cutoff
# Returns index, or vec_len(entries) if none found
fn _retention_first_after(entries, cutoff_secs) {
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var ts = _query_parse_ts(entry_timestamp(e));
        if (ts > cutoff_secs) {
            return i;
        }
        i += 1;
    }
    return n;
}

# --- chain.cyr ---

# chain.cyr — AuditChain and ChainArchive
# Hash-linked chain with auto-rotation, query, pagination, retention.
#
# 2.0: `#derive(accessors)` declares struct layouts once; the compiler
# emits getters/setters. Raw `load64(c + N)` / `store64(c + N, v)` forms
# still live inside this file for the few call sites that outpace the
# cost of a function call, but cross-module readers use the generated
# accessors so offset typos can't pass review.

# ================================================================
# ChainArchive — generated accessors: archive_entries, archive_head_hash
# ================================================================
#derive(accessors)
struct archive { entries; head_hash; }

fn archive_new(entries, head_hash) {
    var a = fl_alloc(16);
    store64(a, entries);
    store64(a + 8, head_hash);
    return a;
}

# ================================================================
# AuditChain — generated accessors:
#   chain_entries, chain_prev_hash, chain_max_capacity, chain_overflow
#   plus chain_set_* setters.
# ================================================================
#derive(accessors)
struct chain { entries; prev_hash; max_capacity; overflow; }

fn chain_new() {
    var c = fl_alloc(32);
    store64(c, vec_new());
    store64(c + 8, 0);
    store64(c + 16, 0);
    store64(c + 24, vec_new());
    return c;
}

fn chain_with_capacity(max_entries) {
    var c = chain_new();
    if (max_entries > 0) {
        chain_set_max_capacity(c, max_entries);
    }
    return c;
}

fn chain_len(c) {
    return vec_len(load64(c));
}

fn chain_is_empty(c) {
    if (chain_len(c) == 0) { return 1; }
    return 0;
}

fn chain_head_hash(c) {
    var entries = load64(c);
    var n = vec_len(entries);
    if (n == 0) { return 0; }
    var last = vec_get(entries, n - 1);
    return entry_hash(last);
}

# ================================================================
# Append — add entry to chain, auto-rotating if full
# ================================================================

fn chain_append(c, severity, source, action, details) {
    _chain_auto_rotate(c);

    # Determine prev_hash
    var prev = _chain_prev_link(c);
    var e = entry_new(severity, source, action, details, prev);
    vec_push(load64(c), e);
    sakshi_debug("chain: append", 13);
    return e;
}

# Batch-append N entries with one rotation check instead of N. Parallel
# vecs — severities[i] / sources[i] / actions[i] / details_vec[i] form the
# i-th entry. Returns a new vec of the created entry pointers.
#
# Capacity enforcement: auto-rotate is checked once at start, so a batch
# larger than `max_capacity` can exceed it for the duration of this call.
# The next `chain_append` / `chain_append_batch` will rotate as usual.
fn chain_append_batch(c, severities, sources, actions, details_vec) {
    _chain_auto_rotate(c);
    var n = vec_len(severities);
    var entries = load64(c);
    var out = vec_new();
    var prev = _chain_prev_link(c);
    var i = 0;
    while (i < n) {
        var e = entry_new(
            vec_get(severities, i),
            vec_get(sources, i),
            vec_get(actions, i),
            vec_get(details_vec, i),
            prev
        );
        vec_push(entries, e);
        vec_push(out, e);
        prev = entry_hash(e);
        i += 1;
    }
    sakshi_debug("chain: append batch", 19);
    return out;
}

fn chain_append_with_agent(c, severity, source, action, details, agent_id) {
    _chain_auto_rotate(c);

    var prev = _chain_prev_link(c);
    var e = entry_new(severity, source, action, details, prev);
    entry_with_agent(e, agent_id);
    vec_push(load64(c), e);
    return e;
}

# Get the prev_hash for a new entry
fn _chain_prev_link(c) {
    var entries = load64(c);
    var n = vec_len(entries);
    if (n > 0) {
        var last = vec_get(entries, n - 1);
        return entry_hash(last);
    }
    var pch = load64(c + 8);
    if (pch != 0) {
        return pch;
    }
    return str_from("");
}

# ================================================================
# Auto-rotation — archive entries when capacity reached
# ================================================================

fn _chain_auto_rotate(c) {
    var cap = load64(c + 16);
    if (cap == 0) { return 0; }
    var entries = load64(c);
    if (vec_len(entries) >= cap) {
        sakshi_info("chain: auto-rotate at capacity", 30);
        var arch = chain_rotate(c);
        vec_push(load64(c + 24), arch);
    }
    return 0;
}

# ================================================================
# Rotate — drain entries to archive, reset chain
# ================================================================

fn chain_rotate(c) {
    var entries = load64(c);
    var n = vec_len(entries);
    sakshi_info("chain: rotate", 13);

    var head = str_from("");
    if (n > 0) {
        var last = vec_get(entries, n - 1);
        head = entry_hash(last);
    }

    var arch = archive_new(entries, head);

    # Reset chain with empty entries, set prev_chain_hash
    store64(c, vec_new());
    if (n > 0) {
        store64(c + 8, head);
    }

    return arch;
}

# Take and clear overflow archives
fn chain_take_overflow(c) {
    var ov = load64(c + 24);
    store64(c + 24, vec_new());
    return ov;
}

# ================================================================
# From entries — create chain from existing entries
# ================================================================

fn chain_from_entries(entries) {
    var c = fl_alloc(32);
    store64(c, entries);
    store64(c + 8, 0);
    store64(c + 16, 0);
    store64(c + 24, vec_new());
    return c;
}

# ================================================================
# Verification — check integrity of the chain
# ================================================================
#
# Two-layer split (not duplication):
#   - `verify_chain(entries, base_index)` in verify.cyr — entry-level:
#     self-hash + adjacent linkage across a vec of entries. No knowledge
#     of AuditChain struct, genesis, or rotation state. Usable on
#     chunks, file-loaded slices, and archives.
#   - `chain_verify(c)` below — struct-level: adds the genesis prev_hash
#     check against `prev_chain_hash` (slot +8), then delegates entry-
#     level work to `verify_chain`.
# Keep the split: consumers verifying loose vecs (FileStore, stream) call
# verify_chain directly; consumers with a live AuditChain call chain_verify.

fn chain_verify(c) {
    sakshi_debug("chain: verify", 13);
    var entries = load64(c);
    var n = vec_len(entries);
    if (n == 0) { return 0; }

    # Check genesis entry's prev_hash matches prev_chain_hash
    var first = vec_get(entries, 0);
    var first_prev = entry_prev_hash(first);
    var expected_prev = load64(c + 8);
    if (expected_prev == 0) {
        expected_prev = str_from("");
    }
    if (constant_time_eq_str(first_prev, expected_prev) == 0) {
        return error_integrity(0, expected_prev, first_prev);
    }

    return verify_chain(entries, 0);
}

# ================================================================
# Query / filter / pagination
# ================================================================

fn chain_by_source(c, source) {
    var result = vec_new();
    var entries = load64(c);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (str_eq(entry_source(e), source) == 1) {
            vec_push(result, e);
        }
        i += 1;
    }
    return result;
}

fn chain_by_severity(c, severity) {
    var result = vec_new();
    var entries = load64(c);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (entry_severity(e) == severity) {
            vec_push(result, e);
        }
        i += 1;
    }
    return result;
}

fn chain_by_agent(c, agent_id) {
    var result = vec_new();
    var entries = load64(c);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var eaid = entry_agent_id(e);
        if (eaid != 0) {
            if (str_eq(eaid, agent_id) == 1) {
                vec_push(result, e);
            }
        }
        i += 1;
    }
    return result;
}

fn chain_query(c, filter) {
    return query_apply(filter, load64(c));
}

# Pagination — returns a vec of entries from offset with limit
fn chain_page(c, offset, limit) {
    var entries = load64(c);
    var n = vec_len(entries);
    var start = offset;
    if (start > n) { start = n; }
    var end = start + limit;
    if (end > n) { end = n; }

    var result = vec_new();
    var i = start;
    while (i < end) {
        vec_push(result, vec_get(entries, i));
        i += 1;
    }
    return result;
}

# ================================================================
# Retention — archive old entries per policy
# ================================================================
# Returns archive pointer, or 0 if nothing archived.

fn chain_apply_retention(c, policy) {
    sakshi_info("chain: apply retention", 22);
    var entries = load64(c);
    var n = vec_len(entries);
    var split = retention_split_index(policy, entries);

    if (split == 0) { return 0; }

    # Split entries: [0..split) = archive, [split..n) = retained
    var archived = vec_new();
    var retained = vec_new();
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (i < split) {
            vec_push(archived, e);
        } else {
            vec_push(retained, e);
        }
        i += 1;
    }

    # Head hash of last archived entry
    var head = str_from("");
    if (vec_len(archived) > 0) {
        var last_arch = vec_get(archived, vec_len(archived) - 1);
        head = entry_hash(last_arch);
    }

    # Update chain
    store64(c, retained);
    store64(c + 8, head);

    return archive_new(archived, head);
}

# --- store.cyr ---

# store.cyr — MemoryStore audit backend
# In-memory storage with verification and query support.
# Cyrius has no traits — MemoryStore is the concrete implementation.
# FileStore / SqliteStore can follow the same function naming pattern.

# ================================================================
# MemoryStore — generated accessors: memstore_entries, memstore_set_entries
# ================================================================
#derive(accessors)
struct memstore { entries; }

fn memstore_new() {
    var s = fl_alloc(8);
    store64(s, vec_new());
    return s;
}

fn memstore_len(s) {
    return vec_len(load64(s));
}

fn memstore_is_empty(s) {
    if (memstore_len(s) == 0) { return 1; }
    return 0;
}

# ================================================================
# Append — add entry to store
# ================================================================

fn memstore_append(s, e) {
    vec_push(load64(s), e);
    sakshi_debug("store: append", 13);
    return 0;
}

# ================================================================
# Load all entries
# ================================================================

fn memstore_load_all(s) {
    return load64(s);
}

# ================================================================
# Load and verify — load all entries, verify chain integrity
# ================================================================

fn memstore_load_and_verify(s) {
    sakshi_info("store: load and verify", 22);
    var entries = load64(s);
    var err = verify_chain(entries, 0);
    if (err != 0) {
        sakshi_error("store: verification failed", 26);
        return err;
    }
    return entries;
}

# ================================================================
# Streaming verification — O(chunk_size) memory
# ================================================================
# Returns total verified count on success, or error pointer on failure.

fn memstore_verify_streamed(s, chunk_size) {
    if (chunk_size < 1) { chunk_size = 1; }
    var entries = load64(s);
    var n = vec_len(entries);
    var verified = 0;
    var prev_tail_hash = str_from("");
    var offset = 0;

    while (offset < n) {
        # Build chunk
        var chunk = vec_new();
        var end = offset + chunk_size;
        if (end > n) { end = n; }
        var i = offset;
        while (i < end) {
            vec_push(chunk, vec_get(entries, i));
            i += 1;
        }

        var clen = vec_len(chunk);

        # Check cross-chunk boundary linkage
        if (offset > 0 && clen > 0) {
            var first = vec_get(chunk, 0);
            var fp = entry_prev_hash(first);
            if (constant_time_eq_str(fp, prev_tail_hash) == 0) {
                return error_integrity(offset, prev_tail_hash, fp);
            }
        }

        # Verify internal integrity
        var err = verify_chain(chunk, offset);
        if (err != 0) { return err; }

        # Track tail hash for next chunk
        if (clen > 0) {
            var last = vec_get(chunk, clen - 1);
            prev_tail_hash = entry_hash(last);
        }

        verified = verified + clen;
        offset = end;
    }

    return verified;
}

# ================================================================
# Query — apply filter to store
# ================================================================

fn memstore_query(s, filter) {
    return query_apply(filter, load64(s));
}

# ================================================================
# Pagination — load a page of entries
# ================================================================

fn memstore_load_page(s, offset, limit) {
    var entries = load64(s);
    var n = vec_len(entries);
    var start = offset;
    if (start > n) { start = n; }
    var end = start + limit;
    if (end > n) { end = n; }

    var result = vec_new();
    var i = start;
    while (i < end) {
        vec_push(result, vec_get(entries, i));
        i += 1;
    }
    return result;
}

# --- export.cyr ---

# export.cyr — export audit entries as JSON Lines or CSV
# Writes to a file descriptor (fd).

# Append a single byte to a str_builder. Inlined variant of
# str_builder_add_cstr for the hot per-character path in escape loops —
# skips strlen + memcpy + the 2-byte scratch alloc that a cstr route
# would pay per character.
fn _sb_add_byte(sb, c) {
    _sb_grow(sb, 1);
    var buf = load64(sb);
    var len = load64(sb + 8);
    store8(buf + len, c);
    store64(sb + 8, len + 1);
    return 0;
}

# ================================================================
# JSON Lines export — one JSON object per line
# ================================================================

fn export_jsonl(entries, fd) {
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        _export_entry_json(e, fd);
        file_write(fd, "\n", 1);
        i += 1;
    }
    return 0;
}

# Write a single entry as a JSON object
fn _export_entry_json(e, fd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"id\":\"");
        str_builder_add(sb, uuid_format(entry_id(e)));
        str_builder_add_cstr(sb, "\",\"timestamp\":\"");
        str_builder_add(sb, entry_timestamp(e));
        str_builder_add_cstr(sb, "\",\"severity\":\"");
        str_builder_add_cstr(sb, severity_as_str(entry_severity(e)));
        str_builder_add_cstr(sb, "\",\"source\":\"");
        _sb_json_escape(sb, entry_source(e));
        str_builder_add_cstr(sb, "\",\"action\":\"");
        _sb_json_escape(sb, entry_action(e));
        str_builder_add_cstr(sb, "\",\"details\":");
        str_builder_add(sb, entry_details(e));
        str_builder_add_cstr(sb, ",\"agent_id\":");
        var aid = entry_agent_id(e);
        if (aid == 0) {
            str_builder_add_cstr(sb, "null");
        } else {
            str_builder_add_cstr(sb, "\"");
            _sb_json_escape(sb, aid);
            str_builder_add_cstr(sb, "\"");
        }
        str_builder_add_cstr(sb, ",\"prev_hash\":\"");
        str_builder_add(sb, entry_prev_hash(e));
        str_builder_add_cstr(sb, "\",\"hash\":\"");
        str_builder_add(sb, entry_hash(e));
        str_builder_add_cstr(sb, "\",\"hash_algorithm\":\"");
        str_builder_add(sb, entry_hash_algorithm(e));
        str_builder_add_cstr(sb, "\"}");

    var s = str_builder_build(sb);
    file_write(fd, str_data(s), str_len(s));
    return 0;
}

# Escape a Str for JSON (handle quotes and backslashes)
fn _sb_json_escape(sb, s) {
    var data = str_data(s);
    var slen = str_len(s);
    var i = 0;
    while (i < slen) {
        var c = load8(data + i) & 0xFF;
        if (c == 34) {
            str_builder_add_cstr(sb, "\\\"");
        }
        if (c == 92) {
            str_builder_add_cstr(sb, "\\\\");
        }
        if (c == 10) {
            str_builder_add_cstr(sb, "\\n");
        }
        if (c != 34 && c != 92 && c != 10) {
            _sb_add_byte(sb, c);
        }
        i += 1;
    }
    return 0;
}

# ================================================================
# CSV export — header + one row per entry
# ================================================================

var _csv_header = "id,timestamp,severity,source,action,details,agent_id,prev_hash,hash\n";

fn export_csv(entries, fd) {
    file_write(fd, _csv_header, strlen(_csv_header));

    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        _export_entry_csv(e, fd);
        i += 1;
    }
    return 0;
}

fn _export_entry_csv(e, fd) {
    var sb = str_builder_new();

    # id
    str_builder_add(sb, uuid_format(entry_id(e)));
    str_builder_add_cstr(sb, ",");

    # timestamp
    str_builder_add(sb, entry_timestamp(e));
    str_builder_add_cstr(sb, ",");

    # severity
    str_builder_add_cstr(sb, severity_as_str(entry_severity(e)));
    str_builder_add_cstr(sb, ",");

    # source (escaped)
    _sb_csv_field(sb, entry_source(e));
    str_builder_add_cstr(sb, ",");

    # action (escaped)
    _sb_csv_field(sb, entry_action(e));
    str_builder_add_cstr(sb, ",");

    # details (escaped)
    _sb_csv_field(sb, entry_details(e));
    str_builder_add_cstr(sb, ",");

    # agent_id (escaped, empty if none)
    var aid = entry_agent_id(e);
    if (aid == 0) {
        # empty field
    } else {
        _sb_csv_field(sb, aid);
    }
    str_builder_add_cstr(sb, ",");

    # prev_hash
    str_builder_add(sb, entry_prev_hash(e));
    str_builder_add_cstr(sb, ",");

    # hash
    str_builder_add(sb, entry_hash(e));
    str_builder_add_cstr(sb, "\n");

    var s = str_builder_build(sb);
    file_write(fd, str_data(s), str_len(s));
    return 0;
}

# CSV field escaping: wrap in quotes if field contains comma, quote, or newline.
# Double all internal quotes. Single scan to decide quoting; on the escape path,
# one pre-grown buffer + direct byte writes (no per-char fn calls).
fn _sb_csv_field(sb, s) {
    var data = str_data(s);
    var slen = str_len(s);

    var needs_quote = 0;
    var i = 0;
    while (i < slen) {
        var c = load8(data + i) & 0xFF;
        if (c == 44 || c == 34 || c == 10) { needs_quote = 1; i = slen; }
        i += 1;
    }

    if (needs_quote == 0) {
        str_builder_add(sb, s);
        return 0;
    }

    # Worst case: every byte is a quote → doubled. +2 for surrounding quotes.
    _sb_grow(sb, slen * 2 + 2);
    var buf = load64(sb);
    var out = load64(sb + 8);
    store8(buf + out, 34);
    out += 1;
    i = 0;
    while (i < slen) {
        var c = load8(data + i) & 0xFF;
        store8(buf + out, c);
        out += 1;
        if (c == 34) {
            store8(buf + out, 34);
            out += 1;
        }
        i += 1;
    }
    store8(buf + out, 34);
    out += 1;
    store64(sb + 8, out);
    return 0;
}

# --- review.cyr ---

# review.cyr — structured chain review and integrity audit
# Generates a summary report of chain contents and health.

# ================================================================
# IntegrityStatus constants
# ================================================================

enum IntegrityStat {
    INTEGRITY_VALID = 0;
    INTEGRITY_EMPTY = 1;
    INTEGRITY_INVALID = 2;
}

# IntegrityStatus — generated accessors: integrity_status, integrity_message
#derive(accessors)
struct integrity { status; message; }

fn integrity_valid() {
    var s = fl_alloc(16);
    store64(s, INTEGRITY_VALID);
    store64(s + 8, 0);
    return s;
}

fn integrity_empty() {
    var s = fl_alloc(16);
    store64(s, INTEGRITY_EMPTY);
    store64(s + 8, 0);
    return s;
}

fn integrity_invalid(msg) {
    var s = fl_alloc(16);
    store64(s, INTEGRITY_INVALID);
    store64(s + 8, msg);
    return s;
}

fn integrity_as_str(s) {
    var st = load64(s);
    if (st == INTEGRITY_VALID) { return "VALID"; }
    if (st == INTEGRITY_EMPTY) { return "EMPTY"; }
    return "INVALID";
}

# ================================================================
# ChainReview — generated accessors:
#   review_entry_count, review_integrity, review_earliest, review_latest,
#   review_sources, review_severities, review_agents,
#   review_head_hash, review_continued_from
# ================================================================
#derive(accessors)
struct review { entry_count; integrity; earliest; latest; sources; severities; agents; head_hash; continued_from; }

# ================================================================
# Generate review from chain
# ================================================================

fn chain_review(c) {
    var r = fl_alloc(72);
    var entries = chain_entries(c);
    var n = vec_len(entries);

    store64(r, n);

    # Determine integrity
    if (n == 0) {
        store64(r + 8, integrity_empty());
    } else {
        var err = chain_verify(c);
        if (err == 0) {
            store64(r + 8, integrity_valid());
        } else {
            store64(r + 8, integrity_invalid(str_from(error_msg(err))));
        }
    }

    # Initialize count maps
    var sources = map_new();
    var severities = map_new();
    var agents = map_new();

    # Iterate entries and count
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);

        # Count source
        var src_cstr = _entry_to_cstr(entry_source(e));
        var src_count = map_get(sources, src_cstr);
        map_set(sources, src_cstr, src_count + 1);

        # Count severity
        var sev_str = severity_as_str(entry_severity(e));
        var sev_count = map_get(severities, sev_str);
        map_set(severities, sev_str, sev_count + 1);

        # Count agent
        var aid = entry_agent_id(e);
        var aid_cstr = "(none)";
        if (aid != 0) {
            aid_cstr = _entry_to_cstr(aid);
        }
        var aid_count = map_get(agents, aid_cstr);
        map_set(agents, aid_cstr, aid_count + 1);

        i += 1;
    }

    store64(r + 32, sources);
    store64(r + 40, severities);
    store64(r + 48, agents);

    # Timestamps
    if (n > 0) {
        var first = vec_get(entries, 0);
        store64(r + 16, entry_timestamp(first));
        var last = vec_get(entries, n - 1);
        store64(r + 24, entry_timestamp(last));
        store64(r + 56, entry_hash(last));
    } else {
        store64(r + 16, 0);
        store64(r + 24, 0);
        store64(r + 56, 0);
    }

    store64(r + 64, chain_prev_hash(c));

    return r;
}

# ================================================================
# Print review to stdout
# ================================================================

fn review_print(r) {
    println("=== Chain Review ===");

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "Entries:    ");
    str_builder_add_int(sb, review_entry_count(r));
    var line = str_builder_build(sb);
    str_println(line);

    sb = str_builder_new();
    str_builder_add_cstr(sb, "Integrity:  ");
    str_builder_add_cstr(sb, integrity_as_str(review_integrity(r)));
    var ist = review_integrity(r);
    if (integrity_status(ist) == INTEGRITY_INVALID) {
        str_builder_add_cstr(sb, ": ");
        str_builder_add(sb, integrity_message(ist));
    }
    line = str_builder_build(sb);
    str_println(line);

    var earliest = review_earliest(r);
    if (earliest != 0) {
        sb = str_builder_new();
        str_builder_add_cstr(sb, "Earliest:   ");
        str_builder_add(sb, earliest);
        str_println(str_builder_build(sb));
    }

    var latest = review_latest(r);
    if (latest != 0) {
        sb = str_builder_new();
        str_builder_add_cstr(sb, "Latest:     ");
        str_builder_add(sb, latest);
        str_println(str_builder_build(sb));
    }

    var head = review_head_hash(r);
    if (head != 0) {
        sb = str_builder_new();
        str_builder_add_cstr(sb, "Head:       ");
        # Abbreviate to first 16 chars
        if (str_len(head) > 16) {
            str_builder_add(sb, str_sub(head, 0, 16));
            str_builder_add_cstr(sb, "...");
        } else {
            str_builder_add(sb, head);
        }
        str_println(str_builder_build(sb));
    }

    var cont = review_continued_from(r);
    if (cont != 0) {
        sb = str_builder_new();
        str_builder_add_cstr(sb, "Continues:  ");
        if (str_len(cont) > 16) {
            str_builder_add(sb, str_sub(cont, 0, 16));
            str_builder_add_cstr(sb, "...");
        } else {
            str_builder_add(sb, cont);
        }
        str_println(str_builder_build(sb));
    }

    # Sources
    println("Sources:");
    _review_print_map(review_sources(r));

    # Severities
    println("Severities:");
    _review_print_map(review_severities(r));

    # Agents
    println("Agents:");
    _review_print_map(review_agents(r));

    return 0;
}

fn _review_print_map(m) {
    var keys = map_keys(m);
    var n = vec_len(keys);
    var i = 0;
    while (i < n) {
        var k = vec_get(keys, i);
        var v = map_get(m, k);
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "  ");
        str_builder_add_cstr(sb, k);
        str_builder_add_cstr(sb, ": ");
        str_builder_add_int(sb, v);
        str_println(str_builder_build(sb));
        i += 1;
    }
    return 0;
}

# --- merkle.cyr ---

# merkle.cyr — Merkle tree, inclusion proofs, RFC 9162 consistency proofs
# Binary hash tree built from audit entry hashes.

# ================================================================
# Side enum
# ================================================================

enum MerkleSide {
    SIDE_LEFT = 0;
    SIDE_RIGHT = 1;
}

# ================================================================
# ProofNode — generated accessors: proof_node_hash, proof_node_side
# ================================================================
#derive(accessors)
struct proof_node { hash; side; }

fn proof_node_new(hash, side) {
    var pn = fl_alloc(16);
    store64(pn, hash);
    store64(pn + 8, side);
    return pn;
}

# ================================================================
# MerkleProof — generated accessors:
#   merkle_proof_index, merkle_proof_leaf, merkle_proof_path, merkle_proof_root
# The struct name shadows what was the `merkle_proof(tree, idx)` function
# in 1.x; that function is now `merkle_inclusion_proof`.
# ================================================================
#derive(accessors)
struct merkle_proof { index; leaf; path; root; }

fn merkle_proof_new(index, leaf_hash, path, root) {
    var mp = fl_alloc(32);
    store64(mp, index);
    store64(mp + 8, leaf_hash);
    store64(mp + 16, path);
    store64(mp + 24, root);
    return mp;
}

# ================================================================
# ConsistencyProof — generated accessors:
#   consistency_old_size, consistency_new_size,
#   consistency_old_root, consistency_new_root, consistency_path
# ================================================================
#derive(accessors)
struct consistency { old_size; new_size; old_root; new_root; path; }

fn consistency_proof_new(old_size, new_size, old_root, new_root, path) {
    var cp = fl_alloc(40);
    store64(cp, old_size);
    store64(cp + 8, new_size);
    store64(cp + 16, old_root);
    store64(cp + 24, new_root);
    store64(cp + 32, path);
    return cp;
}

# ================================================================
# MerkleTree — generated accessors: merkle_tree_nodes, merkle_tree_leaf_count
# ================================================================
#derive(accessors)
struct merkle_tree { nodes; leaf_count; }

fn merkle_tree_root(t) {
    var nodes = load64(t);
    var n = vec_len(nodes);
    if (n == 0) { return str_from(""); }
    return vec_get(nodes, n - 1);
}

# ================================================================
# Hash pair — parent hash from two children
# ================================================================

fn _merkle_hash_pair(left, right) {
    var h = hasher_new();
    hasher_update(h, str_data(left), str_len(left));
    hasher_update(h, str_data(right), str_len(right));
    return hasher_finalize_hex(h);
}

# ================================================================
# Build tree from entries — O(n) time
# ================================================================

fn merkle_build(entries) {
    var n = vec_len(entries);
    if (n == 0) { return 0; }

    var nodes = vec_new();

    # Extract leaf hashes
    var leaves = vec_new();
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        vec_push(leaves, entry_hash(e));
        i += 1;
    }

    # Build levels bottom-up
    var current = leaves;
    while (vec_len(current) > 1) {
        # Add current level to nodes
        var cl = vec_len(current);
        i = 0;
        while (i < cl) {
            vec_push(nodes, vec_get(current, i));
            i += 1;
        }

        # Compute next level
        var next = vec_new();
        i = 0;
        while (i < cl) {
            var left = vec_get(current, i);
            var right = left;
            if (i + 1 < cl) {
                right = vec_get(current, i + 1);
            }
            vec_push(next, _merkle_hash_pair(left, right));
            i = i + 2;
        }
        current = next;
    }

    # Add root
    vec_push(nodes, vec_get(current, 0));

    var t = fl_alloc(16);
    store64(t, nodes);
    store64(t + 8, n);
    return t;
}

# ================================================================
# Inclusion proof — O(log n)
# ================================================================

fn merkle_inclusion_proof(tree, index) {
    var leaf_count = load64(tree + 8);
    if (index >= leaf_count) { return 0; }

    var nodes = load64(tree);
    var path = vec_new();
    var level_start = 0;
    var level_size = leaf_count;
    var idx = index;

    while (level_size > 1) {
        var sibling_idx = idx;
        if ((idx & 1) == 0) {
            sibling_idx = idx + 1;
        } else {
            sibling_idx = idx - 1;
        }

        var sibling_hash = 0;
        if (sibling_idx < level_size) {
            sibling_hash = vec_get(nodes, level_start + sibling_idx);
        } else {
            sibling_hash = vec_get(nodes, level_start + idx);
        }

        var side = SIDE_RIGHT;
        if ((idx & 1) != 0) {
            side = SIDE_LEFT;
        }

        vec_push(path, proof_node_new(sibling_hash, side));

        level_start = level_start + level_size;
        level_size = (level_size + 1) / 2;
        idx = idx / 2;
    }

    var leaf_hash = vec_get(nodes, index);
    var root = merkle_tree_root(tree);
    return merkle_proof_new(index, leaf_hash, path, root);
}

# ================================================================
# Verify inclusion proof — O(log n)
# ================================================================

fn merkle_verify_proof(mp) {
    var current = merkle_proof_leaf(mp);
    var path = merkle_proof_path(mp);
    var n = vec_len(path);
    var i = 0;
    while (i < n) {
        var node = vec_get(path, i);
        var nh = proof_node_hash(node);
        var ns = proof_node_side(node);
        if (ns == SIDE_LEFT) {
            current = _merkle_hash_pair(nh, current);
        } else {
            current = _merkle_hash_pair(current, nh);
        }
        i += 1;
    }
    return constant_time_eq_str(current, merkle_proof_root(mp));
}

# ================================================================
# Largest power of 2 less than n
# ================================================================

fn _largest_pow2_lt(n) {
    var k = 1;
    while (k < n) {
        k = k * 2;
    }
    k = k / 2;
    if (k == n) { k = k / 2; }
    if (k == 0) { k = 1; }
    return k;
}

# ================================================================
# Canonical subtree hash — RFC 9162 no-duplication root
# ================================================================

fn _canonical_subtree_hash(nodes_vec, start, count) {
    if (count == 1) {
        return vec_get(nodes_vec, start);
    }
    var k = _largest_pow2_lt(count);
    var left = _canonical_subtree_hash(nodes_vec, start, k);
    var right = _canonical_subtree_hash(nodes_vec, start + k, count - k);
    return _merkle_hash_pair(left, right);
}

# Canonical root from leaf nodes only (RFC 9162 §2.1.2)
fn merkle_canonical_root(tree, size) {
    if (size == 0) { return 0; }
    var lc = load64(tree + 8);
    if (size > lc) { return 0; }
    var nodes = load64(tree);
    # We need just the leaf nodes (first leaf_count entries in nodes vec)
    return _canonical_subtree_hash(nodes, 0, size);
}

# ================================================================
# Consistency proof — RFC 9162 append-only proof
# ================================================================

var _sp_path = 0;
var _sp_nodes = 0;

fn merkle_consistency_proof(tree, old_size) {
    var leaf_count = load64(tree + 8);
    if (old_size == 0 || old_size > leaf_count) { return 0; }

    var nodes = load64(tree);
    var old_root = _canonical_subtree_hash(nodes, 0, old_size);
    var new_root = _canonical_subtree_hash(nodes, 0, leaf_count);

    if (old_size == leaf_count) {
        return consistency_proof_new(old_size, leaf_count, old_root, new_root, vec_new());
    }

    _sp_path = vec_new();
    _sp_nodes = nodes;
    _subproof(old_size, 0, leaf_count, 1);

    return consistency_proof_new(old_size, leaf_count, old_root, new_root, _sp_path);
}

# RFC 9162 SUBPROOF recursive algorithm
fn _subproof(m, start, n, is_complete) {
    if (m == n) {
        if (is_complete == 0) {
            vec_push(_sp_path, _canonical_subtree_hash(_sp_nodes, start, n));
        }
        return 0;
    }
    if (n == 1) {
        if (is_complete == 0) {
            vec_push(_sp_path, vec_get(_sp_nodes, start));
        }
        return 0;
    }
    var k = _largest_pow2_lt(n);
    if (m <= k) {
        _subproof(m, start, k, is_complete);
        vec_push(_sp_path, _canonical_subtree_hash(_sp_nodes, start + k, n - k));
    } else {
        _subproof(m - k, start + k, n - k, 0);
        vec_push(_sp_path, _canonical_subtree_hash(_sp_nodes, start, k));
    }
    return 0;
}

# ================================================================
# Verify consistency proof — RFC 9162 §2.1.4.2
# ================================================================

fn _is_power_of_2(n) {
    if (n <= 0) { return 0; }
    if ((n & (n - 1)) == 0) { return 1; }
    return 0;
}

fn merkle_verify_consistency(cp) {
    var old_size = load64(cp);
    var new_size = load64(cp + 8);
    var old_root = load64(cp + 16);
    var new_root = load64(cp + 24);
    var path = load64(cp + 32);

    if (old_size == 0 || old_size > new_size) { return 0; }

    if (old_size == new_size) {
        if (vec_len(path) != 0) { return 0; }
        return constant_time_eq_str(old_root, new_root);
    }

    # Build working path — prepend old_root if old_size is power of 2
    var working = vec_new();
    if (_is_power_of_2(old_size) == 1) {
        vec_push(working, old_root);
    }
    var pi = 0;
    while (pi < vec_len(path)) {
        vec_push(working, vec_get(path, pi));
        pi += 1;
    }

    if (vec_len(working) == 0) { return 0; }

    var fn_val = old_size - 1;
    var sn_val = new_size - 1;

    # Right-shift both while LSB of fn is set
    while ((fn_val & 1) == 1) {
        fn_val = fn_val >> 1;
        sn_val = sn_val >> 1;
    }

    var fr = vec_get(working, 0);
    var sr = vec_get(working, 0);

    var wi = 1;
    while (wi < vec_len(working)) {
        var c = vec_get(working, wi);
        if (sn_val == 0) { return 0; }

        if (((fn_val & 1) == 1) || fn_val == sn_val) {
            fr = _merkle_hash_pair(c, fr);
            sr = _merkle_hash_pair(c, sr);
            while (fn_val != 0 && ((fn_val & 1) == 0)) {
                fn_val = fn_val >> 1;
                sn_val = sn_val >> 1;
            }
        } else {
            sr = _merkle_hash_pair(sr, c);
        }

        fn_val = fn_val >> 1;
        sn_val = sn_val >> 1;
        wi += 1;
    }

    if (sn_val != 0) { return 0; }
    if (constant_time_eq_str(fr, old_root) == 0) { return 0; }
    if (constant_time_eq_str(sr, new_root) == 0) { return 0; }
    return 1;
}

# --- signing.cyr ---

# signing.cyr — cryptographic signing for audit entries
#
# Three algorithms supported, dispatched at runtime via the
# `algorithm` field on signing_key / verifying_key / entry_sig:
#
#   SIG_ALG_ED25519     — 64-byte signatures, RFC 8032
#   SIG_ALG_ML_DSA_65   — 3309-byte signatures, NIST FIPS 204
#   SIG_ALG_HYBRID      — Ed25519 + ML-DSA-65 produced together;
#                         verify-AND under both primitives
#
# All three delegate to sigil. The struct layouts carry up to
# two key-material slots so the same shape covers single-alg
# (slot-2 == 0) and hybrid (both slots populated) entries.

# ================================================================
# SigningKey — generated accessors:
#   signing_key_bytes, signing_key_pub_bytes, signing_key_algorithm,
#   signing_key_key_id, signing_key_zeroized, signing_key_seed,
#   signing_key_bytes_2, signing_key_pub_bytes_2, signing_key_seed_2
#   plus `_set_` setters for each.
#
# Slot 1 (bytes / pub_bytes / seed):
#   Ed25519 sk/pk/seed — for SIG_ALG_ED25519 and SIG_ALG_HYBRID
#   ML-DSA-65 sk/pk/seed — for SIG_ALG_ML_DSA_65
# Slot 2 (bytes_2 / pub_bytes_2 / seed_2):
#   ML-DSA-65 sk/pk/seed — for SIG_ALG_HYBRID only; 0 otherwise
# ================================================================
#derive(accessors)
struct signing_key { bytes; pub_bytes; algorithm; key_id; zeroized; seed; bytes_2; pub_bytes_2; seed_2; }

# Per-algorithm sizes. Centralized here so add-an-algorithm changes
# stay localized — no scattered `64` or `MLDSA65_SK_BYTES` literals
# in the dispatch fns below.
fn _sig_pk_bytes(alg) {
    if (alg == SIG_ALG_ED25519)   { return 32; }
    if (alg == SIG_ALG_ML_DSA_65) { return MLDSA65_PK_BYTES; }
    return 0;
}

fn _sig_sk_bytes(alg) {
    if (alg == SIG_ALG_ED25519)   { return 64; }
    if (alg == SIG_ALG_ML_DSA_65) { return MLDSA65_SK_BYTES; }
    return 0;
}

fn _sig_sig_bytes(alg) {
    if (alg == SIG_ALG_ED25519)   { return 64; }
    if (alg == SIG_ALG_ML_DSA_65) { return MLDSA65_SIG_BYTES; }
    return 0;
}

fn signing_key_generate() {
    sakshi_info("signing: key generate", 21);
    var sk = fl_alloc(72);
    var sk_bytes = alloc(64);
    var pk_bytes = alloc(32);
    var seed = alloc(32);
    secret var seed_stack[32];
    random_bytes(&seed_stack, 32);
    memcpy(seed, &seed_stack, 32);
    ed25519_keypair(seed, sk_bytes, pk_bytes);
    store64(sk, sk_bytes);
    store64(sk + 8, pk_bytes);
    store64(sk + 16, SIG_ALG_ED25519);
    store64(sk + 24, 0);
    store64(sk + 32, 0);
    store64(sk + 40, seed);
    store64(sk + 48, 0);  # bytes_2     — unused for single-alg
    store64(sk + 56, 0);  # pub_bytes_2 — unused for single-alg
    store64(sk + 64, 0);  # seed_2      — unused for single-alg
    return sk;
}

# ML-DSA-65 keygen. Same struct shape — only the buffer sizes
# differ (sk: 4032 vs 64, pk: 1952 vs 32). The 32-byte seed is
# the FIPS 204 ξ input, hashed inside sigil to derive (ρ, ρ′, K)
# during ExpandA / ExpandS. Heap-allocates the seed buffer because
# `signing_key_zeroize` clears it from the struct.
fn signing_key_generate_mldsa() {
    sakshi_info("signing: key generate (mldsa65)", 31);
    var sk = fl_alloc(72);
    var sk_bytes = alloc(MLDSA65_SK_BYTES);
    var pk_bytes = alloc(MLDSA65_PK_BYTES);
    var seed = alloc(32);
    secret var seed_stack[32];
    random_bytes(&seed_stack, 32);
    memcpy(seed, &seed_stack, 32);
    mldsa65_keypair_from_seed(seed, pk_bytes, sk_bytes);
    store64(sk, sk_bytes);
    store64(sk + 8, pk_bytes);
    store64(sk + 16, SIG_ALG_ML_DSA_65);
    store64(sk + 24, 0);
    store64(sk + 32, 0);
    store64(sk + 40, seed);
    store64(sk + 48, 0);
    store64(sk + 56, 0);
    store64(sk + 64, 0);
    return sk;
}

# Hybrid keygen — generates Ed25519 + ML-DSA-65 keypairs from
# *independent* 32-byte seeds. Independence matters: a single seed
# fed to both algorithms via different KDFs would still entangle
# their secret material if either KDF were ever shown to leak
# correlation. The 64 bytes of CSPRNG output are cheap; the
# domain-separation is free.
fn signing_key_generate_hybrid() {
    sakshi_info("signing: key generate (hybrid)", 30);
    var sk = fl_alloc(72);
    # Slot 1: Ed25519
    var ed_sk = alloc(64);
    var ed_pk = alloc(32);
    var ed_seed = alloc(32);
    secret var ed_seed_stack[32];
    random_bytes(&ed_seed_stack, 32);
    memcpy(ed_seed, &ed_seed_stack, 32);
    ed25519_keypair(ed_seed, ed_sk, ed_pk);
    # Slot 2: ML-DSA-65
    var pq_sk = alloc(MLDSA65_SK_BYTES);
    var pq_pk = alloc(MLDSA65_PK_BYTES);
    var pq_seed = alloc(32);
    secret var pq_seed_stack[32];
    random_bytes(&pq_seed_stack, 32);
    memcpy(pq_seed, &pq_seed_stack, 32);
    mldsa65_keypair_from_seed(pq_seed, pq_pk, pq_sk);
    # Pack
    store64(sk, ed_sk);
    store64(sk + 8, ed_pk);
    store64(sk + 16, SIG_ALG_HYBRID);
    store64(sk + 24, 0);
    store64(sk + 32, 0);
    store64(sk + 40, ed_seed);
    store64(sk + 48, pq_sk);
    store64(sk + 56, pq_pk);
    store64(sk + 64, pq_seed);
    return sk;
}

fn signing_key_from_seed(seed) {
    var sk = fl_alloc(72);
    var sk_bytes = alloc(64);
    var pk_bytes = alloc(32);
    ed25519_keypair(seed, sk_bytes, pk_bytes);
    store64(sk, sk_bytes);
    store64(sk + 8, pk_bytes);
    store64(sk + 16, SIG_ALG_ED25519);
    store64(sk + 24, 0);
    store64(sk + 32, 0);
    store64(sk + 40, seed);
    store64(sk + 48, 0);
    store64(sk + 56, 0);
    store64(sk + 64, 0);
    return sk;
}

# Zeroize key material. Touches both slots when populated:
#   - bytes (slot 1) sized by primary algorithm; HYBRID treats
#     slot 1 as Ed25519 so 64 bytes apply.
#   - bytes_2 (slot 2) is ML-DSA-65 sk for HYBRID, 0 otherwise.
#   - both seeds, when present.
fn signing_key_zeroize(sk) {
    if (signing_key_zeroized(sk) == 1) { return 0; }
    var alg = signing_key_algorithm(sk);
    if (alg == SIG_ALG_HYBRID) {
        # Slot 1 = Ed25519 (64), slot 2 = ML-DSA-65 (4032).
        memset(signing_key_bytes(sk), 0, 64);
        memset(signing_key_seed(sk), 0, 32);
        memset(signing_key_bytes_2(sk), 0, MLDSA65_SK_BYTES);
        memset(signing_key_seed_2(sk), 0, 32);
    } else {
        var sk_size = _sig_sk_bytes(alg);
        memset(signing_key_bytes(sk), 0, sk_size);
        memset(signing_key_seed(sk), 0, 32);
    }
    signing_key_set_zeroized(sk, 1);
    return 0;
}

# Get verifying (public) key as hex Str. For HYBRID this returns
# only the Ed25519 portion (slot 1) — the ML-DSA-65 public key is
# fetched via `signing_key_verifying_hex_2`. Single-alg returns
# the only pk it has.
fn signing_key_verifying_hex(sk) {
    var alg = signing_key_algorithm(sk);
    if (alg == SIG_ALG_HYBRID) {
        # Slot 1 holds the 32-byte Ed25519 pk.
        return hex_encode_str(load64(sk + 8), 32);
    }
    var pk_size = _sig_pk_bytes(alg);
    return hex_encode_str(load64(sk + 8), pk_size);
}

# Slot-2 verifying-key hex. Only meaningful for HYBRID; returns
# the empty Str otherwise so callers can drop into a single
# straight-line build of entry_sig without alg-branching.
fn signing_key_verifying_hex_2(sk) {
    var alg = signing_key_algorithm(sk);
    if (alg == SIG_ALG_HYBRID) {
        # Slot 2 holds the 1952-byte ML-DSA-65 pk.
        return hex_encode_str(load64(sk + 56), MLDSA65_PK_BYTES);
    }
    return str_from("");
}

# ================================================================
# VerifyingKey — generated accessors:
#   verifying_key_bytes, verifying_key_algorithm, verifying_key_bytes_2
# ================================================================
#derive(accessors)
struct verifying_key { bytes; algorithm; bytes_2; }

# Construct from raw Ed25519 public-key bytes (32 bytes). Kept
# Ed25519-specific for backward compatibility with pre-2.2 callers.
# Use `verifying_key_from_bytes_alg` for ML-DSA-65 or HYBRID.
fn verifying_key_from_bytes(bytes) {
    return verifying_key_from_bytes_alg(bytes, SIG_ALG_ED25519);
}

fn verifying_key_from_bytes_alg(bytes, alg) {
    var pk_size = _sig_pk_bytes(alg);
    var vk = fl_alloc(24);
    var pk = alloc(pk_size);
    memcpy(pk, bytes, pk_size);
    store64(vk, pk);
    store64(vk + 8, alg);
    store64(vk + 16, 0);  # bytes_2 — unused for single-alg
    return vk;
}

# Hybrid constructor — takes both pk byte buffers. ed_bytes must
# be 32 bytes; pq_bytes must be MLDSA65_PK_BYTES.
fn verifying_key_from_bytes_hybrid(ed_bytes, pq_bytes) {
    var vk = fl_alloc(24);
    var ed_pk = alloc(32);
    var pq_pk = alloc(MLDSA65_PK_BYTES);
    memcpy(ed_pk, ed_bytes, 32);
    memcpy(pq_pk, pq_bytes, MLDSA65_PK_BYTES);
    store64(vk, ed_pk);
    store64(vk + 8, SIG_ALG_HYBRID);
    store64(vk + 16, pq_pk);
    return vk;
}

fn verifying_key_from_signing(sk) {
    var alg = signing_key_algorithm(sk);
    if (alg == SIG_ALG_HYBRID) {
        return verifying_key_from_bytes_hybrid(load64(sk + 8), load64(sk + 56));
    }
    return verifying_key_from_bytes_alg(load64(sk + 8), alg);
}

fn verifying_key_to_hex(vk) {
    var alg = verifying_key_algorithm(vk);
    if (alg == SIG_ALG_HYBRID) {
        # Return only the Ed25519 portion for backward compat with
        # pre-2.3 callers that expect a single hex string. Use
        # verifying_key_to_hex_2 for the slot-2 pk.
        return hex_encode_str(load64(vk), 32);
    }
    var pk_size = _sig_pk_bytes(alg);
    return hex_encode_str(load64(vk), pk_size);
}

fn verifying_key_to_hex_2(vk) {
    var alg = verifying_key_algorithm(vk);
    if (alg == SIG_ALG_HYBRID) {
        return hex_encode_str(load64(vk + 16), MLDSA65_PK_BYTES);
    }
    return str_from("");
}

# ================================================================
# EntrySignature — generated accessors:
#   entry_sig_hash, entry_sig_signature, entry_sig_verifying_key,
#   entry_sig_key_id, entry_sig_algorithm, entry_sig_signature_2,
#   entry_sig_verifying_key_2
#
# Single-alg (Ed25519 or ML-DSA-65 only):
#   signature, verifying_key  → that algorithm's hex sig + hex pk
#   signature_2, verifying_key_2 → 0
#
# Hybrid:
#   signature, verifying_key   → Ed25519 hex sig + hex pk
#   signature_2, verifying_key_2 → ML-DSA-65 hex sig + hex pk
# ================================================================
#derive(accessors)
struct entry_sig { hash; signature; verifying_key; key_id; algorithm; signature_2; verifying_key_2; }

fn entry_sig_new(ehash, signature, verifying_key, key_id, algorithm) {
    var es = fl_alloc(56);
    store64(es, ehash);
    store64(es + 8, signature);
    store64(es + 16, verifying_key);
    store64(es + 24, key_id);
    store64(es + 32, algorithm);
    store64(es + 40, 0);  # signature_2     — single-alg leaves 0
    store64(es + 48, 0);  # verifying_key_2 — single-alg leaves 0
    return es;
}

fn entry_sig_new_hybrid(ehash, ed_sig, ed_vk, key_id, algorithm, pq_sig, pq_vk) {
    var es = fl_alloc(56);
    store64(es, ehash);
    store64(es + 8, ed_sig);
    store64(es + 16, ed_vk);
    store64(es + 24, key_id);
    store64(es + 32, algorithm);
    store64(es + 40, pq_sig);
    store64(es + 48, pq_vk);
    return es;
}

# ================================================================
# Sign an entry — returns EntrySignature. Dispatches on the
# signing key's algorithm; the resulting EntrySignature carries
# the canonical algorithm name (`sig_alg_name`) and, for hybrid,
# both signatures and both verifying-key hexes.
# ================================================================

fn sign_entry(sk, e) {
    sakshi_debug("signing: sign entry", 19);
    var ehash = entry_hash(e);
    var alg = signing_key_algorithm(sk);
    if (alg == SIG_ALG_HYBRID) {
        return _sign_entry_hybrid(sk, ehash);
    }
    var sig_size = _sig_sig_bytes(alg);
    var sig_buf = alloc(sig_size);
    if (alg == SIG_ALG_ED25519) {
        ed25519_sign(load64(sk), str_data(ehash), str_len(ehash), sig_buf);
    } elif (alg == SIG_ALG_ML_DSA_65) {
        # mldsa65_sign argument order: (sig_out, msg, msglen, sk).
        mldsa65_sign(sig_buf, str_data(ehash), str_len(ehash), load64(sk));
    } else {
        sakshi_warn("signing: unknown algorithm in sign_entry", 40);
        return 0;
    }
    var sig_hex = hex_encode_str(sig_buf, sig_size);
    var vk_hex = signing_key_verifying_hex(sk);
    var kid = signing_key_key_id(sk);
    var alg_cstr = sig_alg_name(alg);
    var alg_str = str_new(alg_cstr, strlen(alg_cstr));
    return entry_sig_new(ehash, sig_hex, vk_hex, kid, alg_str);
}

# Hybrid sign — produces Ed25519 + ML-DSA-65 signatures over the
# same entry hash and packs both into the entry_sig slots.
fn _sign_entry_hybrid(sk, ehash) {
    var ed_sig_buf = alloc(64);
    ed25519_sign(load64(sk), str_data(ehash), str_len(ehash), ed_sig_buf);
    var pq_sig_buf = alloc(MLDSA65_SIG_BYTES);
    mldsa65_sign(pq_sig_buf, str_data(ehash), str_len(ehash), load64(sk + 48));
    var ed_sig_hex = hex_encode_str(ed_sig_buf, 64);
    var pq_sig_hex = hex_encode_str(pq_sig_buf, MLDSA65_SIG_BYTES);
    var ed_vk_hex = signing_key_verifying_hex(sk);
    var pq_vk_hex = signing_key_verifying_hex_2(sk);
    var kid = signing_key_key_id(sk);
    var alg_cstr = sig_alg_name(SIG_ALG_HYBRID);
    var alg_str = str_new(alg_cstr, strlen(alg_cstr));
    return entry_sig_new_hybrid(ehash, ed_sig_hex, ed_vk_hex, kid, alg_str, pq_sig_hex, pq_vk_hex);
}

fn sign_entry_with_key_id(sk, e, key_id) {
    var es = sign_entry(sk, e);
    store64(es + 24, key_id);
    return es;
}

# ================================================================
# Verify entry signature
# ================================================================
# Returns 1 if valid, 0 if invalid. Dispatches on the *verifying
# key's* algorithm — that's the trust anchor in the verify path.
# A hybrid vk requires AND-mode verification: both Ed25519 and
# ML-DSA-65 must validate. This is the SIG_ALG_HYBRID semantic
# in sigil's `sigil_verify_hybrid`.

fn verify_entry_signature(vk, e, es) {
    sakshi_debug("signing: verify entry", 21);
    var ehash = entry_hash(e);
    var sig_ehash = entry_sig_hash(es);
    if (constant_time_eq_str(ehash, sig_ehash) == 0) {
        sakshi_warn("signing: hash mismatch", 22);
        return 0;
    }

    var alg = verifying_key_algorithm(vk);
    if (alg == SIG_ALG_ED25519) {
        var sig_bytes = hex_decode_str(entry_sig_signature(es));
        return ed25519_verify(load64(vk), str_data(sig_ehash), str_len(sig_ehash), sig_bytes);
    } elif (alg == SIG_ALG_ML_DSA_65) {
        var sig_bytes = hex_decode_str(entry_sig_signature(es));
        if (mldsa65_verify(sig_bytes, str_data(sig_ehash), str_len(sig_ehash), load64(vk)) == 0) {
            return 1;
        }
        return 0;
    } elif (alg == SIG_ALG_HYBRID) {
        # Both slots must be populated and both must verify.
        var ed_sig_str = entry_sig_signature(es);
        var pq_sig_str = entry_sig_signature_2(es);
        if (ed_sig_str == 0 || pq_sig_str == 0) { return 0; }
        if (str_len(ed_sig_str) == 0 || str_len(pq_sig_str) == 0) { return 0; }
        var ed_sig_bytes = hex_decode_str(ed_sig_str);
        var pq_sig_bytes = hex_decode_str(pq_sig_str);
        return sigil_verify_hybrid(str_data(sig_ehash), str_len(sig_ehash),
            ed_sig_bytes, load64(vk),
            pq_sig_bytes, load64(vk + 16),
            SIG_ALG_HYBRID);
    }
    sakshi_warn("signing: unknown algorithm in verify", 36);
    return 0;
}

# ================================================================
# Sign/verify tree head (for IntegrityProof)
# ================================================================
# Same dispatch shape as sign_entry / verify_entry_signature.
# Tree-head signatures are over the merkle root hex (`root_hash`),
# not raw bytes — both ed25519_sign and mldsa65_sign accept the
# hex Str's data pointer + length. Hybrid mode emits a `|`-
# delimited concat of the two hex sigs into the single Str field;
# verify_tree_head splits and dispatches sigil_verify_hybrid.

fn sign_tree_head(sk, root_hash) {
    var alg = signing_key_algorithm(sk);
    if (alg == SIG_ALG_HYBRID) {
        var ed_sig_buf = alloc(64);
        ed25519_sign(load64(sk), str_data(root_hash), str_len(root_hash), ed_sig_buf);
        var pq_sig_buf = alloc(MLDSA65_SIG_BYTES);
        mldsa65_sign(pq_sig_buf, str_data(root_hash), str_len(root_hash), load64(sk + 48));
        var ed_hex = hex_encode_str(ed_sig_buf, 64);
        var pq_hex = hex_encode_str(pq_sig_buf, MLDSA65_SIG_BYTES);
        var sb = str_builder_new();
        str_builder_add_str(sb, ed_hex);
        str_builder_add_cstr(sb, "|");
        str_builder_add_str(sb, pq_hex);
        return str_builder_build(sb);
    }
    var sig_size = _sig_sig_bytes(alg);
    var sig_buf = alloc(sig_size);
    if (alg == SIG_ALG_ED25519) {
        ed25519_sign(load64(sk), str_data(root_hash), str_len(root_hash), sig_buf);
    } elif (alg == SIG_ALG_ML_DSA_65) {
        mldsa65_sign(sig_buf, str_data(root_hash), str_len(root_hash), load64(sk));
    } else {
        sakshi_warn("signing: unknown algorithm in sign_tree_head", 44);
        return str_from("");
    }
    return hex_encode_str(sig_buf, sig_size);
}

fn verify_tree_head(vk, root_hash, sig_hex) {
    var alg = verifying_key_algorithm(vk);
    if (alg == SIG_ALG_ED25519) {
        var sig_bytes = hex_decode_str(sig_hex);
        return ed25519_verify(load64(vk), str_data(root_hash), str_len(root_hash), sig_bytes);
    } elif (alg == SIG_ALG_ML_DSA_65) {
        var sig_bytes = hex_decode_str(sig_hex);
        if (mldsa65_verify(sig_bytes, str_data(root_hash), str_len(root_hash), load64(vk)) == 0) {
            return 1;
        }
        return 0;
    } elif (alg == SIG_ALG_HYBRID) {
        # Split the `|`-delimited Ed25519 hex | ML-DSA-65 hex.
        var pipe = _sig_find_pipe(sig_hex);
        if (pipe < 0) { return 0; }
        var ed_hex = str_substr(sig_hex, 0, pipe);
        var pq_hex = str_substr(sig_hex, pipe + 1, str_len(sig_hex));
        var ed_bytes = hex_decode_str(ed_hex);
        var pq_bytes = hex_decode_str(pq_hex);
        return sigil_verify_hybrid(str_data(root_hash), str_len(root_hash),
            ed_bytes, load64(vk),
            pq_bytes, load64(vk + 16),
            SIG_ALG_HYBRID);
    }
    return 0;
}

# Find the byte offset of the first `|` in `s`, or -1 if none.
# Used by verify_tree_head's hybrid delimiter split.
fn _sig_find_pipe(s) {
    var data = str_data(s);
    var n = str_len(s);
    var i = 0;
    while (i < n) {
        if ((load8(data + i) & 0xFF) == 124) { return i; }  # '|' = 0x7C
        i = i + 1;
    }
    return -1;
}

# --- anchoring.cyr ---

# anchoring.cyr — Merkle root anchoring and witness receipts
# Self-hashing anchor chain for tamper-proof witness attestations.

# ================================================================
# AnchorVerification constants
# ================================================================

enum AnchorVerify {
    ANCHOR_VALID = 0;
    ANCHOR_ROOT_MISMATCH = 1;
    ANCHOR_COUNT_MISMATCH = 2;
    ANCHOR_HEAD_MISMATCH = 3;
}

# ================================================================
# WitnessAnchor — generated accessors:
#   anchor_merkle_root, anchor_entry_count, anchor_chain_head,
#   anchor_hash_alg, anchor_created_at, anchor_prev_hash, anchor_hash
# The inline 16-byte UUID at +0 is reserved with `_uuid_hi`/`_uuid_lo`
# (can't model a raw blob); public `anchor_id(a)` stays manual and
# returns the pointer.
# ================================================================
#derive(accessors)
struct anchor { _uuid_hi; _uuid_lo; merkle_root; entry_count; chain_head; hash_alg; created_at; prev_hash; hash; }

fn anchor_id(a) { return a; }

# ================================================================
# Anchor construction
# ================================================================

fn anchor_from_tree(tree, chain_head_hash) {
    sakshi_info("anchor: create", 14);
    var a = fl_alloc(72);
    uuid_v4(a);
    store64(a + 16, merkle_tree_root(tree));
    store64(a + 24, merkle_tree_leaf_count(tree));
    store64(a + 32, chain_head_hash);
    store64(a + 40, str_from(HASH_ALGORITHM));
    store64(a + 48, timestamp_rfc3339(get_epoch_secs()));
    store64(a + 56, 0);
    var h = anchor_compute_hash(a);
    store64(a + 64, h);
    return a;
}

fn anchor_new(tree, chain) {
    var hh = chain_head_hash(chain);
    if (hh == 0) { hh = str_from(""); }
    return anchor_from_tree(tree, hh);
}

fn anchor_with_prev(a, prev_anchor) {
    store64(a + 56, anchor_hash(prev_anchor));
    var h = anchor_compute_hash(a);
    store64(a + 64, h);
    return a;
}

# ================================================================
# Anchor self-hash — deterministic, length-prefixed
# ================================================================
# Order: id(16 raw) → merkle_root → entry_count(8 LE) →
#         chain_head → hash_algorithm → created_at → prev_anchor_hash

fn anchor_compute_hash(a) {
    var hasher = hasher_new();

    # 1. UUID (16 raw bytes)
    hasher_update(hasher, a, 16);

    # 2. merkle_root (length-prefixed)
    var mr = load64(a + 16);
    hash_field(hasher, str_data(mr), str_len(mr));

    # 3. entry_count as 8-byte LE
    if (_hf_lebuf == 0) { _hf_lebuf = alloc(8); }
    store64(_hf_lebuf, load64(a + 24));
    hasher_update(hasher, _hf_lebuf, 8);

    # 4. chain_head (length-prefixed)
    var ch = load64(a + 32);
    hash_field(hasher, str_data(ch), str_len(ch));

    # 5. hash_algorithm (length-prefixed)
    var ha = load64(a + 40);
    hash_field(hasher, str_data(ha), str_len(ha));

    # 6. created_at (length-prefixed)
    var ca = load64(a + 48);
    hash_field(hasher, str_data(ca), str_len(ca));

    # 7. prev_anchor_hash (length-prefixed, empty if none)
    var pah = load64(a + 56);
    if (pah == 0) {
        hash_field(hasher, "", 0);
    } else {
        hash_field(hasher, str_data(pah), str_len(pah));
    }

    return hasher_finalize_hex(hasher);
}

# ================================================================
# Anchor verification
# ================================================================

fn anchor_verify_integrity(a) {
    sakshi_debug("anchor: verify integrity", 24);
    var computed = anchor_compute_hash(a);
    var stored = load64(a + 64);
    return constant_time_eq_str(computed, stored);
}

fn anchor_verify_against_tree(a, tree) {
    var expected_count = load64(a + 24);
    var actual_count = merkle_tree_leaf_count(tree);
    if (expected_count != actual_count) { return ANCHOR_COUNT_MISMATCH; }

    var expected_root = load64(a + 16);
    var actual_root = merkle_tree_root(tree);
    if (constant_time_eq_str(expected_root, actual_root) == 0) {
        return ANCHOR_ROOT_MISMATCH;
    }

    return ANCHOR_VALID;
}

fn anchor_verify_against(a, tree, chain) {
    var expected_head = load64(a + 32);
    var actual_head = chain_head_hash(chain);
    if (actual_head == 0) { actual_head = str_from(""); }
    if (constant_time_eq_str(expected_head, actual_head) == 0) {
        return ANCHOR_HEAD_MISMATCH;
    }
    return anchor_verify_against_tree(a, tree);
}

# ================================================================
# WitnessReceipt — generated accessors:
#   receipt_backend, receipt_received_at, receipt_data
# Same UUID-at-+0 pattern as anchor; `receipt_anchor_id(r)` stays manual.
# ================================================================
#derive(accessors)
struct receipt { _uuid_hi; _uuid_lo; backend; received_at; data; }

fn receipt_new(anchor, backend, receipt_data) {
    var r = fl_alloc(40);
    memcpy(r, anchor, 16);
    store64(r + 16, backend);
    store64(r + 24, timestamp_rfc3339(get_epoch_secs()));
    store64(r + 32, receipt_data);
    return r;
}

fn receipt_anchor_id(r) { return r; }

# --- timestamping.cyr ---

# timestamping.cyr — RFC 3161 trusted timestamp request/response
# Hand-rolled DER encoding/decoding for timestamp protocol.

# ================================================================
# DER tag constants
# ================================================================

var DER_SEQUENCE = 0x30;
var DER_INTEGER = 0x02;
var DER_OCTET_STRING = 0x04;
var DER_BOOLEAN = 0x01;
var DER_OID = 0x06;
var DER_NULL = 0x05;

# ================================================================
# OID bytes for hash algorithms (pre-encoded)
# ================================================================
# SHA-256: 2.16.840.1.101.3.4.2.1
# SHA-384: 2.16.840.1.101.3.4.2.2
# SHA-512: 2.16.840.1.101.3.4.2.3

var _oid_sha256 = 0;
var _oid_sha384 = 0;
var _oid_sha512 = 0;

fn _ts_init_oids() {
    if (_oid_sha256 != 0) { return 0; }
    _oid_sha256 = alloc(9);
    store8(_oid_sha256, 0x60); store8(_oid_sha256 + 1, 0x86);
    store8(_oid_sha256 + 2, 0x48); store8(_oid_sha256 + 3, 0x01);
    store8(_oid_sha256 + 4, 0x65); store8(_oid_sha256 + 5, 0x03);
    store8(_oid_sha256 + 6, 0x04); store8(_oid_sha256 + 7, 0x02);
    store8(_oid_sha256 + 8, 0x01);

    _oid_sha384 = alloc(9);
    memcpy(_oid_sha384, _oid_sha256, 8);
    store8(_oid_sha384 + 8, 0x02);

    _oid_sha512 = alloc(9);
    memcpy(_oid_sha512, _oid_sha256, 8);
    store8(_oid_sha512 + 8, 0x03);
    return 0;
}

# ================================================================
# Hash algorithm enum
# ================================================================

enum TsHashAlg {
    TS_SHA256 = 0;
    TS_SHA384 = 1;
    TS_SHA512 = 2;
}

fn ts_hash_oid(alg) {
    _ts_init_oids();
    if (alg == TS_SHA256) { return _oid_sha256; }
    if (alg == TS_SHA384) { return _oid_sha384; }
    if (alg == TS_SHA512) { return _oid_sha512; }
    return _oid_sha256;
}

fn ts_hash_oid_len(alg) { return 9; }

# ================================================================
# Timestamp subject enum
# ================================================================

enum TsSubject {
    TS_ENTRY_HASH = 0;
    TS_MERKLE_ROOT = 1;
    TS_CHAIN_HEAD = 2;
}

# ================================================================
# Timestamp status enum (RFC 3161 PKI status)
# ================================================================

enum TsStatus {
    TS_GRANTED = 0;
    TS_GRANTED_WITH_MODS = 1;
    TS_REJECTION = 2;
    TS_WAITING = 3;
    TS_REVOCATION_WARNING = 4;
    TS_REVOCATION_NOTIFICATION = 5;
}

fn ts_status_is_granted(status) {
    if (status == TS_GRANTED) { return 1; }
    if (status == TS_GRANTED_WITH_MODS) { return 1; }
    return 0;
}

# ================================================================
# DER encoding helpers
# ================================================================

# Encode DER length into buffer, return number of bytes written
fn _der_write_length(buf, len) {
    if (len < 128) {
        store8(buf, len);
        return 1;
    }
    if (len < 256) {
        store8(buf, 0x81);
        store8(buf + 1, len);
        return 2;
    }
    if (len < 65536) {
        store8(buf, 0x82);
        store8(buf + 1, (len >> 8) & 0xFF);
        store8(buf + 2, len & 0xFF);
        return 3;
    }
    store8(buf, 0x83);
    store8(buf + 1, (len >> 16) & 0xFF);
    store8(buf + 2, (len >> 8) & 0xFF);
    store8(buf + 3, len & 0xFF);
    return 4;
}

# Encode a TLV (tag-length-value) into buffer, return total bytes
fn _der_write_tlv(buf, tag, value, value_len) {
    store8(buf, tag);
    var len_bytes = _der_write_length(buf + 1, value_len);
    memcpy(buf + 1 + len_bytes, value, value_len);
    return 1 + len_bytes + value_len;
}

# Build a SEQUENCE wrapping content, return total bytes
fn _der_write_sequence(buf, content, content_len) {
    return _der_write_tlv(buf, DER_SEQUENCE, content, content_len);
}

# ================================================================
# TimestampRequest — generated accessors:
#   ts_request_hash_alg, ts_request_hash, ts_request_nonce, ts_request_cert_req
# ================================================================
#derive(accessors)
struct ts_request { hash_alg; hash; nonce; cert_req; }

fn ts_request_new(hash_hex) {
    var r = fl_alloc(32);
    store64(r, TS_SHA256);
    store64(r + 8, hash_hex);
    store64(r + 16, 0);
    store64(r + 24, 1);
    return r;
}

fn ts_request_generate_nonce(r) {
    # Generate 16-byte random nonce. The raw bytes go through
    # hex_encode_str into the request struct — `secret var` zeros
    # the stack buffer on return as a defense-in-depth measure
    # (nonces aren't strictly secret, but a stale-stack-buffer
    # read should never reveal the nonce material to an attacker
    # observing later stack frames).
    secret var nonce_buf[16];
    random_bytes(&nonce_buf, 16);
    ts_request_set_nonce(r, hex_encode_str(&nonce_buf, 16));
    return r;
}

# ================================================================
# Encode TimestampRequest to DER
# ================================================================
# Returns: { buffer_ptr, length } as Str (buffer is the data, len is the DER length)

fn ts_request_to_der(r) {
    _ts_init_oids();
    var work = alloc(512);
    var pos = 0;

    # 1. Version INTEGER 1
    var ver_val = alloc(1);
    store8(ver_val, 1);
    var ver_buf = alloc(8);
    var ver_len = _der_write_tlv(ver_buf, DER_INTEGER, ver_val, 1);

    # 2. AlgorithmIdentifier SEQUENCE { OID, NULL }
    var oid = ts_hash_oid(load64(r));
    var oid_buf = alloc(16);
    var oid_tlv_len = _der_write_tlv(oid_buf, DER_OID, oid, 9);

    var null_buf = alloc(2);
    store8(null_buf, DER_NULL);
    store8(null_buf + 1, 0);
    var null_len = 2;

    var alg_content = alloc(32);
    memcpy(alg_content, oid_buf, oid_tlv_len);
    memcpy(alg_content + oid_tlv_len, null_buf, null_len);
    var alg_content_len = oid_tlv_len + null_len;

    var alg_buf = alloc(48);
    var alg_len = _der_write_sequence(alg_buf, alg_content, alg_content_len);

    # 3. MessageImprint SEQUENCE { AlgId, OCTET STRING hash }
    var hash_hex = load64(r + 8);
    var hash_bytes = hex_decode_str(hash_hex);
    var hash_bytes_len = str_len(hash_hex) / 2;

    var hash_tlv = alloc(48);
    var hash_tlv_len = _der_write_tlv(hash_tlv, DER_OCTET_STRING, hash_bytes, hash_bytes_len);

    var mi_content = alloc(96);
    memcpy(mi_content, alg_buf, alg_len);
    memcpy(mi_content + alg_len, hash_tlv, hash_tlv_len);
    var mi_content_len = alg_len + hash_tlv_len;

    var mi_buf = alloc(128);
    var mi_len = _der_write_sequence(mi_buf, mi_content, mi_content_len);

    # 4. Build body = version + messageImprint [+ nonce] [+ certReq]
    memcpy(work, ver_buf, ver_len);
    pos = ver_len;
    memcpy(work + pos, mi_buf, mi_len);
    pos = pos + mi_len;

    # 5. Optional nonce
    var nonce_str = load64(r + 16);
    if (nonce_str != 0) {
        var nonce_bytes = hex_decode_str(nonce_str);
        var nonce_bytes_len = str_len(nonce_str) / 2;
        # Trim leading zeros for DER integer
        var nonce_start = 0;
        var ns_max = nonce_bytes_len - 1;
        while (nonce_start < ns_max) {
            var nb = load8(nonce_bytes + nonce_start);
            if ((nb & 0xFF) != 0) { nonce_start = ns_max; }
            if ((nb & 0xFF) == 0) {
                nonce_start += 1;
            }
        }
        var trimmed = nonce_bytes + nonce_start;
        var trimmed_len = nonce_bytes_len - nonce_start;
        # If high bit set, prepend 0x00
        var nonce_enc = alloc(trimmed_len + 1);
        var nonce_enc_len = trimmed_len;
        if ((load8(trimmed) & 0x80) != 0) {
            store8(nonce_enc, 0);
            memcpy(nonce_enc + 1, trimmed, trimmed_len);
            nonce_enc_len = trimmed_len + 1;
        } else {
            memcpy(nonce_enc, trimmed, trimmed_len);
        }
        var nonce_tlv = alloc(32);
        var nonce_tlv_len = _der_write_tlv(nonce_tlv, DER_INTEGER, nonce_enc, nonce_enc_len);
        memcpy(work + pos, nonce_tlv, nonce_tlv_len);
        pos = pos + nonce_tlv_len;
    }

    # 6. Optional certReq
    if (load64(r + 24) == 1) {
        var cert_val = alloc(1);
        store8(cert_val, 0xFF);
        var cert_tlv = alloc(8);
        var cert_tlv_len = _der_write_tlv(cert_tlv, DER_BOOLEAN, cert_val, 1);
        memcpy(work + pos, cert_tlv, cert_tlv_len);
        pos = pos + cert_tlv_len;
    }

    # 7. Wrap in outer SEQUENCE
    var out = alloc(pos + 8);
    var total = _der_write_sequence(out, work, pos);
    return str_new(out, total);
}

# ================================================================
# DER parsing helpers
# ================================================================

# Parse a TLV header. Returns (total_consumed_bytes, value_ptr) — value_len is
# derivable as total - (value_ptr - data). total == 0 signals parse failure;
# value_ptr is undefined in that case.
fn _der_parse_tlv(data, data_len) {
    if (data_len < 2) { return (0, 0); }

    var len_byte = load8(data + 1) & 0xFF;
    var header_size = 2;
    var length = len_byte;

    if (len_byte >= 128) {
        var num_bytes = len_byte & 0x7F;
        if (data_len < 2 + num_bytes) { return (0, 0); }
        length = 0;
        var i = 0;
        while (i < num_bytes) {
            length = (length << 8) | (load8(data + 2 + i) & 0xFF);
            i += 1;
        }
        header_size = 2 + num_bytes;
    }

    var total = header_size + length;
    if (data_len < total) { return (0, 0); }

    return (total, data + header_size);
}

# Decode unsigned integer from DER bytes
fn _der_decode_unsigned(data, len) {
    var val = 0;
    var i = 0;
    while (i < len) {
        val = (val << 8) | (load8(data + i) & 0xFF);
        i += 1;
    }
    return val;
}

# ================================================================
# TimestampResponse — generated accessors:
#   ts_response_status, ts_response_token, ts_response_status_string
# ================================================================
#derive(accessors)
struct ts_response { status; token; status_string; }

fn ts_response_from_der(data, data_len) {
    var resp = fl_alloc(24);

    # Parse outer SEQUENCE
    var total, seq_data = _der_parse_tlv(data, data_len);
    if (total == 0) {
        store64(resp, TS_REJECTION);
        store64(resp + 8, 0);
        store64(resp + 16, str_from("DER parse error"));
        return resp;
    }
    var seq_len = total - (seq_data - data);

    # Parse PKIStatusInfo SEQUENCE
    var si_total, si_data = _der_parse_tlv(seq_data, seq_len);
    if (si_total == 0) {
        store64(resp, TS_REJECTION);
        store64(resp + 8, 0);
        store64(resp + 16, str_from("status info parse error"));
        return resp;
    }
    var si_len = si_total - (si_data - seq_data);

    # Parse status INTEGER from PKIStatusInfo
    var st_total, st_data = _der_parse_tlv(si_data, si_len);
    if (st_total == 0) {
        store64(resp, TS_REJECTION);
        store64(resp + 8, 0);
        store64(resp + 16, str_from("status integer parse error"));
        return resp;
    }
    var st_len = st_total - (st_data - si_data);

    var status_val = _der_decode_unsigned(st_data, st_len);
    store64(resp, status_val);

    # Token = remaining bytes after PKIStatusInfo
    var token_offset = si_total;
    if (token_offset < seq_len) {
        var token_ptr = seq_data + token_offset;
        var token_len = seq_len - token_offset;
        store64(resp + 8, hex_encode_str(token_ptr, token_len));
    } else {
        store64(resp + 8, 0);
    }

    store64(resp + 16, 0);
    return resp;
}

# ================================================================
# TimestampAttestation — generated accessors:
#   ts_attestation_hash, ts_attestation_subject, ts_attestation_algorithm,
#   ts_attestation_token, ts_attestation_tsa_url, ts_attestation_created_at
# ================================================================
#derive(accessors)
struct ts_attestation { hash; subject; algorithm; token; tsa_url; created_at; }

fn ts_attestation_new(hash, subject, algorithm, response) {
    if (ts_status_is_granted(ts_response_status(response)) == 0) {
        return 0;
    }
    var a = fl_alloc(48);
    store64(a, hash);
    store64(a + 8, subject);
    store64(a + 16, algorithm);
    store64(a + 24, ts_response_token(response));
    store64(a + 32, 0);
    store64(a + 40, timestamp_rfc3339(get_epoch_secs()));
    return a;
}

fn ts_attestation_for_merkle_root(tree, response) {
    return ts_attestation_new(merkle_tree_root(tree), TS_MERKLE_ROOT, TS_SHA256, response);
}

fn ts_attestation_verify_hash(a, hash) {
    return constant_time_eq_str(load64(a), hash);
}

# --- proof.cyr ---

# proof.cyr — integrity proof bundle
# Combines signed tree head, Merkle proofs, consistency proofs,
# and anchoring into a single verifiable package.

# ================================================================
# SignedTreeHead — generated accessors:
#   sth_root, sth_tree_size, sth_timestamp,
#   sth_signature, sth_verifying_key, sth_algorithm
# ================================================================
#derive(accessors)
struct sth { root; tree_size; timestamp; signature; verifying_key; algorithm; }

fn sth_new(root, tree_size, sig, vk_hex, alg) {
    var s = fl_alloc(48);
    store64(s, root);
    store64(s + 8, tree_size);
    store64(s + 16, timestamp_rfc3339(get_epoch_secs()));
    store64(s + 24, sig);
    store64(s + 32, vk_hex);
    store64(s + 40, alg);
    return s;
}

# ================================================================
# ProofVerification — generated accessors:
#   pv_tree_head_valid, pv_entries_valid, pv_tree_matches,
#   pv_inclusions_valid, pv_consistency_valid, pv_anchor_valid
# ================================================================
#derive(accessors)
struct pv { tree_head_valid; entries_valid; tree_matches; inclusions_valid; consistency_valid; anchor_valid; }

fn pv_new() {
    var p = fl_alloc(48);
    store64(p, 0);
    store64(p + 8, 0);
    store64(p + 16, 0);
    store64(p + 24, 0);
    store64(p + 32, -1);
    store64(p + 40, -1);
    return p;
}

fn pv_is_valid(p) {
    if (load64(p) != 1) { return 0; }
    if (load64(p + 8) != 1) { return 0; }
    if (load64(p + 16) != 1) { return 0; }
    if (load64(p + 24) != 1) { return 0; }
    var cv = load64(p + 32);
    if (cv != -1 && cv != 1) { return 0; }
    var av = load64(p + 40);
    if (av != -1 && av != 1) { return 0; }
    return 1;
}

# ================================================================
# IntegrityProof — generated accessors:
#   iproof_tree_head, iproof_consistency, iproof_inclusions,
#   iproof_entries, iproof_anchor, iproof_tree
# ================================================================
#derive(accessors)
struct iproof { tree_head; consistency; inclusions; entries; anchor; tree; }

# ================================================================
# ProofBuilder — fluent API for constructing proofs
# ================================================================

# Build unsigned proof from chain
fn proof_build_unsigned(chain) {
    sakshi_info("proof: build unsigned", 21);
    var entries = chain_entries(chain);
    var tree = merkle_build(entries);
    if (tree == 0) { return 0; }

    var root = merkle_tree_root(tree);
    var sth = sth_new(root, merkle_tree_leaf_count(tree), str_from(""), str_from(""), 0);

    var ip = fl_alloc(48);
    store64(ip, sth);
    store64(ip + 8, 0);
    store64(ip + 16, vec_new());
    store64(ip + 24, entries);
    store64(ip + 32, 0);
    store64(ip + 40, tree);
    return ip;
}

# Build signed proof from chain
fn proof_build_signed(chain, sk) {
    sakshi_info("proof: build signed", 19);
    var entries = chain_entries(chain);
    var tree = merkle_build(entries);
    if (tree == 0) { return 0; }

    var root = merkle_tree_root(tree);
    var sig = sign_tree_head(sk, root);
    var vk_hex = signing_key_verifying_hex(sk);
    var alg_cstr = sig_alg_name(signing_key_algorithm(sk));
    var alg = str_new(alg_cstr, strlen(alg_cstr));
    var sth = sth_new(root, merkle_tree_leaf_count(tree), sig, vk_hex, alg);

    var ip = fl_alloc(48);
    store64(ip, sth);
    store64(ip + 8, 0);
    store64(ip + 16, vec_new());
    store64(ip + 24, entries);
    store64(ip + 32, 0);
    store64(ip + 40, tree);
    return ip;
}

# Add consistency proof from old_size
fn proof_with_consistency(ip, old_size) {
    var tree = load64(ip + 40);
    var cp = merkle_consistency_proof(tree, old_size);
    store64(ip + 8, cp);
    return ip;
}

# Add inclusion proof for entry at index
fn proof_with_inclusion(ip, index) {
    var tree = load64(ip + 40);
    var mp = merkle_inclusion_proof(tree, index);
    if (mp != 0) {
        vec_push(load64(ip + 16), mp);
    }
    return ip;
}

# Add all inclusion proofs
fn proof_with_all_inclusions(ip) {
    var tree = load64(ip + 40);
    var lc = merkle_tree_leaf_count(tree);
    var i = 0;
    while (i < lc) {
        proof_with_inclusion(ip, i);
        i += 1;
    }
    return ip;
}

# Attach anchor
fn proof_with_anchor(ip, anchor) {
    store64(ip + 32, anchor);
    return ip;
}

# ================================================================
# Verify unsigned proof
# ================================================================

fn proof_verify_unsigned(ip) {
    return _proof_verify_common(ip, 1);
}

# Verify signed proof
fn proof_verify_signed(ip, vk) {
    var sth = load64(ip);
    var root = sth_root(sth);
    var sig = sth_signature(sth);
    var th_valid = verify_tree_head(vk, root, sig);
    return _proof_verify_common(ip, th_valid);
}

# Common verification logic
fn _proof_verify_common(ip, tree_head_valid) {
    var pv = pv_new();
    store64(pv, tree_head_valid);

    var entries = load64(ip + 24);
    var sth = load64(ip);

    # Verify entry chain integrity
    var err = verify_chain(entries, 0);
    if (err == 0) {
        store64(pv + 8, 1);
    }

    # Rebuild tree and check root matches
    var rebuilt = merkle_build(entries);
    if (rebuilt != 0) {
        var rebuilt_root = merkle_tree_root(rebuilt);
        var sth_root_val = sth_root(sth);
        if (constant_time_eq_str(rebuilt_root, sth_root_val) == 1) {
            if (merkle_tree_leaf_count(rebuilt) == sth_tree_size(sth)) {
                store64(pv + 16, 1);
            }
        }
    }

    # Verify all inclusion proofs
    var inclusions = load64(ip + 16);
    var all_inc_valid = 1;
    var ni = vec_len(inclusions);
    var i = 0;
    while (i < ni) {
        var mp = vec_get(inclusions, i);
        if (merkle_verify_proof(mp) == 0) {
            all_inc_valid = 0;
        }
        i += 1;
    }
    store64(pv + 24, all_inc_valid);

    # Verify consistency proof if present
    var cp = load64(ip + 8);
    if (cp != 0) {
        store64(pv + 32, merkle_verify_consistency(cp));
    }

    # Verify anchor if present
    var anchor = load64(ip + 32);
    if (anchor != 0) {
        if (anchor_verify_integrity(anchor) == 1) {
            store64(pv + 40, 1);
        } else {
            store64(pv + 40, 0);
        }
    }

    return pv;
}

# --- kernel_audit.cyr ---

# kernel_audit.cyr — Linux kernel audit integration
# Reads AGNOS kernel audit events from /proc/agnos/audit.

var AGNOS_AUDIT_PATH = "/proc/agnos/audit";

# ================================================================
# Check if AGNOS audit interface is available
# ================================================================

fn kernel_audit_available() {
    return file_exists(AGNOS_AUDIT_PATH);
}

# ================================================================
# Classify kernel result codes to severity
# ================================================================

fn classify_kernel_result(result) {
    if (result == 0) { return SEV_INFO; }
    if (result > 0) { return SEV_WARNING; }
    if (result == -13) { return SEV_SECURITY; }
    return SEV_ERROR;
}

# ================================================================
# Log to kernel audit interface
# ================================================================

fn log_syscall(action, data, result) {
    if (kernel_audit_available() == 0) {
        return error_new(ERR_IO, "AGNOS audit not available");
    }

    var sb = str_builder_new();
    str_builder_add_cstr(sb, action);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, data);
    str_builder_add_cstr(sb, " ");
    str_builder_add_int(sb, result);
    str_builder_add_cstr(sb, "\n");
    var line = str_builder_build(sb);

    var fd = file_open(AGNOS_AUDIT_PATH, 1, 0);
    if (fd < 0) {
        return error_new(ERR_IO, "failed to open audit interface");
    }
    file_write(fd, str_data(line), str_len(line));
    file_close(fd);
    return 0;
}

# --- file_store.cyr ---

# file_store.cyr — append-only JSON Lines file backend
# Uses flock for concurrent-process safety.
# Each entry is one JSON object per line (JSON Lines format).

# ================================================================
# FileStore — generated accessors:
#   filestore_path, filestore_count (+ setters), filestore_cpath
# `cpath` is the null-terminated cstr cached once at open.
# ================================================================
#derive(accessors)
struct filestore { path; count; cpath; }

fn filestore_open(path) {
    sakshi_info("filestore: open", 15);
    var s = fl_alloc(24);
    store64(s, path);
    store64(s + 8, -1);

    var cpath = _entry_to_cstr(path);
    store64(s + 16, cpath);

    if (file_exists(cpath) == 0) {
        var fd = file_open(cpath, O_WRONLY | O_CREAT, 0x1A4);
        if (fd >= 0) { file_close(fd); }
    }
    return s;
}

# ================================================================
# Append — write entry as JSON line with exclusive lock
# ================================================================

fn filestore_append(s, e) {
    sakshi_debug("filestore: append", 17);
    var cpath = filestore_cpath(s);

    # Build JSON line
    var sb = str_builder_new();
    _filestore_entry_json(sb, e);
    str_builder_add_cstr(sb, "\n");
    var line = str_builder_build(sb);

    # Atomic append with lock
    file_append_locked(cpath, str_data(line), str_len(line));

    # Invalidate count cache
    store64(s + 8, -1);
    return 0;
}

# ================================================================
# Load all — read file, parse JSON Lines, return vec of entries
# ================================================================
# Scratch read buffer — right-sized per call via lseek(fd, 0, SEEK_END),
# so the bump allocator never orphans 64KB-doubling intermediate buffers
# on large files. 2.0 replaced the 1.x doubling scheme; see CHANGELOG.

var _fs_buf = 0;
var _fs_buf_size = 0;

# lseek(fd, 0, SEEK_END) — returns the file's size in bytes, or -1 on error.
# Symbolic SYS_LSEEK (Linux #8 / agnos #58) — a raw syscall(8) is `dup` on agnos.
fn _fs_file_size(fd) {
    return syscall(SYS_LSEEK, fd, 0, 2);
}

fn filestore_load_all(s) {
    sakshi_info("filestore: load all", 19);
    var cpath = filestore_cpath(s);
    var fd = file_open(cpath, O_RDONLY, 0);
    if (fd < 0) {
        sakshi_error("filestore: open failed", 22);
        return vec_new();
    }

    # Shared lock for reading
    file_lock_shared(fd);

    # Size the read buffer to the file exactly (fall back to 4 KB for empty).
    var fsize = _fs_file_size(fd);
    if (fsize < 0) { fsize = 0; }
    syscall(SYS_LSEEK, fd, 0, 0);  # lseek back to SEEK_SET so file_read starts at 0
    var needed = fsize + 1;
    if (needed < 4096) { needed = 4096; }
    if (needed > _fs_buf_size) {
        _fs_buf = alloc(needed);
        _fs_buf_size = needed;
    }

    var total_read = 0;
    var entries = vec_new();

    var read_done = 0;
    while (read_done == 0) {
        var n = file_read(fd, _fs_buf + total_read, _fs_buf_size - total_read);
        if (n <= 0) {
            read_done = 1;
        } else {
            total_read = total_read + n;
        }
    }

    file_unlock(fd);
    file_close(fd);

    # Parse JSON Lines
    var pos = 0;
    while (pos < total_read) {
        # Find end of line
        var eol = pos;
        while (eol < total_read && (load8(_fs_buf + eol) & 0xFF) != 10) {
            eol += 1;
        }

        var line_len = eol - pos;
        if (line_len > 0) {
            # Clone the line out of the shared `_fs_buf` read buffer before
            # parsing. `_fs_buf` is re-used (and may be reallocated larger)
            # on the next `filestore_load_all` call, so any `Str` that
            # wraps a pointer into it — including the derived
            # `str_new(data + offset, ...)` pointers produced by
            # `json_parse` — would dangle once a second load runs.
            # See docs/audit/2026-04-19-audit.md Finding 3.
            var line_str = str_clone(str_new(_fs_buf + pos, line_len));
            var e = _filestore_parse_entry(line_str);
            if (e != 0) {
                vec_push(entries, e);
            }
        }

        pos = eol + 1;
    }

    store64(s + 8, vec_len(entries));
    return entries;
}

# ================================================================
# Len — count entries (loads if cache invalid)
# ================================================================

fn filestore_len(s) {
    var cached = load64(s + 8);
    if (cached != -1) { return cached; }

    # Count lines in file
    var cpath = filestore_cpath(s);
    var fd = file_open(cpath, O_RDONLY, 0);
    if (fd < 0) { return 0; }
    file_lock_shared(fd);

    var buf = alloc(4096);
    var count = 0;
    var n = 1;
    while (n > 0) {
        n = file_read(fd, buf, 4096);
        var i = 0;
        while (i < n) {
            if ((load8(buf + i) & 0xFF) == 10) { count = count + 1; }
            i += 1;
        }
    }

    file_unlock(fd);
    file_close(fd);
    store64(s + 8, count);
    return count;
}

fn filestore_is_empty(s) {
    if (filestore_len(s) == 0) { return 1; }
    return 0;
}

# ================================================================
# Load and verify
# ================================================================

fn filestore_load_and_verify(s) {
    var entries = filestore_load_all(s);
    var err = verify_chain(entries, 0);
    if (err != 0) {
        sakshi_error("filestore: verification failed", 30);
        return err;
    }
    return entries;
}

# ================================================================
# Streaming verification — O(chunk_size) entry-pointer memory
# ================================================================
# Reads the JSONL file in 64KB byte chunks, parsing one line at a time
# and verifying in groups of `chunk_size` entries. Cross-chunk linkage
# is carried via `prev_tail_hash`, so it's equivalent to verify_chain
# over the full file. Returns total verified count on success, or an
# error pointer on failure.
#
# Lines longer than 64KB are not supported (asserts via `assert` on
# buffer-full without newline). Current entry JSON is well under this.

var _fsvs_buf_size = 65536;
var _fsvs_buf = 0;

fn filestore_verify_streamed(s, chunk_size) {
    sakshi_info("filestore: verify streamed", 26);
    if (chunk_size < 1) { chunk_size = 1; }
    if (_fsvs_buf == 0) { _fsvs_buf = alloc(_fsvs_buf_size); }

    var cpath = filestore_cpath(s);
    var fd = file_open(cpath, O_RDONLY, 0);
    if (fd < 0) { return 0; }
    file_lock_shared(fd);

    var buf_fill = 0;
    var chunk = vec_new();
    var verified = 0;
    var offset = 0;
    var prev_tail_hash = str_from("");

    var eof = 0;
    while (eof == 0 || buf_fill > 0) {
        if (eof == 0 && buf_fill < _fsvs_buf_size) {
            var n = file_read(fd, _fsvs_buf + buf_fill, _fsvs_buf_size - buf_fill);
            if (n <= 0) { eof = 1; } else { buf_fill = buf_fill + n; }
        }

        var consumed = 0;
        var scan_done = 0;
        while (scan_done == 0) {
            var nl = -1;
            var i = consumed;
            while (i < buf_fill && nl < 0) {
                if ((load8(_fsvs_buf + i) & 0xFF) == 10) { nl = i; }
                i += 1;
            }
            if (nl < 0) {
                scan_done = 1;
            } else {
                var line_len = nl - consumed;
                if (line_len > 0) {
                    var line_str = str_clone(str_new(_fsvs_buf + consumed, line_len));
                    var e = _filestore_parse_entry(line_str);
                    if (e != 0) {
                        vec_push(chunk, e);
                        if (vec_len(chunk) >= chunk_size) {
                            var err = _fsvs_verify_chunk(chunk, offset, prev_tail_hash);
                            if (err != 0) {
                                file_unlock(fd);
                                file_close(fd);
                                return err;
                            }
                            var last = vec_get(chunk, vec_len(chunk) - 1);
                            prev_tail_hash = entry_hash(last);
                            verified = verified + vec_len(chunk);
                            offset = offset + vec_len(chunk);
                            chunk = vec_new();
                        }
                    }
                }
                consumed = nl + 1;
            }
        }

        if (consumed > 0) {
            if (consumed < buf_fill) {
                memcpy(_fsvs_buf, _fsvs_buf + consumed, buf_fill - consumed);
            }
            buf_fill = buf_fill - consumed;
        }

        # Terminal-line handling at EOF. Without this the outer loop
        # spins forever when the file has bytes after the last newline:
        # `eof == 0 || buf_fill > 0` stays true, inner scan finds no
        # newline, `consumed` stays 0, no progress. Inject a synthetic
        # newline so the scan loop treats the residual as a final line
        # on the next iteration, then exits via the usual path.
        # Caught by fuzz_filestore_verify_streamed in 2.0.3.
        if (eof == 1 && consumed == 0 && buf_fill > 0 && buf_fill < _fsvs_buf_size) {
            store8(_fsvs_buf + buf_fill, 10);
            buf_fill = buf_fill + 1;
        }

        if (buf_fill >= _fsvs_buf_size) {
            sakshi_error("filestore: verify streamed — line exceeds 64KB", 47);
            file_unlock(fd);
            file_close(fd);
            return 0;
        }
    }

    file_unlock(fd);
    file_close(fd);

    if (vec_len(chunk) > 0) {
        var err2 = _fsvs_verify_chunk(chunk, offset, prev_tail_hash);
        if (err2 != 0) { return err2; }
        verified = verified + vec_len(chunk);
    }

    return verified;
}

# Verify a chunk's internal linkage and boundary against the prior tail hash.
fn _fsvs_verify_chunk(chunk, offset, prev_tail_hash) {
    var clen = vec_len(chunk);
    if (clen == 0) { return 0; }
    if (offset > 0) {
        var first = vec_get(chunk, 0);
        var fp = entry_prev_hash(first);
        if (constant_time_eq_str(fp, prev_tail_hash) == 0) {
            return error_integrity(offset, prev_tail_hash, fp);
        }
    }
    return verify_chain(chunk, offset);
}

# ================================================================
# Query — load all, apply filter
# ================================================================

fn filestore_query(s, filter) {
    var entries = filestore_load_all(s);
    return query_apply(filter, entries);
}

# ================================================================
# JSON serialization for entries
# ================================================================

# Serialize entry to flat JSON (all values as strings for stdlib json compat).
# Details is stored as an escaped string value, not a nested object.
fn _filestore_entry_json(sb, e) {
    str_builder_add_cstr(sb, "{\"id\":\"");
        str_builder_add(sb, uuid_format(entry_id(e)));
        str_builder_add_cstr(sb, "\",\"timestamp\":\"");
        str_builder_add(sb, entry_timestamp(e));
        str_builder_add_cstr(sb, "\",\"severity\":\"");
        str_builder_add_cstr(sb, severity_as_str(entry_severity(e)));
        str_builder_add_cstr(sb, "\",\"source\":\"");
        str_builder_add(sb, entry_source(e));
        str_builder_add_cstr(sb, "\",\"action\":\"");
        str_builder_add(sb, entry_action(e));
        str_builder_add_cstr(sb, "\",\"details\":\"");
        # Escape details JSON as a string value (avoids nested object parse issues)
        _sb_json_escape(sb, entry_details(e));
        str_builder_add_cstr(sb, "\",\"agent_id\":\"");
        var aid = entry_agent_id(e);
        if (aid == 0) {
            str_builder_add_cstr(sb, "");
        } else {
            str_builder_add(sb, aid);
        }
        str_builder_add_cstr(sb, "\",\"prev_hash\":\"");
        str_builder_add(sb, entry_prev_hash(e));
        str_builder_add_cstr(sb, "\",\"hash\":\"");
        str_builder_add(sb, entry_hash(e));
        str_builder_add_cstr(sb, "\",\"hash_algorithm\":\"");
        str_builder_add(sb, entry_hash_algorithm(e));
        str_builder_add_cstr(sb, "\"}");
    return 0;
}

# ================================================================
# JSON deserialization — parse a JSON line back to AuditEntry
# ================================================================

var _fsp_pairs = 0;

fn _filestore_parse_entry(line) {
    _fsp_pairs = json_parse(line);
    if (vec_len(_fsp_pairs) == 0) { return 0; }

    # Extract fields from JSON pairs
    var id_hex = _fsp_get("id");
    var ts_str = _fsp_get("timestamp");
    var sev_str = _fsp_get("severity");
    var source = _fsp_get("source");
    var action = _fsp_get("action");
    var details = _fsp_get("details");
    var agent_id = _fsp_get("agent_id");
    var prev_hash = _fsp_get("prev_hash");
    var hash = _fsp_get("hash");
    var hash_alg = _fsp_get("hash_algorithm");

    if (source == 0 || action == 0 || hash == 0) { return 0; }

    # Build entry from raw fields (no hash recomputation)
    var e = fl_alloc(88);

    # Parse UUID from hex (8-4-4-4-12 format, strip dashes)
    _filestore_parse_uuid(e, id_hex);

    store64(e + 16, ts_str);
    store64(e + 24, _parse_severity(sev_str));
    store64(e + 32, source);
    store64(e + 40, action);
    if (details == 0 || str_len(details) == 0) {
        store64(e + 48, str_from("{}"));
    } else {
        # Details was escaped as a string — unescape backslash sequences
        store64(e + 48, _filestore_unescape(details));
    }
    if (agent_id != 0 && str_len(agent_id) > 0) {
        # Check for "null" literal
        var ad = str_data(agent_id);
        if (str_len(agent_id) == 4 && (load8(ad) & 0xFF) == 110) {
            store64(e + 56, 0);
        } else {
            store64(e + 56, agent_id);
        }
    } else {
        store64(e + 56, 0);
    }
    store64(e + 64, prev_hash);
    store64(e + 72, hash);
    if (hash_alg != 0) {
        store64(e + 80, hash_alg);
    } else {
        store64(e + 80, str_from(HASH_ALGORITHM));
    }

    return e;
}

fn _fsp_get(key) {
    var skey = str_from(key);
    var v = json_get(_fsp_pairs, skey);
    if (v == 0) { return 0; }
    return v;
}

fn _parse_severity(s) {
    if (s == 0) { return SEV_INFO; }
    var d = str_data(s);
    var first = load8(d) & 0xFF;
    if (first == 68) { return SEV_DEBUG; }
    if (first == 87) { return SEV_WARNING; }
    if (first == 69) { return SEV_ERROR; }
    if (first == 67) { return SEV_CRITICAL; }
    if (first == 83) { return SEV_SECURITY; }
    return SEV_INFO;
}

# Unescape JSON string escapes (\", \\, \n)
fn _filestore_unescape(s) {
    var data = str_data(s);
    var slen = str_len(s);
    var out = alloc(slen + 1);
    var oi = 0;
    var i = 0;
    while (i < slen) {
        var c = load8(data + i) & 0xFF;
        if (c == 92 && i + 1 < slen) {
            var nc = load8(data + i + 1) & 0xFF;
            if (nc == 34) { store8(out + oi, 34); oi = oi + 1; i = i + 2; }
            if (nc == 92) { store8(out + oi, 92); oi = oi + 1; i = i + 2; }
            if (nc == 110) { store8(out + oi, 10); oi = oi + 1; i = i + 2; }
            if (nc != 34 && nc != 92 && nc != 110) {
                store8(out + oi, c); oi = oi + 1; i = i + 1;
            }
        } else {
            store8(out + oi, c);
            oi += 1;
            i += 1;
        }
    }
    store8(out + oi, 0);
    return str_new(out, oi);
}

fn _filestore_parse_uuid(buf, hex_str) {
    if (hex_str == 0) {
        memset(buf, 0, 16);
        return 0;
    }
    # UUID format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (36 chars)
    # Strip dashes, decode 32 hex chars to 16 bytes
    var hd = str_data(hex_str);
    var hl = str_len(hex_str);
    var bi = 0;
    var hi = 0;
    while (hi < hl && bi < 16) {
        var c = load8(hd + hi) & 0xFF;
        if (c == 45) {
            hi += 1;
        } else {
            var high = _hex_nibble(c);
            hi += 1;
            if (hi < hl) {
                var low = _hex_nibble(load8(hd + hi) & 0xFF);
                store8(buf + bi, (high << 4) | low);
                bi += 1;
                hi += 1;
            }
        }
    }
    return 0;
}

# --- chain_io.cyr ---

# chain_io.cyr — full-chain export/import as JSON Lines.
#
# Format: one JSON line per record.
#   Line 0:   meta  → {"_libro_chain":1,"prev_chain_hash":"…","max_capacity":N}
#   Lines 1+: entries — same shape as FileStore JSONL (reuses the helper).
#
# Reuses `_filestore_entry_json` + `_filestore_parse_entry` from
# file_store.cyr, so this file must be included after it. Requires
# `lib/io.cyr` (`file_open`/`file_read`/`file_write`/`file_close`).
#
# Overflow archives are NOT serialized — callers wanting full persistence
# across rotations should drive a FileStore or patra store directly.

# Entry-count cache for round-trip validation without re-reading the file.
var _ci_last_imported = 0;

# Write the chain's live entries + metadata to `path`. Truncates.
# Returns 0 on success, -1 on open failure.
fn chain_export(c, path) {
    sakshi_info("chain_io: export", 16);
    var cpath = _entry_to_cstr(path);
    var fd = file_open(cpath, O_WRONLY | O_CREAT | O_TRUNC, 0x1A4);
    if (fd < 0) {
        sakshi_error("chain_io: export open failed", 28);
        return -1;
    }

    # Header line — meta
    var hdr = str_builder_new();
    str_builder_add_cstr(hdr, "{\"_libro_chain\":1,\"prev_chain_hash\":\"");
    var prev = chain_prev_hash(c);
    if (prev != 0) {
        str_builder_add(hdr, prev);
    }
    str_builder_add_cstr(hdr, "\",\"max_capacity\":");
    str_builder_add_int(hdr, chain_max_capacity(c));
    str_builder_add_cstr(hdr, "}\n");
    var hline = str_builder_build(hdr);
    file_write(fd, str_data(hline), str_len(hline));

    # Entry lines
    var entries = chain_entries(c);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var sb = str_builder_new();
        _filestore_entry_json(sb, e);
        str_builder_add_cstr(sb, "\n");
        var line = str_builder_build(sb);
        file_write(fd, str_data(line), str_len(line));
        i += 1;
    }

    file_close(fd);
    return 0;
}

# Read a chain back from a file written by chain_export. Returns a new
# AuditChain pointer, or 0 on failure (missing/invalid header).
fn chain_import(path) {
    sakshi_info("chain_io: import", 16);
    var cpath = _entry_to_cstr(path);
    var fd = file_open(cpath, O_RDONLY, 0);
    if (fd < 0) {
        sakshi_error("chain_io: import open failed", 28);
        return 0;
    }

    var fsize = _fs_file_size(fd);
    if (fsize < 0) { fsize = 0; }
    syscall(SYS_LSEEK, fd, 0, 0);   # SEEK_SET — was raw syscall(8): agnos #8=dup, lseek=#58
    var buf = alloc(fsize + 1);
    var total = 0;
    var done = 0;
    while (done == 0) {
        var n = file_read(fd, buf + total, (fsize + 1) - total);
        if (n <= 0) { done = 1; } else { total = total + n; }
    }
    file_close(fd);

    var c = chain_new();
    var pos = 0;
    var line_idx = 0;
    _ci_last_imported = 0;

    while (pos < total) {
        var eol = pos;
        while (eol < total && (load8(buf + eol) & 0xFF) != 10) { eol += 1; }
        var line_len = eol - pos;
        if (line_len > 0) {
            # Clone the line off the shared read buffer before parse —
            # json_parse creates Str views pointing into the raw bytes.
            var line_str = str_clone(str_new(buf + pos, line_len));
            if (line_idx == 0) {
                _chain_import_apply_meta(c, line_str);
            } else {
                var e = _filestore_parse_entry(line_str);
                if (e != 0) { vec_push(chain_entries(c), e); }
            }
            line_idx += 1;
        }
        pos = eol + 1;
    }

    _ci_last_imported = chain_len(c);
    return c;
}

fn chain_import_count() { return _ci_last_imported; }

fn _chain_import_apply_meta(c, line) {
    var pairs = json_parse(line);
    if (vec_len(pairs) == 0) { return 0; }

    var prev = json_get(pairs, str_from("prev_chain_hash"));
    if (prev != 0 && str_len(prev) > 0) {
        chain_set_prev_hash(c, prev);
    }

    var cap = json_get(pairs, str_from("max_capacity"));
    if (cap != 0 && str_len(cap) > 0) {
        chain_set_max_capacity(c, str_to_int(cap));
    }
    return 0;
}

# --- patra_store.cyr ---

# patra_store.cyr — SQL-backed audit store via patra
# Indexed storage with transactions, WAL crash recovery,
# and SQL queries. Persistent alternative to MemoryStore.
#
# 2.4.0 — perf tier:
#   - Prepared SELECT and COUNT statements (parsed once at open,
#     reused across calls; finalized at close).
#   - STR-indexed `src` column for `patrastore_by_source` queries
#     (patra 1.7.0 STR-keyed btree index).
#   - patrastore_append_batch + sync-mode controls
#     (patra 1.8.0 group commit / batched fsync).

# ================================================================
# PatraStore — internal-only accessors (underscore-prefixed type name
# keeps the generated fns out of the public surface).
#   _patrastore_db, _patrastore_inited, _patrastore_select_stmt,
#   _patrastore_count_stmt (+ _set_ setters)
#
# select_stmt / count_stmt are patra-prepared statement handles for
# the two constant-SQL queries (SELECT * and SELECT COUNT(*)). Both
# are parsed once at patrastore_open and finalized at close —
# every patrastore_load_all / patrastore_len call skips the ~8µs
# tokenize+parse step.
# ================================================================
#derive(accessors)
struct _patrastore { db; inited; select_stmt; count_stmt; }

fn patrastore_open(path) {
    sakshi_info("patrastore: open", 16);
    var s = fl_alloc(32);
    var db = patra_open(_entry_to_cstr(path));
    if (db == 0) {
        sakshi_error("patrastore: open failed", 23);
        return 0;
    }
    store64(s, db);
    store64(s + 8, 0);
    store64(s + 16, 0);  # select_stmt populated after table-ensure
    store64(s + 24, 0);  # count_stmt
    _patrastore_ensure_table(s);
    _patrastore_prepare_stmts(s);
    return s;
}

fn patrastore_close(s) {
    if (s == 0) { return 0; }
    # Finalize prepared statements before closing the db. Safe on 0
    # — patra_finalize is a no-op for a null stmt handle.
    patra_finalize(load64(s + 16));
    patra_finalize(load64(s + 24));
    patra_close(load64(s));
    fl_free(s);
    return 0;
}

# ================================================================
# Schema
# ================================================================

fn _ps_build_create_sql() {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "CREATE TABLE audit_entries (");
    str_builder_add_cstr(sb, "id STR, ts STR, sev STR, src STR, act STR, ");
    str_builder_add_cstr(sb, "det STR, aid STR, phash STR, hash STR, halg STR)");
    return _entry_to_cstr(str_builder_build(sb));
}

fn _patrastore_ensure_table(s) {
    if (load64(s + 8) == 1) { return 0; }
    var db = load64(s);
    var r = patra_exec(db, _ps_build_create_sql());
    if (r == PATRA_OK || r == PATRA_ERR_EXISTS) {
        store64(s + 8, 1);
    }
    return 0;
}

# Opt-in STR index on `src`. Consumers that query by_source
# frequently can call this once after open to convert subsequent
# patrastore_by_source calls from O(N) full-scan to O(log N)
# btree probe + filter (patra 1.7.0 STR-keyed btree). The
# trade-off is per-insert cost: every patrastore_append must
# now also update the index page, which on real-disk btrfs/nvme
# adds an extra write to the fsync window.
#
# Heuristic: enable if `vec_len(by_source(...))` is consistently
# small relative to total entries (selective queries) AND
# by_source dominates the read mix. Don't enable for
# write-heavy / read-rare workloads.
#
# Idempotent — PATRA_ERR_EXISTS on a second call is fine.
fn patrastore_create_source_index(s) {
    if (s == 0) { return PATRA_ERR_IO; }
    return patra_exec(load64(s), "CREATE INDEX ON audit_entries (src)");
}

# ================================================================
# Prepared statements (2.4.0)
# ================================================================

# SQL strings prepared once per open. Patra's prepared model is "parse
# once, dispatch many" — no parameter binding — so only constant-SQL
# queries are eligible. patrastore_append and patrastore_by_source
# build per-call SQL with embedded values; those stay un-prepared.
var _ps_select_sql = "SELECT * FROM audit_entries";
var _ps_count_sql = "SELECT COUNT(*) FROM audit_entries";

fn _patrastore_prepare_stmts(s) {
    var db = load64(s);
    var sel = patra_prepare(db, _ps_select_sql);
    var cnt = patra_prepare(db, _ps_count_sql);
    store64(s + 16, sel);
    store64(s + 24, cnt);
    return 0;
}

# ================================================================
# Sync-mode controls (2.4.0 — patra 1.8.0 group commit)
# ================================================================
# Wraps patra's per-handle sync-mode API. Default after open is
# PATRA_SYNC_FULL — fdatasync on every mutating exec, durable per call.
# PATRA_SYNC_BATCH amortizes fsync across multiple writes (auto-flush
# every PATRA_BATCH_FLUSH_N writes; flush on close, on switch back to
# FULL, or on explicit patrastore_flush). Real-disk speedup is ~64×
# (per patra's bench notes); on tmpfs (e.g. /tmp) fdatasync is a no-op
# and the win is invisible.

fn patrastore_set_sync_mode(s, mode) {
    if (s == 0) { return PATRA_ERR_IO; }
    return patra_set_sync_mode(load64(s), mode);
}

fn patrastore_get_sync_mode(s) {
    if (s == 0) { return PATRA_SYNC_FULL; }
    return patra_get_sync_mode(load64(s));
}

fn patrastore_flush(s) {
    if (s == 0) { return 0; }
    return patra_flush(load64(s));
}

# ================================================================
# Append — build INSERT SQL and execute
# ================================================================
# patra_exec re-tokenizes + re-parses on every call; we can't share a
# prepared statement across appends because each entry's INSERT carries
# a different value tuple in the SQL string itself (patra has no bind
# parameters as of 1.9.3). The big perf knob for append-heavy workloads
# is patrastore_append_batch + SYNC_BATCH below.

fn patrastore_append(s, e) {
    sakshi_debug("patrastore: append", 18);
    var db = load64(s);

    # Entry fields as locals. The 1.0.x era held these in globals because
    # cc3 could clobber locals across the str_builder_add* call chain
    # below; cc5 5.4.2 preserves them reliably — confirmed by the full
    # test suite passing with this refactor.
    var id = uuid_format(entry_id(e));
    var ts = entry_timestamp(e);
    var sev = severity_as_str(entry_severity(e));
    var src = entry_source(e);
    var act = entry_action(e);
    var det = entry_details(e);
    var aid_raw = entry_agent_id(e);
    var aid = aid_raw;
    if (aid_raw == 0) { aid = str_from(""); }
    var ph = entry_prev_hash(e);
    var hash = entry_hash(e);
    var halg = entry_hash_algorithm(e);

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "INSERT INTO audit_entries VALUES ('");
    str_builder_add(sb, id);
    str_builder_add_cstr(sb, "', '");
    str_builder_add(sb, ts);
    str_builder_add_cstr(sb, "', '");
    str_builder_add_cstr(sb, sev);
    str_builder_add_cstr(sb, "', '");
    str_builder_add(sb, src);
    str_builder_add_cstr(sb, "', '");
    str_builder_add(sb, act);
    str_builder_add_cstr(sb, "', '");
    str_builder_add(sb, det);
    str_builder_add_cstr(sb, "', '");
    str_builder_add(sb, aid);
    str_builder_add_cstr(sb, "', '");
    str_builder_add(sb, ph);
    str_builder_add_cstr(sb, "', '");
    str_builder_add(sb, hash);
    str_builder_add_cstr(sb, "', '");
    str_builder_add(sb, halg);
    str_builder_add_cstr(sb, "')");

    var sql = str_builder_build(sb);
    var cstr = _entry_to_cstr(sql);
    var r = patra_exec(db, cstr);
    if (r != PATRA_OK) {
        sakshi_error("patrastore: insert failed", 25);
    }
    return r;
}

# Bulk-append N entries with a single fsync amortized across the batch.
# The 1.8.0 patra group-commit numbers show ~64× speedup vs FULL on
# real-disk btrfs/nvme. Toggles sync mode around the loop and restores
# the caller's mode (in case they were already in BATCH for a larger
# bulk window). Returns the count of successful inserts.
fn patrastore_append_batch(s, entries) {
    if (s == 0) { return 0; }
    var prior_mode = patrastore_get_sync_mode(s);
    patrastore_set_sync_mode(s, PATRA_SYNC_BATCH);
    var n = vec_len(entries);
    var ok = 0;
    var i = 0;
    while (i < n) {
        var r = patrastore_append(s, vec_get(entries, i));
        if (r == PATRA_OK) { ok = ok + 1; }
        i = i + 1;
    }
    patrastore_flush(s);
    patrastore_set_sync_mode(s, prior_mode);
    return ok;
}

# ================================================================
# Load all
# ================================================================

fn patrastore_load_all(s) {
    sakshi_info("patrastore: load all", 20);
    var db = load64(s);
    var stmt = load64(s + 16);
    var rs = 0;
    if (stmt != 0) {
        rs = patra_query_prepared(db, stmt);
    } else {
        rs = patra_query(db, _ps_select_sql);
    }
    if (rs == 0) { return vec_new(); }

    var entries = vec_new();
    var n = patra_result_count(rs);
    var i = 0;
    while (i < n) {
        var e = _patrastore_row_to_entry(rs, i);
        if (e != 0) {
            vec_push(entries, e);
        }
        i += 1;
    }
    patra_result_free(rs);
    return entries;
}

# ================================================================
# Row → AuditEntry
# ================================================================

# Copy a null-terminated C string out of the patra result-set buffer
# into independent heap memory, wrapped as a Str. Patra's rs buffer is
# freed by patra_result_free() at the end of load_all; Strs built with
# str_from() alone would dangle. This copies first.
fn _ps_copy_cstr(cstr) {
    var n = strlen(cstr);
    var buf = alloc(n + 1);
    memcpy(buf, cstr, n);
    store8(buf + n, 0);
    return str_new(buf, n);
}

fn _patrastore_row_to_entry(rs, row) {
    var e = fl_alloc(88);

    var id_str = patra_result_get_str(rs, row, 0);
    _filestore_parse_uuid(e, _ps_copy_cstr(id_str));

    store64(e + 16, _ps_copy_cstr(
    patra_result_get_str(rs, row, 1)));

    store64(e + 24, _parse_severity(_ps_copy_cstr(
    patra_result_get_str(rs, row, 2))));

    store64(e + 32, _ps_copy_cstr(
    patra_result_get_str(rs, row, 3)));

    store64(e + 40, _ps_copy_cstr(
    patra_result_get_str(rs, row, 4)));

    var det = patra_result_get_str(rs, row, 5);
    if (strlen(det) > 0) {
        store64(e + 48, _ps_copy_cstr(det));
    } else {
        store64(e + 48, str_from("{}"));
    }

    var aid = patra_result_get_str(rs, row, 6);
    if (strlen(aid) > 0) {
        store64(e + 56, _ps_copy_cstr(aid));
    } else {
        store64(e + 56, 0);
    }

    store64(e + 64, _ps_copy_cstr(
    patra_result_get_str(rs, row, 7)));

    store64(e + 72, _ps_copy_cstr(
    patra_result_get_str(rs, row, 8)));

    var ha = patra_result_get_str(rs, row, 9);
    if (strlen(ha) > 0) {
        store64(e + 80, _ps_copy_cstr(ha));
    } else {
        store64(e + 80, str_from(HASH_ALGORITHM));
    }

    return e;
}

# ================================================================
# Len
# ================================================================

fn patrastore_len(s) {
    var db = load64(s);
    var stmt = load64(s + 24);
    var rs = 0;
    if (stmt != 0) {
        rs = patra_query_prepared(db, stmt);
    } else {
        rs = patra_query(db, _ps_count_sql);
    }
    if (rs == 0) { return 0; }
    var n = patra_result_get_int(rs, 0, 0);
    patra_result_free(rs);
    return n;
}

fn patrastore_is_empty(s) {
    if (patrastore_len(s) == 0) { return 1; }
    return 0;
}

# ================================================================
# Load and verify
# ================================================================

fn patrastore_load_and_verify(s) {
    var entries = patrastore_load_all(s);
    var err = verify_chain(entries, 0);
    if (err != 0) {
        sakshi_error("patrastore: verify failed", 25);
        return err;
    }
    return entries;
}

# ================================================================
# Query
# ================================================================

fn patrastore_query(s, filter) {
    var entries = patrastore_load_all(s);
    return query_apply(filter, entries);
}

# ================================================================
# Query by source — uses the STR index on `src` (patra 1.7.0)
# ================================================================

fn patrastore_by_source(s, source) {
    var db = load64(s);
    var sb = str_builder_new();
    str_builder_add_cstr(sb,
    "SELECT * FROM audit_entries WHERE src = '");
    str_builder_add(sb, source);
    str_builder_add_cstr(sb, "'");
    var sql = str_builder_build(sb);
    var rs = patra_query(db, _entry_to_cstr(sql));
    if (rs == 0) { return vec_new(); }

    var entries = vec_new();
    var n = patra_result_count(rs);
    var i = 0;
    while (i < n) {
        var e = _patrastore_row_to_entry(rs, i);
        if (e != 0) { vec_push(entries, e); }
        i += 1;
    }
    patra_result_free(rs);
    return entries;
}

# ================================================================
# Transactions
# ================================================================

fn patrastore_begin(s) {
    return patra_begin(load64(s));
}

fn patrastore_commit(s) {
    return patra_commit(load64(s));
}

fn patrastore_rollback(s) {
    return patra_rollback(load64(s));
}

# --- streaming.cyr ---

# streaming.cyr — streaming pub/sub for audit entries
#
# Publishes each appended entry to a configurable topic hierarchy.
# Subscribers receive entries using MQTT-style wildcard patterns.
#
# Topic hierarchy:
#   Entries published to "{prefix}/{source}/{action}", e.g.:
#     libro/daimon/agent.start
#
# Wildcard patterns:
#   libro/#              — all entries
#   libro/daimon/#       — all daimon entries
#   libro/*/agent.start  — agent.start from any source
#
# Self-contained: includes minimal topic matching. In production,
# consumers can route through majra pubsub for cross-process delivery.

# ================================================================
# Topic matching (MQTT-style wildcards)
# ================================================================

# Match a topic against a pattern with wildcards:
#   * matches exactly one level
#   # matches zero or more levels (must be last)
fn _topic_match(topic, pattern) {
    var ti = 0;
    var pi = 0;
    var tlen = strlen(topic);
    var plen = strlen(pattern);
    while (pi < plen) {
        var pc = load8(pattern + pi);
        if (pc == 35) { return 1; }  # '#' matches rest
        if (ti >= tlen) { return 0; }
        var tc = load8(topic + ti);
        if (pc == 42) {
            # '*' matches one level — skip to next '/' in both
            while (ti < tlen) { if (load8(topic + ti) == 47) { break; } ti = ti + 1; }
            while (pi < plen) { if (load8(pattern + pi) == 47) { break; } pi = pi + 1; }
        } else {
            if (tc != pc) { return 0; }
            ti += 1;
            pi += 1;
        }
    }
    if (ti == tlen) { return 1; }
    return 0;
}

# ================================================================
# Subscription — generated accessors: _sub_pattern, _sub_entries, _sub_next
# ================================================================
#derive(accessors)
struct _sub { pattern; entries; next; }

fn _sub_new(pattern) {
    var sub = alloc(24);
    store64(sub, pattern);
    store64(sub + 8, vec_new());
    store64(sub + 16, 0);
    return sub;
}

# ================================================================
# AuditStream — generated accessors: stream_subs, stream_prefix, stream_published
# ================================================================
#derive(accessors)
struct stream { subs; prefix; published; }

fn stream_new() {
    var s = alloc(24);
    store64(s, 0);
    store64(s + 8, "libro");
    store64(s + 16, 0);
    return s;
}

fn stream_with_prefix(prefix) {
    var s = alloc(24);
    store64(s, 0);
    store64(s + 8, prefix);
    store64(s + 16, 0);
    return s;
}

# Build topic: "{prefix}/{source}/{action}"
fn _stream_topic(s, entry) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, load64(s + 8));
    str_builder_add_cstr(sb, "/");
    str_builder_add(sb, entry_source(entry));
    str_builder_add_cstr(sb, "/");
    str_builder_add(sb, entry_action(entry));
    return str_builder_build(sb);
}

# Subscribe to a topic pattern. Returns subscription handle.
fn stream_subscribe(s, pattern) {
    var sub = _sub_new(pattern);
    store64(sub + 16, load64(s));
    store64(s, sub);
    return sub;
}

# Publish an audit entry. Delivers to all matching subscriptions.
fn stream_publish(s, entry) {
    sakshi_debug("stream: publish", 15);
    var topic = _stream_topic(s, entry);
    var td = str_data(topic);
    var sub = load64(s);
    while (sub != 0) {
        if (_topic_match(td, _sub_pattern(sub)) == 1) {
            vec_push(_sub_entries(sub), entry);
        }
        sub = _sub_next(sub);
    }
    store64(s + 16, load64(s + 16) + 1);
    return 0;
}

# Receive next entry from a subscription. Removes from queue.
fn stream_recv(sub) {
    var entries = _sub_entries(sub);
    var elen = vec_len(entries);
    if (elen == 0) { return 0; }
    var e = vec_get(entries, 0);
    # Shift remaining entries left
    var i = 0;
    while (i < elen - 1) {
        vec_set(entries, i, vec_get(entries, i + 1));
        i += 1;
    }
    # Decrement length (vec stores len at offset 8)
    store64(entries + 8, elen - 1);
    return e;
}

# Number of pending entries in a subscription
fn stream_pending(sub) {
    return vec_len(_sub_entries(sub));
}

# --- proof_json.cyr ---

# proof_json.cyr — JSON pretty-printer for IntegrityProof.
#
# Lives in its own module (rather than proof.cyr) so that benchmark binaries
# that exercise proof verification without needing JSON output — notably
# libro_core.bcyr — can exclude it and stay under cc5 5.4.2's 16384
# fixup-table cap. References _sb_json_escape (export.cyr) and anchor_*
# (anchoring.cyr); both must be included before this file.
#
# Added in 2.0. Ports `to_proof_json()` from the Rust reference.

fn _sb_json_str_or_null(sb, s) {
    if (s == 0 || str_len(s) == 0) {
        str_builder_add_cstr(sb, "null");
        return 0;
    }
    str_builder_add_cstr(sb, "\"");
    _sb_json_escape(sb, s);
    str_builder_add_cstr(sb, "\"");
    return 0;
}

fn _sb_proof_entry(sb, e) {
    str_builder_add_cstr(sb, "    {\"id\":\"");
    str_builder_add(sb, uuid_format(entry_id(e)));
    str_builder_add_cstr(sb, "\",\"timestamp\":\"");
    str_builder_add(sb, entry_timestamp(e));
    str_builder_add_cstr(sb, "\",\"severity\":\"");
    str_builder_add_cstr(sb, severity_as_str(entry_severity(e)));
    str_builder_add_cstr(sb, "\",\"source\":\"");
    _sb_json_escape(sb, entry_source(e));
    str_builder_add_cstr(sb, "\",\"action\":\"");
    _sb_json_escape(sb, entry_action(e));
    str_builder_add_cstr(sb, "\",\"details\":");
    str_builder_add(sb, entry_details(e));
    str_builder_add_cstr(sb, ",\"agent_id\":");
    _sb_json_str_or_null(sb, entry_agent_id(e));
    str_builder_add_cstr(sb, ",\"prev_hash\":\"");
    str_builder_add(sb, entry_prev_hash(e));
    str_builder_add_cstr(sb, "\",\"hash\":\"");
    str_builder_add(sb, entry_hash(e));
    str_builder_add_cstr(sb, "\"}");
    return 0;
}

fn _sb_proof_inclusion(sb, mp) {
    str_builder_add_cstr(sb, "    {\"index\":");
    str_builder_add_int(sb, merkle_proof_index(mp));
    str_builder_add_cstr(sb, ",\"leaf\":\"");
    str_builder_add(sb, merkle_proof_leaf(mp));
    str_builder_add_cstr(sb, "\",\"root\":\"");
    str_builder_add(sb, merkle_proof_root(mp));
    # Path entries are emitted as `{"h":"<hex>","s":<0|1>}` so the
    # side bit survives round-trip — merkle_verify_proof needs it to
    # decide left vs right hash ordering at each level. Pre-2.6.0
    # libro emitted bare hex strings here, losing the side; the
    # parser side accepts both forms.
    str_builder_add_cstr(sb, "\",\"path\":[");
    var path = merkle_proof_path(mp);
    var pn = vec_len(path);
    var i = 0;
    while (i < pn) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        var node = vec_get(path, i);
        str_builder_add_cstr(sb, "{\"h\":\"");
        str_builder_add(sb, proof_node_hash(node));
        str_builder_add_cstr(sb, "\",\"s\":");
        str_builder_add_int(sb, proof_node_side(node));
        str_builder_add_cstr(sb, "}");
        i += 1;
    }
    str_builder_add_cstr(sb, "]}");
    return 0;
}

fn _sb_proof_anchor(sb, a) {
    str_builder_add_cstr(sb, "  \"anchor\": {\n");
    str_builder_add_cstr(sb, "    \"merkle_root\": \"");
    str_builder_add(sb, anchor_merkle_root(a));
    str_builder_add_cstr(sb, "\",\n    \"entry_count\": ");
    str_builder_add_int(sb, anchor_entry_count(a));
    str_builder_add_cstr(sb, ",\n    \"chain_head\": \"");
    str_builder_add(sb, anchor_chain_head(a));
    str_builder_add_cstr(sb, "\",\n    \"hash\": \"");
    str_builder_add(sb, anchor_hash(a));
    str_builder_add_cstr(sb, "\"\n  }");
    return 0;
}

# ================================================================
# proof_from_json — parse proof_to_json output back to an iproof
# ================================================================
# The 2.0.5 CHANGELOG's "Upcoming" for 2.0.6. Rebuilds an iproof
# structure that passes proof_verify_* (as long as the original
# proof also did).
#
# Tradeoffs / known limitations:
#   - Anchor is a lossy field in the JSON emission format (only
#     merkle_root / entry_count / chain_head / hash are emitted; UUID /
#     hash_alg / created_at / prev_hash are dropped). A parsed anchor
#     can't re-compute its self-hash, so anchor_verify_integrity
#     would fail on a parsed anchor. The parser therefore leaves the
#     iproof's anchor slot null regardless of what the JSON contains.
#     Consumers who need anchor re-verification should cross-check
#     out-of-band or use a lossless snapshot format.
#   - Consistency proofs are not emitted by proof_to_json and so
#     can't be parsed either — the iproof's consistency slot is
#     always null on parse.
#   - The tree field is not serialized; verify rebuilds it from
#     entries as part of the "tree matches" check, so this is fine.
#   - The hash_algorithm field on entries is preserved.
#
# lib/json.cyr is a flat parser; the proof shape has nested values
# (especially per-entry `details` which can itself be a full JSON
# object). This file implements the handful of byte-walker primitives
# needed to handle that without pulling in a general nested parser.

fn _pfj_skip_ws(d, p, end) {
    while (p < end) {
        var c = load8(d + p) & 0xFF;
        if (c != 32 && c != 9 && c != 10 && c != 13) { return p; }
        p = p + 1;
    }
    return p;
}

# Skip one JSON value starting at p. Handles strings (with \" escapes),
# objects, arrays, numbers, true/false/null. Returns position after the
# value, or -1 on malformed input.
fn _pfj_skip_value(d, p, end) {
    p = _pfj_skip_ws(d, p, end);
    if (p >= end) { return -1; }
    var c = load8(d + p) & 0xFF;
    if (c == 34) {
        # string
        p = p + 1;
        while (p < end) {
            var x = load8(d + p) & 0xFF;
            if (x == 92) { p = p + 2; }
            else {
                if (x == 34) { return p + 1; }
                else { p = p + 1; }
            }
        }
        return -1;
    }
    if (c == 123 || c == 91) {
        # object {} or array []
        var depth = 1;
        p = p + 1;
        while (p < end && depth > 0) {
            var x = load8(d + p) & 0xFF;
            if (x == 34) {
                # skip embedded string
                p = p + 1;
                var done_str = 0;
                while (p < end && done_str == 0) {
                    var y = load8(d + p) & 0xFF;
                    if (y == 92) { p = p + 2; }
                    else {
                        if (y == 34) { p = p + 1; done_str = 1; }
                        else { p = p + 1; }
                    }
                }
            } else {
                if (x == 123 || x == 91) {
                    depth = depth + 1;
                    p = p + 1;
                } else {
                    if (x == 125 || x == 93) {
                        depth = depth - 1;
                        p = p + 1;
                    } else {
                        p = p + 1;
                    }
                }
            }
        }
        if (depth != 0) { return -1; }
        return p;
    }
    # Scalar — scan until ,}] or whitespace
    while (p < end) {
        var x = load8(d + p) & 0xFF;
        if (x == 44 || x == 125 || x == 93 || x == 32 || x == 9 || x == 10 || x == 13) { return p; }
        p = p + 1;
    }
    return p;
}

# Extract a quoted string starting at p (must point at `"`). Returns
# (end_pos, cloned Str) packed — but Cyrius 5.4.2 caps multi-return at
# 2, so we return end_pos via global and the Str as the function value.
var _pfj_end_pos = 0;

fn _pfj_parse_string(d, p, end) {
    p = _pfj_skip_ws(d, p, end);
    if (p >= end) { _pfj_end_pos = -1; return 0; }
    if ((load8(d + p) & 0xFF) != 34) { _pfj_end_pos = -1; return 0; }
    p = p + 1;
    var start = p;
    var has_escape = 0;
    var str_done = 0;
    while (p < end && str_done == 0) {
        var x = load8(d + p) & 0xFF;
        if (x == 92) { has_escape = 1; p = p + 2; }
        else {
            if (x == 34) { str_done = 1; }
            else { p = p + 1; }
        }
    }
    if (p >= end) { _pfj_end_pos = -1; return 0; }
    var raw_len = p - start;
    var out = 0;
    if (has_escape == 0) {
        out = str_clone(str_new(d + start, raw_len));
    } else {
        # Unescape minimally — we only emit \" \\ \n \r \t \/ in _sb_json_escape.
        var buf = alloc(raw_len);
        var bi = 0;
        var si = start;
        while (si < p) {
            var x = load8(d + si) & 0xFF;
            if (x == 92 && si + 1 < p) {
                var nx = load8(d + si + 1) & 0xFF;
                # Default: copy the byte after `\` as-is (covers \" \\ \/).
                var ec = nx;
                if (nx == 110) { ec = 10; }   # \n
                if (nx == 114) { ec = 13; }   # \r
                if (nx == 116) { ec = 9; }    # \t
                if (nx == 98)  { ec = 8; }    # \b
                if (nx == 102) { ec = 12; }   # \f
                store8(buf + bi, ec);
                bi = bi + 1;
                si = si + 2;
            } else {
                store8(buf + bi, x);
                bi = bi + 1;
                si = si + 1;
            }
        }
        out = str_clone(str_new(buf, bi));
    }
    _pfj_end_pos = p + 1;
    return out;
}

# Parse an integer (possibly negative) at p. Returns the int, sets _pfj_end_pos.
fn _pfj_parse_int(d, p, end) {
    p = _pfj_skip_ws(d, p, end);
    if (p >= end) { _pfj_end_pos = -1; return 0; }
    var neg = 0;
    if ((load8(d + p) & 0xFF) == 45) { neg = 1; p = p + 1; }
    var n = 0;
    var started = 0;
    while (p < end) {
        var c = load8(d + p) & 0xFF;
        if (c >= 48 && c <= 57) {
            n = n * 10 + (c - 48);
            started = 1;
            p = p + 1;
        } else { break; }
    }
    if (started == 0) { _pfj_end_pos = -1; return 0; }
    _pfj_end_pos = p;
    if (neg == 1) { return -n; }
    return n;
}

# Match a literal at p (returns end pos on match, or -1).
fn _pfj_match_literal(d, p, end, lit, lit_len) {
    p = _pfj_skip_ws(d, p, end);
    if (p + lit_len > end) { return -1; }
    var i = 0;
    while (i < lit_len) {
        if ((load8(d + p + i) & 0xFF) != (load8(lit + i) & 0xFF)) { return -1; }
        i = i + 1;
    }
    return p + lit_len;
}

# Find the value-start position for key "name" within [p, end). Returns -1 if not found.
# Assumes we're inside an object — scans key:value pairs, balancing nested braces/strings.
fn _pfj_find_key_at(d, p, end, key_cstr) {
    var klen = strlen(key_cstr);
    p = _pfj_skip_ws(d, p, end);
    if (p >= end || (load8(d + p) & 0xFF) != 123) { return -1; }
    p = p + 1;
    var depth = 1;
    while (p < end && depth > 0) {
        p = _pfj_skip_ws(d, p, end);
        if (p >= end) { return -1; }
        var c = load8(d + p) & 0xFF;
        if (c == 125) { return -1; }
        if (c != 34) {
            p = p + 1;
            continue;
        }
        # At a key string
        var key_start = p + 1;
        var kp = key_start;
        var key_done = 0;
        while (kp < end && key_done == 0) {
            var x = load8(d + kp) & 0xFF;
            if (x == 92) { kp = kp + 2; }
            else {
                if (x == 34) { key_done = 1; }
                else { kp = kp + 1; }
            }
        }
        if (kp >= end) { return -1; }
        var this_klen = kp - key_start;
        # Skip colon
        var ap = kp + 1;
        ap = _pfj_skip_ws(d, ap, end);
        if (ap >= end || (load8(d + ap) & 0xFF) != 58) { return -1; }
        ap = _pfj_skip_ws(d, ap + 1, end);
        # Compare key
        if (this_klen == klen && memeq(d + key_start, key_cstr, klen) == 1) {
            return ap;
        }
        # Skip value, then a comma or closing brace
        var after_val = _pfj_skip_value(d, ap, end);
        if (after_val < 0) { return -1; }
        after_val = _pfj_skip_ws(d, after_val, end);
        if (after_val >= end) { return -1; }
        var sep = load8(d + after_val) & 0xFF;
        if (sep == 125) { return -1; }
        if (sep != 44) { return -1; }
        p = after_val + 1;
    }
    return -1;
}

# Parse an optional "null | string" field at p. Returns 0 for null, Str for string.
# Sets _pfj_end_pos to the position after the value.
fn _pfj_parse_string_or_null(d, p, end) {
    p = _pfj_skip_ws(d, p, end);
    if (p >= end) { _pfj_end_pos = -1; return 0; }
    # Check for "null"
    if (p + 4 <= end) {
        if ((load8(d + p) & 0xFF) == 110 &&
            (load8(d + p + 1) & 0xFF) == 117 &&
            (load8(d + p + 2) & 0xFF) == 108 &&
            (load8(d + p + 3) & 0xFF) == 108) {
            _pfj_end_pos = p + 4;
            return 0;
        }
    }
    return _pfj_parse_string(d, p, end);
}

fn _pfj_parse_tree_head(d, start, end) {
    var root_pos = _pfj_find_key_at(d, start, end, "root");
    if (root_pos < 0) { return 0; }
    var root = _pfj_parse_string(d, root_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    var ts_pos = _pfj_find_key_at(d, start, end, "tree_size");
    if (ts_pos < 0) { return 0; }
    var tree_size = _pfj_parse_int(d, ts_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    var tsp = _pfj_find_key_at(d, start, end, "timestamp");
    var timestamp = str_from("");
    if (tsp >= 0) {
        var t = _pfj_parse_string(d, tsp, end);
        if (_pfj_end_pos >= 0) { timestamp = t; }
    }

    var sig_pos = _pfj_find_key_at(d, start, end, "signature");
    var sig = str_from("");
    if (sig_pos >= 0) {
        var s = _pfj_parse_string_or_null(d, sig_pos, end);
        if (s != 0) { sig = s; }
    }

    var vk_pos = _pfj_find_key_at(d, start, end, "verifying_key");
    var vk = str_from("");
    if (vk_pos >= 0) {
        var v = _pfj_parse_string_or_null(d, vk_pos, end);
        if (v != 0) { vk = v; }
    }

    var alg_pos = _pfj_find_key_at(d, start, end, "algorithm");
    var alg = 0;  # SIG_ALG_ED25519 is 0
    if (alg_pos >= 0) {
        var a = _pfj_parse_string_or_null(d, alg_pos, end);
        # If present and equals "ML-DSA-65" or similar, would map to 1.
        # For now accept only null or Ed25519 (matches what 2.0.x emits).
        if (a != 0 && str_len(a) > 0 && str_eq(a, str_from("ML-DSA-65")) == 1) {
            alg = 1;
        }
    }

    var sth = sth_new(root, tree_size, sig, vk, alg);
    # sth_new uses current time for timestamp; overwrite with the parsed one.
    sth_set_timestamp(sth, timestamp);
    return sth;
}

fn _pfj_parse_one_entry(d, start, end) {
    # Parse the 10 entry fields.
    var id_pos = _pfj_find_key_at(d, start, end, "id");
    if (id_pos < 0) { return 0; }
    var id_hex = _pfj_parse_string(d, id_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    var ts_pos = _pfj_find_key_at(d, start, end, "timestamp");
    if (ts_pos < 0) { return 0; }
    var timestamp = _pfj_parse_string(d, ts_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    var sev_pos = _pfj_find_key_at(d, start, end, "severity");
    if (sev_pos < 0) { return 0; }
    var sev_str = _pfj_parse_string(d, sev_pos, end);
    if (_pfj_end_pos < 0) { return 0; }
    var severity = _parse_severity(sev_str);

    var src_pos = _pfj_find_key_at(d, start, end, "source");
    if (src_pos < 0) { return 0; }
    var source = _pfj_parse_string(d, src_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    var act_pos = _pfj_find_key_at(d, start, end, "action");
    if (act_pos < 0) { return 0; }
    var action = _pfj_parse_string(d, act_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    # details: raw JSON value — grab its substring as-is.
    var det_pos = _pfj_find_key_at(d, start, end, "details");
    if (det_pos < 0) { return 0; }
    var det_start = _pfj_skip_ws(d, det_pos, end);
    var det_end_pos = _pfj_skip_value(d, det_start, end);
    if (det_end_pos < 0) { return 0; }
    var details = str_clone(str_new(d + det_start, det_end_pos - det_start));

    var aid_pos = _pfj_find_key_at(d, start, end, "agent_id");
    var agent_id = 0;
    if (aid_pos >= 0) {
        agent_id = _pfj_parse_string_or_null(d, aid_pos, end);
    }

    var ph_pos = _pfj_find_key_at(d, start, end, "prev_hash");
    var prev_hash = str_from("");
    if (ph_pos >= 0) {
        var ph = _pfj_parse_string(d, ph_pos, end);
        if (_pfj_end_pos >= 0) { prev_hash = ph; }
    }

    var h_pos = _pfj_find_key_at(d, start, end, "hash");
    if (h_pos < 0) { return 0; }
    var hash = _pfj_parse_string(d, h_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    # Build the entry with known hash — bypass entry_new which would
    # recompute. Set fields via derived setters.
    var e = fl_alloc(88);
    _filestore_parse_uuid(e, id_hex);
    entry_set_timestamp(e, timestamp);
    entry_set_severity(e, severity);
    entry_set_source(e, source);
    entry_set_action(e, action);
    entry_set_details(e, details);
    entry_set_agent_id(e, agent_id);
    entry_set_prev_hash(e, prev_hash);
    entry_set_hash(e, hash);
    entry_set_hash_algorithm(e, str_from(HASH_ALGORITHM));
    return e;
}

fn _pfj_parse_one_inclusion(d, start, end) {
    var idx_pos = _pfj_find_key_at(d, start, end, "index");
    if (idx_pos < 0) { return 0; }
    var index = _pfj_parse_int(d, idx_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    var leaf_pos = _pfj_find_key_at(d, start, end, "leaf");
    if (leaf_pos < 0) { return 0; }
    var leaf = _pfj_parse_string(d, leaf_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    var root_pos = _pfj_find_key_at(d, start, end, "root");
    if (root_pos < 0) { return 0; }
    var root = _pfj_parse_string(d, root_pos, end);
    if (_pfj_end_pos < 0) { return 0; }

    var path_pos = _pfj_find_key_at(d, start, end, "path");
    if (path_pos < 0) { return 0; }
    path_pos = _pfj_skip_ws(d, path_pos, end);
    if (path_pos >= end || (load8(d + path_pos) & 0xFF) != 91) { return 0; }
    path_pos = path_pos + 1;
    # Path entries are proof_node structs. Accept TWO emission shapes:
    #   2.6.0+: {"h":"<hex>","s":<0|1>}  — lossless, side bit preserved.
    #   Legacy (pre-2.6): "<hex>"        — side dropped, treat as SIDE_LEFT.
    # The legacy path produces proof_nodes that can be carried through
    # the iproof struct but won't pass merkle_verify_proof (correctness
    # of the path-sides is lost). Round-trip from 2.6.0+ emissions is
    # fully lossless.
    var path = vec_new();
    while (path_pos < end) {
        path_pos = _pfj_skip_ws(d, path_pos, end);
        if (path_pos >= end) { return 0; }
        var c = load8(d + path_pos) & 0xFF;
        if (c == 93) { break; }
        if (c == 44) { path_pos = path_pos + 1; continue; }
        if (c == 123) {
            # Object form. Find the object's bounds, then look up h + s
            # inside that range.
            var obj_end = _pfj_skip_value(d, path_pos, end);
            if (obj_end < 0) { return 0; }
            var h_pos = _pfj_find_key_at(d, path_pos, obj_end, "h");
            if (h_pos < 0) { return 0; }
            var h = _pfj_parse_string(d, h_pos, obj_end);
            if (_pfj_end_pos < 0) { return 0; }
            var s_pos = _pfj_find_key_at(d, path_pos, obj_end, "s");
            var side = SIDE_LEFT;
            if (s_pos >= 0) {
                var sv = _pfj_parse_int(d, s_pos, obj_end);
                if (sv == SIDE_RIGHT) { side = SIDE_RIGHT; }
            }
            vec_push(path, proof_node_new(h, side));
            path_pos = obj_end;
        } elif (c == 34) {
            # Legacy bare-string form. Side defaults to LEFT — this is
            # lossy and verification of the resulting proof will fail
            # unless the leaf actually sat on the left at every level.
            var s = _pfj_parse_string(d, path_pos, end);
            if (_pfj_end_pos < 0) { return 0; }
            vec_push(path, proof_node_new(s, SIDE_LEFT));
            path_pos = _pfj_end_pos;
        } else {
            return 0;
        }
    }

    return merkle_proof_new(index, leaf, path, root);
}

# Walk an array `[{...},{...},…]` at pos, calling parser_id for each element.
# parser_id = 0 → entries; 1 → inclusions. (Cyrius fnptrs on inline callbacks
# here would work too, but keeping it dispatch-by-id avoids a callback dance.)
fn _pfj_parse_array(d, pos, end, parser_id) {
    var out = vec_new();
    pos = _pfj_skip_ws(d, pos, end);
    if (pos >= end || (load8(d + pos) & 0xFF) != 91) { return out; }
    pos = pos + 1;
    while (pos < end) {
        pos = _pfj_skip_ws(d, pos, end);
        if (pos >= end) { return out; }
        var c = load8(d + pos) & 0xFF;
        if (c == 93) { return out; }
        if (c == 44) { pos = pos + 1; continue; }
        if (c != 123) { return out; }
        # Find the bounds of this object
        var obj_end = _pfj_skip_value(d, pos, end);
        if (obj_end < 0) { return out; }
        var item = 0;
        if (parser_id == 0) {
            item = _pfj_parse_one_entry(d, pos, obj_end);
        } else {
            item = _pfj_parse_one_inclusion(d, pos, obj_end);
        }
        if (item != 0) { vec_push(out, item); }
        pos = obj_end;
    }
    return out;
}

fn proof_from_json(s) {
    if (s == 0 || str_len(s) == 0) { return 0; }
    var d = str_data(s);
    var end = str_len(s);

    # Check for top-level "null"
    var first = _pfj_skip_ws(d, 0, end);
    if (first + 4 <= end) {
        if ((load8(d + first) & 0xFF) == 110 &&
            (load8(d + first + 1) & 0xFF) == 117 &&
            (load8(d + first + 2) & 0xFF) == 108 &&
            (load8(d + first + 3) & 0xFF) == 108) {
            return 0;
        }
    }

    # tree_head
    var th_pos = _pfj_find_key_at(d, 0, end, "tree_head");
    if (th_pos < 0) { return 0; }
    var th_end = _pfj_skip_value(d, th_pos, end);
    if (th_end < 0) { return 0; }
    var sth = _pfj_parse_tree_head(d, th_pos, th_end);
    if (sth == 0) { return 0; }

    # entries
    var en_pos = _pfj_find_key_at(d, 0, end, "entries");
    if (en_pos < 0) { return 0; }
    var entries = _pfj_parse_array(d, en_pos, end, 0);

    # inclusions
    var in_pos = _pfj_find_key_at(d, 0, end, "inclusions");
    var inclusions = vec_new();
    if (in_pos >= 0) {
        inclusions = _pfj_parse_array(d, in_pos, end, 1);
    }

    # anchor — intentionally not reconstructed (lossy format; see header
    # docs above). The iproof's anchor slot stays null.

    var ip = fl_alloc(48);
    iproof_set_tree_head(ip, sth);
    iproof_set_consistency(ip, 0);
    iproof_set_inclusions(ip, inclusions);
    iproof_set_entries(ip, entries);
    iproof_set_anchor(ip, 0);
    # Rebuild tree from entries so proof_verify's tree-matches check has
    # something to work with. If entries is empty, leave tree at 0.
    if (vec_len(entries) > 0) {
        iproof_set_tree(ip, merkle_build(entries));
    } else {
        iproof_set_tree(ip, 0);
    }
    return ip;
}

fn proof_to_json(ip) {
    if (ip == 0) { return str_from("null"); }
    var sb = str_builder_new();
    var sth = iproof_tree_head(ip);
    var entries = iproof_entries(ip);
    var inclusions = iproof_inclusions(ip);
    var anchor = iproof_anchor(ip);

    str_builder_add_cstr(sb, "{\n  \"tree_head\": {\n");
    str_builder_add_cstr(sb, "    \"root\": \"");
    str_builder_add(sb, sth_root(sth));
    str_builder_add_cstr(sb, "\",\n    \"tree_size\": ");
    str_builder_add_int(sb, sth_tree_size(sth));
    str_builder_add_cstr(sb, ",\n    \"timestamp\": \"");
    str_builder_add(sb, sth_timestamp(sth));
    str_builder_add_cstr(sb, "\",\n    \"signature\": ");
    _sb_json_str_or_null(sb, sth_signature(sth));
    str_builder_add_cstr(sb, ",\n    \"verifying_key\": ");
    _sb_json_str_or_null(sb, sth_verifying_key(sth));
    str_builder_add_cstr(sb, ",\n    \"algorithm\": ");
    _sb_json_str_or_null(sb, sth_algorithm(sth));
    str_builder_add_cstr(sb, "\n  },\n");

    str_builder_add_cstr(sb, "  \"entries\": [");
    var en = vec_len(entries);
    var i = 0;
    while (i < en) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        str_builder_add_cstr(sb, "\n");
        _sb_proof_entry(sb, vec_get(entries, i));
        i += 1;
    }
    if (en > 0) { str_builder_add_cstr(sb, "\n  "); }
    str_builder_add_cstr(sb, "],\n");

    str_builder_add_cstr(sb, "  \"inclusions\": [");
    var inn = vec_len(inclusions);
    i = 0;
    while (i < inn) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        str_builder_add_cstr(sb, "\n");
        _sb_proof_inclusion(sb, vec_get(inclusions, i));
        i += 1;
    }
    if (inn > 0) { str_builder_add_cstr(sb, "\n  "); }
    str_builder_add_cstr(sb, "],\n");

    if (anchor == 0) {
        str_builder_add_cstr(sb, "  \"anchor\": null\n}");
    } else {
        _sb_proof_anchor(sb, anchor);
        str_builder_add_cstr(sb, "\n}");
    }

    return str_builder_build(sb);
}
