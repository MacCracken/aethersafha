# entry.cyr — AuditEntry, the core data type
# Tamper-proof hash-linked audit entries with UUID, timestamps,
# severity levels, and deterministic hash computation.

# ================================================================
# Severity constants
# ================================================================

enum Severity {
    SEV_DEBUG = 0;
    SEV_INFO = 1;
    SEV_WARNING = 2;
    SEV_ERROR = 3;
    SEV_CRITICAL = 4;
    SEV_SECURITY = 5;
}

fn severity_as_str(sev) {
    if (sev == SEV_DEBUG) { return "Debug"; }
    if (sev == SEV_INFO) { return "Info"; }
    if (sev == SEV_WARNING) { return "Warning"; }
    if (sev == SEV_ERROR) { return "Error"; }
    if (sev == SEV_CRITICAL) { return "Critical"; }
    if (sev == SEV_SECURITY) { return "Security"; }
    return "Unknown";
}

# Length of the severity_as_str() result without a strlen call.
# Entry hashing length-prefixes the severity name on every compute_hash;
# this avoids scanning the constant string once per entry.
fn severity_len(sev) {
    if (sev == SEV_DEBUG) { return 5; }
    if (sev == SEV_INFO) { return 4; }
    if (sev == SEV_WARNING) { return 7; }
    if (sev == SEV_ERROR) { return 5; }
    if (sev == SEV_CRITICAL) { return 8; }
    if (sev == SEV_SECURITY) { return 8; }
    return 7;
}

fn severity_at_or_above(sev, threshold) {
    if (sev >= threshold) { return 1; }
    return 0;
}

