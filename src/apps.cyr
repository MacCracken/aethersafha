    if (p == 0) { return 0; }
    store64(p + MI_ID, id);
    store64(p + MI_NAME, name);
    store64(p + MI_SIZE, size);
    store64(p + MI_PROVIDER, provider);
    store64(p + MI_IS_DOWNLOADED, is_downloaded);
    return p;
}
fn app_modelinfo_id(p)            { return load64(p + MI_ID); }
fn app_modelinfo_name(p)          { return load64(p + MI_NAME); }
fn app_modelinfo_size(p)          { return load64(p + MI_SIZE); }
fn app_modelinfo_provider(p)      { return load64(p + MI_PROVIDER); }
fn app_modelinfo_is_downloaded(p) { return load64(p + MI_IS_DOWNLOADED); }

fn app_modelmgr_new(): i64 {
    var p = alloc(MM_SZ);
    if (p == 0) { return 0; }
    store64(p + MM_ID, "model-manager");
    store64(p + MM_NAME, "Model Manager");
    store64(p + MM_INSTALLED, vec_new());
    store64(p + MM_ACTIVE_MODEL, 0);
    return p;
}
fn app_modelmgr_id(p)              { return load64(p + MM_ID); }
fn app_modelmgr_name(p)            { return load64(p + MM_NAME); }
fn app_modelmgr_installed_models(p){ return load64(p + MM_INSTALLED); }
fn app_modelmgr_active_model(p)    { return load64(p + MM_ACTIVE_MODEL); }
fn app_modelmgr_model_count(p)     { return vec_len(load64(p + MM_INSTALLED)); }
# select_model: local hit -> set active, Ok(0). Miss -> NotFound (gateway C3).
fn app_modelmgr_select_model(p, model_id): i64 {
    var v = load64(p + MM_INSTALLED);
    var i = 0;
    while (i < vec_len(v)) {
        if (streq(app_modelinfo_id(vec_get(v, i)), model_id) == 1) {
            store64(p + MM_ACTIVE_MODEL, model_id);
            return AppErr.APP_OK;
        }
        i = i + 1;
    }
    # PARITY (C3): full Rust consults the LLM gateway before failing; a clean env
    # is unreachable -> same NotFound.
    return AppErr.APP_ERR_NOT_FOUND;
}
# list_models — PARITY (C3): real body GETs the gateway /v1/models + merges.
fn app_modelmgr_list_models(p): i64 { return load64(p + MM_INSTALLED); }
# download_model — PARITY (C3): real body POSTs the gateway /api/pull.
fn app_modelmgr_download_model(p, id): i64 { return AppErr.APP_ERR_WINDOW; }

