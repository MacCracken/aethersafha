# aethersafha — built-in applications (Bite C, slice C1)
# Parity: rust-old/src/apps.rs
#   (AppError, AppType, AppWindow, DesktopApplications + the sub-apps:
#    FileManager, AgentManager, AuditViewer, ModelManager, WebBrowser, Shruti,
#    Terminal). C1 = the app framework + pure data-model apps + the aggregate.
#
# Convention (same as src/screen_capture.cyr / src/security_ui.cyr): heap objects
# = offset enum + alloc + load64/store64 accessors. Substitutions: Uuid -> i64 id
# (0 == nil), minted by the owning object's NEXT_ID; String -> cstr char*; built
# strings -> bare-cstr concatenation (app_cstr_cat3); Vec -> stdlib vec;
# HashMap<Uuid,_> -> map_u64; Option<String> -> cstr (0 == None); Option<numeric>
# -> -1 sentinel; Result<_,AppError> -> i64 code (0 == Ok); bool -> 0/1; tracing dropped.
#
# DEFERRED (C2/C3, marked `# PARITY (C2/C3)`): process spawning
# (Terminal.execute_command spawn body, WebBrowser/Shruti launch) and the
# filesystem/network effect bodies (list_agents, get_logs, list/download_model).
# C1 ships the pure logic incl. the security-critical allowlist + path-strip.
#
# LIBRARY MODULE: definitions only, no main / no top-level statements.

# ---------------------------------------------------------------------------
# Value enums.
# ---------------------------------------------------------------------------
enum AppErr {           # AppError -> i64 (payload strings dropped)
    APP_OK              = 0;
    APP_ERR_NOT_FOUND   = 1;   # AppNotFound(String)
    APP_ERR_WINDOW      = 2;   # WindowError(String) — empty command, spawn/exit failure
    APP_ERR_PERM_DENIED = 3;   # PermissionDenied(String) — program not in allowlist
}
enum AppType {          # AppType (9 variants; Shruti uses APP_CUSTOM)
    APP_CMDPALETTE      = 0;
    APP_FILE_MANAGER  = 1;
    APP_TEXT_EDITOR   = 2;
    APP_WEB_BROWSER   = 3;
    APP_AGENT_MANAGER = 4;
    APP_AUDIT_VIEWER  = 5;
    APP_MODEL_MANAGER = 6;
    APP_SETTINGS      = 7;
    APP_CUSTOM        = 8;
}
enum TimeRange {        # AuditViewer time filter
    TR_LAST_HOUR = 0;
    TR_LAST_DAY  = 1;
    TR_LAST_WEEK = 2;
    TR_CUSTOM    = 3;
}

# ---------------------------------------------------------------------------
# Offset enums (heap layouts; 8-byte slots).
# ---------------------------------------------------------------------------
enum AppWinOff {        # AppWindow
    AWIN_ID         = 0;   # i64 id (0 == nil)
    AWIN_TYPE       = 8;   # AppType
    AWIN_TITLE      = 16;  # cstr
    AWIN_WIDTH      = 24;  # i64 (default 800)
    AWIN_HEIGHT     = 32;  # i64 (default 600)
    AWIN_AI_ENABLED = 40;  # 0/1 (default 0)
    AWIN_SZ         = 48;
}
enum FileMgrOff {       # FileManagerApp
    FM_ID           = 0;   # cstr "filemanager"
    FM_NAME         = 8;   # cstr "File Manager"
    FM_CURRENT_PATH = 16;  # cstr "/home"
    FM_AGENT_ASSIST = 24;  # 0/1 (default 1)
    FM_SZ           = 32;
}
enum AgentInfoOff {     # AgentInfo
    AI_ID           = 0;   # i64
    AI_NAME         = 8;   # cstr
    AI_STATUS       = 16;  # cstr ("Starting" / "Running" / ...)
    AI_CAPABILITIES = 24;  # *vec of cstr
    AI_SZ           = 32;
}
enum AgentMgrOff {      # AgentManagerApp
    AM_ID      = 0;   # cstr "agent-manager"
    AM_NAME    = 8;   # cstr "Agent Manager"
    AM_AGENTS  = 16;  # *vec of *AgentInfo
    AM_NEXT_ID = 24;  # i64 monotonic, init 1
    AM_SZ      = 32;
}
enum AuditFiltOff {     # AuditFilters
    AF_INCLUDE_AGENT    = 0;   # 0/1
    AF_INCLUDE_SECURITY = 8;   # 0/1
    AF_INCLUDE_SYSTEM   = 16;  # 0/1
    AF_TIME_RANGE       = 24;  # TimeRange
    AF_SZ               = 32;
}
enum AuditEntryOff {    # AuditEntry
    AE_ID          = 0;   # i64
    AE_TIMESTAMP   = 8;   # i64 epoch
    AE_EVENT_TYPE  = 16;  # cstr
    AE_DESCRIPTION = 24;  # cstr
    AE_SOURCE      = 32;  # cstr
    AE_SZ          = 40;
}
enum AuditViewOff {     # AuditViewerApp
    AV_ID      = 0;   # cstr "audit-viewer"
    AV_NAME    = 8;   # cstr "Audit Log Viewer"
    AV_FILTERS = 16;  # *AuditFilters
    AV_SZ      = 24;
}
enum ModelInfoOff {     # ModelInfo
    MI_ID            = 0;   # cstr
    MI_NAME          = 8;   # cstr
    MI_SIZE          = 16;  # i64 (holds u64, incl. u64::MAX bit-pattern)
    MI_PROVIDER      = 24;  # cstr
    MI_IS_DOWNLOADED = 32;  # 0/1
    MI_SZ            = 40;
}
enum ModelMgrOff {      # ModelManagerApp
    MM_ID           = 0;   # cstr "model-manager"
    MM_NAME         = 8;   # cstr "Model Manager"
    MM_INSTALLED    = 16;  # *vec of *ModelInfo
    MM_ACTIVE_MODEL = 24;  # cstr (0 == None)
    MM_SZ           = 32;
}
enum BrowOff {          # WebBrowserApp
    BROW_ID     = 0;   # cstr
    BROW_NAME   = 8;   # cstr
    BROW_BINARY = 16;  # cstr
    BROW_ENV    = 24;  # cstr "KEY=VALUE" or 0 (None)
    BROW_DEFURL = 32;  # cstr or 0
    BROW_SZ     = 40;
}
enum ShrCfgOff {        # ShrutiSurfaceConfig
    SHRCFG_W      = 0;   # i64 (1400)
    SHRCFG_H      = 8;   # i64 (900)
    SHRCFG_EXCL   = 16;  # 0/1 exclusive audio (0)
    SHRCFG_PWNODE = 24;  # cstr "shruti-main"
    SHRCFG_SZ     = 32;
}
enum ShrOff {           # ShrutiApp
    SHR_ID      = 0;   # cstr "shruti"
    SHR_NAME    = 8;   # cstr "Shruti"
    SHR_BINARY  = 16;  # cstr "/usr/local/bin/shruti"
    SHR_DATADIR = 24;  # cstr "~/.local/share/shruti"
    SHR_CFG     = 32;  # *ShrutiSurfaceConfig
    SHR_RUNNING = 40;  # 0/1
    SHR_SZ      = 48;
}
enum TermOff {          # CmdPaletteApp
    CMDP_ID   = 0;   # cstr "cmdpalette"
    CMDP_NAME = 8;   # cstr "Command Palette"
    CMDP_AI   = 16;  # 0/1 (1)
    CMDP_SZ   = 24;
}
enum AppDeskOff {       # DesktopApplications
    AD_CMDPALETTE     = 0;   # *CmdPaletteApp
    AD_FILE_MGR     = 8;   # *FileManagerApp
    AD_BROWSERS     = 16;  # *vec of *WebBrowserApp (8)
    AD_AGENT_MGR    = 24;  # *AgentManagerApp
    AD_AUDIT_VIEW   = 32;  # *AuditViewerApp
    AD_MODEL_MGR    = 40;  # *ModelManagerApp
    AD_SHRUTI       = 48;  # *ShrutiApp
    AD_OPEN_WINDOWS = 56;  # *vec of *AppWindow (linear-scan by id; map_u64 has no values() iterator)
    AD_NEXT_ID      = 64;  # i64 monotonic, init 1
    AD_LAST_ERR     = 72;  # AppErr of the last fallible call
    AD_SZ           = 80;
}

# ---------------------------------------------------------------------------
# String helper — concat three bare cstrs into a fresh NUL-terminated buffer.
# (Used for the two built window titles + search_with_agent's "Found: {q}".)
# ---------------------------------------------------------------------------
fn app_cstr_cat3(a, b, c): i64 {
    var la = strlen(a);
    var lb = strlen(b);
    var lc = strlen(c);
    var out = alloc(la + lb + lc + 1);
    if (out == 0) { return 0; }
    var i = 0;
    while (i < la) { store8(out + i, load8(a + i)); i = i + 1; }
    var j = 0;
    while (j < lb) { store8(out + la + j, load8(b + j)); j = j + 1; }
    var k = 0;
    while (k < lc) { store8(out + la + lb + k, load8(c + k)); k = k + 1; }
    store8(out + la + lb + lc, 0);
    return out;
}
# app_substr(s, start, len): a fresh NUL-terminated copy of s[start .. start+len].
fn app_substr(s, start, len): i64 {
    var out = alloc(len + 1);
    if (out == 0) { return 0; }
    var i = 0;
    while (i < len) { store8(out + i, load8(s + start + i)); i = i + 1; }
    store8(out + len, 0);
    return out;
}
# app_cstr_contains(hay, needle): 1 if needle occurs as a substring of hay, else 0.
fn app_cstr_contains(hay, needle): i64 {
    var hl = strlen(hay);
    var nl = strlen(needle);
    if (nl == 0) { return 1; }
    var i = 0;
    while ((i + nl) <= hl) {
        var j = 0;
        while ((j < nl) && (load8(hay + i + j) == load8(needle + j))) { j = j + 1; }
        if (j == nl) { return 1; }
        i = i + 1;
    }
    return 0;
}
# app_is_ws(ch): the ASCII subset of Rust split_whitespace() — space, tab, LF, VT,
# FF, CR. (Full Unicode whitespace is out of scope for shell input.)
fn app_is_ws(ch): i64 {
    if (ch == 32) { return 1; }
    if (ch == 9) { return 1; }
    if (ch == 10) { return 1; }
    if (ch == 11) { return 1; }
    if (ch == 12) { return 1; }
    if (ch == 13) { return 1; }
    return 0;
}

# ---------------------------------------------------------------------------
# C2 process seam — DIRECT fork+execve, faithful to Rust's unsandboxed
# tokio::process::Command (the allowlist is the security control, in Rust and
# here; sandboxing would be an ADR-gated enhancement beyond parity). Distinct
# from lib/process.cyr's exec_capture (discards exit status + child stderr) and
# exec_env (waits — wrong for a detached GUI launch).
# ---------------------------------------------------------------------------
# app_which_path(name): the first of the 4 standard dirs where `name` exists, as a
# full-path cstr, or 0. execve has no $PATH; Rust runs the bare name via execvp.
fn app_which_path(name): i64 {
    var dirs = vec_new();
    vec_push(dirs, "/usr/local/bin/");
    vec_push(dirs, "/usr/bin/");
    vec_push(dirs, "/bin/");
    vec_push(dirs, "/usr/sbin/");
    var i = 0;
    while (i < vec_len(dirs)) {
        var full = app_cstr_cat3(vec_get(dirs, i), name, "");
        if (path_exists(full) != 0) { return full; }   # F_OK existence (like Rust Path::exists)
        i = i + 1;
    }
    return 0;
}
# app_cmdp_run_capture(argv, buf, buflen, status_out): fork+execve argv[0] with the
# inherited environ, capture stdout into buf (stderr -> /dev/null), wait, and write
# the child's real WEXITSTATUS to *status_out. -> bytes captured, or -1 on fork fail.
fn app_cmdp_run_capture(argv_vec, buf, buflen, status_out): i64 {
    var argc = vec_len(argv_vec);
    if (argc < 1) { return 0 - 1; }
    var cmd = vec_get(argv_vec, 0);
    var argv = alloc((argc + 1) * 8);
    var avi = 0;
    while (avi < argc) { store64(argv + avi * 8, vec_get(argv_vec, avi)); avi = avi + 1; }
    store64(argv + argc * 8, 0);
    var envp = _read_environ_envp();
    if (envp == 0) { envp = alloc(8); store64(envp, 0); }   # empty-env fallback (proc unreadable)
    var pipefd[16];
    sys_pipe(&pipefd);
    var rfd = load32(&pipefd);
    var wfd = load32(&pipefd + 4);
    var pid = sys_fork();
    if (pid < 0) { sys_close(rfd); sys_close(wfd); return 0 - 1; }
    if (pid == 0) {
        sys_close(rfd);
        sys_dup2(wfd, 1);
        sys_close(wfd);
        var devnull = sys_open("/dev/null", 1, 0);
        if (devnull >= 0) { sys_dup2(devnull, 2); sys_close(devnull); }
        sys_execve(cmd, argv, envp);
        sys_exit(127);
    }
    sys_close(wfd);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var n = sys_read(rfd, buf + total, buflen - total);
        if (n <= 0) { rgo = 0; } else { total = total + n; if (total >= buflen) { rgo = 0; } }
    }
    sys_close(rfd);
    var stbuf[4];
    sys_waitpid(pid, &stbuf, 0);
    var st = load32(&stbuf);
    if (WIFEXITED(st) == 1) { store64(status_out, WEXITSTATUS(st)); } else { store64(status_out, 0 - 1); }
    return total;
}
# app_merge_env(overrides): a fresh NULL-terminated envp = the inherited environ +
# each "KEY=VALUE" cstr in the `overrides` vec (0 == none). Rust cmd.env augments.
fn app_merge_env(overrides): i64 {
    var parent = _read_environ_envp();
    var count = 0;
    if (parent != 0) {
        while (load64(parent + count * 8) != 0) { count = count + 1; }
    }
    var nover = 0;
    if (overrides != 0) { nover = vec_len(overrides); }
    var out = alloc((count + nover + 1) * 8);
    var i = 0;
    while (i < count) { store64(out + i * 8, load64(parent + i * 8)); i = i + 1; }
    var j = 0;
    while (j < nover) { store64(out + (count + j) * 8, vec_get(overrides, j)); j = j + 1; }
    store64(out + (count + nover) * 8, 0);
    return out;
}
# app_spawn_detached(argv, envp): fire-and-forget fork+execve argv[0] with all stdio
# redirected to /dev/null and NO waitpid. -> child pid (>0), or -1 on fork failure.
fn app_spawn_detached(argv_vec, envp): i64 {
    var argc = vec_len(argv_vec);
    if (argc < 1) { return 0 - 1; }
    var cmd = vec_get(argv_vec, 0);
    var argv = alloc((argc + 1) * 8);
    var avi = 0;
    while (avi < argc) { store64(argv + avi * 8, vec_get(argv_vec, avi)); avi = avi + 1; }
    store64(argv + argc * 8, 0);
    var pid = sys_fork();
    if (pid < 0) { return 0 - 1; }
    if (pid == 0) {
        var devnull = sys_open("/dev/null", 2, 0);
        if (devnull >= 0) {
            sys_dup2(devnull, 0);
            sys_dup2(devnull, 1);
            sys_dup2(devnull, 2);
            sys_close(devnull);
        }
        sys_execve(cmd, argv, envp);
        sys_exit(127);
    }
    return pid;
}

# ---------------------------------------------------------------------------
# Enum display helpers.
# ---------------------------------------------------------------------------
fn app_type_debug_name(t): i64 {
    if (t == AppType.APP_CMDPALETTE)      { return "CommandPalette"; }
    if (t == AppType.APP_FILE_MANAGER)  { return "FileManager"; }
    if (t == AppType.APP_TEXT_EDITOR)   { return "TextEditor"; }
    if (t == AppType.APP_WEB_BROWSER)   { return "WebBrowser"; }
    if (t == AppType.APP_AGENT_MANAGER) { return "AgentManager"; }
    if (t == AppType.APP_AUDIT_VIEWER)  { return "AuditViewer"; }
    if (t == AppType.APP_MODEL_MANAGER) { return "ModelManager"; }
    if (t == AppType.APP_SETTINGS)      { return "Settings"; }
    return "Custom";
}
# app_error_display(code, arg): the Rust Display string, as a fresh cstr.
fn app_error_display(code, arg): i64 {
    if (code == AppErr.APP_ERR_NOT_FOUND)   { return app_cstr_cat3("App not found: ", arg, ""); }
    if (code == AppErr.APP_ERR_WINDOW)      { return app_cstr_cat3("Window error: ", arg, ""); }
    if (code == AppErr.APP_ERR_PERM_DENIED) { return app_cstr_cat3("Permission denied: ", arg, ""); }
    return app_cstr_cat3("", arg, "");
}

# ---------------------------------------------------------------------------
# Module constants (C1 stubs never open these paths; C3 does).
# ---------------------------------------------------------------------------
fn app_llm_gateway_addr(): i64 { return "http://localhost:8088"; }
fn app_agent_socket_dir(): i64 { return "/run/agnos/agents"; }
fn app_audit_log_path(): i64   { return "/var/log/agnos/audit.log"; }

# ---------------------------------------------------------------------------
# AppWindow.
# ---------------------------------------------------------------------------
fn app_window_new(id, app_type, title): i64 {
    var w = alloc(AWIN_SZ);
    if (w == 0) { return 0; }
    store64(w + AWIN_ID, id);
    store64(w + AWIN_TYPE, app_type);
    store64(w + AWIN_TITLE, title);
    store64(w + AWIN_WIDTH, 800);
    store64(w + AWIN_HEIGHT, 600);
    store64(w + AWIN_AI_ENABLED, 0);
    return w;
}
fn app_window_id(w)         { return load64(w + AWIN_ID); }
fn app_window_type(w)       { return load64(w + AWIN_TYPE); }
fn app_window_title(w)      { return load64(w + AWIN_TITLE); }
fn app_window_width(w)      { return load64(w + AWIN_WIDTH); }
fn app_window_height(w)     { return load64(w + AWIN_HEIGHT); }
fn app_window_ai_enabled(w) { return load64(w + AWIN_AI_ENABLED); }
fn app_window_set_width(w, v)  { store64(w + AWIN_WIDTH, v); return 0; }
fn app_window_set_height(w, v) { store64(w + AWIN_HEIGHT, v); return 0; }
fn app_window_set_ai(w, v)     { store64(w + AWIN_AI_ENABLED, v); return 0; }
# app_window_clone(w): field-copy that REUSES the id (test asserts same id).
fn app_window_clone(w): i64 {
    var c = app_window_new(app_window_id(w), app_window_type(w), app_window_title(w));
    store64(c + AWIN_WIDTH, app_window_width(w));
    store64(c + AWIN_HEIGHT, app_window_height(w));
    store64(c + AWIN_AI_ENABLED, app_window_ai_enabled(w));
    return c;
}

# ---------------------------------------------------------------------------
# FileManagerApp.
# ---------------------------------------------------------------------------
fn app_filemgr_new(): i64 {
    var p = alloc(FM_SZ);
    if (p == 0) { return 0; }
    store64(p + FM_ID, "filemanager");
    store64(p + FM_NAME, "File Manager");
    store64(p + FM_CURRENT_PATH, "/home");
    store64(p + FM_AGENT_ASSIST, 1);
    return p;
}
fn app_filemgr_id(p)               { return load64(p + FM_ID); }
fn app_filemgr_name(p)             { return load64(p + FM_NAME); }
fn app_filemgr_current_path(p)     { return load64(p + FM_CURRENT_PATH); }
fn app_filemgr_agent_assistance(p) { return load64(p + FM_AGENT_ASSIST); }
# navigate: store the path verbatim (no fs touch; accepts any path). -> Ok(0).
fn app_filemgr_navigate(p, path): i64 {
    store64(p + FM_CURRENT_PATH, path);
    return AppErr.APP_OK;
}
# search_with_agent: a one-element vec ["Found: {query}"].
fn app_filemgr_search_with_agent(p, query): i64 {
    var v = vec_new();
    vec_push(v, app_cstr_cat3("Found: ", query, ""));
    return v;
}

# ---------------------------------------------------------------------------
# AgentInfo + AgentManagerApp.
# ---------------------------------------------------------------------------
fn app_agentinfo_new(id, name, status, caps): i64 {
    var p = alloc(AI_SZ);
    if (p == 0) { return 0; }
    if (caps == 0) { caps = vec_new(); }
    store64(p + AI_ID, id);
    store64(p + AI_NAME, name);
    store64(p + AI_STATUS, status);
    store64(p + AI_CAPABILITIES, caps);
    return p;
}
fn app_agentinfo_id(p)           { return load64(p + AI_ID); }
fn app_agentinfo_name(p)         { return load64(p + AI_NAME); }
fn app_agentinfo_status(p)       { return load64(p + AI_STATUS); }
fn app_agentinfo_capabilities(p) { return load64(p + AI_CAPABILITIES); }
fn app_agentinfo_set_status(p, s) { store64(p + AI_STATUS, s); return 0; }

fn app_agentmgr_new(): i64 {
    var p = alloc(AM_SZ);
    if (p == 0) { return 0; }
    store64(p + AM_ID, "agent-manager");
    store64(p + AM_NAME, "Agent Manager");
    store64(p + AM_AGENTS, vec_new());
    store64(p + AM_NEXT_ID, 1);
    return p;
}
fn app_agentmgr_id(p)             { return load64(p + AM_ID); }
fn app_agentmgr_name(p)           { return load64(p + AM_NAME); }
fn app_agentmgr_running_agents(p) { return load64(p + AM_AGENTS); }
fn app_agentmgr_agent_count(p)    { return vec_len(load64(p + AM_AGENTS)); }
fn app_agentmgr_next_id(p): i64 {
    var id = load64(p + AM_NEXT_ID);
    store64(p + AM_NEXT_ID, id + 1);
    return id;
}
# start_agent: append an AgentInfo ("Starting"), return its new id (never fails).
fn app_agentmgr_start_agent(p, name, caps): i64 {
    var id = app_agentmgr_next_id(p);
    vec_push(load64(p + AM_AGENTS), app_agentinfo_new(id, name, "Starting", caps));
    return id;
}
# stop_agent: remove the agent with that id; Ok(0) even if absent (no-op).
fn app_agentmgr_stop_agent(p, id): i64 {
    var v = load64(p + AM_AGENTS);
    var i = 0;
    while (i < vec_len(v)) {
        if (app_agentinfo_id(vec_get(v, i)) == id) {
            vec_remove(v, i);
        } else {
            i = i + 1;
        }
    }
    return AppErr.APP_OK;
}
# list_agents — PARITY (C3): real body scans /run/agnos/agents + UnixStream.
# In a clean env read_dir errors and Rust returns the untouched local vec.
fn app_agentmgr_list_agents(p): i64 { return load64(p + AM_AGENTS); }

# ---------------------------------------------------------------------------
# AuditFilters + AuditEntry + AuditViewerApp.
# ---------------------------------------------------------------------------
fn app_auditfilters_new(agent, security, system, time_range): i64 {
    var p = alloc(AF_SZ);
    if (p == 0) { return 0; }
    store64(p + AF_INCLUDE_AGENT, agent);
    store64(p + AF_INCLUDE_SECURITY, security);
    store64(p + AF_INCLUDE_SYSTEM, system);
    store64(p + AF_TIME_RANGE, time_range);
    return p;
}
fn app_auditfilters_default(): i64 {
    return app_auditfilters_new(1, 1, 1, TimeRange.TR_LAST_DAY);
}
fn app_auditfilters_include_agent(p)    { return load64(p + AF_INCLUDE_AGENT); }
fn app_auditfilters_include_security(p) { return load64(p + AF_INCLUDE_SECURITY); }
fn app_auditfilters_include_system(p)   { return load64(p + AF_INCLUDE_SYSTEM); }
fn app_auditfilters_time_range(p)       { return load64(p + AF_TIME_RANGE); }

fn app_auditentry_new(id, ts, event_type, description, source): i64 {
    var p = alloc(AE_SZ);
    if (p == 0) { return 0; }
    store64(p + AE_ID, id);
    store64(p + AE_TIMESTAMP, ts);
    store64(p + AE_EVENT_TYPE, event_type);
    store64(p + AE_DESCRIPTION, description);
    store64(p + AE_SOURCE, source);
    return p;
}
fn app_auditentry_id(p)          { return load64(p + AE_ID); }
fn app_auditentry_timestamp(p)   { return load64(p + AE_TIMESTAMP); }
fn app_auditentry_event_type(p)  { return load64(p + AE_EVENT_TYPE); }
fn app_auditentry_description(p) { return load64(p + AE_DESCRIPTION); }
fn app_auditentry_source(p)      { return load64(p + AE_SOURCE); }

fn app_auditview_new(): i64 {
    var p = alloc(AV_SZ);
    if (p == 0) { return 0; }
    store64(p + AV_ID, "audit-viewer");
    store64(p + AV_NAME, "Audit Log Viewer");
    store64(p + AV_FILTERS, app_auditfilters_default());
    return p;
}
fn app_auditview_id(p)      { return load64(p + AV_ID); }
fn app_auditview_name(p)    { return load64(p + AV_NAME); }
fn app_auditview_filters(p) { return load64(p + AV_FILTERS); }
# filter_cutoff(now): epoch cutoff for the active time range; -1 == None (Custom).
fn app_auditview_filter_cutoff(p, now): i64 {
    var tr = app_auditfilters_time_range(app_auditview_filters(p));
    if (tr == TimeRange.TR_LAST_HOUR) { return now - 3600; }
    if (tr == TimeRange.TR_LAST_DAY)  { return now - 86400; }
    if (tr == TimeRange.TR_LAST_WEEK) { return now - 604800; }
    return 0 - 1;
}
# get_logs — PARITY (C3): real body reads /var/log/agnos/audit.log + JSON parse.
# Clean-env file-missing branch returns empty.
fn app_auditview_get_logs(p): i64 { return vec_new(); }

