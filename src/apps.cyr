fn app_browser_new(id, name, binary, env, defurl): i64 {
    var p = alloc(BROW_SZ);
    if (p == 0) { return 0; }
    store64(p + BROW_ID, id);
    store64(p + BROW_NAME, name);
    store64(p + BROW_BINARY, binary);
    store64(p + BROW_ENV, env);
    store64(p + BROW_DEFURL, defurl);
    return p;
}
fn app_browser_id(p)     { return load64(p + BROW_ID); }
fn app_browser_name(p)   { return load64(p + BROW_NAME); }
fn app_browser_binary(p) { return load64(p + BROW_BINARY); }
fn app_browser_env(p)    { return load64(p + BROW_ENV); }
fn app_browser_default_url(p) { return load64(p + BROW_DEFURL); }
fn app_browser_firefox(): i64 {
    return app_browser_new("firefox", "Firefox", "/usr/bin/firefox", "MOZ_ENABLE_WAYLAND=1", 0);
}
fn app_browser_chromium(): i64 { return app_browser_new("chromium", "Chromium", "/usr/bin/chromium", 0, 0); }
fn app_browser_zen(): i64 {
    return app_browser_new("zen-browser", "Zen Browser", "/usr/bin/zen-browser", "MOZ_ENABLE_WAYLAND=1", 0);
}
fn app_browser_brave(): i64 { return app_browser_new("brave", "Brave", "/usr/bin/brave", 0, 0); }
fn app_browser_librewolf(): i64 {
    return app_browser_new("librewolf", "LibreWolf", "/usr/bin/librewolf", "MOZ_ENABLE_WAYLAND=1", 0);
}
fn app_browser_vivaldi(): i64 { return app_browser_new("vivaldi", "Vivaldi", "/usr/bin/vivaldi", 0, 0); }
fn app_browser_falkon(): i64 {
    return app_browser_new("falkon", "Falkon", "/usr/bin/falkon", "QT_QPA_PLATFORM=wayland", 0);
}
fn app_browser_midori(): i64 { return app_browser_new("midori", "Midori", "/usr/bin/midori", 0, 0); }
fn app_browser_default(): i64   { return app_browser_firefox(); }
# is_installed: real fs probe of the binary path (test only asserts no-crash).
fn app_browser_is_installed(p): i64 {
    if (path_exists(app_browser_binary(p)) != 0) { return 1; }   # F_OK, like Rust Path::exists()
    return 0;
}
# app_browser_launch(p, url): is_installed guard -> AppNotFound; else a detached spawn
# with this browser's env override (url arg if given, else the default_url). NOTE: the
# detached-spawn body is untested (no browser binary in CI) — only the guard is exercised.
fn app_browser_launch(p, url): i64 {
    if (app_browser_is_installed(p) == 0) { return AppErr.APP_ERR_NOT_FOUND; }
    var argv = vec_new();
    vec_push(argv, app_browser_binary(p));
    if (url != 0) {
        vec_push(argv, url);
    } else {
        if (app_browser_default_url(p) != 0) { vec_push(argv, app_browser_default_url(p)); }
    }
    var ov = vec_new();
    if (app_browser_env(p) != 0) { vec_push(ov, app_browser_env(p)); }
    var pid = app_spawn_detached(argv, app_merge_env(ov));
    if (pid < 0) { return AppErr.APP_ERR_WINDOW; }
    return AppErr.APP_OK;
}

# ---------------------------------------------------------------------------
# ShrutiSurfaceConfig + ShrutiApp (launch deferred to C2).
# ---------------------------------------------------------------------------
fn app_shrutisurf_new(w, h, exclusive, pw_node): i64 {
    var p = alloc(SHRCFG_SZ);
    if (p == 0) { return 0; }
    store64(p + SHRCFG_W, w);
    store64(p + SHRCFG_H, h);
    store64(p + SHRCFG_EXCL, exclusive);
    store64(p + SHRCFG_PWNODE, pw_node);
    return p;
}
fn app_shrutisurf_default(): i64 { return app_shrutisurf_new(1400, 900, 0, "shruti-main"); }
fn app_shrutisurf_width(p)     { return load64(p + SHRCFG_W); }
fn app_shrutisurf_height(p)    { return load64(p + SHRCFG_H); }
fn app_shrutisurf_exclusive(p) { return load64(p + SHRCFG_EXCL); }
fn app_shrutisurf_pw_node(p)   { return load64(p + SHRCFG_PWNODE); }

fn app_shruti_new(): i64 {
    var p = alloc(SHR_SZ);
    if (p == 0) { return 0; }
    store64(p + SHR_ID, "shruti");
    store64(p + SHR_NAME, "Shruti");
    store64(p + SHR_BINARY, "/usr/local/bin/shruti");
    store64(p + SHR_DATADIR, "~/.local/share/shruti");
    store64(p + SHR_CFG, app_shrutisurf_default());
    store64(p + SHR_RUNNING, 0);
    return p;
}
fn app_shruti_id(p)        { return load64(p + SHR_ID); }
fn app_shruti_name(p)      { return load64(p + SHR_NAME); }
fn app_shruti_binary(p)    { return load64(p + SHR_BINARY); }
fn app_shruti_data_dir(p)  { return load64(p + SHR_DATADIR); }
fn app_shruti_cfg(p)       { return load64(p + SHR_CFG); }
fn app_shruti_is_running(p){ return load64(p + SHR_RUNNING); }
fn app_shruti_is_installed(p): i64 {
    if (path_exists(app_shruti_binary(p)) != 0) { return 1; }   # F_OK, like Rust Path::exists()
    return 0;
}
# app_shruti_launch(p, session_path): is_installed guard -> AppNotFound; else a detached
# spawn with the Wayland/PipeWire env; is_running=1 only on success. NOTE: the
# detached-spawn body is untested (no shruti binary in CI) — only the guard runs.
fn app_shruti_launch(p, session_path): i64 {
    if (app_shruti_is_installed(p) == 0) { return AppErr.APP_ERR_NOT_FOUND; }
    var argv = vec_new();
    vec_push(argv, app_shruti_binary(p));
    if (session_path != 0) {
        vec_push(argv, "--open");
        vec_push(argv, session_path);
    }
    var cfg = app_shruti_cfg(p);
    var ov = vec_new();
    vec_push(ov, "GDK_BACKEND=wayland");
    vec_push(ov, "QT_QPA_PLATFORM=wayland");
    vec_push(ov, app_cstr_cat3("SHRUTI_DATA_DIR=", app_shruti_data_dir(p), ""));
    vec_push(ov, app_cstr_cat3("PIPEWIRE_NODE=", app_shrutisurf_pw_node(cfg), ""));
    var wbuf = alloc(24);
    fmt_int_buf(app_shrutisurf_width(cfg), wbuf);
    vec_push(ov, app_cstr_cat3("SHRUTI_WINDOW_WIDTH=", wbuf, ""));
    var hbuf = alloc(24);
    fmt_int_buf(app_shrutisurf_height(cfg), hbuf);
    vec_push(ov, app_cstr_cat3("SHRUTI_WINDOW_HEIGHT=", hbuf, ""));
    if (app_shrutisurf_exclusive(cfg) != 0) { vec_push(ov, "SHRUTI_EXCLUSIVE_AUDIO=1"); }
    var pid = app_spawn_detached(argv, app_merge_env(ov));
    if (pid < 0) { return AppErr.APP_ERR_WINDOW; }
    store64(p + SHR_RUNNING, 1);
    return AppErr.APP_OK;
}

# ---------------------------------------------------------------------------
# CmdPaletteApp — pure part: allowlist + basename-strip + pre-spawn checks.
# The security-critical logic ports NOW; the actual spawn is deferred to C2.
# ---------------------------------------------------------------------------
fn app_cmdp_new(): i64 {
    var p = alloc(CMDP_SZ);
    if (p == 0) { return 0; }
    store64(p + CMDP_ID, "cmdpalette");
    store64(p + CMDP_NAME, "Command Palette");
    store64(p + CMDP_AI, 1);
    return p;
}
fn app_cmdp_id(p)   { return load64(p + CMDP_ID); }
fn app_cmdp_name(p) { return load64(p + CMDP_NAME); }
fn app_cmdp_ai_integration(p) { return load64(p + CMDP_AI); }
# The 30-entry allowlist (Rust ALLOWED_PROGRAMS).
fn app_cmdp_allowlist(): i64 {
    var v = vec_new();
    vec_push(v, "ls"); vec_push(v, "cat"); vec_push(v, "echo"); vec_push(v, "pwd");
    vec_push(v, "whoami"); vec_push(v, "date"); vec_push(v, "uname"); vec_push(v, "env");
    vec_push(v, "printenv"); vec_push(v, "id"); vec_push(v, "df"); vec_push(v, "du");
    vec_push(v, "free"); vec_push(v, "uptime"); vec_push(v, "head"); vec_push(v, "tail");
    vec_push(v, "wc"); vec_push(v, "sort"); vec_push(v, "uniq"); vec_push(v, "grep");
    vec_push(v, "find"); vec_push(v, "which"); vec_push(v, "file"); vec_push(v, "stat");
    vec_push(v, "basename"); vec_push(v, "dirname"); vec_push(v, "realpath"); vec_push(v, "true");
    vec_push(v, "false"); vec_push(v, "expr");
    return v;
}
# app_cmdp_basename(program): the final path component, replicating Rust
# std::path::Path::file_name() — strips trailing '/' and a trailing "." component;
# an empty / all-slashes / ".." path yields None (-> the raw program). This is the
# path-traversal neutralisation feeding the allowlist check.
fn app_cmdp_basename(program): i64 {
    var end = strlen(program);
    while ((end > 0) && (load8(program + end - 1) == 47)) { end = end - 1; }   # trim trailing '/'
    if (end == 0) { return program; }
    var start = end;
    while ((start > 0) && (load8(program + start - 1) != 47)) { start = start - 1; }
    var clen = end - start;
    # a trailing "." component -> use the preceding component (Path drops "./")
    if ((clen == 1) && (load8(program + start) == 46)) {
        var e2 = start;
        while ((e2 > 0) && (load8(program + e2 - 1) == 47)) { e2 = e2 - 1; }
        if (e2 == 0) { return program; }
        var s2 = e2;
        while ((s2 > 0) && (load8(program + s2 - 1) != 47)) { s2 = s2 - 1; }
        return app_substr(program, s2, e2 - s2);
    }
    # ".." -> file_name() is None -> fall back to the raw program
    if ((clen == 2) && (load8(program + start) == 46) && (load8(program + start + 1) == 46)) {
        return program;
    }
    return app_substr(program, start, clen);
}
# app_cmdp_is_allowed(program): basename-strip then allowlist membership. -> 0/1.
fn app_cmdp_is_allowed(program): i64 {
    var base = app_cmdp_basename(program);
    var v = app_cmdp_allowlist();
    var i = 0;
    while (i < vec_len(v)) {
        if (streq(vec_get(v, i), base) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}
# execute_command (C1 pre-spawn checks only): empty/whitespace -> WindowError;
# non-allowlisted first token -> PermDenied; allowed -> Ok (spawn is C2).
# app_cmdp_execute_command(p, command, out): run the command (C2). Pre-spawn checks:
# empty/whitespace -> APP_ERR_WINDOW; non-allowlisted first token -> APP_ERR_PERM_DENIED.
# Then resolve the allowlisted bare name to a full path and fork+execve it, capturing
# stdout. exit 0 -> APP_OK with *out = the stdout cstr; non-zero exit / spawn failure ->
# APP_ERR_WINDOW. On any error *out = 0. (Rust returns Result<String, AppError>.)
fn app_cmdp_execute_command(p, command, out): i64 {
    var len = strlen(command);
    # skip leading whitespace to the first token (split_whitespace semantics)
    var start = 0;
    while (start < len) {
        if (app_is_ws(load8(command + start)) == 1) { start = start + 1; } else { break; }
    }
    if (start >= len) { store64(out, 0); return AppErr.APP_ERR_WINDOW; }   # empty / whitespace-only
    # first token runs to the next whitespace
    var end = start;
    while (end < len) {
        if (app_is_ws(load8(command + end)) == 1) { break; }
        end = end + 1;
    }
    var tok = app_substr(command, start, end - start);
    if (app_cmdp_is_allowed(tok) == 0) { store64(out, 0); return AppErr.APP_ERR_PERM_DENIED; }
    # --- C2 spawn: resolve the bare basename to a full path (execve has no $PATH) ---
    var full = app_which_path(app_cmdp_basename(tok));
    if (full == 0) { store64(out, 0); return AppErr.APP_ERR_WINDOW; }   # not found == spawn error
    # argv = [full, <remaining whitespace-split tokens>]
    var argv = vec_new();
    vec_push(argv, full);
    var i = end;
    while (i < len) {
        while ((i < len) && (app_is_ws(load8(command + i)) == 1)) { i = i + 1; }
        if (i >= len) { break; }
        var ts = i;
        while ((i < len) && (app_is_ws(load8(command + i)) == 0)) { i = i + 1; }
        vec_push(argv, app_substr(command, ts, i - ts));
    }
    var buf = alloc(65536);
    var status = 0;
    # cap the read at 65535 so there is always room for the NUL terminator below —
    # else a command whose stdout fills the buffer would make store8(buf+n,0) overrun.
    var n = app_cmdp_run_capture(argv, buf, 65535, &status);
    if (n < 0) { store64(out, 0); return AppErr.APP_ERR_WINDOW; }   # fork failure
    if (status != 0) { store64(out, 0); return AppErr.APP_ERR_WINDOW; }   # non-zero exit -> WindowError
    store8(buf + n, 0);   # NUL-terminate the captured stdout (n <= 65535, in-bounds)
    store64(out, buf);
    return AppErr.APP_OK;
}

# ---------------------------------------------------------------------------
# DesktopApplications aggregate.
# ---------------------------------------------------------------------------
fn app_desk_new(): i64 {
    var d = alloc(AD_SZ);
    if (d == 0) { return 0; }
    store64(d + AD_CMDPALETTE, app_cmdp_new());
    store64(d + AD_FILE_MGR, app_filemgr_new());
    var browsers = vec_new();
    vec_push(browsers, app_browser_firefox());
    vec_push(browsers, app_browser_chromium());
    vec_push(browsers, app_browser_zen());
    vec_push(browsers, app_browser_brave());
    vec_push(browsers, app_browser_librewolf());
    vec_push(browsers, app_browser_vivaldi());
    vec_push(browsers, app_browser_falkon());
    vec_push(browsers, app_browser_midori());
    store64(d + AD_BROWSERS, browsers);
    store64(d + AD_AGENT_MGR, app_agentmgr_new());
    store64(d + AD_AUDIT_VIEW, app_auditview_new());
    store64(d + AD_MODEL_MGR, app_modelmgr_new());
    store64(d + AD_SHRUTI, app_shruti_new());
    store64(d + AD_OPEN_WINDOWS, vec_new());
    store64(d + AD_NEXT_ID, 1);
    store64(d + AD_LAST_ERR, AppErr.APP_OK);
    return d;
}
fn app_desk_cmdpalette(d)      { return load64(d + AD_CMDPALETTE); }
fn app_desk_file_manager(d)  { return load64(d + AD_FILE_MGR); }
fn app_desk_last_err(d)      { return load64(d + AD_LAST_ERR); }
fn app_desk_get_agent_manager(d) { return load64(d + AD_AGENT_MGR); }
fn app_desk_get_model_manager(d) { return load64(d + AD_MODEL_MGR); }
fn app_desk_get_shruti(d)        { return load64(d + AD_SHRUTI); }
fn app_desk_list_browsers(d)     { return load64(d + AD_BROWSERS); }
fn app_desk_next_id(d): i64 {
    var id = load64(d + AD_NEXT_ID);
    store64(d + AD_NEXT_ID, id + 1);
    return id;
}
fn app_desk_register(d, w): i64 {
    vec_push(load64(d + AD_OPEN_WINDOWS), w);
    return w;
}
fn app_desk_open_cmdpalette(d): i64 {
    var w = app_window_new(app_desk_next_id(d), AppType.APP_CMDPALETTE, app_cmdp_name(app_desk_cmdpalette(d)));
    return app_desk_register(d, w);
}
fn app_desk_open_file_manager(d, path): i64 {
    var w = app_window_new(app_desk_next_id(d), AppType.APP_FILE_MANAGER, app_filemgr_name(app_desk_file_manager(d)));
    app_window_set_ai(w, app_filemgr_agent_assistance(app_desk_file_manager(d)));
    return app_desk_register(d, w);
}
fn app_desk_open_agent_manager(d): i64 {
    var nm = app_agentmgr_name(app_desk_get_agent_manager(d));
    var w = app_window_new(app_desk_next_id(d), AppType.APP_AGENT_MANAGER, nm);
    app_window_set_ai(w, 1);
    return app_desk_register(d, w);
}
fn app_desk_open_audit_viewer(d): i64 {
    var nm = app_auditview_name(load64(d + AD_AUDIT_VIEW));
    var w = app_window_new(app_desk_next_id(d), AppType.APP_AUDIT_VIEWER, nm);
    app_window_set_ai(w, 1);
    return app_desk_register(d, w);
}
fn app_desk_open_model_manager(d): i64 {
    var nm = app_modelmgr_name(app_desk_get_model_manager(d));
    var w = app_window_new(app_desk_next_id(d), AppType.APP_MODEL_MANAGER, nm);
    app_window_set_ai(w, 1);
    return app_desk_register(d, w);
}
# get_browser: id==0 -> first (firefox); else scan by id; miss/empty -> 0.
fn app_desk_get_browser(d, id): i64 {
    var v = load64(d + AD_BROWSERS);
    if (vec_len(v) == 0) { return 0; }
    if (id == 0) { return vec_get(v, 0); }
    var i = 0;
    while (i < vec_len(v)) {
        var b = vec_get(v, i);
        if (streq(app_browser_id(b), id) == 1) { return b; }
        i = i + 1;
    }
    return 0;
}
# open_web_browser: resolve browser (0 == default); miss -> NotFound/0. Title is
# "{name} — {url}" (em-dash) when a url is given, else the browser name. 1280x900.
fn app_desk_open_web_browser(d, browser_id, url): i64 {
    var b = app_desk_get_browser(d, browser_id);
    if (b == 0) { store64(d + AD_LAST_ERR, AppErr.APP_ERR_NOT_FOUND); return 0; }
    var title = app_browser_name(b);
    if (url != 0) { title = app_cstr_cat3(app_browser_name(b), " — ", url); }
    var w = app_window_new(app_desk_next_id(d), AppType.APP_WEB_BROWSER, title);
    app_window_set_width(w, 1280);
    app_window_set_height(w, 900);
    return app_desk_register(d, w);
}
# open_shruti: title "Shruti — {path}" (em-dash) with a session path, else "Shruti".
# Type is APP_CUSTOM (no Shruti AppType). 1400x900, ai=1.
fn app_desk_open_shruti(d, session_path): i64 {
    var title = "Shruti";
    if (session_path != 0) { title = app_cstr_cat3("Shruti", " — ", session_path); }
    var w = app_window_new(app_desk_next_id(d), AppType.APP_CUSTOM, title);
    var cfg = app_shruti_cfg(app_desk_get_shruti(d));
    app_window_set_width(w, app_shrutisurf_width(cfg));
    app_window_set_height(w, app_shrutisurf_height(cfg));
    app_window_set_ai(w, 1);
    return app_desk_register(d, w);
}
# close_window: remove the window with that id; Ok(0) unconditionally (even if absent).
fn app_desk_close_window(d, window_id): i64 {
    var v = load64(d + AD_OPEN_WINDOWS);
    var i = 0;
    while (i < vec_len(v)) {
        if (app_window_id(vec_get(v, i)) == window_id) {
            vec_remove(v, i);
        } else {
            i = i + 1;
        }
    }
    return AppErr.APP_OK;
}
# get_open_windows: a fresh vec of the live *AppWindow pointers. NOTE: Rust returns
# .values().cloned() (independent AppWindow copies); the port shares the stored
# pointers. Unobservable in C1 (no path mutates a window post-open); a future C2/C3
# caller that mutates a returned handle expecting an isolated snapshot must clone first.
fn app_desk_get_open_windows(d): i64 {
    var out = vec_new();
    var v = load64(d + AD_OPEN_WINDOWS);
    var i = 0;
    while (i < vec_len(v)) {
        vec_push(out, vec_get(v, i));
        i = i + 1;
    }
    return out;
}
